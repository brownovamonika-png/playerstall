# MailerSend API token — get yours at https://app.mailersend.com/api-tokens
# Add the real value to .env (local dev) and to Vercel Environment Variables (production)
MAILERSEND_API_TOKEN=mlsn.your_token_here

# The verified "from" address in your MailerSend account
# Must match a verified domain/email in MailerSend
MAILERSEND_FROM_EMAIL=sales@playerstall.com
