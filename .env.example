# Full CRM setup: docs/SUPABASE_CRM_SETUP.md
# Local: Docker + `npm run supabase:start` then `npm run supabase:status` → paste URL + keys below.

# Shared CRM password cookie: required for /admin when Supabase is NOT configured (preview/sample data).
# When Supabase IS configured, set this to require this password first, then Supabase email + password.
# CRM_SHARED_PASSWORD=your-strong-shared-secret

# Supabase Configuration
# Project URL: Settings → General (or top of API section) — https://xxxxx.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co
# "Public" key — use EITHER the new Publishable key (sb_publishable_…) OR Legacy "anon" JWT (eyJ…)
SUPABASE_ANON_KEY=your-publishable-or-anon-key-here
# "Backend" key — use EITHER the new Secret key (sb_secret_…) OR Legacy "service_role" JWT (eyJ…)
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key-here

# MailerSend (already in use for room planner)
MAILERSEND_API_TOKEN=your-mailersend-token
MAILERSEND_FROM_EMAIL=team@playerstall.com
# CRM email templates: “Send as” Custom Sport Lockers uses this from-address (verify domain in MailerSend)
MAILERSEND_FROM_EMAIL_CUSTOM_SPORT_LOCKERS=sales@customsportslockers.com

# Optional: CRM “Client copy” page — override CSV URL (Google Sheets publish/export or any raw CSV URL)
# CLIENT_COPY_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_ID/export?format=csv&gid=0
