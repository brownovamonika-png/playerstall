---
// ESSENTIAL — Generic Essential Locker (e.g. Semi Pro, Varsity). 19" only, birch. Not used as the dedicated spec for Pro Locker or Stadium Locker.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductSpecSheet from '../../components/ProductSpecSheet.astro';
const dimensionsSheetSrc = '/images/stadium-locker-dimensions-sheet.png';
const birchPlywoodImg = '/images/birch-plywood-essential.png';

const essentialSpecs = [
	{ label: 'Standard dimensions', value: '24" W × 76" H × 19" D' },
	{ label: 'Base', value: 'Optional 4" high base' },
	{ label: 'Frame', value: '3/4"' },
	{ label: 'Backing', value: '3/4"' },
	{ label: 'Weight', value: 'Approx. 66–75 lbs (model dependent)' },
	{ label: 'Construction', value: '19mm cabinet-grade pre-finished birch plywood, UV-coated both sides' },
	{ label: 'Edgebanding', value: 'PVC edgebanding' },
	{ label: 'Width range', value: '18" – 32"' },
	{ label: 'Depth options', value: '19" (standard)' },
	{ label: 'Material', value: 'Birch plywood only — no other wood types' },
	{ label: 'Custom build', value: '8–12 weeks — any size, color, options' },
	{ label: 'Warranty', value: '5 year warranty' },
];
---

<BaseLayout
	title="Essential Locker – Spec Sheet (PDF) | PlayerStall"
	description="Essential wood locker spec sheet: Semi Pro & Varsity. 19mm pre-finished birch plywood only. 76&quot; H x 19&quot; D, widths 18&quot;–32&quot;. From $349. Custom-built in 8–12 weeks. 5 year warranty."
>
	<main class="pdf-spec-page no-downloads no-accessories">
		<section class="product-hero-section pdf-hero">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Essential Locker" class="hero-image-print-only" />
			<div class="product-hero-background">
				<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Essential Locker" class="product-hero-bg-image" />
			</div>
			<div class="product-hero-background-overlay"></div>
			<div class="product-hero-container">
				<div class="product-breadcrumbs">
					<a href="/">Home</a>
					<span class="breadcrumbs-sep">/</span>
					<a href="/shop">Shop</a>
					<span class="breadcrumbs-sep">/</span>
					<span class="breadcrumbs-current">Essential Locker – Spec Sheet</span>
				</div>
				<h1 class="product-page-title">Essential</h1>
			</div>
		</section>

		<div class="product-container top-locker-block">
			<div class="top-locker-image-wrap">
				<img
					src="/images/varsity-locker.png"
					alt="Essential wood athletic locker for locker rooms"
					class="top-locker-image"
				/>
			</div>
			<div class="product-options-images-section">
				<h3 class="option-label">Other views &amp; options</h3>
				<div class="options-images-grid">
					<figure class="option-image-fig">
						<img src="/images/varsity-locker.png" alt="Essential locker front view" />
						<figcaption>Front view</figcaption>
					</figure>
					<figure class="option-image-fig">
						<img src="/images/semi-pro-locker-side.png" alt="Essential locker side view" />
						<figcaption>Side view</figcaption>
					</figure>
					<figure class="option-image-fig">
						<img src="/images/semi-pro-locker-third.png" alt="Essential locker alternate view" />
						<figcaption>Alternate view</figcaption>
					</figure>
					<figure class="option-image-fig">
						<img src={dimensionsSheetSrc} alt="Essential locker dimensions" />
						<figcaption>Dimensions</figcaption>
					</figure>
					<figure class="option-image-fig">
						<img src="/images/stadium-locker-vent-panel.png" alt="Vented front panel option" />
						<figcaption>Vented front option</figcaption>
					</figure>
					<figure class="option-image-fig option-image-fig--lock-box">
						<img src="/images/lock-box-spec-sheet.png" alt="Lock box option with digital key lock" />
						<figcaption>Lock box option</figcaption>
					</figure>
				</div>
			</div>
		</div>

		<section class="product-main-section">
			<div class="product-container">
				<div class="product-layout product-layout-single">
					<div class="product-detail">
						<h2 class="product-title">Essential Locker</h2>
						<p class="product-model">Semi Pro & Varsity — birch plywood construction only</p>
						<p class="product-lead-time">Lead time: custom-built in three months</p>
						<div class="product-price-block">
							<span class="product-price">From $349.00</span>
							<p class="price-width-note">Semi Pro from $349 · Varsity from $449. Base model widths (with optional 4" base): 18"–32". Contact us for exact pricing by width and options.</p>
						</div>

						<div class="product-options-static">
							<p><strong>Depth:</strong> 19" (standard)</p>
							<p><strong>Width:</strong> 18", 20", 22", 24", 26", 28", 30", 32"</p>
							<p><strong>Color:</strong> Designer White, White Sand, Fashion Grey, North Sea, Graphite, Black, Hollyberry, Lapis Blue; woodgrains: Fusion Maple, Pasadena Oak, Walnut Heights, Hampton Walnut</p>
						</div>

						<div class="product-wood-material">
							<h3 class="option-label">Cabinet-Grade Pre-Finished Birch Plywood for Wood Lockers</h3>
							<div class="product-wood-material-content">
								<div class="product-wood-material-image-wrap">
									<img src={birchPlywoodImg} alt="Cabinet-grade pre-finished birch plywood used for Essential wood lockers" class="product-wood-material-image" />
								</div>
								<div class="product-wood-material-text">
									<p>Our lockers are built using 19mm pre-finished birch plywood, a high-quality panel material known for its smooth face, stable veneer core, and attractive natural wood look. With a durable UV-coated finish on both sides, this plywood is ideal for creating strong, professional-grade wood lockers that perform well in demanding locker room settings.</p>
								</div>
							</div>
						</div>

						<div class="product-accessories-static">
							<h3 class="option-label">Accessories</h3>
							<p class="option-value">Add-ons available — see <a href="/shop">Shop</a> for details and to add to cart</p>
							<ul class="accessories-list-static">
								<li>Vented Panel (+$40)</li>
								<li>Bottom cushion only; top and bottom cushions. Colors: black, dark blue, red, green, purple; other — note on order.</li>
								<li>Hooks (+$15) — black or silver</li>
								<li>Name Plate (+$10) — black or silver</li>
								<li>Skate Hooks (+$25) — black or silver</li>
								<li>Custom Logo (+$75) · custom orders only</li>
								<li>Stick Rack (from $299)</li>
								<li>Lock Box with Digital Key Lock (+$80)</li>
							</ul>
						</div>

						<div class="product-volume-discounts">
							<h3 class="volume-title">Volume Discounts</h3>
							<table class="volume-table">
								<thead>
									<tr>
										<th>Quantity</th>
										<th>Price</th>
									</tr>
								</thead>
								<tbody>
									<tr>
										<td>50 + lockers</td>
										<td>3–5% discount – Contact us for pricing</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>
				</div>

				<div class="product-info-section" id="moreinfo">
					<h2 class="product-info-heading">Essential Wood Locker – Features &amp; Options</h2>
					<div class="product-info-grid">
						<div class="product-info-col product-info-col-specs">
							<ProductSpecSheet productName="Essential Locker" specs={essentialSpecs} />
							<div class="product-dimensions-sheet-figure">
								<img src={dimensionsSheetSrc} alt="Essential locker dimensions – front and side views with measurements in inches" class="product-dimensions-sheet-image" />
								<p class="product-dimensions-sheet-caption">Essential Locker dimensions (front and side)</p>
							</div>
						</div>
						<div class="product-info-col product-info-col-features">
							<h3 class="product-info-subheading">Features</h3>
							<ul class="product-features-list">
								<li>19mm cabinet-grade pre-finished birch plywood — the only wood type used for Essential lockers</li>
								<li>Smooth face, stable veneer core, durable UV-coated finish on both sides</li>
								<li>Professional-grade construction for demanding locker room settings</li>
								<li>Available in Semi Pro (from $349) and Varsity (from $449) configurations</li>
								<li>18" to 32" widths; standard 24" W × 76" H × 19" D with optional 4" base</li>
								<li>5 year warranty</li>
							</ul>
							<h3 class="product-info-subheading">Options</h3>
							<ul class="product-options-list">
								<li>Vented front panel for increased airflow</li>
								<li>Secure lock box integrated into the upper compartment</li>
								<li>Bottom cushion or both cushions for added seating comfort</li>
								<li>Skate hooks for hockey or figure skating storage</li>
								<li>Custom logo option for teams or programs (custom orders only)</li>
								<li>Name plate and additional gear hooks</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</section>
		<section class="pdf-spec-accessories-section">
			<div class="pdf-spec-accessories-container">
				<div class="pdf-spec-accessories-header">
					<p class="pdf-spec-accessories-subtitle">finishing touches</p>
					<h2 class="pdf-spec-accessories-title">LOCKER ACCESSORIES</h2>
				</div>
				<div class="pdf-spec-accessories-grid">
					<div class="pdf-spec-accessory-card">
						<div class="pdf-spec-accessory-image"><img src="/images/elite-locker-vent-panel.png" alt="Vented front panel for sports lockers" /></div>
						<div class="pdf-spec-accessory-content"><span class="pdf-spec-accessory-cat">Accessories</span><h3 class="pdf-spec-accessory-title">Vented Panel</h3></div>
					</div>
					<div class="pdf-spec-accessory-card">
						<div class="pdf-spec-accessory-image"><img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Locker cushion with team logo" /></div>
						<div class="pdf-spec-accessory-content"><span class="pdf-spec-accessory-cat">Accessories</span><h3 class="pdf-spec-accessory-title">Cushions</h3></div>
					</div>
					<div class="pdf-spec-accessory-card pdf-spec-accessory-card--hooks">
						<div class="pdf-spec-accessory-image"><img src="/images/hook-silver.png" alt="Silver hook for lockers" /></div>
						<div class="pdf-spec-accessory-content"><span class="pdf-spec-accessory-cat">Accessories</span><h3 class="pdf-spec-accessory-title">Hooks</h3></div>
					</div>
					<div class="pdf-spec-accessory-card pdf-spec-accessory-card--name-plate">
						<div class="pdf-spec-accessory-image"><img src="/images/name-plate-black.png" alt="Black name plate for lockers" /></div>
						<div class="pdf-spec-accessory-content"><span class="pdf-spec-accessory-cat">Accessories</span><h3 class="pdf-spec-accessory-title">Name Plate</h3></div>
					</div>
					<div class="pdf-spec-accessory-card">
						<div class="pdf-spec-accessory-image"><img src="/images/skate-hook-silver.png" alt="Silver skate hook for hockey lockers" /></div>
						<div class="pdf-spec-accessory-content"><span class="pdf-spec-accessory-cat">Accessories</span><h3 class="pdf-spec-accessory-title">Skate Hooks</h3></div>
					</div>
					<div class="pdf-spec-accessory-card pdf-spec-accessory-card--custom-logo">
						<div class="pdf-spec-accessory-image"><img src="/images/custom-logo-example.png" alt="Custom team logo example" /></div>
						<div class="pdf-spec-accessory-content"><span class="pdf-spec-accessory-cat">Accessories</span><h3 class="pdf-spec-accessory-title">Custom Logo</h3></div>
					</div>
					<div class="pdf-spec-accessory-card pdf-spec-accessory-card--stick-rack">
						<div class="pdf-spec-accessory-image"><img src="/images/stick-rack.png" alt="Wood stick rack for locker rooms" /></div>
						<div class="pdf-spec-accessory-content"><span class="pdf-spec-accessory-cat">Accessories</span><h3 class="pdf-spec-accessory-title">Stick Rack</h3></div>
					</div>
					<div class="pdf-spec-accessory-card pdf-spec-accessory-card--lock-box">
						<div class="pdf-spec-accessory-image"><img src="/images/lock-box.png" alt="Lock box with digital keypad and RFID lock" /></div>
						<div class="pdf-spec-accessory-content"><span class="pdf-spec-accessory-cat">Accessories</span><h3 class="pdf-spec-accessory-title">Lock Box with Digital Key Lock</h3></div>
					</div>
				</div>
			</div>
		</section>
		<section class="product-main-section">
			<div class="product-container">
				<p class="pdf-cta">
					<span class="pdf-hint">Use your browser’s <strong>Print</strong> → <strong>Save as PDF</strong> to download this spec sheet.</span>
				</p>
			</div>
		</section>
	</main>
</BaseLayout>

<style is:global>
	.pdf-spec-page {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	.product-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.product-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 40px;
		overflow: hidden;
		min-height: 240px;
	}

	.product-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.product-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.product-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.hero-image-print-only {
		display: none;
	}

	.product-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.product-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 20px;
	}

	.product-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
	}

	.product-breadcrumbs a:hover {
		color: #fe5900;
	}

	.breadcrumbs-sep { margin: 0 8px; color: rgba(255, 255, 255, 0.6); }
	.breadcrumbs-current { color: #ffffff; }

	.product-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
	}

	.product-main-section {
		padding: 60px 0 80px;
		background: #ffffff;
	}

	.product-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: start;
		margin-bottom: 60px;
	}

	.product-gallery-main {
		position: relative;
		background: #f7f7f7;
		aspect-ratio: 1;
		overflow: hidden;
		margin-bottom: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.product-main-image {
		width: 96%;
		height: 96%;
		object-fit: contain;
		display: block;
	}

	.pdf-spec-page .product-gallery-thumbs {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.pdf-spec-page .product-gallery-thumbs .thumb {
		width: 80px;
		height: 80px;
		border: 2px solid #e0e0e0;
		background: #f0f0f0;
		overflow: hidden;
		border-radius: 0;
	}

	.pdf-spec-page .product-gallery-thumbs .thumb.active {
		border-color: #fe5900;
	}

	.pdf-spec-page .product-gallery-thumbs .thumb img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		display: block;
	}

	.product-detail { position: relative; }

	.pdf-spec-page .product-title {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		margin: 0 0 12px;
	}

	.product-model {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 8px;
	}

	.product-lead-time {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin: 0 0 24px;
	}

	.product-price-block {
		margin-bottom: 24px;
		padding-bottom: 24px;
		border-bottom: 2px solid #fe5900;
	}

	.product-price {
		font-family: 'Oswald', sans-serif;
		font-size: 36px;
		font-weight: 600;
		color: #0d0d0d;
	}

	.price-width-note {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #555;
		line-height: 1.5;
		margin: 10px 0 0;
		max-width: 420px;
	}

	.product-options-static {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #333;
		line-height: 1.6;
		margin-bottom: 24px;
	}

	.product-options-static p { margin: 0 0 8px; }

	/* Birch plywood section – same style as "Other views & options" */
	.product-wood-material {
		margin-bottom: 24px;
		padding-top: 20px;
		border-top: 1px solid #e8e8e8;
	}

	.product-wood-material .option-label {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 12px;
		padding-left: 12px;
		border-left: 4px solid #fe5900;
	}

	.product-wood-material-content {
		display: flex;
		gap: 24px;
		align-items: flex-start;
		flex-wrap: wrap;
	}

	.product-wood-material-image-wrap {
		flex: 0 0 auto;
		background: #f7f7f7;
		padding: 12px;
		border: 1px solid #e0e0e0;
	}

	.product-wood-material-image {
		display: block;
		width: 180px;
		height: auto;
		max-height: 140px;
		object-fit: contain;
	}

	.product-wood-material-text {
		flex: 1;
		min-width: 260px;
	}

	.product-wood-material-text p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #333;
		line-height: 1.6;
		margin: 0;
	}

	.product-accessories-static {
		margin-bottom: 24px;
	}

	.pdf-spec-page .product-accessories-static .option-label {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 6px;
	}

	.pdf-spec-page .product-accessories-static .option-value {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 10px;
	}

	.accessories-list-static {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		line-height: 1.5;
		margin: 0;
		padding-left: 20px;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4px 24px;
		list-style: disc;
	}

	@media (max-width: 600px) {
		.accessories-list-static { grid-template-columns: 1fr; }
		.product-wood-material-content { flex-direction: column; }
		.product-wood-material-text { min-width: 0; }
	}

	.pdf-spec-accessories-section {
		padding: 80px 0;
		background: #f7f7f7;
	}
	.pdf-spec-accessories-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}
	.pdf-spec-accessories-header {
		text-align: center;
		margin-bottom: 60px;
		position: relative;
		z-index: 10;
	}
	.pdf-spec-accessories-subtitle {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		margin: 0 0 15px;
	}
	.pdf-spec-accessories-title {
		font-family: 'Oswald', sans-serif;
		font-size: 48px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0;
	}
	.pdf-spec-accessories-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 25px;
		margin-bottom: 0;
		position: relative;
		z-index: 10;
	}
	.pdf-spec-accessory-card {
		background: #fff;
		display: flex;
		flex-direction: column;
		align-items: center;
		overflow: hidden;
	}
	.pdf-spec-accessory-image {
		width: 200px;
		height: 200px;
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #fff;
		margin-bottom: 16px;
		overflow: hidden;
		position: relative;
		box-sizing: border-box;
	}
	.pdf-spec-accessory-image img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center center;
		display: block;
	}
	.pdf-spec-accessory-card--hooks .pdf-spec-accessory-image {
		padding-top: 20%;
	}
	.pdf-spec-accessory-card--hooks .pdf-spec-accessory-image img {
		width: auto;
		height: auto;
		max-width: 97px;
		max-height: 97px;
	}
	.pdf-spec-accessory-card--name-plate .pdf-spec-accessory-image {
		padding-top: 20%;
	}
	.pdf-spec-accessory-card--name-plate .pdf-spec-accessory-image img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		transform: scale(0.8);
	}
	.pdf-spec-accessory-card--custom-logo .pdf-spec-accessory-image,
	.pdf-spec-accessory-card--stick-rack .pdf-spec-accessory-image {
