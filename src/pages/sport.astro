<script>
	document.addEventListener('DOMContentLoaded', function () {
		const slides = document.querySelectorAll('.sport-slide');
		const dots = document.querySelectorAll('.sport-dot');
		const prevBtn = document.querySelector('.sport-slide-prev');
		const nextBtn = document.querySelector('.sport-slide-next');
		const jumpBtns = document.querySelectorAll('.sport-jump');
		if (slides.length === 0) return;

		let current = 0;
		let autoPlayTimer;

		function goTo(index) {
			index = (index + slides.length) % slides.length;
			current = index;
			slides.forEach(function (s, i) {
				s.classList.toggle('active', i === index);
			});
			dots.forEach(function (d, i) {
				d.classList.toggle('active', i === index);
			});
			jumpBtns.forEach(function (b, i) {
				b.setAttribute('aria-selected', i === index ? 'true' : 'false');
			});
		}

		function next() {
			goTo(current + 1);
		}
		function prev() {
			goTo(current - 1);
		}

		function startAutoPlay() {
			stopAutoPlay();
			autoPlayTimer = setInterval(next, 6000);
		}
		function stopAutoPlay() {
			if (autoPlayTimer) {
				clearInterval(autoPlayTimer);
				autoPlayTimer = null;
			}
		}

		if (prevBtn) prevBtn.addEventListener('click', function () { stopAutoPlay(); prev(); startAutoPlay(); });
		if (nextBtn) nextBtn.addEventListener('click', function () { stopAutoPlay(); next(); startAutoPlay(); });
		dots.forEach(function (d, i) {
			d.addEventListener('click', function () { stopAutoPlay(); goTo(i); startAutoPlay(); });
		});
		jumpBtns.forEach(function (b) {
			b.addEventListener('click', function () {
				var idx = parseInt(b.getAttribute('data-slide'), 10);
				if (!isNaN(idx)) { stopAutoPlay(); goTo(idx); startAutoPlay(); }
			});
		});

		startAutoPlay();
	});
</script>
