---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getBlogHeroUrl } from '../lib/blog-hero';

// Only MDX posts from src/content/blog (Content Collections)
const mdxPosts = await getCollection('blog');

const posts = mdxPosts
	.map(entry => {
		const dateObj = new Date(entry.data.datePublished + 'T12:00:00');
		return {
			title: entry.data.title,
			date: dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
			category: entry.data.category || 'Blog',
			summary: (entry.data.description || entry.data.title).slice(0, 200) + '…',
			heroImage: getBlogHeroUrl({ slug: entry.slug, heroImage: entry.data.heroImage, category: entry.data.category, tags: entry.data.tags }),
			url: `/blog/${entry.slug}`,
			rowSpan: 35 + (Math.abs(entry.slug.length % 15)),
			imageHeight: 220 + (entry.slug.length % 3) * 40,
			dateSort: dateObj.getTime()
		};
	})
	.sort((a, b) => b.dateSort - a.dateSort);
---

<BaseLayout title="Blog - Sports Locker Insights & Tips | PlayerStall" description="Expert insights on sports lockers, locker room design, and athletic facility management. Tips from 30+ years of experience.">
	<!-- Hero Section (same as shop: image + overlay + title "Blog") -->
	<section class="blog-hero-section">
		<div class="blog-hero-background">
			<img src="https://topscorer.qodeinteractive.com/wp-content/uploads/2020/02/h1-img-8.jpg" alt="Blog" class="blog-hero-bg-image" />
		</div>
		<div class="blog-hero-background-overlay"></div>
		<div class="blog-hero-container">
			<div class="blog-breadcrumbs">
				<a href="/">Home</a>
				<span>Blog</span>
			</div>
			<h1 class="blog-page-title">Blog</h1>
			<div class="blog-background-text">blog</div>
		</div>
	</section>

	<!-- Masonry Blog Section -->
	<section class="masonry-blog-section" id="blog-posts">
		<div class="container">
			<div class="masonry-blog-grid">
				{posts.map((post) => (
					<article class="masonry-blog-article" style={`grid-row-end: span ${post.rowSpan};`}>
						<a href={post.url ?? '#'} style="display: block; text-decoration: none; color: inherit;">
							<div class="masonry-blog-image" style={`height: ${post.imageHeight}px;`}>
								<img src={post.heroImage} alt={post.title} loading="lazy" />
							</div>
							<div class="masonry-blog-content">
								<div class="masonry-blog-meta">
									<a href={`/blog?category=${post.category.toLowerCase()}`} class="masonry-blog-category">{post.category}</a>
									<span class="masonry-blog-date">{post.date}</span>
								</div>
								<h4 class="masonry-blog-title">
									<a href={post.url ?? '#'}>{post.title}</a>
								</h4>
								<p class="masonry-blog-excerpt">{post.summary}</p>
								<a href={post.url ?? '#'} class="masonry-blog-read-more">Read More</a>
							</div>
						</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="cta-section">
		<div class="container">
			<div class="cta-content">
				<h2>Have Questions About Your Locker Room Project?</h2>
				<p>Get expert advice from 30+ years of experience. Free custom design consultation.</p>
				<a href="/contact" class="btn btn-primary btn-large">Get Free Consultation</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
		margin: 0;
		padding: 0;
		line-height: 1.6;
	}

	/* Only content sections get max-width/padding; hero is full-bleed like our-process */
	.masonry-blog-section .container,
	.cta-section .container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Blog Hero Section (same as our-process: full-bleed image + overlay + title) */
	.blog-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
		width: 100%;
		max-width: none;
		margin: 0;
	}

	.blog-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.blog-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.blog-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.blog-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.blog-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}

	.blog-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.blog-breadcrumbs a:hover {
		color: #fe5900;
	}

	.blog-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.blog-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 72px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	.blog-background-text {
		display: none;
	}

	.btn {
		display: inline-block;
		padding: 15px 40px;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 500;
		letter-spacing: 0.1em;
		font-size: 20px;
		transition: all 0.3s;
		font-family: 'Roboto', sans-serif;
	}

	.btn-primary {
		background: #fe5900;
		color: #ffffff;
		border: 2px solid #fe5900;
	}

	.btn-primary:hover {
		background: #e04d00;
		border-color: #e04d00;
	}

	.btn-outline {
		background: transparent;
		color: #0d0d0d;
		border: 2px solid #bfbfbf;
	}

	.btn-outline:hover {
		border-color: #0d0d0d;
		color: #0d0d0d;
	}

	.hero-image {
		position: absolute;
		right: 0;
		top: 50%;
		transform: translateY(-50%);
		z-index: 5;
	}

	.hero-image img {
		max-width: 810px;
		height: auto;
	}

	.container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Masonry Blog Section */
	.masonry-blog-section {
		background: #ffffff;
		padding: 80px 0;
	}

	.masonry-blog-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 25px;
		grid-auto-rows: 10px;
	}

	.masonry-blog-article {
		background: #ffffff;
		overflow: hidden;
	}

	.masonry-blog-image {
		width: 100%;
		overflow: hidden;
		margin-bottom: 20px;
	}

	.masonry-blog-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s;
	}

	.masonry-blog-article:hover .masonry-blog-image img {
		transform: scale(1.05);
	}

	.masonry-blog-content {
		padding: 0 0 20px;
	}

	.masonry-blog-meta {
		display: flex;
		gap: 15px;
		margin-bottom: 15px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.masonry-blog-category {
		color: #8c8c8c;
		text-decoration: none;
		transition: color 0.3s;
	}

	.masonry-blog-category:hover {
		color: #fe5900;
	}

	.masonry-blog-date {
		color: #8c8c8c;
	}

	.masonry-blog-title {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		color: #0d0d0d;
		margin-bottom: 15px;
		line-height: 1.3;
	}

	.masonry-blog-title a {
		color: #0d0d0d;
		text-decoration: none;
		transition: color 0.3s;
	}

	.masonry-blog-article:hover .masonry-blog-title a {
		color: #fe5900;
	}

	.masonry-blog-excerpt {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #666666;
		line-height: 1.6;
		margin-bottom: 15px;
	}

	.masonry-blog-read-more {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #0d0d0d;
		text-decoration: none;
		display: inline-block;
		transition: color 0.3s;
		font-weight: 500;
	}

	.masonry-blog-article:hover .masonry-blog-read-more {
		color: #fe5900;
	}

	/* CTA Section */
	.cta-section {
		padding: 5rem 0;
		background: #0d0d0d;
		color: #fff;
		text-align: center;
	}

	.cta-content h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 48px;
		font-weight: 600;
		color: #fff;
		text-transform: uppercase;
		margin-bottom: 1.5rem;
	}

	.cta-content p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 20px;
		color: #ccc;
		margin-bottom: 2rem;
		max-width: 700px;
		margin-left: auto;
		margin-right: auto;
		line-height: 1.8;
	}

	.btn-large {
		padding: 18px 50px;
		font-size: 18px;
	}

	@media (max-width: 1200px) {
		.masonry-blog-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 1024px) {
		.blog-page-title {
			font-size: 56px;
		}
	}

	@media (max-width: 768px) {
		.blog-hero-section {
			min-height: 300px;
		}

		.blog-page-title {
			font-size: 42px;
		}

		.masonry-blog-section .container {
			padding: 0 1.5rem;
		}

		.cta-section .container {
			padding: 0 1.5rem;
		}

		.hero-buttons {
			flex-direction: column;
		}

		.playoff-text {
			font-size: 100px;
		}

		.masonry-blog-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.cta-content h2 {
			font-size: 36px;
		}
	}

	@media (max-width: 480px) {
		.blog-page-title {
			font-size: 32px;
		}

		.masonry-blog-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

