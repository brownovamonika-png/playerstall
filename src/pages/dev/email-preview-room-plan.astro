---
/**
 * Local preview of MailerSend HTML for room planner emails.
 * Run: npm run dev → open http://localhost:4321/dev/email-preview-room-plan
 * Not shown in production builds (redirects home).
 */
if (import.meta.env.PROD) {
	return Astro.redirect('/');
}

/*
 * Point iframes at the standalone preview routes instead of stuffing the
 * entire HTML into a `data:text/html,…` URL. Data URLs have an opaque origin,
 * making Google Fonts / clamp() rendering unreliable and — at these payload
 * sizes — some browsers (Chrome in particular) silently show a blank frame
 * because the encoded URL exceeds the data: length budget, which is exactly
 * the "static / empty iframe" bug we hit after wiring Oswald + Yantramanav
 * into the email HTML. `src=/dev/…` always works, keeps DevTools inspectable,
 * and gives us a direct URL the team can open when QA'ing the exact payload.
 */
const customerSrc = '/dev/email-preview-room-plan-customer';
const teamSrc = '/dev/email-preview-room-plan-team';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex,nofollow" />
		<title>Room plan email preview (dev)</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				margin: 0;
				padding: 24px;
				background: #e8e8e8;
				color: #333;
			}
			h1 {
				font-size: 1rem;
				margin: 0 0 8px;
			}
			p.hint {
				font-size: 13px;
				color: #666;
				margin: 0 0 16px;
				max-width: 720px;
			}
			section {
				margin-bottom: 48px;
			}
			iframe {
				width: 100%;
				min-height: 920px;
				border: 1px solid #ccc;
				border-radius: 8px;
				background: #fff;
			}
			code {
				background: #ddd;
				padding: 2px 6px;
				border-radius: 4px;
				font-size: 12px;
			}
		</style>
	</head>
	<body>
		<p class="hint">
			Customer and team emails both use the same compact HTML pattern (<code>buildCustomerHTML</code> /
			<code>buildSalesHTML</code>): totals + pointer to PDFs; team adds a Customer mailto row on the card. The estimate
			PDF has the full table + your selections — see <code>src/room-planner/pdfEstimate.ts</code>. Edit copy in
			<code>src/lib/roomPlanCustomerCopy.ts</code> and layout in <code>src/lib/roomPlanEmailTemplates.ts</code>. Subjects
			are in <code>src/pages/api/send-room-plan.ts</code>. Run <code>npm run email:export-preview</code> to write HTML +
			sample PDF to <code>email-export/</code>.
		</p>

		<section>
			<h1>Customer email (inbox of the address they typed in the planner)</h1>
			<p class="hint">Subject: <strong>Review your layout — PlayerStall (PDFs attached)</strong></p>
			<iframe title="Customer email preview" src={customerSrc}></iframe>
		</section>

		<section>
			<h1>Team email (team@)</h1>
			<p class="hint">Subject: <strong>New layout submission — …</strong></p>
			<iframe title="Team email preview" src={teamSrc}></iframe>
		</section>
	</body>
</html>
