---
/**
 * Local preview of MailerSend HTML for room planner emails.
 * Run: npm run dev → open http://localhost:4321/dev/email-preview-room-plan
 * Not shown in production builds (redirects home).
 */
import {
	buildCustomerHTML,
	buildSalesHTML,
	SAMPLE_ORDER_SUMMARY,
} from '../../lib/roomPlanEmailTemplates';

if (import.meta.env.PROD) {
	return Astro.redirect('/');
}

const sampleEmail = 'you@example.com';
const sampleTotal = '5908.00';
const customerHtml = buildCustomerHTML(sampleEmail, SAMPLE_ORDER_SUMMARY, sampleTotal);
const teamHtml = buildSalesHTML(sampleEmail, SAMPLE_ORDER_SUMMARY, sampleTotal);
const customerSrc = `data:text/html;charset=utf-8,${encodeURIComponent(customerHtml)}`;
const teamSrc = `data:text/html;charset=utf-8,${encodeURIComponent(teamHtml)}`;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex,nofollow" />
		<title>Room plan email preview (dev)</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				margin: 0;
				padding: 24px;
				background: #e8e8e8;
				color: #333;
			}
			h1 {
				font-size: 1rem;
				margin: 0 0 8px;
			}
			p.hint {
				font-size: 13px;
				color: #666;
				margin: 0 0 16px;
				max-width: 720px;
			}
			section {
				margin-bottom: 48px;
			}
			iframe {
				width: 100%;
				min-height: 920px;
				border: 1px solid #ccc;
				border-radius: 8px;
				background: #fff;
			}
			code {
				background: #ddd;
				padding: 2px 6px;
				border-radius: 4px;
				font-size: 12px;
			}
		</style>
	</head>
	<body>
		<p class="hint">
			Customer and team emails both use the same compact HTML pattern (<code>buildCustomerHTML</code> /
			<code>buildSalesHTML</code>): totals + pointer to PDFs; team adds a Customer mailto row on the card. The estimate
			PDF has the full table + your selections — see <code>src/room-planner/pdfEstimate.ts</code>. Edit copy in
			<code>src/lib/roomPlanCustomerCopy.ts</code> and layout in <code>src/lib/roomPlanEmailTemplates.ts</code>. Subjects
			are in <code>src/pages/api/send-room-plan.ts</code>. Run <code>npm run email:export-preview</code> to write HTML +
			sample PDF to <code>email-export/</code>.
		</p>

		<section>
			<h1>Customer email (inbox of the address they typed in the planner)</h1>
			<p class="hint">Subject: <strong>Review your layout — PlayerStall (PDFs attached)</strong></p>
			<iframe title="Customer email preview" src={customerSrc}></iframe>
		</section>

		<section>
			<h1>Team email (team@)</h1>
			<p class="hint">Subject: <strong>New layout submission — …</strong></p>
			<iframe title="Team email preview" src={teamSrc}></iframe>
		</section>
	</body>
</html>
