<script>
	document.addEventListener('DOMContentLoaded', () => {
		const triggers = document.querySelectorAll('.product-card-with-spec .product-card-trigger');
		triggers.forEach((btn) => {
			btn.addEventListener('click', () => {
				const targetId = btn.getAttribute('data-spec-target');
				if (!targetId) return;
				const panel = document.getElementById(targetId);
				if (!panel) return;

				const isOpen = !panel.hasAttribute('hidden');
				if (isOpen) {
					panel.setAttribute('hidden', '');
					btn.setAttribute('aria-expanded', 'false');
					const label = btn.querySelector('.spec-toggle-label');
					if (label) label.textContent = 'View specs ↓';
				} else {
					// Close any other open panels
					document.querySelectorAll('.product-card-with-spec .spec-panel').forEach((p) => {
						p.setAttribute('hidden', '');
						const otherBtn = document.querySelector(`[data-spec-target="${p.id}"]`);
						if (otherBtn) {
							otherBtn.setAttribute('aria-expanded', 'false');
							const lbl = otherBtn.querySelector('.spec-toggle-label');
							if (lbl) lbl.textContent = 'View specs ↓';
						}
					});
					panel.removeAttribute('hidden');
					btn.setAttribute('aria-expanded', 'true');
					const label = btn.querySelector('.spec-toggle-label');
					if (label) label.textContent = 'Hide specs ↑';
				}
			});
		});
	});
</script>
