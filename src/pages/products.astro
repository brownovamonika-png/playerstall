			"name": "Model X Locker",
			"description": "Ultimate premium tier wood sports locker with maximum customization options. Elite finishing for championship facilities.",
			"brand": {
				"@type": "Brand",
				"name": "PlayerStall"
			},
			"image": "https://playerstall.b-cdn.net/images/legendary-locker.png",
