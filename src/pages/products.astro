// BreadcrumbList Schema
const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": "https://playerstall.com"
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Our Products",
			"item": "https://playerstall.com/products"
		}
	]
};
---

<BaseLayout 
	title="Wood Sports Locker Models & Pricing | PlayerStall" 
	description="Quick ship in 2–4 weeks: Stadium, Elite and Model X in 24 inch width, Light or Dark Gray. Custom wood and more in 8–12 weeks. Price match guarantee. Five tiers from $349. 5 year warranty."
	canonical="https://playerstall.com/products"
>
	<!-- Schema.org Structured Data -->
	<script type="application/ld+json" set:html={JSON.stringify(productsSchema)} slot="head" />
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
	<!-- Hero Section -->
	<section class="hero-section">
		<div class="hero-parallax-img-holder">
			<div class="hero-parallax-img-wrapper">
				<img src="https://playerstall.b-cdn.net/images/our-team-title-photo.jpg" alt="Our Products" class="hero-parallax-img" />
			</div>
		</div>
		<div class="hero-content qodef-content-grid">
			<div class="breadcrumbs">
				<a href="/">Home</a>
				<span class="breadcrumbs-separator"></span>
				<span class="breadcrumbs-current">Our Products</span>
			</div>
			<h1 class="hero-title">Premium Wood Lockers. Priced Right.</h1>
		</div>
	</section>

	<!-- Products Grid Section -->
	<section class="products-team-section">
		<!-- Background Elements -->
		<div class="products-background-dots"></div>
		<div class="products-background-text-holder">
			<span class="products-background-text">p r o d u c t</span>
		</div>
		
		<div class="products-container qodef-content-grid">
			<div class="section-header">
				<p class="section-subtitle">our products</p>
				<h2 class="section-title">Quick Ship &amp; Custom</h2>
				<p style="max-width: 700px; margin: 1rem auto 0; font-size: 1rem; color: #666;">Quick ship ships in 2 to 4 weeks: Stadium, Elite &amp; Model X in 24&quot; width, Light Gray or Dark Gray. Custom orders are 8–12 weeks: any size, any wood, or materials. Price match guarantee on USA competitors.</p>
			</div>
			
			<div class="products-grid">
				<!-- Semi Pro -->
				<div class="product-card" id="semi-pro">
					<a href="/product-semi-pro-locker" class="product-link product-card-trigger-link">
						<div class="product-image">
							<img src="http://playerstall.com/wp-content/uploads/2016/03/Athletic-Locker-Semipro.jpg" alt="Semi Pro Locker" loading="lazy" />
						</div>
						<div class="product-details">
							<div class="product-position">Semi Pro</div>
							<h4 class="product-name">Semi Pro <span class="product-price-inline">$349</span></h4>
							<span class="spec-toggle-label">View spec sheet &rarr;</span>
						</div>
					</a>
				</div>

				<!-- Varsity -->
				<div class="product-card" id="varsity">
					<a href="/product-varsity-locker" class="product-link product-card-trigger-link">
						<div class="product-image">
							<img src="/images/varsity-locker.png" alt="Varsity Locker" loading="lazy" />
						</div>
						<div class="product-details">
							<div class="product-position">Varsity</div>
							<h4 class="product-name">Varsity <span class="product-price-inline">$449</span></h4>
							<span class="spec-toggle-label">View spec sheet &rarr;</span>
						</div>
					</a>
				</div>

				<!-- Pro -->
				<div class="product-card" id="pro">
					<a href="/product-pro-locker" class="product-link product-card-trigger-link">
						<div class="product-image">
							<img src="http://playerstall.com/wp-content/uploads/2016/03/Athletic-Locker-Pro.jpg" alt="Pro Locker" loading="lazy" />
						</div>
						<div class="product-details">
							<div class="product-position">Pro</div>
							<h4 class="product-name">Pro <span class="product-price-inline">$549</span></h4>
							<span class="spec-toggle-label">View spec sheet &rarr;</span>
						</div>
					</a>
				</div>

				<!-- Stadium -->
				<div class="product-card" id="stadium">
					<a href="/product-stadium-locker" class="product-link product-card-trigger-link">
						<div class="product-image">
							<img src="/images/stadium-locker.png" alt="Stadium Locker" loading="lazy" />
						</div>
						<div class="product-details">
							<div class="product-position">Stadium &middot; Quick Ship (2–4 weeks)</div>
							<h4 class="product-name">Stadium <span class="product-price-inline">From $649</span></h4>
							<span class="spec-toggle-label">View spec sheet &rarr;</span>
						</div>
					</a>
				</div>

				<!-- Elite Locker -->
				<div class="product-card product-card-with-spec" id="elite">
					<button type="button" class="product-card-trigger" aria-expanded="false" aria-controls="spec-elite" data-spec-target="spec-elite">
						<div class="product-image">
							<img src="/images/elite-locker.png" alt="Elite Locker" loading="lazy" />
						</div>
						<div class="product-details">
							<div class="product-position">Elite • Quick Ship (2–4 weeks)</div>
							<h4 class="product-name">Elite Locker <span class="product-price-inline">From $649</span></h4>
							<span class="spec-toggle-label">View specs &darr;</span>
						</div>
					</button>
					<div id="spec-elite" class="spec-panel" hidden>
						<div class="spec-panel-inner">
							<h5>Specifications</h5>
							<ul>
								<li><strong>Standard size shown:</strong> 24&quot; W x 76&quot; H x 19&quot; D</li>
								<li><strong>Base:</strong> optional 4&quot; high base can be added</li>
								<li><strong>Weight:</strong> approx. 175 lbs</li>
								<li><strong>Quick Ship (2–4 weeks):</strong> 24&quot; width, Light Gray or Dark Gray</li>
								<li><strong>Base price:</strong> $649 · <strong>Quick ship (24&quot;):</strong> $749 (includes accessories) · <strong>Colors:</strong> Black, Light Grey, Dark Grey, Maple</li>
								<li><strong>Custom:</strong> 8–12 weeks — any size, any wood, or materials</li>
							</ul>
							<a href="/product-elite-locker" class="spec-cta">View product</a>
							<a href="/contact" class="spec-cta">Request a quote</a>
						</div>
					</div>
				</div>

				<!-- Model X Locker -->
				<div class="product-card product-card-with-spec" id="model-x">
					<button type="button" class="product-card-trigger" aria-expanded="false" aria-controls="spec-model-x" data-spec-target="spec-model-x">
						<div class="product-image">
							<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Model X Locker" loading="lazy" />
						</div>
						<div class="product-details">
							<div class="product-position">Model X</div>
							<h4 class="product-name">Model X Locker <span class="product-price-inline">From $649</span></h4>
							<span class="spec-toggle-label">View specs &darr;</span>
						</div>
					</button>
					<div id="spec-model-x" class="spec-panel" hidden>
						<div class="spec-panel-inner">
							<h5>Specifications</h5>
							<ul>
								<li><strong>Standard size shown:</strong> 24&quot; W x 76&quot; H x 19&quot; D</li>
								<li><strong>Base:</strong> optional 4&quot; high base can be added</li>
								<li><strong>Weight:</strong> approx. 175 lbs</li>
								<li><strong>Premium tier</strong> with maximum customization · <strong>Base price:</strong> $649 · <strong>Quick ship (24&quot;):</strong> $749 (includes accessories)</li>
								<li><strong>Colors:</strong> Black, Light Grey, Dark Grey, Maple</li>
								<li><strong>Custom:</strong> 8–12 weeks — any size, wood, or materials</li>
							</ul>
							<a href="/product-legendary-locker" class="spec-cta">View product</a>
							<a href="/contact" class="spec-cta">Request a quote</a>
						</div>
					</div>
				</div>

				<!-- Bench -->
				<div class="product-card product-card-with-spec" id="wood-locker-bench">
					<button type="button" class="product-card-trigger" aria-expanded="false" aria-controls="spec-bench" data-spec-target="spec-bench">
						<div class="product-image">
							<img src="https://playerstall.b-cdn.net/images/wood-lockers-starting-lineup.jpg" alt="Bench free standing for locker rooms" loading="lazy" />
						</div>
						<div class="product-details">
							<div class="product-position">Accessory</div>
							<h4 class="product-name">Bench <span class="product-price-inline">From $225</span></h4>
							<span class="spec-toggle-label">View specs &darr;</span>
						</div>
					</button>
					<div id="spec-bench" class="spec-panel" hidden>
						<div class="spec-panel-inner">
							<h5>Specifications</h5>
							<ul>
								<li><strong>Standard size shown:</strong> 24&quot; W x 76&quot; H x 19&quot; D</li>
								<li><strong>Base:</strong> optional 4&quot; high base can be added</li>
								<li><strong>Weight:</strong> approx. 175 lbs</li>
								<li><strong>Colors:</strong> Black, Light Grey, Dark Grey, Maple · Custom colors available</li>
							</ul>
							<a href="/product-wood-locker-bench" class="spec-cta">View product</a>
							<a href="/contact" class="spec-cta">Request a quote</a>
						</div>
					</div>
				</div>

				<!-- Accessories -->
				<div class="product-card">
					<a href="/accessories" class="product-link product-card-trigger-link">
						<div class="product-image">
							<img src="https://playerstall.b-cdn.net/images/player-img-12.jpg" alt="Accessories" loading="lazy" />
						</div>
						<div class="product-details">
							<div class="product-position">Accessories</div>
							<h4 class="product-name">Lock Box &amp; Stick Rack</h4>
							<span class="spec-toggle-label">View accessories &rarr;</span>
						</div>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Accessories Section -->
	<section class="accessories-section" id="accessories">
		<div class="container">
			<div class="accessories-header">
				<p class="section-subtitle">finishing touches</p>
				<h2 class="section-title">locker accessories</h2>
				<p class="accessories-tagline">Dial in every detail – airflow, storage, comfort, and branding.</p>
			</div>

			<div class="accessories-grid">
				<div class="accessory-card">
					<div class="accessory-image">
						<img src="https://playerstall.b-cdn.net/images/cushion-logo.png" alt="Locker cushion with team logo" loading="lazy" />
					</div>
					<h3 class="accessory-title">Cushions</h3>
					<p class="accessory-price">+ $75.00 (top or bottom) / $150.00 (both)</p>
					<p class="accessory-copy">High-density foam cushions upholstered for comfort and durability – available on the top, bottom, or both.</p>
				</div>

				<div class="accessory-card">
					<div class="accessory-image">
						<img src="https://playerstall.b-cdn.net/images/coat-rod.png" alt="Coat rod for lockers" loading="lazy" />
					</div>
					<h3 class="accessory-title">Coat Rod</h3>
					<p class="accessory-price">Call for pricing</p>
					<p class="accessory-copy">Heavy-duty coat rod for jerseys, jackets, and gear – sized to match each locker style.</p>
				</div>

				<div class="accessory-card">
					<div class="accessory-image">
						<img src="https://playerstall.b-cdn.net/images/wall-hook.png" alt="Interior locker hook" loading="lazy" />
					</div>
					<h3 class="accessory-title">Hooks</h3>
					<p class="accessory-price">Call for pricing</p>
					<p class="accessory-copy">Additional interior hooks for bags, helmets, and everyday gear, matched to your locker layout.</p>
				</div>

				<div class="accessory-card">
					<div class="accessory-image">
						<img src="https://playerstall.b-cdn.net/images/name-plate.png" alt="Locker name plate" loading="lazy" />
					</div>
					<h3 class="accessory-title">Name Plate</h3>
					<p class="accessory-price">+ $10.00</p>
					<p class="accessory-copy">Clean, simple name plate for player identification – ideal for teams that want a classic, organized look.</p>
				</div>

				<div class="accessory-card">
					<div class="accessory-image">
						<img src="https://playerstall.b-cdn.net/images/skate-hook.png" alt="Skate hook for hockey lockers" loading="lazy" />
					</div>
					<h3 class="accessory-title">Skate Hooks</h3>
					<p class="accessory-price">+ $25.00</p>
					<p class="accessory-copy">Additional wall-mounted hooks positioned for skates or gear, perfect for hockey or figure skating locker rooms.</p>
				</div>

				<div class="accessory-card">
					<div class="accessory-image">
						<img src="https://playerstall.b-cdn.net/images/custom-logo-example.png" alt="Example of custom team logo on wood background" loading="lazy" />
					</div>
					<h3 class="accessory-title">Custom Logo</h3>
					<p class="accessory-price">+ $75.00</p>
					<p class="accessory-copy">Team or program branding applied to the locker face – reinforce your identity every time players walk in.</p>
				</div>

				<div class="accessory-card accessory-card-link">
					<a href="/accessories" class="accessory-card-link-inner">
						<h3 class="accessory-title">Lock Box &amp; Stick Rack</h3>
						<p class="accessory-copy">Lock box with digital key lock (+$80) and stick rack (from $299). View details and request a quote.</p>
						<span class="spec-toggle-label">View accessories &rarr;</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Comparison Table -->
	<section class="comparison-table-section" id="comparison">
		<div class="container">
			<h2>Compare All Tiers</h2>
			<div class="comparison-table-wrapper">
				<table class="comparison-table">
					<thead>
						<tr>
							<th>Feature</th>
							<th>Semi Pro</th>
							<th>Varsity</th>
							<th>Pro</th>
							<th>Elite</th>
							<th>Stadium</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td>Price (Sale)</td>
							<td>$349</td>
							<td>$449</td>
							<td>$649</td>
							<td>$649</td>
							<td>$649</td>
						</tr>
						<tr>
							<td>3/4" Solid Wood</td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
						</tr>
						<tr>
							<td>5 Year Warranty</td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
						</tr>
						<tr>
							<td>Modular Design</td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
							<td><span class="checkmark">Yes</span></td>
						</tr>
						<tr>
							<td>Custom Branding</td>
							<td>Basic</td>
							<td>Premium</td>
							<td>Maximum</td>
							<td>Premium</td>
							<td>Ultimate</td>
						</tr>
						<tr>
							<td>Storage Capacity</td>
							<td>Standard</td>
							<td>Enhanced</td>
							<td>Maximum</td>
							<td>Enhanced</td>
							<td>Elite</td>
						</tr>
						<tr>
							<td>Finishing Quality</td>
