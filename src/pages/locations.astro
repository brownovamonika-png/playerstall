---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Custom Wood Lockers — Shipping Nationwide | PlayerStall"
	description="PlayerStall builds and ships custom wood locker rooms to collegiate and professional teams across all 50 states. One facility. Thirty years. Nationwide delivery."
>
	<!-- Hero Section -->
	<section class="hero" id="hero">
		<div class="playoff-text">NATIONWIDE</div>
		<div class="hero-content">
			<p class="hero-subtitle">We Ship Everywhere</p>
			<h1 class="hero-title">Built Here.<br />Delivered Anywhere.</h1>
			<p class="hero-text">We manufacture every locker at our facility in Langley, BC and ship direct to teams across all 50 states. No middlemen. No regional markups.</p>
			<div class="hero-buttons">
				<a href="/contact" class="btn btn-primary">Start a Consultation</a>
				<a href="/products" class="btn btn-outline">View the Collection</a>
			</div>
		</div>
		<div class="hero-image">
			<img src="https://playerstall.b-cdn.net/images/h3-rev-img-2.png" alt="PlayerStall custom wood locker rooms" />
		</div>
	</section>

	<!-- Our Facility -->
	<section class="facility-section">
		<div class="container">
			<div class="facility-grid">
				<div class="facility-text">
					<p class="section-subtitle">Our Home Base</p>
					<h2 class="section-title">One Facility.<br />Every Order.</h2>
					<p class="facility-body">Every PlayerStall locker is built at our manufacturing facility in Langley, British Columbia. We've operated from the same location for 30 years — not because we haven't grown, but because quality doesn't need to franchise.</p>
					<p class="facility-body">All design consultations and custom orders are handled directly through our team. When you call, you reach us.</p>
					<div class="facility-address">
						<strong>PlayerStall Manufacturing</strong><br />
						2934 200 Street<br />
						Langley, BC V2Z 2C1 Canada<br />
						<a href="tel:18885841444">1 888 584 1444</a><br />
						<a href="mailto:team@playerstall.com">team@playerstall.com</a>
					</div>
				</div>
				<div class="facility-stats">
					<div class="stat-card">
						<span class="stat-number">30+</span>
						<span class="stat-label">Years in business</span>
					</div>
					<div class="stat-card">
						<span class="stat-number">50</span>
						<span class="stat-label">States we deliver to</span>
					</div>
					<div class="stat-card">
						<span class="stat-number">8–12</span>
						<span class="stat-label">Weeks to custom delivery</span>
					</div>
					<div class="stat-card">
						<span class="stat-number">5yr</span>
						<span class="stat-label">Warranty on every locker</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- States We Serve -->
	<section class="states-section">
		<div class="container">
			<p class="section-subtitle">Coverage</p>
			<h2 class="section-title">All 50 States</h2>
			<p class="states-intro">We ship to collegiate and professional programs across every region of the United States. Below are the states we most frequently serve — though no zip code is out of reach.</p>
			<div class="regions-grid">
				<div class="region-card">
					<h3>Southeast</h3>
					<ul>
						<li>Florida</li>
						<li>Georgia</li>
						<li>North Carolina</li>
						<li>South Carolina</li>
						<li>Tennessee</li>
						<li>Alabama</li>
						<li>Mississippi</li>
					</ul>
				</div>
				<div class="region-card">
					<h3>South &amp; Southwest</h3>
					<ul>
						<li>Texas</li>
						<li>Oklahoma</li>
						<li>Louisiana</li>
						<li>Arkansas</li>
						<li>Arizona</li>
						<li>New Mexico</li>
					</ul>
				</div>
				<div class="region-card">
					<h3>Midwest</h3>
					<ul>
						<li>Ohio</li>
						<li>Michigan</li>
						<li>Illinois</li>
						<li>Indiana</li>
						<li>Wisconsin</li>
						<li>Minnesota</li>
						<li>Iowa</li>
					</ul>
				</div>
				<div class="region-card">
					<h3>Northeast</h3>
					<ul>
						<li>New York</li>
						<li>Pennsylvania</li>
						<li>New Jersey</li>
						<li>Massachusetts</li>
						<li>Connecticut</li>
						<li>Maryland</li>
					</ul>
				</div>
				<div class="region-card">
					<h3>West</h3>
					<ul>
						<li>California</li>
						<li>Washington</li>
						<li>Oregon</li>
						<li>Colorado</li>
						<li>Utah</li>
						<li>Nevada</li>
					</ul>
				</div>
				<div class="region-card">
					<h3>Mountain &amp; Plains</h3>
					<ul>
						<li>Kansas</li>
						<li>Missouri</li>
						<li>Nebraska</li>
						<li>Montana</li>
						<li>Wyoming</li>
						<li>Idaho</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="map-cta">
		<div class="container">
			<h2>Ready to Build Your Locker Room?</h2>
			<p>Tell us about your program and we'll take it from there. Free consultation. No obligation.</p>
			<a href="/contact" class="btn btn-primary">Start a Consultation</a>
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #f7f7f7;
		color: #0d0d0d;
	}

	.container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Hero Section */
	.hero {
		position: relative;
		height: 800px;
		background: #f7f7f7;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		padding-left: 10%;
		margin-top: 0;
	}

	.playoff-text {
		position: absolute;
		font-family: 'Oswald', sans-serif;
		font-size: 280px;
		font-weight: 700;
		color: rgba(13, 13, 13, 0.03);
		text-transform: uppercase;
		letter-spacing: -3px;
		z-index: 1;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		white-space: nowrap;
	}

	.hero-content {
		position: relative;
		z-index: 10;
		max-width: 600px;
	}

	.hero-subtitle {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		margin-bottom: 20px;
	}

	.hero-title {
		font-family: 'Oswald', sans-serif;
		font-size: 62px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		line-height: 1.05;
		margin-bottom: 30px;
	}

	.hero-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 20px;
		color: #666666;
		line-height: 30px;
		margin-bottom: 40px;
	}

	.hero-buttons {
		display: flex;
		gap: 20px;
	}

	.btn {
		display: inline-block;
		padding: 15px 40px;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 500;
		letter-spacing: 0.1em;
		font-size: 16px;
		transition: all 0.3s;
		font-family: 'Roboto', sans-serif;
	}

	.btn-primary {
		background: #fe5900;
		color: #ffffff;
		border: 2px solid #fe5900;
	}

	.btn-primary:hover {
		background: #e04d00;
		border-color: #e04d00;
	}

	.btn-outline {
		background: transparent;
		color: #0d0d0d;
		border: 2px solid #bfbfbf;
	}

	.btn-outline:hover {
		border-color: #0d0d0d;
	}

	.hero-image {
		position: absolute;
		right: 0;
		top: 50%;
		transform: translateY(-50%);
		z-index: 5;
	}

	.hero-image img {
		max-width: 810px;
		height: auto;
	}

	/* Facility Section */
	.facility-section {
		padding: 6rem 0;
		background: #ffffff;
	}

	.section-subtitle {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		margin-bottom: 16px;
	}

	.section-title {
		font-family: 'Oswald', sans-serif;
		font-size: 44px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		line-height: 1.1;
		margin-bottom: 30px;
	}

	.facility-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 80px;
		align-items: start;
	}

	.facility-body {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #555;
		line-height: 1.7;
		margin-bottom: 20px;
	}

	.facility-address {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #333;
		line-height: 2;
		margin-top: 32px;
		padding-top: 32px;
		border-top: 1px solid #e5e5e5;
	}

	.facility-address a {
		color: #fe5900;
		text-decoration: none;
	}

	.facility-address a:hover {
		text-decoration: underline;
	}

	.facility-stats {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 24px;
	}

	.stat-card {
		background: #f7f7f7;
		padding: 36px 28px;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.stat-number {
		font-family: 'Oswald', sans-serif;
		font-size: 48px;
		font-weight: 700;
		color: #fe5900;
		line-height: 1;
	}

	.stat-label {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #666;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	/* States Section */
	.states-section {
		padding: 6rem 0;
		background: #f7f7f7;
	}

	.states-intro {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #555;
		line-height: 1.7;
		max-width: 700px;
		margin-bottom: 48px;
	}

	.regions-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.region-card {
		background: #ffffff;
		padding: 32px;
	}

	.region-card h3 {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 20px;
		padding-bottom: 12px;
		border-bottom: 2px solid #fe5900;
	}

	.region-card ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.region-card ul li {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #555;
		padding: 6px 0;
		border-bottom: 1px solid #f0f0f0;
	}

	.region-card ul li:last-child {
		border-bottom: none;
	}

	/* CTA Section */
	.map-cta {
		padding: 6rem 0;
		background: #1a1a1a;
		color: #fff;
		text-align: center;
	}

	.map-cta h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 40px;
		font-weight: 600;
		text-transform: uppercase;
		margin-bottom: 16px;
	}

	.map-cta p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		margin-bottom: 40px;
		color: #cccccc;
	}

	@media (max-width: 1024px) {
		.facility-grid {
			grid-template-columns: 1fr;
			gap: 48px;
		}

		.hero-image {
			display: none;
		}

		.playoff-text {
			font-size: 150px;
		}

		.regions-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.hero {
			height: auto;
			padding: 100px 20px 60px;
		}

		.hero-title {
			font-size: 42px;
		}

		.hero-text {
			font-size: 16px;
		}

		.hero-buttons {
			flex-direction: column;
		}

		.playoff-text {
			font-size: 100px;
		}

		.section-title {
			font-size: 32px;
		}

		.regions-grid {
			grid-template-columns: 1fr;
		}

		.facility-stats {
			grid-template-columns: 1fr 1fr;
		}
	}
</style>
