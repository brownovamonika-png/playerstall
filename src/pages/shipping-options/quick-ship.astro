---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageDescription = 'Quick ship Model S, Model Z, and Model X lockers in 2–4 weeks (24" width). Colored melamine and maple cabinetry grade plywood. Lock box and vented front included. 5-year warranty.';
---

<BaseLayout
	title="Quick Ship | Shipping | PlayerStall"
	description={pageDescription}
>
	<section class="ship-hero-section">
		<div class="ship-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Quick ship lockers" class="ship-hero-bg-image" />
		</div>
		<div class="ship-hero-background-overlay"></div>
		<div class="ship-hero-container">
			<div class="ship-breadcrumbs">
				<a href="/">Home</a>
				<a href="/shipping-options">Shipping</a>
				<span>Quick Ship</span>
			</div>
			<h1 class="ship-page-title">Quick Ship</h1>
		</div>
	</section>

	<section class="home-shop-section">
		<div class="home-shop-container">
			<div class="home-shop-section-header">
				<p class="home-shop-section-subtitle">DELIVERY TIMEFRAMES</p>
				<h2 class="home-shop-section-title">QUICK SHIP LOCKERS</h2>
			</div>
			<div class="ts-spotlight-inner-centered">
				<div class="ts-spotlight-content">
					<a href="/products" class="ts-spotlight-position">Model S, Model Z &amp; Model X</a>
					<div class="ts-spotlight-meta">
						24&quot; width · 2–4 weeks · Lock box &amp; vented front included
					</div>
					<p class="ts-spotlight-bio">When you need lockers fast, we keep Model S, Model Z, and Model X ready to ship in 2–4 weeks. Each comes in one finish—black, dark grey, or light grey—at 24&quot; width with lock box and vented front standard. Same solid wood construction and 5-year warranty as our custom builds. We run production year-round so these are available when you need them, and we pass the savings on in our pricing.</p>
					<p class="ship-quick-accessories-hint">Click any locker image below to see what’s included.</p>
					<div class="ship-quick-line">
						<h3 class="ship-quick-line-title">Colored melamine</h3>
						<p class="ship-quick-line-desc">Durable, moisture-resistant finish in black, dark grey, or light grey. Easy to clean and built for heavy use in locker rooms. Melamine holds up to bumps, spills, and daily wear while keeping a consistent, professional look across your space.</p>
					<div class="ship-quick-products">
						<article class="ship-quick-product">
							<div class="ship-quick-product-image ship-quick-product-image-wrap" role="button" tabindex="0" aria-label="View locker details">
							<img src="/images/stadium-locker-side.png" alt="Model S quick ship wood locker" loading="lazy" />
							<div class="ship-quick-image-overlay" aria-hidden="true">
								<button type="button" class="ship-quick-view-details-overlay-btn">View details</button>
							</div>
						</div>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name">Model S</h3>
								<p class="ship-quick-product-price">$749</p>
								<p class="ship-quick-product-color">Black</p>
								<button type="button" class="ship-add-to-cart" data-product-id="stadium-quick-ship" data-product-name="Model S Quick Ship" data-product-price="749" data-product-image="/images/stadium-locker-side.png">Add to cart</button>
							</div>
						</article>
						<article class="ship-quick-product">
							<div class="ship-quick-product-image ship-quick-product-image-wrap" role="button" tabindex="0" aria-label="View locker details">
							<img src="/images/elite-locker-side.png" alt="Model Z quick ship wood locker" loading="lazy" />
							<div class="ship-quick-image-overlay" aria-hidden="true">
								<button type="button" class="ship-quick-view-details-overlay-btn">View details</button>
							</div>
						</div>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name">Model Z</h3>
								<p class="ship-quick-product-price">$749</p>
								<p class="ship-quick-product-color">Dark grey</p>
								<button type="button" class="ship-add-to-cart" data-product-id="elite-quick-ship" data-product-name="Model Z Quick Ship" data-product-price="749" data-product-image="/images/elite-locker-side.png">Add to cart</button>
							</div>
						</article>
						<article class="ship-quick-product">
							<div class="ship-quick-product-image ship-quick-product-image-wrap" role="button" tabindex="0" aria-label="View locker details">
							<img src="/images/model-x-website-images/model-x-locker-side.png" alt="Model X quick ship wood locker" loading="lazy" />
							<div class="ship-quick-image-overlay" aria-hidden="true">
								<button type="button" class="ship-quick-view-details-overlay-btn">View details</button>
							</div>
						</div>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name">Model X</h3>
								<p class="ship-quick-product-price">$749</p>
								<p class="ship-quick-product-color">Light grey</p>
								<button type="button" class="ship-add-to-cart" data-product-id="model-x-quick-ship" data-product-name="Model X Quick Ship" data-product-price="749" data-product-image="/images/model-x-website-images/model-x-locker-side.png">Add to cart</button>
							</div>
						</article>
					</div>
					</div>
					<div class="ship-quick-line">
						<h3 class="ship-quick-line-title">Maple cabinetry grade plywood</h3>
						<p class="ship-quick-line-desc">Premium hardwood tops for a classic look and long-lasting durability. Maple is used for the top of the locker, where it adds strength and a natural wood finish that pairs well with any team colors or facility style.</p>
					<div class="ship-quick-products ship-quick-products-row-2">
						<article class="ship-quick-product">
							<div class="ship-quick-product-image ship-quick-product-image-wrap" role="button" tabindex="0" aria-label="View locker details">
							<img src="https://playerstall.b-cdn.net/images/semi-pro-locker-new.png" alt="Semi Pro wood locker" loading="lazy" />
							<div class="ship-quick-image-overlay" aria-hidden="true">
								<button type="button" class="ship-quick-view-details-overlay-btn">View details</button>
							</div>
						</div>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name">Semi Pro</h3>
								<p class="ship-quick-product-price">$349</p>
								<p class="ship-quick-product-color">Maple</p>
								<button type="button" class="ship-add-to-cart" data-product-id="semi-pro-quick-ship" data-product-name="Semi Pro Quick Ship" data-product-price="349" data-product-image="https://playerstall.b-cdn.net/images/semi-pro-locker-new.png">Add to cart</button>
							</div>
						</article>
						<article class="ship-quick-product">
							<div class="ship-quick-product-image ship-quick-product-image-wrap" role="button" tabindex="0" aria-label="View locker details">
							<img src="/images/varsity-locker.png" alt="Varsity wood locker" loading="lazy" />
							<div class="ship-quick-image-overlay" aria-hidden="true">
								<button type="button" class="ship-quick-view-details-overlay-btn">View details</button>
							</div>
						</div>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name">Varsity</h3>
								<p class="ship-quick-product-price">$449</p>
								<p class="ship-quick-product-color">Maple</p>
								<button type="button" class="ship-add-to-cart" data-product-id="varsity-quick-ship" data-product-name="Varsity Quick Ship" data-product-price="449" data-product-image="/images/varsity-locker.png">Add to cart</button>
							</div>
						</article>
						<article class="ship-quick-product">
							<div class="ship-quick-product-image ship-quick-product-image-wrap" role="button" tabindex="0" aria-label="View locker details">
							<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Pro wood locker" loading="lazy" />
							<div class="ship-quick-image-overlay" aria-hidden="true">
								<button type="button" class="ship-quick-view-details-overlay-btn">View details</button>
							</div>
						</div>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name">Pro</h3>
								<p class="ship-quick-product-price">$549</p>
								<p class="ship-quick-product-color">Maple</p>
								<button type="button" class="ship-add-to-cart" data-product-id="pro-quick-ship" data-product-name="Pro Quick Ship" data-product-price="549" data-product-image="https://playerstall.b-cdn.net/images/legendary-locker.png">Add to cart</button>
							</div>
						</article>
						<article class="ship-quick-product">
							<div class="ship-quick-product-image ship-quick-product-image-wrap" role="button" tabindex="0" aria-label="View locker details">
							<img src="/images/stadium-locker-side.png" alt="Model S wood locker" loading="lazy" />
							<div class="ship-quick-image-overlay" aria-hidden="true">
								<button type="button" class="ship-quick-view-details-overlay-btn">View details</button>
							</div>
						</div>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name">Model S</h3>
								<p class="ship-quick-product-price">$599</p>
								<p class="ship-quick-product-color">Maple</p>
								<button type="button" class="ship-add-to-cart" data-product-id="stadium-maple-quick-ship" data-product-name="Model S Maple Quick Ship" data-product-price="599" data-product-image="/images/stadium-locker-side.png">Add to cart</button>
							</div>
						</article>
					</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<div id="ship-quick-acc-modal" class="ship-quick-acc-modal" role="dialog" aria-modal="true" aria-labelledby="ship-quick-acc-modal-title" hidden>
		<div class="ship-quick-acc-modal-backdrop"></div>
		<div class="ship-quick-acc-modal-box">
			<button type="button" class="ship-quick-acc-modal-close" aria-label="Close">&times;</button>
			<div class="ship-quick-accessories">
				<p id="ship-quick-acc-modal-title" class="ship-quick-accessories-label">Each quick ship locker includes</p>
				<div class="ship-quick-accessories-window">
					<div class="ship-quick-accessories-slider">
						<div class="ship-quick-accessories-track" id="ship-quick-acc-track">
							<div class="ship-quick-accessories-slide">
								<div class="ship-quick-accessories-image"><img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Lock box" loading="lazy" /></div>
							</div>
							<div class="ship-quick-accessories-slide">
								<div class="ship-quick-accessories-image"><img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Vented front panel" loading="lazy" /></div>
							</div>
							<div class="ship-quick-accessories-slide">
								<div class="ship-quick-accessories-image"><img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Hooks" loading="lazy" /></div>
							</div>
							<div class="ship-quick-accessories-slide">
								<div class="ship-quick-accessories-image"><img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Dimensions and warranty" loading="lazy" /></div>
							</div>
						</div>
						<button type="button" class="ship-quick-accessories-prev" id="ship-quick-acc-prev" aria-label="Previous">‹</button>
						<button type="button" class="ship-quick-accessories-next" id="ship-quick-acc-next" aria-label="Next">›</button>
						<div class="ship-quick-accessories-dots" id="ship-quick-acc-dots">
							<button type="button" class="ship-quick-acc-dot active" data-index="0" aria-label="Slide 1"></button>
							<button type="button" class="ship-quick-acc-dot" data-index="1" aria-label="Slide 2"></button>
							<button type="button" class="ship-quick-acc-dot" data-index="2" aria-label="Slide 3"></button>
							<button type="button" class="ship-quick-acc-dot" data-index="3" aria-label="Slide 4"></button>
						</div>
					</div>
					<div class="ship-quick-accessories-desc" id="ship-quick-acc-desc">Secure lock box with slow-closing hinge for valuables. Included with every quick ship locker.</div>
				</div>
				<div class="ship-quick-accessories-captions" id="ship-quick-acc-captions" hidden>
					<p data-index="0">Secure lock box with slow-closing hinge for valuables. Included with every quick ship locker.</p>
					<p data-index="1">Vented front panel for airflow to keep gear dry and reduce odor. Standard on all quick ship models.</p>
					<p data-index="2">Interior hooks for bags, helmets, and everyday gear. Standard layout included.</p>
					<p data-index="3">24&quot; width (Model S 24&quot; deep). Full 5-year warranty on every quick ship locker.</p>
				</div>
			</div>
		</div>
	</div>
</BaseLayout>

<script>
	document.querySelectorAll('.ship-add-to-cart').forEach(function(btn) {
		btn.addEventListener('click', function() {
			const id = this.getAttribute('data-product-id') || '';
			const name = this.getAttribute('data-product-name') || '';
			const price = parseFloat(this.getAttribute('data-product-price') || '0') || 0;
			const image = this.getAttribute('data-product-image') || '';
			const cart = JSON.parse(localStorage.getItem('playerstall_cart') || '[]');
			const existing = cart.find(function(item) { return item.id === id; });
			if (existing) existing.quantity += 1;
			else cart.push({ id, name, price, image, quantity: 1 });
			localStorage.setItem('playerstall_cart', JSON.stringify(cart));
			const totalItems = cart.reduce(function(sum, item) { return sum + item.quantity; }, 0);
			window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: totalItems } }));
			const label = btn.textContent;
			btn.textContent = 'Added!';
			btn.classList.add('ship-add-to-cart-added');
			setTimeout(function() { btn.textContent = label; btn.classList.remove('ship-add-to-cart-added'); }, 1500);
		});
	});
	(function() {
		var track = document.getElementById('ship-quick-acc-track');
		var desc = document.getElementById('ship-quick-acc-desc');
		var captions = document.getElementById('ship-quick-acc-captions');
		var prev = document.getElementById('ship-quick-acc-prev');
		var next = document.getElementById('ship-quick-acc-next');
		var dots = document.getElementById('ship-quick-acc-dots');
		if (!track || !desc || !captions) return;
		var slides = track.querySelectorAll('.ship-quick-accessories-slide');
		var captionsList = captions.querySelectorAll('p[data-index]');
		var index = 0;
		var total = slides.length;
		function goTo(i) {
			index = (i + total) % total;
			track.style.transform = 'translateX(-' + index * 100 + '%)';
			desc.textContent = captionsList[index] ? captionsList[index].textContent : '';
			if (dots) {
				dots.querySelectorAll('.ship-quick-acc-dot').forEach(function(dot, j) {
					dot.classList.toggle('active', j === index);
					dot.setAttribute('aria-current', j === index ? 'true' : null);
				});
			}
		}
		if (prev) prev.addEventListener('click', function() { goTo(index - 1); });
		if (next) next.addEventListener('click', function() { goTo(index + 1); });
		if (dots) dots.querySelectorAll('.ship-quick-acc-dot').forEach(function(dot) {
			dot.addEventListener('click', function() { goTo(parseInt(dot.getAttribute('data-index'), 10)); });
		});
	})();
	(function() {
		var modal = document.getElementById('ship-quick-acc-modal');
		var backdrop = modal && modal.querySelector('.ship-quick-acc-modal-backdrop');
		var closeBtn = modal && modal.querySelector('.ship-quick-acc-modal-close');
		function openModal() {
			if (modal) {
				modal.hidden = false;
				modal.removeAttribute('hidden');
				document.body.style.overflow = 'hidden';
			}
		}
		function closeModal() {
			if (modal) {
				modal.hidden = true;
				modal.setAttribute('hidden', '');
				document.body.style.overflow = '';
			}
		}
		document.querySelectorAll('.ship-quick-view-details-overlay-btn').forEach(function(btn) {
			btn.addEventListener('click', function(e) {
				e.preventDefault();
				e.stopPropagation();
				openModal();
			});
		});
		if (closeBtn) closeBtn.addEventListener('click', closeModal);
		if (backdrop) backdrop.addEventListener('click', closeModal);
	})();
</script>

<style>
	.ship-hero-section { position: relative; display: flex; flex-direction: column; justify-content: flex-end; padding: 0 0 80px; overflow: hidden; min-height: 320px; }
	.ship-hero-background { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; overflow: hidden; }
	.ship-hero-bg-image { width: 100%; height: 100%; object-fit: cover; object-position: center; filter: grayscale(100%); }
	.ship-hero-background-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.2); z-index: 1; }
	.ship-hero-container { position: relative; z-index: 10; max-width: 1300px; margin: 0 auto; padding: 0 20px; text-align: left; width: 100%; }
	.ship-breadcrumbs { font-family: 'Yantramanav', sans-serif; font-size: 12px; color: rgba(255,255,255,0.85); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 30px; }
	.ship-breadcrumbs a { color: rgba(255,255,255,0.85); text-decoration: none; transition: color 0.3s; }
	.ship-breadcrumbs a:hover { color: #fe5900; }
	.ship-breadcrumbs span { margin-left: 10px; color: #fff; }
	.ship-page-title { font-family: 'Oswald', sans-serif; font-size: 52px; font-weight: 600; color: #fff; text-transform: uppercase; margin: 0; line-height: 1.1; }
	/* Materials We Use style (same as home page) */
	.home-shop-section { position: relative; padding: 100px 0; background: #fff; overflow: hidden; }
	.home-shop-container { max-width: 1300px; margin: 0 auto; padding: 0 20px; position: relative; z-index: 10; }
	.home-shop-section-header { text-align: center; margin-bottom: 60px; }
	.home-shop-section-subtitle { display: block; font-family: 'Yantramanav', sans-serif; font-size: 13px; letter-spacing: 6px; text-transform: uppercase; color: #8c8c8c; margin-bottom: 10px; }
	.home-shop-section-title { font-family: 'Oswald', sans-serif; font-size: clamp(32px, 4vw, 52px); font-weight: 700; text-transform: uppercase; color: #0d0d0d; line-height: 1.1; margin: 0; }
	.ts-spotlight-inner-centered { max-width: 900px; margin: 0 auto; text-align: center; }
	.ts-spotlight-position { font-family: 'Yantramanav', sans-serif; font-size: 13px; letter-spacing: 4px; text-transform: uppercase; color: #8c8c8c; text-decoration: none; }
	.ts-spotlight-position:hover { color: #fe5900; }
	.ts-spotlight-meta { font-family: 'Yantramanav', sans-serif; font-size: 14px; color: #8c8c8c; margin-bottom: 25px; }
	.ts-spotlight-bio { font-family: 'Yantramanav', sans-serif; font-size: 15px; line-height: 1.8; color: #666; margin-bottom: 30px; }
	.ship-quick-accessories-hint { font-family: 'Yantramanav', sans-serif; font-size: 14px; color: #8c8c8c; margin: 0 0 32px; text-align: center; }
	.ship-quick-product-image-wrap { position: relative; cursor: pointer; }
	.ship-quick-image-overlay { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.6); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; z-index: 2; }
	.ship-quick-product-image-wrap:hover .ship-quick-image-overlay { opacity: 1; pointer-events: auto; }
	.ship-quick-view-details-overlay-btn { font-family: 'Oswald', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; background: #fe5900; color: #fff; border: none; padding: 12px 30px; cursor: pointer; transition: background 0.3s; }
	.ship-quick-view-details-overlay-btn:hover { background: #e04d00; color: #fff; }
	.ship-quick-acc-modal { position: fixed; inset: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 20px; }
	.ship-quick-acc-modal[hidden] { display: none; }
	.ship-quick-acc-modal-backdrop { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.5); }
	.ship-quick-acc-modal-box { position: relative; z-index: 1; background: #fff; border-radius: 8px; padding: 32px 24px 24px; max-width: 460px; width: 100%; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2); }
	.ship-quick-acc-modal-close { position: absolute; top: 12px; right: 12px; width: 36px; height: 36px; border: none; background: #eee; color: #0d0d0d; font-size: 24px; line-height: 1; cursor: pointer; border-radius: 4px; transition: background 0.2s; }
	.ship-quick-acc-modal-close:hover { background: #fe5900; color: #fff; }
	.ship-quick-acc-modal .ship-quick-accessories { margin-bottom: 0; text-align: center; }
	.ship-quick-accessories { margin-bottom: 48px; text-align: center; }
	.ship-quick-accessories-label { font-family: 'Oswald', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: #0d0d0d; margin: 0 0 16px; }
	.ship-quick-accessories-window { max-width: 420px; margin: 0 auto; background: #f9f9f9; border: 1px solid #eee; padding: 24px; border-radius: 4px; }
	.ship-quick-accessories-slider { position: relative; overflow: hidden; border-radius: 4px; background: #fff; }
	.ship-quick-accessories-track { display: flex; width: 400%; transition: transform 0.35s ease; }
	.ship-quick-accessories-slide { flex: 0 0 25%; width: 25%; }
	.ship-quick-accessories-image { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; padding: 20px; background: #fff; }
	.ship-quick-accessories-image img { max-width: 100%; max-height: 100%; object-fit: contain; }
	.ship-quick-accessories-prev, .ship-quick-accessories-next { position: absolute; top: 50%; transform: translateY(-50%); width: 40px; height: 40px; border: none; background: rgba(0,0,0,0.5); color: #fff; font-size: 24px; line-height: 1; cursor: pointer; z-index: 2; transition: background 0.2s; border-radius: 4px; }
	.ship-quick-accessories-prev:hover, .ship-quick-accessories-next:hover { background: #fe5900; }
	.ship-quick-accessories-prev { left: 8px; }
	.ship-quick-accessories-next { right: 8px; }
	.ship-quick-accessories-dots { display: flex; justify-content: center; gap: 8px; padding: 12px 0; }
	.ship-quick-acc-dot { width: 10px; height: 10px; border-radius: 50%; border: 2px solid #8c8c8c; background: transparent; cursor: pointer; transition: background 0.2s, border-color 0.2s; padding: 0; }
	.ship-quick-acc-dot.active, .ship-quick-acc-dot:hover { background: #fe5900; border-color: #fe5900; }
	.ship-quick-accessories-desc { font-family: 'Yantramanav', sans-serif; font-size: 14px; line-height: 1.6; color: #666; margin: 0; padding-top: 12px; min-height: 2.5em; }
	.ship-quick-line { margin-bottom: 96px; }
	.ship-quick-line:last-of-type { margin-bottom: 0; }
	.ship-quick-line-title { font-family: 'Oswald', sans-serif; font-size: clamp(26px, 3.2vw, 42px); font-weight: 700; text-transform: uppercase; color: #0d0d0d; margin: 0 0 32px; line-height: 1.1; }
