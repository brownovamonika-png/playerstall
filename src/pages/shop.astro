---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="Shop - Custom Sports Lockers | PlayerStall"
	description="Shop luxury custom-built wood sports lockers and accessories. Quick ship in one month or custom-built in three months. Full color options. 5 year warranty."
>
	<!-- Hero Section (same image as contact page) -->
	<section class="shop-hero-section">
		<div class="shop-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Shop custom sports lockers" class="shop-hero-bg-image" />
		</div>
		<div class="shop-hero-background-overlay"></div>
		<div class="shop-hero-container">
			<div class="shop-breadcrumbs">
				<a href="/">Home</a>
				<span>Shop</span>
			</div>
			<h1 class="shop-page-title">Shop</h1>
		</div>
	</section>

	<!-- Shop Section (same design as gallery "the locker room" / sport-specific lockers) -->
	<section class="shop-section">
		<div class="shop-container qodef-content-grid">
			<!-- Section header: subtitle + title (like gallery) -->
			<div class="shop-section-header">
				<p class="shop-section-subtitle">the locker room</p>
				<h2 class="shop-section-title">PREMIUM LOCKERS</h2>
			</div>

			<!-- Main Content -->
			<div class="shop-main">

					<!-- Lockers: top row Pro, Stadium, Elite, Model X; bottom row Semi Pro, Varsity (centered) -->
					<div class="shop-products-grid shop-lockers-grid">
					<!-- Pro -->
					<div class="shop-product-item" data-price="649" data-category="lockers">
						<div class="shop-product-image shop-locker-image">
							<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Pro Locker" />
							<div class="shop-product-overlay">
								<a href="/product-pro-locker" class="shop-see-details-btn-overlay">Details</a>
							</div>
						</div>
						<div class="shop-product-content">
							<div class="shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="shop-product-title"><a href="/product-pro-locker">Pro</a></h5>
							<span class="shop-product-price">$649</span>
						</div>
					</div>

					<!-- Stadium -->
					<div class="shop-product-item" data-price="649" data-category="lockers">
						<div class="shop-product-image shop-locker-image">
							<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Stadium Locker" />
							<div class="shop-product-overlay">
								<a href="/product-stadium-locker" class="shop-see-details-btn-overlay">Details</a>
							</div>
						</div>
						<div class="shop-product-content">
							<div class="shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="shop-product-title"><a href="/product-stadium-locker">Stadium</a></h5>
							<span class="shop-product-price">$649</span>
						</div>
					</div>

					<!-- Elite -->
					<div class="shop-product-item" data-price="649" data-category="lockers">
						<div class="shop-product-image shop-locker-image">
							<span class="shop-badge new">New</span>
							<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Elite Locker" loading="lazy" />
							<div class="shop-product-overlay">
								<a href="/product-elite-locker" class="shop-see-details-btn-overlay">Details</a>
							</div>
						</div>
						<div class="shop-product-content">
							<div class="shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="shop-product-title"><a href="/product-elite-locker">Elite</a></h5>
							<span class="shop-product-price">$649</span>
						</div>
					</div>

					<!-- Model X -->
					<div class="shop-product-item" data-price="649" data-category="lockers">
						<div class="shop-product-image shop-locker-image">
							<span class="shop-badge new">New</span>
							<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Model X Locker" loading="lazy" />
							<div class="shop-product-overlay">
								<a href="/product-legendary-locker" class="shop-see-details-btn-overlay">Details</a>
							</div>
						</div>
						<div class="shop-product-content">
							<div class="shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="shop-product-title"><a href="/product-legendary-locker">Model X</a></h5>
							<span class="shop-product-price">$649</span>
						</div>
					</div>

					<!-- Semi Pro (bottom row, centered) -->
					<div class="shop-product-item shop-locker-bottom-item" data-price="349" data-category="lockers">
						<div class="shop-product-image shop-locker-image">
							<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Semi Pro Locker" />
							<div class="shop-product-overlay">
								<a href="/product-semi-pro-locker" class="shop-see-details-btn-overlay">Details</a>
							</div>
						</div>
						<div class="shop-product-content">
							<div class="shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="shop-product-title"><a href="/product-semi-pro-locker">Semi Pro</a></h5>
							<span class="shop-product-price">$349</span>
						</div>
					</div>

					<!-- Varsity (bottom row, centered) -->
					<div class="shop-product-item shop-locker-bottom-item" data-price="449" data-category="lockers">
						<div class="shop-product-image shop-locker-image">
							<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Varsity Locker" />
							<div class="shop-product-overlay">
								<a href="/product-varsity-locker" class="shop-see-details-btn-overlay">Details</a>
							</div>
						</div>
						<div class="shop-product-content">
							<div class="shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="shop-product-title"><a href="/product-varsity-locker">Varsity</a></h5>
							<span class="shop-product-price">$449</span>
						</div>
					</div>

					</div>

			</div>
		</div>
	</section>

	<!-- Accessories (same card style as lockers; click image opens PDP-style modal) -->
	<section class="shop-accessories-section" id="accessories">
		<div class="shop-accessories-container">
		<div class="shop-section-header">
			<p class="shop-section-subtitle">finishing touches</p>
			<h2 class="shop-section-title">LOCKER ACCESSORIES</h2>
		</div>
			<div class="shop-products-grid shop-accessories-grid">
				<!-- Cushions (two sliding images in modal) -->
				<div class="shop-product-item shop-accessory-item" data-acc-image="https://playerstall.b-cdn.net/images/lock-box.png" data-acc-image-2="https://playerstall.b-cdn.net/images/cushion-logo.png" data-acc-title="Cushions" data-acc-price="$75.00 (top or bottom) / $150.00 (both)" data-acc-desc="High-density foam cushions upholstered for comfort and durability – available on the top, bottom, or both.">
					<div class="shop-product-image">
						<img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Locker cushion with team logo" loading="lazy" />
					</div>
					<button type="button" class="shop-accessory-trigger">
						<div class="shop-product-content">
							<div class="shop-product-categories">Accessories</div>
							<h5 class="shop-product-title">Cushions</h5>
						</div>
					</button>
				</div>
				<!-- Coat Rod (two picture options in modal) -->
				<div class="shop-product-item shop-accessory-item" data-acc-image="https://playerstall.b-cdn.net/images/lock-box.png" data-acc-image-2="https://playerstall.b-cdn.net/images/cushion-logo.png" data-acc-title="Coat Rod" data-acc-price="$20.00" data-acc-desc="Heavy-duty coat rod for jerseys, jackets, and gear – sized to match each locker style.">
					<div class="shop-product-image">
						<img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Coat rod for lockers" loading="lazy" />
					</div>
					<button type="button" class="shop-accessory-trigger">
						<div class="shop-product-content">
							<div class="shop-product-categories">Accessories</div>
							<h5 class="shop-product-title">Coat Rod</h5>
						</div>
					</button>
				</div>
				<!-- Hooks (two picture options, Black/Silver, $20) -->
				<div class="shop-product-item shop-accessory-item" data-acc-image="https://playerstall.b-cdn.net/images/lock-box.png" data-acc-image-2="https://playerstall.b-cdn.net/images/cushion-logo.png" data-acc-title="Hooks" data-acc-price="$15.00" data-acc-desc="Additional interior hooks for bags, helmets, and everyday gear, matched to your locker layout.">
					<div class="shop-product-image">
						<img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Interior locker hook" loading="lazy" />
					</div>
					<button type="button" class="shop-accessory-trigger">
						<div class="shop-product-content">
							<div class="shop-product-categories">Accessories</div>
							<h5 class="shop-product-title">Hooks</h5>
						</div>
					</button>
				</div>
				<!-- Name Plate (two picture options, Black/Silver, $10) -->
				<div class="shop-product-item shop-accessory-item" data-acc-image="https://playerstall.b-cdn.net/images/lock-box.png" data-acc-image-2="https://playerstall.b-cdn.net/images/cushion-logo.png" data-acc-title="Name Plate" data-acc-price="$10.00" data-acc-desc="Clean, simple name plate for player identification – ideal for teams that want a classic, organized look.">
					<div class="shop-product-image">
						<img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Locker name plate" loading="lazy" />
					</div>
					<button type="button" class="shop-accessory-trigger">
						<div class="shop-product-content">
							<div class="shop-product-categories">Accessories</div>
							<h5 class="shop-product-title">Name Plate</h5>
						</div>
					</button>
				</div>
				<!-- Skate Hooks (same style as Hooks: two images, Black/Silver, $25) -->
				<div class="shop-product-item shop-accessory-item" data-acc-image="https://playerstall.b-cdn.net/images/lock-box.png" data-acc-image-2="https://playerstall.b-cdn.net/images/cushion-logo.png" data-acc-title="Skate Hooks" data-acc-price="$25.00" data-acc-desc="Additional wall-mounted hooks positioned for skates or gear, perfect for hockey or figure skating locker rooms.">
					<div class="shop-product-image">
						<img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Skate hook for hockey lockers" loading="lazy" />
					</div>
					<button type="button" class="shop-accessory-trigger">
						<div class="shop-product-content">
							<div class="shop-product-categories">Accessories</div>
							<h5 class="shop-product-title">Skate Hooks</h5>
						</div>
					</button>
				</div>
				<!-- Custom Logo -->
				<div class="shop-product-item shop-accessory-item" data-acc-image="https://playerstall.b-cdn.net/images/lock-box.png" data-acc-title="Custom Logo" data-acc-price="+ $75.00" data-acc-desc="Team or program branding applied to the locker face – reinforce your identity every time players walk in.">
					<div class="shop-product-image">
						<img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Custom team logo on wood" loading="lazy" />
					</div>
					<button type="button" class="shop-accessory-trigger">
						<div class="shop-product-content">
							<div class="shop-product-categories">Accessories</div>
							<h5 class="shop-product-title">Custom Logo</h5>
						</div>
					</button>
				</div>
				<!-- Stick Rack -->
				<div class="shop-product-item shop-accessory-item" data-acc-image="https://playerstall.b-cdn.net/images/lock-box.png" data-acc-title="Stick Rack" data-acc-price="Starting at $299" data-acc-desc="Dedicated stick storage that keeps sticks organized, off the floor, and easy to grab on the way to the ice." data-acc-view-href="/accessories#stick-rack">
					<div class="shop-product-image">
						<img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Stick rack for locker rooms" loading="lazy" />
					</div>
					<button type="button" class="shop-accessory-trigger">
						<div class="shop-product-content">
							<div class="shop-product-categories">Accessories</div>
							<h5 class="shop-product-title">Stick Rack</h5>
						</div>
					</button>
				</div>
				<!-- Lock Box (4 image options) -->
				<div class="shop-product-item shop-accessory-item" data-acc-image="https://playerstall.b-cdn.net/images/lock-box.png" data-acc-image-2="https://playerstall.b-cdn.net/images/lock-box.png" data-acc-image-3="https://playerstall.b-cdn.net/images/lock-box.png" data-acc-image-4="/images/lock-box-spec-sheet.png" data-acc-title="Lock Box with Digital Key Lock" data-acc-price="$80.00" data-acc-desc="Lock box with slow-closing hinge that closes gently and securely. Fitted with an electronic touchable keypad and RFID card lock: password or card entry, programmable master and user codes, battery-powered with emergency external power." data-acc-view-href="/accessories#lock-box">
					<div class="shop-product-image">
						<img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Lock box with digital keypad and RFID lock" loading="lazy" />
					</div>
					<button type="button" class="shop-accessory-trigger">
						<div class="shop-product-content">
							<div class="shop-product-categories">Accessories</div>
							<h5 class="shop-product-title">Lock Box with Digital Key Lock</h5>
						</div>
					</button>
				</div>
			</div>
		</div>
	</section>

	<!-- Accessory product detail modal (PDP-style, like lockers) -->
	<div id="shop-accessory-modal" class="acc-modal" role="dialog" aria-modal="true" aria-labelledby="acc-modal-title" hidden>
		<div class="acc-modal-backdrop"></div>
		<div class="acc-modal-box">
			<button type="button" class="acc-modal-close" aria-label="Close">&times;</button>
			<div class="acc-modal-layout">
				<div class="acc-modal-gallery">
					<div class="acc-modal-slider" id="acc-modal-slider">
						<div class="acc-modal-slides" id="acc-modal-slides">
							<div class="acc-modal-slide">
								<img id="acc-modal-image" src="" alt="" />
							</div>
							<div class="acc-modal-slide" id="acc-modal-slide-2">
								<img id="acc-modal-image-2" src="" alt="" />
							</div>
							<div class="acc-modal-slide" id="acc-modal-slide-3">
								<img id="acc-modal-image-3" src="" alt="" />
							</div>
							<div class="acc-modal-slide" id="acc-modal-slide-4">
								<img id="acc-modal-image-4" src="" alt="" />
							</div>
						</div>
						<div class="acc-modal-slider-dots" id="acc-modal-slider-nav" hidden>
							<button type="button" class="acc-modal-slider-dot active" data-slide="0" aria-label="Image 1" aria-current="true"></button>
							<button type="button" class="acc-modal-slider-dot" data-slide="1" aria-label="Image 2"></button>
							<button type="button" class="acc-modal-slider-dot" data-slide="2" aria-label="Image 3"></button>
							<button type="button" class="acc-modal-slider-dot" data-slide="3" aria-label="Image 4"></button>
						</div>
					</div>
				</div>
				<div class="acc-modal-detail">
					<h2 id="acc-modal-title" class="acc-modal-title"></h2>
					<p id="acc-modal-price" class="acc-modal-price"></p>
					<p id="acc-modal-desc" class="acc-modal-desc"></p>
					<p id="acc-modal-size" class="acc-modal-size" hidden></p>
					<div id="acc-modal-ctas" class="acc-modal-ctas"></div>
					<!-- Cushion: Colors available PDF link (above the line) -->
					<div id="acc-modal-colors-pdf-above" class="acc-modal-colors-pdf-above" hidden>
						<a href="/colors/cushion-colors-pdf.html" target="_blank" rel="noopener noreferrer" class="acc-modal-colors-pdf-link">Colors available (PDF)</a>
					</div>
					<!-- Cushion: color, placement (bottom / both), Add to cart (below the line) -->
					<div id="acc-modal-color-sheet" class="acc-modal-color-sheet" hidden>
						<div class="acc-modal-cushion-options">
							<label for="acc-cushion-color-select" class="acc-modal-cushion-label">Color</label>
							<select id="acc-cushion-color-select" class="acc-modal-cushion-select" aria-label="Select cushion color">
								<option value="white">White</option>
								<option value="black">Black</option>
								<option value="charcoal">Charcoal</option>
								<option value="grey">Grey</option>
								<option value="red">Red</option>
								<option value="navy">Navy</option>
								<option value="blue">Blue</option>
								<option value="green">Green</option>
							</select>
						</div>
						<div class="acc-modal-cushion-options acc-modal-cushion-placement">
							<span class="acc-modal-cushion-label">Placement</span>
							<div class="acc-modal-cushion-radios" role="radiogroup" aria-label="Cushion placement">
								<label class="acc-modal-cushion-radio-label">
									<input type="radio" name="acc-cushion-placement" value="bottom" checked class="acc-modal-cushion-radio" />
									<span>Bottom cushion ($75)</span>
								</label>
								<label class="acc-modal-cushion-radio-label">
									<input type="radio" name="acc-cushion-placement" value="both" class="acc-modal-cushion-radio" />
									<span>Both top &amp; bottom ($150)</span>
								</label>
							</div>
						</div>
						<div class="acc-modal-cushion-options acc-modal-cushion-qty">
							<label for="acc-cushion-qty" class="acc-modal-cushion-label">Quantity</label>
							<input type="number" id="acc-cushion-qty" class="acc-modal-qty-input" min="1" value="1" aria-label="Quantity" />
						</div>
						<div class="acc-modal-cushion-add">
							<button type="button" id="acc-cushion-add-to-cart-btn" class="acc-modal-add-to-cart-btn">Add to cart</button>
						</div>
					</div>
					<!-- Coat Rod: color (Black / Silver), Add to cart -->
					<div id="acc-modal-coat-rod" class="acc-modal-color-sheet" hidden>
						<div class="acc-modal-cushion-options">
							<label for="acc-coat-rod-color-select" class="acc-modal-cushion-label">Color</label>
							<select id="acc-coat-rod-color-select" class="acc-modal-cushion-select" aria-label="Select coat rod color">
								<option value="black">Black</option>
								<option value="silver">Silver</option>
							</select>
						</div>
						<div class="acc-modal-cushion-options acc-modal-cushion-qty">
							<label for="acc-coat-rod-qty" class="acc-modal-cushion-label">Quantity</label>
							<input type="number" id="acc-coat-rod-qty" class="acc-modal-qty-input" min="1" value="1" aria-label="Quantity" />
						</div>
						<div class="acc-modal-cushion-add">
							<button type="button" id="acc-coat-rod-add-to-cart-btn" class="acc-modal-add-to-cart-btn">Add to cart</button>
						</div>
					</div>
					<!-- Hooks: color (Black / Silver), Quantity, Add to cart -->
					<div id="acc-modal-hooks" class="acc-modal-color-sheet" hidden>
						<div class="acc-modal-cushion-options">
							<label for="acc-hooks-color-select" class="acc-modal-cushion-label">Color</label>
							<select id="acc-hooks-color-select" class="acc-modal-cushion-select" aria-label="Select hooks color">
								<option value="black">Black</option>
								<option value="silver">Silver</option>
							</select>
						</div>
						<div class="acc-modal-cushion-options acc-modal-cushion-qty">
							<label for="acc-hooks-qty" class="acc-modal-cushion-label">Quantity</label>
							<input type="number" id="acc-hooks-qty" class="acc-modal-qty-input" min="1" value="1" aria-label="Quantity" />
						</div>
						<div class="acc-modal-cushion-add">
							<button type="button" id="acc-hooks-add-to-cart-btn" class="acc-modal-add-to-cart-btn">Add to cart</button>
						</div>
					</div>
					<!-- Skate Hooks: color (Black / Silver), Quantity, Add to cart -->
					<div id="acc-modal-skate-hooks" class="acc-modal-color-sheet" hidden>
						<div class="acc-modal-cushion-options">
							<label for="acc-skate-hooks-color-select" class="acc-modal-cushion-label">Color</label>
							<select id="acc-skate-hooks-color-select" class="acc-modal-cushion-select" aria-label="Select skate hooks color">
								<option value="black">Black</option>
								<option value="silver">Silver</option>
							</select>
						</div>
						<div class="acc-modal-cushion-options acc-modal-cushion-qty">
							<label for="acc-skate-hooks-qty" class="acc-modal-cushion-label">Quantity</label>
							<input type="number" id="acc-skate-hooks-qty" class="acc-modal-qty-input" min="1" value="1" aria-label="Quantity" />
						</div>
						<div class="acc-modal-cushion-add">
							<button type="button" id="acc-skate-hooks-add-to-cart-btn" class="acc-modal-add-to-cart-btn">Add to cart</button>
						</div>
					</div>
					<!-- Name Plate: color (Black / Silver), Add to cart -->
					<div id="acc-modal-name-plate" class="acc-modal-color-sheet" hidden>
						<div class="acc-modal-cushion-options">
							<label for="acc-name-plate-color-select" class="acc-modal-cushion-label">Color</label>
							<select id="acc-name-plate-color-select" class="acc-modal-cushion-select" aria-label="Select name plate color">
								<option value="black">Black</option>
								<option value="silver">Silver</option>
							</select>
						</div>
						<div class="acc-modal-cushion-options acc-modal-cushion-qty">
							<label for="acc-name-plate-qty" class="acc-modal-cushion-label">Quantity</label>
							<input type="number" id="acc-name-plate-qty" class="acc-modal-qty-input" min="1" value="1" aria-label="Quantity" />
						</div>
						<div class="acc-modal-cushion-add">
							<button type="button" id="acc-name-plate-add-to-cart-btn" class="acc-modal-add-to-cart-btn">Add to cart</button>
						</div>
					</div>
					<!-- Lock Box: Add to cart only -->
					<div id="acc-modal-lock-box" class="acc-modal-color-sheet" hidden>
						<div class="acc-modal-cushion-options acc-modal-cushion-qty">
							<label for="acc-lock-box-qty" class="acc-modal-cushion-label">Quantity</label>
							<input type="number" id="acc-lock-box-qty" class="acc-modal-qty-input" min="1" value="1" aria-label="Quantity" />
						</div>
						<div class="acc-modal-cushion-add">
							<button type="button" id="acc-lock-box-add-to-cart-btn" class="acc-modal-add-to-cart-btn">Add to cart</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
