		const productItems = document.querySelectorAll('.shop-product-item');

		// Sorting
		const sortSelect = document.getElementById('shop-sort');
		if (sortSelect) {
			sortSelect.addEventListener('change', function() {
				const sortValue = this.value;
				const items = Array.from(productItems);

				items.sort((a, b) => {
					const priceA = parseFloat(a.getAttribute('data-price'));
					const priceB = parseFloat(b.getAttribute('data-price'));

					if (sortValue === 'price-low') {
						return priceA - priceB;
					} else if (sortValue === 'price-high') {
						return priceB - priceA;
					}
					return 0;
				});

				const grid = document.querySelector('.shop-products-grid');
				if (grid) {
					items.forEach(item => grid.appendChild(item));
				}
			});
		}

		// Cart utility functions
		function getCart() {
			const cart = localStorage.getItem('playerstall_cart');
			return cart ? JSON.parse(cart) : [];
		}

		function saveCart(cart) {
			localStorage.setItem('playerstall_cart', JSON.stringify(cart));
			updateCartCount();
		}

		function addToCart(product, quantity) {
			const qty = Math.max(1, parseInt(quantity, 10) || 1);
			const cart = getCart();
			const existingItem = cart.find(item => item.id === product.id);
			
			if (existingItem) {
				existingItem.quantity += qty;
			} else {
				cart.push({
					id: product.id,
					name: product.name,
					price: product.price,
					image: product.image,
					quantity: qty
				});
			}
			
			saveCart(cart);
			return cart;
		}

		function updateCartCount() {
			const cart = getCart();
			const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
			const cartCount = document.querySelector('.cart-count');
			if (cartCount) {
				cartCount.textContent = totalItems;
			}
			// Dispatch event for other pages
			window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: totalItems } }));
		}

		// Initialize cart count
		updateCartCount();

		// Accessory PDP-style modal – open on image/card click, same look as locker product page
		const accModal = document.getElementById('shop-accessory-modal');
		const accModalImage = document.getElementById('acc-modal-image');
		const accModalImage2 = document.getElementById('acc-modal-image-2');
		const accModalImage3 = document.getElementById('acc-modal-image-3');
		const accModalImage4 = document.getElementById('acc-modal-image-4');
		const accModalSlide2 = document.getElementById('acc-modal-slide-2');
		const accModalSlide3 = document.getElementById('acc-modal-slide-3');
		const accModalSlide4 = document.getElementById('acc-modal-slide-4');
		const accModalSlides = document.getElementById('acc-modal-slides');
		const accModalSliderNav = document.getElementById('acc-modal-slider-nav');
		const accModalSliderDots = document.querySelectorAll('.acc-modal-slider-dot');
		const accModalTitle = document.getElementById('acc-modal-title');
		const accModalPrice = document.getElementById('acc-modal-price');
		const accModalDesc = document.getElementById('acc-modal-desc');
		const accModalCtas = document.getElementById('acc-modal-ctas');

		const accModalColorSheet = document.getElementById('acc-modal-color-sheet');

		let accModalSlideIndex = 0;

		function setAccModalSlide(index) {
			if (!accModalSlides) return;
			accModalSlideIndex = index;
			accModalSlides.style.transform = 'translateX(-' + (accModalSlideIndex * 100) + '%)';
			document.querySelectorAll('.acc-modal-slider-dot').forEach(function(dot, i) {
				dot.classList.toggle('active', i === index);
				dot.setAttribute('aria-current', i === index ? 'true' : 'false');
			});
		}

		function openAccModal(item) {
			const img = item.getAttribute('data-acc-image');
			const img2 = item.getAttribute('data-acc-image-2');
			const img3 = item.getAttribute('data-acc-image-3');
			const img4 = item.getAttribute('data-acc-image-4');
			const title = item.getAttribute('data-acc-title');
			const price = item.getAttribute('data-acc-price');
			const desc = item.getAttribute('data-acc-desc');
			if (!img || !title) return;
			accModalImage.src = img;
			accModalImage.alt = title;
			const slideCount = img4 ? 4 : (img3 ? 3 : (img2 ? 2 : 1));
			if (accModalSlide2) accModalSlide2.style.display = slideCount >= 2 ? '' : 'none';
			if (accModalSlide3) accModalSlide3.style.display = slideCount >= 3 ? '' : 'none';
			if (accModalSlide4) accModalSlide4.style.display = slideCount >= 4 ? '' : 'none';
			if (accModalImage2 && img2) {
				accModalImage2.src = img2;
				accModalImage2.alt = title + ' (2)';
			}
			if (accModalImage3 && img3) {
				accModalImage3.src = img3;
				accModalImage3.alt = title + ' (3)';
			}
			if (accModalImage4 && img4) {
				accModalImage4.src = img4;
				accModalImage4.alt = title + ' (4)';
			}
			if (accModalSliderNav && accModalSliderDots.length) {
				accModalSliderNav.hidden = slideCount <= 1;
				accModalSliderDots.forEach(function(dot, i) {
					dot.style.display = i < slideCount ? '' : 'none';
				});
				setAccModalSlide(0);
			}
			accModalTitle.textContent = title;
			accModalPrice.textContent = price || '';
			accModalDesc.textContent = desc || '';
			const accModalSize = document.getElementById('acc-modal-size');
			if (accModalSize) {
				if (title === 'Name Plate') {
					accModalSize.textContent = 'Size: 2 inches by 10 inches.';
					accModalSize.hidden = false;
				} else {
					accModalSize.hidden = true;
				}
			}
			accModalCtas.innerHTML = '';
			// Cushion: show Colors available PDF (above line) and color dropdown / Add to cart (below line)
			const accModalColorsPdfAbove = document.getElementById('acc-modal-colors-pdf-above');
			const accModalCoatRod = document.getElementById('acc-modal-coat-rod');
			const accModalHooks = document.getElementById('acc-modal-hooks');
			const accModalSkateHooks = document.getElementById('acc-modal-skate-hooks');
			const accModalNamePlate = document.getElementById('acc-modal-name-plate');
			const accModalLockBox = document.getElementById('acc-modal-lock-box');
			if (accModalColorSheet) accModalColorSheet.hidden = title !== 'Cushions';
			if (accModalColorsPdfAbove) accModalColorsPdfAbove.hidden = title !== 'Cushions';
			if (accModalCoatRod) accModalCoatRod.hidden = title !== 'Coat Rod';
			if (accModalHooks) accModalHooks.hidden = title !== 'Hooks';
			if (accModalSkateHooks) accModalSkateHooks.hidden = title !== 'Skate Hooks';
			if (accModalNamePlate) accModalNamePlate.hidden = title !== 'Name Plate';
			if (accModalLockBox) accModalLockBox.hidden = title !== 'Lock Box with Digital Key Lock';
			if (title === 'Lock Box with Digital Key Lock') {
				accModal.classList.add('acc-modal-is-lock-box');
			} else {
				accModal.classList.remove('acc-modal-is-lock-box');
			}
			accModal.hidden = false;
			document.body.style.overflow = 'hidden';
		}

		// Slider dots: click small circle to switch image (Cushions)
		document.querySelectorAll('.acc-modal-slider-dot').forEach(function(dot) {
			dot.addEventListener('click', function() {
				if (accModalSliderNav && accModalSliderNav.hidden) return;
				const slide = parseInt(this.getAttribute('data-slide'), 10);
				if (!isNaN(slide)) setAccModalSlide(slide);
			});
		});

		// Cushion Add to cart: color + placement (bottom $75 / both $150)
		const accCushionColorSelect = document.getElementById('acc-cushion-color-select');
		const accCushionAddToCartBtn = document.getElementById('acc-cushion-add-to-cart-btn');
		const CUSHION_IMAGE = 'https://playerstall.b-cdn.net/images/cushion-logo.png';
		const accCushionQty = document.getElementById('acc-cushion-qty');
		if (accCushionAddToCartBtn && accCushionColorSelect) {
			accCushionAddToCartBtn.addEventListener('click', function() {
				const colorValue = accCushionColorSelect.value;
				const colorLabel = accCushionColorSelect.options[accCushionColorSelect.selectedIndex].text;
				const placementRadio = document.querySelector('input[name="acc-cushion-placement"]:checked');
				const placement = placementRadio ? placementRadio.value : 'bottom';
				const price = placement === 'both' ? 150 : 75;
				const placementLabel = placement === 'both' ? 'Top & bottom' : 'Bottom';
				const product = {
					id: 'cushions-' + colorValue + '-' + placement,
					name: 'Cushions (' + colorLabel + ') – ' + placementLabel,
					price: price,
					image: CUSHION_IMAGE
				};
				const qty = accCushionQty ? parseInt(accCushionQty.value, 10) || 1 : 1;
				addToCart(product, qty);
				const originalText = accCushionAddToCartBtn.textContent;
				accCushionAddToCartBtn.textContent = 'Added!';
				accCushionAddToCartBtn.classList.add('added');
				setTimeout(function() {
					accCushionAddToCartBtn.textContent = originalText;
					accCushionAddToCartBtn.classList.remove('added');
				}, 1500);
			});
		}

		// Coat Rod Add to cart: color Black or Silver, $20
		const accCoatRodColorSelect = document.getElementById('acc-coat-rod-color-select');
		const accCoatRodAddToCartBtn = document.getElementById('acc-coat-rod-add-to-cart-btn');
		const COAT_ROD_PRICE = 20;
		const COAT_ROD_IMAGE = 'https://playerstall.b-cdn.net/images/lock-box.png';
		const accCoatRodQty = document.getElementById('acc-coat-rod-qty');
		if (accCoatRodAddToCartBtn && accCoatRodColorSelect) {
			accCoatRodAddToCartBtn.addEventListener('click', function() {
				const colorValue = accCoatRodColorSelect.value;
				const colorLabel = accCoatRodColorSelect.options[accCoatRodColorSelect.selectedIndex].text;
				const product = {
					id: 'coat-rod-' + colorValue,
					name: 'Coat Rod (' + colorLabel + ')',
					price: COAT_ROD_PRICE,
