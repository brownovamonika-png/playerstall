				};
				const qty = accCoatRodQty ? parseInt(accCoatRodQty.value, 10) || 1 : 1;
				addToCart(product, qty);
				const originalText = accCoatRodAddToCartBtn.textContent;
				accCoatRodAddToCartBtn.textContent = 'Added!';
				accCoatRodAddToCartBtn.classList.add('added');
				setTimeout(function() {
					accCoatRodAddToCartBtn.textContent = originalText;
					accCoatRodAddToCartBtn.classList.remove('added');
				}, 1500);
			});
		}

		// Hooks Add to cart: color Black or Silver, $20
		const accHooksColorSelect = document.getElementById('acc-hooks-color-select');
		const accHooksAddToCartBtn = document.getElementById('acc-hooks-add-to-cart-btn');
		const HOOKS_PRICE = 15;
		const HOOKS_IMAGE = 'https://playerstall.b-cdn.net/images/lock-box.png';
		const accHooksQty = document.getElementById('acc-hooks-qty');
