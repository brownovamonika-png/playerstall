				const qty = accSkateHooksQty ? parseInt(accSkateHooksQty.value, 10) || 1 : 1;
				addToCart(product, qty);
				const originalText = accSkateHooksAddToCartBtn.textContent;
				accSkateHooksAddToCartBtn.textContent = 'Added!';
				accSkateHooksAddToCartBtn.classList.add('added');
				setTimeout(function() {
					accSkateHooksAddToCartBtn.textContent = originalText;
					accSkateHooksAddToCartBtn.classList.remove('added');
				}, 1500);
			});
		}

		// Name Plate Add to cart: color Black or Silver, $10
		const accNamePlateColorSelect = document.getElementById('acc-name-plate-color-select');
		const accNamePlateAddToCartBtn = document.getElementById('acc-name-plate-add-to-cart-btn');
		const NAME_PLATE_PRICE = 10;
		const NAME_PLATE_IMAGE = 'https://playerstall.b-cdn.net/images/lock-box.png';
		const accNamePlateQty = document.getElementById('acc-name-plate-qty');
		if (accNamePlateAddToCartBtn && accNamePlateColorSelect) {
			accNamePlateAddToCartBtn.addEventListener('click', function() {
				const colorValue = accNamePlateColorSelect.value;
				const colorLabel = accNamePlateColorSelect.options[accNamePlateColorSelect.selectedIndex].text;
				const product = {
					id: 'name-plate-' + colorValue,
					name: 'Name Plate (' + colorLabel + ')',
					price: NAME_PLATE_PRICE,
					image: NAME_PLATE_IMAGE
				};
				const qty = accNamePlateQty ? parseInt(accNamePlateQty.value, 10) || 1 : 1;
				addToCart(product, qty);
				const originalText = accNamePlateAddToCartBtn.textContent;
				accNamePlateAddToCartBtn.textContent = 'Added!';
				accNamePlateAddToCartBtn.classList.add('added');
				setTimeout(function() {
					accNamePlateAddToCartBtn.textContent = originalText;
					accNamePlateAddToCartBtn.classList.remove('added');
				}, 1500);
			});
		}

		// Lock Box Add to cart: $80
		const accLockBoxAddToCartBtn = document.getElementById('acc-lock-box-add-to-cart-btn');
		const LOCK_BOX_PRICE = 80;
		const LOCK_BOX_IMAGE = '/images/lock-box-keypad.png';
		const accLockBoxQty = document.getElementById('acc-lock-box-qty');
		if (accLockBoxAddToCartBtn) {
			accLockBoxAddToCartBtn.addEventListener('click', function() {
				const product = {
					id: 'lock-box',
					name: 'Lock Box with Digital Key Lock',
					price: LOCK_BOX_PRICE,
					image: LOCK_BOX_IMAGE
				};
				const qty = accLockBoxQty ? parseInt(accLockBoxQty.value, 10) || 1 : 1;
				addToCart(product, qty);
				const originalText = accLockBoxAddToCartBtn.textContent;
				accLockBoxAddToCartBtn.textContent = 'Added!';
				accLockBoxAddToCartBtn.classList.add('added');
				setTimeout(function() {
					accLockBoxAddToCartBtn.textContent = originalText;
					accLockBoxAddToCartBtn.classList.remove('added');
				}, 1500);
			});
		}

		function closeAccModal() {
			accModal.hidden = true;
			document.body.style.overflow = '';
		}

		document.querySelectorAll('.shop-accessory-trigger').forEach(function(btn) {
			btn.addEventListener('click', function() {
				const item = this.closest('.shop-accessory-item');
				if (item) openAccModal(item);
			});
		});

		document.querySelectorAll('.shop-accessory-item .shop-product-image').forEach(function(imgEl) {
			imgEl.addEventListener('click', function() {
				const item = this.closest('.shop-accessory-item');
				if (item) openAccModal(item);
			});
		});

		if (accModal) {
			accModal.querySelector('.acc-modal-backdrop').addEventListener('click', closeAccModal);
			accModal.querySelector('.acc-modal-close').addEventListener('click', closeAccModal);
			document.addEventListener('keydown', function(e) {
				if (e.key === 'Escape' && accModal && !accModal.hidden) closeAccModal();
			});
		}
	});
</script>
