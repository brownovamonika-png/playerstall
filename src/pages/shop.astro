					accHooksAddToCartBtn.classList.remove('added');
				}, 1500);
			});
		}

		// Skate Hooks Add to cart: color Black or Silver, $25
		const accSkateHooksColorSelect = document.getElementById('acc-skate-hooks-color-select');
		const accSkateHooksAddToCartBtn = document.getElementById('acc-skate-hooks-add-to-cart-btn');
		const SKATE_HOOKS_PRICE = 25;
		const SKATE_HOOKS_IMAGE = 'https://playerstall.b-cdn.net/images/lock-box.png';
		const accSkateHooksQty = document.getElementById('acc-skate-hooks-qty');
		if (accSkateHooksAddToCartBtn && accSkateHooksColorSelect) {
			accSkateHooksAddToCartBtn.addEventListener('click', function() {
