		}
		:global(.guide-fab) {
			bottom: 16px;
			right: 16px;
			width: 46px;
			height: 46px;
			font-size: 22px;
		}
	}
</style>

<script>
	import { createInitialState, nextInstanceId, buildWalls, defaultDimensions, needByTimelineLabel, fundingStatusLabel } from '../room-planner/state';
	import type { RoomDimensions } from '../room-planner/state';
	import { render, screenToWorld, setFloorLogo2D, removeFloorLogo2D } from '../room-planner/render';
	import { getAllTemplates, getTemplate } from '../room-planner/catalog';
	import { priceLocker } from '../room-planner/pricing';
	import { lockerAABB, wouldOverlap, packWall, wallLength, openingExclusionAABB, getWallsWithLockers, projectOntoWall, hitTestOpening, clampLockerToRoom } from '../room-planner/geometry';
	import { drawWallHighlight } from '../room-planner/render';
	import { formatDimension, unitLabel } from '../room-planner/units';
	import { CUSHION_COLORS } from '../room-planner/types';
	import type { PlannerState, LockerInstance, Opening, Selection, DisplayUnit } from '../room-planner/types';
	import { generateEstimatePdfBlob } from '../room-planner/pdfEstimate';
	import { generateLayoutPdfBlob } from '../room-planner/pdfLayoutDoc';
	import { launch3DPreview, dispose3DPreview, resetCamera, rotateSelected3D, hasSelection3D, updateFloorColor3D, updateWallColor3D, setFloorLogo, removeFloorLogo, rebuildLockerMesh3D, highlightAllLockers3D, clearSelection3D, toggleBase3D, updateBaseColor3D, updateEdgebandColor3D, removeLockers3D } from '../room-planner/render3d';

	const canvas = document.getElementById('planner-canvas') as HTMLCanvasElement;
	const ctx = canvas.getContext('2d')!;

	let roomDims: RoomDimensions = defaultDimensions();
	const state: PlannerState = createInitialState(roomDims);

	// ─── Multi-room management ───
	interface SavedRoom {
		roomName: string;
		needByTimeline: string;
		fundingStatus: string;
		sportType: string;
		floorColor: string;
		wallColor: string;
		showBase: boolean;
		baseColor: string;
		edgebandColor: string;
		customLogoDataUrl: string | null;
		roomDims: RoomDimensions;
		walls: PlannerState['walls'];
		openings: PlannerState['openings'];
		lockers: PlannerState['lockers'];
	}
	const savedRooms: SavedRoom[] = [];
	let activeRoomIndex = 0;

	function snapshotCurrentRoom(): SavedRoom {
		return {
			roomName: state.roomName,
			needByTimeline: state.needByTimeline,
			fundingStatus: state.fundingStatus,
			sportType: state.sportType,
			floorColor: state.floorColor,
			wallColor: state.wallColor,
			showBase: state.showBase,
			baseColor: state.baseColor,
			edgebandColor: state.edgebandColor,
			customLogoDataUrl: _savedLogoDataUrl,
			roomDims: { ...roomDims },
			walls: JSON.parse(JSON.stringify(state.walls)),
			openings: JSON.parse(JSON.stringify(state.openings)),
			lockers: JSON.parse(JSON.stringify(state.lockers)),
		};
	}

	function saveCurrentRoom() {
		savedRooms[activeRoomIndex] = snapshotCurrentRoom();
		persistRooms();
	}

	const ROOMS_STORAGE_KEY = 'playerstall_rooms';

	function persistRooms() {
		try {
			const data = { activeRoomIndex, rooms: savedRooms };
			localStorage.setItem(ROOMS_STORAGE_KEY, JSON.stringify(data));
		} catch (_) { /* quota exceeded or private browsing */ }
	}

	function restoreRooms(): boolean {
		try {
			const raw = localStorage.getItem(ROOMS_STORAGE_KEY);
			if (!raw) return false;
			const data = JSON.parse(raw);
			if (!Array.isArray(data.rooms) || data.rooms.length === 0) return false;
			savedRooms.length = 0;
			for (const r of data.rooms) savedRooms.push(r);
			activeRoomIndex = Math.min(data.activeRoomIndex || 0, savedRooms.length - 1);
			loadRoom(activeRoomIndex);
			return true;
		} catch (_) { return false; }
	}

	function loadRoom(index: number) {
		const room = savedRooms[index];
		if (!room) return;
		roomDims = { ...room.roomDims };
		state.roomName = room.roomName;
		state.needByTimeline = room.needByTimeline || '';
		state.fundingStatus = room.fundingStatus || '';
		state.sportType = (room.sportType || '') as any;
		state.floorColor = room.floorColor || '#8B7355';
		state.wallColor = room.wallColor || '#ffffff';
		state.showBase = room.showBase ?? false;
		state.baseColor = room.baseColor || '#1A1A1A';
		state.edgebandColor = room.edgebandColor || '';
		state.walls = JSON.parse(JSON.stringify(room.walls));
		state.openings = JSON.parse(JSON.stringify(room.openings));
		state.lockers = JSON.parse(JSON.stringify(room.lockers));
		state.selection = null;

		roomNameInput.value = state.roomName;
		needBySelect.value = state.needByTimeline || '';
		fundingSelect.value = state.fundingStatus || '';
		sportSelect.value = state.sportType;

		syncFloorSwatches();
		syncWallSwatches();

		_savedLogoDataUrl = room.customLogoDataUrl || null;
		if (_savedLogoDataUrl && !SPORT_LOGO_MAP[state.sportType]) {
			setFloorLogo2D(_savedLogoDataUrl, () => redraw());
			setFloorLogo(_savedLogoDataUrl);
			btnLogoRemove.style.display = '';
		} else {
			applySportLogo(state.sportType);
		}

		rebuildOpeningCounter();
		writeAllDimInputs();
		renderWallOpeningsForms();
		zoomFit();
		redraw();
	}

	function rebuildOpeningCounter() {
		let maxId = 0;
		for (const op of state.openings) {
			const m = op.id.match(/^op_(\d+)$/);
			if (m) maxId = Math.max(maxId, parseInt(m[1], 10));
		}
		_openingCounter = maxId;
	}

	function removeRoom(index: number) {
		if (savedRooms.length <= 1) return;
		savedRooms.splice(index, 1);
		if (activeRoomIndex >= savedRooms.length) {
			activeRoomIndex = savedRooms.length - 1;
		} else if (index < activeRoomIndex) {
			activeRoomIndex--;
		} else if (index === activeRoomIndex) {
			activeRoomIndex = Math.min(index, savedRooms.length - 1);
		}
		loadRoom(activeRoomIndex);
		persistRooms();
		renderRoomTabs();
	}

	function renderCarouselNav() {
		const list = document.getElementById('room-tabs-list')!;
		if (!list) return;
		list.innerHTML = '';
		const canRemove = savedRooms.length > 1;
		const idx = activeRoomIndex;
		for (let i = 0; i < savedRooms.length; i++) {
			if (i > 0) {
				const sep = document.createElement('span');
				sep.className = 'room-tab-sep';
				sep.textContent = '/';
				list.appendChild(sep);
			}
			const isActive = i === idx;
			const label = (i === idx ? state.roomName : savedRooms[i].roomName) || `Room ${i + 1}`;
			const btn = document.createElement('button');
			btn.type = 'button';
			btn.className = `room-tab${isActive ? ' active' : ''}`;
			btn.dataset.roomIdx = String(i);
			btn.onclick = () => switchToRoom(i);
			const nameSpan = document.createElement('span');
			nameSpan.textContent = label;
			btn.appendChild(nameSpan);
			if (canRemove) {
				const xBtn = document.createElement('span');
				xBtn.className = 'room-tab-x';
				xBtn.textContent = '\u00d7';
				xBtn.title = 'Remove room';
				xBtn.onclick = (e) => {
					e.stopPropagation();
					removeRoom(i);
				};
				btn.appendChild(xBtn);
			}
			list.appendChild(btn);
		}
		const roomLabel = document.getElementById('room-name-label');
		if (roomLabel) roomLabel.textContent = `Name Room ${idx + 1}`;
	}

	const renderRoomTabs = renderCarouselNav;

	function switchToRoom(index: number) {
		if (index === activeRoomIndex) return;
		saveCurrentRoom();
		activeRoomIndex = index;
		loadRoom(index);
		renderRoomTabs();
	}

	const MAX_ROOMS = 5;
	document.getElementById('btn-add-room')!.onclick = () => {
		if (savedRooms.length >= MAX_ROOMS) {
			alert(`You can add up to ${MAX_ROOMS} rooms.`);
			return;
		}
		saveCurrentRoom();
		const newIndex = savedRooms.length;
		savedRooms.push({
			roomName: '',
			needByTimeline: '',
			fundingStatus: '',
			sportType: '',
			floorColor: '#8B7355',
			wallColor: '#ffffff',
			showBase: false,
			baseColor: '#1A1A1A',
			edgebandColor: '',
			customLogoDataUrl: null,
			roomDims: defaultDimensions(),
			walls: buildWalls(defaultDimensions()),
			openings: [],
			lockers: [],
		});
		activeRoomIndex = newIndex;
		loadRoom(newIndex);
		persistRooms();
		renderCarouselNav();
	};

	document.addEventListener('keydown', (e) => {
		const tag = (e.target as HTMLElement).tagName;
		if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
		const inPlanner = (e.target as HTMLElement).closest('#planner-canvas, .carousel-nav, .room-tabs, #room-tabs-bar, .room-tabs-list');
		if (!inPlanner && e.target !== document.body) return;
		if (e.key === 'ArrowLeft' && activeRoomIndex > 0) { e.preventDefault(); switchToRoom(activeRoomIndex - 1); }
		if (e.key === 'ArrowRight' && activeRoomIndex < savedRooms.length - 1) { e.preventDefault(); switchToRoom(activeRoomIndex + 1); }
	});

	// ─── Save buttons (dots row + 2D toolbar) ───
	let _saveTimeout: ReturnType<typeof setTimeout> | null = null;
	const allSaveBtns = [
		document.getElementById('btn-save-room'),
		document.getElementById('btn-toolbar-save'),
	].filter(Boolean) as HTMLElement[];

	function flashAllSaveBtns() {
		saveCurrentRoom();
		const check = document.getElementById('room-save-check');
		allSaveBtns.forEach(b => b.classList.add('saved'));
		if (check) { check.textContent = '✓'; check.classList.add('show'); }
		if (_saveTimeout) clearTimeout(_saveTimeout);
		_saveTimeout = setTimeout(() => {
			allSaveBtns.forEach(b => b.classList.remove('saved'));
			if (check) { check.textContent = ''; check.classList.remove('show'); }
		}, 2000);
	}

	allSaveBtns.forEach(b => { b.onclick = flashAllSaveBtns; });
	document.getElementById('btn-3d-flash-save')!.onclick = flashAllSaveBtns;

	// ─── Need-by, funding & sport ───
	const needBySelect = document.getElementById('need-by-timeline') as HTMLSelectElement;
	const fundingSelect = document.getElementById('funding-status') as HTMLSelectElement;
	const sportSelect = document.getElementById('sport-type') as HTMLSelectElement;
	const SPORT_LOGO_MAP: Record<string, string> = {
		football:   '/images/sport-football-floor.png',
		hockey:     '/images/sport-hockey-floor.png',
		basketball: '/images/sport-basketball-floor.png',
		baseball:   '/images/sport-baseball-floor.png',
		soccer:     '/images/sport-soccer-floor.png',
		lacrosse:   '/images/sport-lacrosse-floor.png',
	};

	// ─── Room name ───
	const roomNameInput = document.getElementById('room-name') as HTMLInputElement;
	roomNameInput.oninput = () => {
		state.roomName = roomNameInput.value.trim();
		renderCarouselNav();
	};

	// ─── Room setup form (feet + inches) ───
	const dimFtA = document.getElementById('dim-wall-a-ft') as HTMLInputElement;
	const dimInA = document.getElementById('dim-wall-a-in') as HTMLInputElement;
	const dimFtB = document.getElementById('dim-wall-b-ft') as HTMLInputElement;
	const dimInB = document.getElementById('dim-wall-b-in') as HTMLInputElement;
	const dimFtC = document.getElementById('dim-wall-c-ft') as HTMLInputElement;
	const dimInC = document.getElementById('dim-wall-c-in') as HTMLInputElement;
	const dimFtD = document.getElementById('dim-wall-d-ft') as HTMLInputElement;
	const dimInD = document.getElementById('dim-wall-d-in') as HTMLInputElement;

	function readFtIn(ft: HTMLInputElement, inches: HTMLInputElement): number {
		return (parseFloat(ft.value) || 0) * 12 + (parseFloat(inches.value) || 0);
	}

	function writeFtIn(totalInches: number, ft: HTMLInputElement, inches: HTMLInputElement) {
		const f = Math.floor(totalInches / 12);
		const i = Math.round(totalInches % 12);
		ft.value = f > 0 ? String(f) : '';
		inches.value = i > 0 ? String(i) : '';
	}

	function readRoomDims(): RoomDimensions {
		return {
			wallA: readFtIn(dimFtA, dimInA),
			wallB: readFtIn(dimFtB, dimInB),
			wallC: readFtIn(dimFtC, dimInC),
			wallD: readFtIn(dimFtD, dimInD),
			thicknessA: roomDims.thicknessA,
			thicknessB: roomDims.thicknessB,
			thicknessC: roomDims.thicknessC,
			thicknessD: roomDims.thicknessD,
		};
	}

	function writeAllDimInputs() {
		writeFtIn(roomDims.wallA, dimFtA, dimInA);
		writeFtIn(roomDims.wallB, dimFtB, dimInB);
		writeFtIn(roomDims.wallC, dimFtC, dimInC);
		writeFtIn(roomDims.wallD, dimFtD, dimInD);
	}
	writeAllDimInputs();

	function applyRoom() {
		roomDims = readRoomDims();
		state.walls = buildWalls(roomDims);
		state.lockers = [];
		// Keep openings that still fit on the rebuilt walls
		state.openings = state.openings.filter((op) => {
			const wall = state.walls.find((w) => w.id === op.wallId);
			return wall && (op.offsetAlongWall + op.widthIn) <= wallLength(wall);
		});
		state.selection = null;
		renderWallOpeningsForms();
		zoomFit();
		redraw();
	}

	document.getElementById('btn-apply-room')!.onclick = applyRoom;

	document.getElementById('btn-reset-room')!.onclick = () => {
		roomDims = defaultDimensions();
		writeAllDimInputs();
		state.roomName = '';
		roomNameInput.value = '';
		state.needByTimeline = '';
		needBySelect.value = '';
		state.fundingStatus = '';
		fundingSelect.value = '';
		state.sportType = '';
		sportSelect.value = '';
		state.walls = buildWalls(roomDims);
		state.lockers = [];
		state.openings = [];
		state.selection = null;
		saveCurrentRoom();
		renderRoomTabs();
		renderWallOpeningsForms();
		zoomFit();
		redraw();
	};

	function syncFloorSwatches() {
		updateFloorColor3D(state.floorColor);
	}
	function syncWallSwatches() {
		updateWallColor3D(state.wallColor);
	}

	// ─── Locker type dropdown in setup form ───
	const ltModel = document.getElementById('lt-model') as HTMLSelectElement;
	const ltWidth = document.getElementById('lt-width') as HTMLSelectElement;
	const ltDepth = document.getElementById('lt-depth') as HTMLSelectElement;
	const ltDepthField = document.getElementById('lt-depth-field')!;
	const ltColor = document.getElementById('lt-color') as HTMLSelectElement;
	const ltAccList = document.getElementById('lt-acc-list')!;
	const ltAccRow = document.getElementById('lt-accessories-row')!;
	const ltQty = document.getElementById('lt-qty') as HTMLInputElement;
	const ltPrice = document.getElementById('lt-price')!;

	for (const t of getAllTemplates()) {
		const opt = document.createElement('option');
		opt.value = t.templateId;
		opt.textContent = t.displayName;
		ltModel.appendChild(opt);
	}

	const lockerImages: Record<string, string> = {
		'model-s': '/images/stadium-locker-side.png',
		'model-l': '/images/elite-locker-side.png',
		'model-z': '/images/elite-locker-side.png',
		'model-x': '/images/model-x-website-images/model-x-locker-side.png',
		'varsity': '/images/varsity-locker.png',
		'semi-pro': '/images/semi-pro-locker-third.png',
		'pro': '/images/pro-locker-quick-ship.png',
		'stadium': '/images/stadium-locker-side.png',
	};
	const ltPreviewImg = document.getElementById('lt-preview-img') as HTMLImageElement;

	function syncLockerFields() {
		const t = getTemplate(ltModel.value) ?? getAllTemplates()[0];

		if (ltPreviewImg && lockerImages[t.templateId]) {
			ltPreviewImg.src = lockerImages[t.templateId];
			ltPreviewImg.alt = t.displayName;
		}

		// Width
		ltWidth.innerHTML = '';
		for (const w of t.geometry.widthOptionsIn) {
			const opt = document.createElement('option');
			opt.value = String(w);
			opt.textContent = `${w}″`;
			if (w === t.geometry.defaultWidthIn) opt.selected = true;
			ltWidth.appendChild(opt);
		}

		// Depth
		ltDepth.innerHTML = '';
		if (t.geometry.depthOptionsIn.length > 1) {
			ltDepthField.style.display = '';
			for (const d of t.geometry.depthOptionsIn) {
				const opt = document.createElement('option');
				opt.value = String(d);
				opt.textContent = `${d}″`;
				if (d === t.geometry.defaultDepthIn) opt.selected = true;
				ltDepth.appendChild(opt);
			}
		} else {
			ltDepthField.style.display = 'none';
		}

		// Color
		ltColor.innerHTML = '';
		for (const c of t.colors) {
			const opt = document.createElement('option');
			opt.value = c.code;
			opt.textContent = c.label;
			opt.style.color = c.hex;
			ltColor.appendChild(opt);
		}

		// Accessories
		ltAccList.innerHTML = '';
		if (t.accessories.length > 0) {
			ltAccRow.style.display = '';
			for (const acc of t.accessories) {
				const lbl = document.createElement('label');
				const cb = document.createElement('input');
				cb.type = 'checkbox';
				cb.value = acc.id;
				cb.dataset.price = String(acc.price);
				cb.onchange = updateLtPrice;
				lbl.appendChild(cb);
				lbl.appendChild(document.createTextNode(` ${acc.label} (+$${acc.price})`));
				ltAccList.appendChild(lbl);
			}
		} else {
			ltAccRow.style.display = 'none';
		}

		updateLtPrice();
	}

	function getSelectedAccessoryIds(): string[] {
		const ids: string[] = [];
		ltAccList.querySelectorAll('input[type="checkbox"]:checked').forEach((cb) => {
			ids.push((cb as HTMLInputElement).value);
		});
		return ids;
	}

	function updateLtPrice() {
		const t = getTemplate(ltModel.value);
		if (!t) return;
		const base = t.pricing.basePriceByWidthIn[ltWidth.value] ?? 0;
		const depthKey = ltDepthField.style.display !== 'none' ? ltDepth.value : String(t.geometry.defaultDepthIn);
		const depthExtra = t.pricing.depthSurcharge[depthKey] ?? 0;
		let accTotal = 0;
		ltAccList.querySelectorAll('input[type="checkbox"]:checked').forEach((cb) => {
			accTotal += parseFloat((cb as HTMLInputElement).dataset.price ?? '0');
		});
		const total = base + depthExtra + accTotal;
		ltPrice.textContent = `$${total} ea`;
	}

	ltModel.onchange = syncLockerFields;
	ltWidth.onchange = updateLtPrice;
	ltDepth.onchange = updateLtPrice;
	syncLockerFields();

	document.getElementById('lt-add-btn')!.onclick = () => {
		const t = getTemplate(ltModel.value);
		if (!t) return;
		const qty = Math.max(1, parseInt(ltQty.value, 10) || 1);
		const widthIn = parseInt(ltWidth.value, 10) || t.geometry.defaultWidthIn;
		const depthIn = t.geometry.depthOptionsIn.length > 1
			? (parseInt(ltDepth.value, 10) || t.geometry.defaultDepthIn)
			: t.geometry.defaultDepthIn;
		const colorCode = ltColor.value || t.colors[0].code;
		const accessoryIds = getSelectedAccessoryIds();

		const cx = state.camera.centerX - widthIn / 2;
		const cy = state.camera.centerY - depthIn / 2;
		let lastId: string | null = null;

		for (let n = 0; n < qty; n++) {
			let placed = false;
			for (let ring = 0; ring < 60 && !placed; ring++) {
				const step = ring * Math.max(widthIn, depthIn);
				const spots = ring === 0
					? [{ dx: 0, dy: 0 }]
					: [
						{ dx: step, dy: 0 }, { dx: -step, dy: 0 },
						{ dx: 0, dy: step }, { dx: 0, dy: -step },
						{ dx: step, dy: step }, { dx: -step, dy: step },
						{ dx: step, dy: -step }, { dx: -step, dy: -step },
					];
				for (const { dx, dy } of spots) {
					const inst: LockerInstance = {
						instanceId: nextInstanceId(),
						templateId: t.templateId,
						config: { widthIn, depthIn, colorCode, cushionColorHex: '#1A1A1A', accessoryIds: [...accessoryIds] },
						x: cx + dx, y: cy + dy, rotationDeg: 0,
					};
					if (!wouldOverlap(inst, state.lockers, state.openings, state.walls)) {
						state.lockers.push(inst);
						lastId = inst.instanceId;
						placed = true;
						break;
					}
				}
			}
		}

		if (lastId) state.selection = { type: 'locker', id: lastId };
		redraw();
	};

	// ─── Redraw ───
	const canvasHint = document.getElementById('canvas-empty-hint');
	function adjustLockerPosition(locker: any, oldWidthIn: number, oldDepthIn: number) {
		const isRotated = locker.rotationDeg === 90 || locker.rotationDeg === 270;
		const oldW = isRotated ? oldDepthIn : oldWidthIn;
		const oldD = isRotated ? oldWidthIn : oldDepthIn;
		const newW = isRotated ? locker.config.depthIn : locker.config.widthIn;
		const newD = isRotated ? locker.config.widthIn : locker.config.depthIn;

		const roomMinX = Math.min(...state.walls.map((w: any) => Math.min(w.start.x, w.end.x)));
		const roomMaxX = Math.max(...state.walls.map((w: any) => Math.max(w.start.x, w.end.x)));
		const roomMinY = Math.min(...state.walls.map((w: any) => Math.min(w.start.y, w.end.y)));
		const roomMaxY = Math.max(...state.walls.map((w: any) => Math.max(w.start.y, w.end.y)));
		const roomCenterX = (roomMinX + roomMaxX) / 2;
		const roomCenterY = (roomMinY + roomMaxY) / 2;

		if (newW !== oldW) {
			if (locker.x + oldW / 2 > roomCenterX) locker.x += oldW - newW;
		}
		if (newD !== oldD) {
			if (locker.y + oldD / 2 > roomCenterY) locker.y += oldD - newD;
		}
	}

	function updateCornerNotice() {
		const status = document.getElementById('corner-status')!;
		if (state.lockers.length === 0) {
			status.className = 'corner-status';
			return;
		}
		const occupied = getWallsWithLockers(state.walls, state.lockers);
		if (occupied.size === 0) {
			status.className = 'corner-status';
			return;
		}

		const corners: string[] = [];
		for (let i = 0; i < state.walls.length; i++) {
			const curr = state.walls[i];
			const next = state.walls[(i + 1) % state.walls.length];
			if (occupied.has(curr.id) && occupied.has(next.id)) {
				corners.push(curr.id + ' & ' + next.id);
			}
		}

		if (corners.length > 0) {
			status.className = 'corner-status active';
			status.innerHTML = '\u26A0 <strong>Right now:</strong> Corner clearance is active at ' + corners.join(', ') + ' because lockers are on both connecting walls.';
		} else {
			status.className = 'corner-status clear';
			const wallList = Array.from(occupied).join(', ');
			status.innerHTML = '\u2713 <strong>Right now:</strong> No corner clearance needed \u2014 your lockers are on ' + wallList + ' only.';
		}
	}

