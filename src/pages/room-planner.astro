	:global(.guide-nav-btn) {
		flex: 1;
		padding: 9px 0;
		border: 1px solid #ddd;
		border-radius: 8px;
		background: #fff;
		color: #555;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		cursor: pointer;
		transition: border-color 0.2s, color 0.2s, background 0.2s;
	}
	:global(.guide-nav-btn:hover:not(:disabled)) { border-color: #bbb; color: #222; }
