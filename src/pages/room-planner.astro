	/* Corner clearance guide */
	.corner-guide {
		background: #fafafa;
		border: 1px solid #e0e0e0;
		border-radius: 6px;
		margin: 0 12px 8px;
		overflow: hidden;
	}
	.corner-guide-header {
		background: #1a1a1a;
		color: #fff;
		padding: 8px 14px;
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.5px;
		text-transform: uppercase;
		font-family: 'Oswald', sans-serif;
	}
	.corner-guide-rules {
		display: flex;
		gap: 0;
	}
	.corner-rule {
		flex: 1;
		display: flex;
		gap: 10px;
		padding: 12px 14px;
		font-size: 12.5px;
		line-height: 1.5;
		border-right: 1px solid #e0e0e0;
	}
	.corner-rule:last-child { border-right: none; }
	.corner-rule strong { font-weight: 600; display: block; margin-bottom: 2px; }
	.corner-rule-icon { flex-shrink: 0; font-size: 18px; margin-top: 1px; }
	.corner-rule-warn { background: rgba(255, 89, 0, 0.05); }
	.corner-rule-warn .corner-rule-icon { color: #d35400; }
	.corner-rule-ok { background: rgba(0, 128, 80, 0.04); }
	.corner-rule-ok .corner-rule-icon { color: #1a8a52; }
	.corner-status {
		padding: 8px 14px;
		font-size: 12.5px;
		font-weight: 500;
		border-top: 1px solid #e0e0e0;
		display: none;
	}
	.corner-status.active {
		display: block;
		background: rgba(255, 89, 0, 0.07);
		color: #b84400;
	}
	.corner-status.clear {
		display: block;
		background: rgba(0, 128, 80, 0.05);
		color: #1a6b45;
	}
	@media (max-width: 640px) {
		.corner-guide-rules { flex-direction: column; }
		.corner-rule { border-right: none; border-bottom: 1px solid #e0e0e0; }
		.corner-rule:last-child { border-bottom: none; }
	}

