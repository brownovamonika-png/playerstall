	const _wallPositionLabels: Record<string, string> = {
		'Wall A': 'from left end',
		'Wall B': 'from top end',
		'Wall C': 'from right end',
		'Wall D': 'from bottom end',
	};

	function _inToFt(inches: number) { return { ft: Math.floor(inches / 12), inch: Math.round(inches % 12) }; }
	function _ftToIn(ft: number, inch: number) { return ft * 12 + inch; }

	function _makeFtInInput(valueInches: number, onChange: (newInches: number) => void) {
		const wrap = document.createElement('div');
		wrap.className = 'op-ftin-row';
		const { ft, inch } = _inToFt(valueInches);

		const ftInput = document.createElement('input');
		ftInput.type = 'number'; ftInput.value = String(ft); ftInput.min = '0'; ftInput.step = '1';
		wrap.appendChild(ftInput);
		const ftU = document.createElement('span'); ftU.className = 'op-ftin-unit'; ftU.textContent = 'ft';
		wrap.appendChild(ftU);

		const inInput = document.createElement('input');
		inInput.type = 'number'; inInput.value = String(inch); inInput.min = '0'; inInput.max = '11'; inInput.step = '1';
		wrap.appendChild(inInput);
		const inU = document.createElement('span'); inU.className = 'op-ftin-unit'; inU.textContent = 'in';
		wrap.appendChild(inU);

		const update = () => {
			const f = Math.max(0, parseInt(ftInput.value, 10) || 0);
			const i = Math.max(0, Math.min(11, parseInt(inInput.value, 10) || 0));
			onChange(_ftToIn(f, i));
		};
		ftInput.onchange = update;
		inInput.onchange = update;
		return wrap;
	}

	function _buildWallBar(wallId: string) {
		const wall = state.walls.find((w) => w.id === wallId);
		if (!wall) return null;
		const len = wallLength(wall);
		if (len <= 0) return null;
		const ops = state.openings.filter((o) => o.wallId === wallId);
		if (ops.length === 0) return null;

		const wrap = document.createElement('div');
		wrap.className = 'wall-bar-wrap';
		const bar = document.createElement('div');
		bar.className = 'wall-bar';

		for (const op of ops) {
			const pct = (op.offsetAlongWall / len) * 100;
			const wPct = (op.widthIn / len) * 100;
			const block = document.createElement('div');
			block.className = 'wall-bar-opening ' + op.type;
			block.style.left = pct + '%';
			block.style.width = Math.max(wPct, 2) + '%';
			const lbl = document.createElement('span');
			lbl.className = 'wall-bar-opening-label';
			lbl.textContent = op.type === 'door' ? 'D' : op.type === 'window' ? 'W' : 'O';
			block.appendChild(lbl);
			bar.appendChild(block);
		}
		wrap.appendChild(bar);

		const labels = document.createElement('div');
		labels.className = 'wall-bar-labels';
		const { ft: tFt, inch: tIn } = _inToFt(len);
		labels.innerHTML = '<span>0\u2032</span><span>' + tFt + '\u2032 ' + tIn + '\u2033</span>';
		wrap.appendChild(labels);
		return wrap;
	}

	/** Render the per-wall opening rows inside the Room Dimensions form. */
	function renderWallOpeningsForms() {
		const wallKeys = [
			{ wallId: 'Wall A', containerId: 'openings-wall-a' },
			{ wallId: 'Wall B', containerId: 'openings-wall-b' },
			{ wallId: 'Wall C', containerId: 'openings-wall-c' },
			{ wallId: 'Wall D', containerId: 'openings-wall-d' },
		];

		for (const { wallId, containerId } of wallKeys) {
			const container = document.getElementById(containerId)!;
			const wallOpenings = state.openings.filter((o) => o.wallId === wallId);
			container.innerHTML = '';

			const wallBar = _buildWallBar(wallId);
			if (wallBar) container.appendChild(wallBar);

			for (const op of wallOpenings) {
				const card = document.createElement('div');
				card.className = 'wall-opening-row';

				const header = document.createElement('div');
				header.className = 'op-header';
				const badge = document.createElement('span');
				badge.className = `op-badge ${op.type}`;
				badge.textContent = op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle';
				header.appendChild(badge);
				const removeBtn = document.createElement('button');
				removeBtn.className = 'op-remove';
				removeBtn.textContent = '\u2715';
				removeBtn.title = 'Remove this opening';
				removeBtn.onclick = () => {
					state.openings = state.openings.filter((o) => o.id !== op.id);
					if (state.selection?.type === 'opening' && state.selection.id === op.id) {
						state.selection = null;
					}
					renderWallOpeningsForms();
					redraw();
				};
				header.appendChild(removeBtn);
				card.appendChild(header);

				const grid = document.createElement('div');
				grid.className = 'op-fields';

				// Position — ft + in with clear label
				const posGroup = document.createElement('div');
				posGroup.className = 'op-field';
				const posLabel = document.createElement('label');
				posLabel.textContent = 'Position ' + (_wallPositionLabels[wallId] || '');
				posGroup.appendChild(posLabel);
				posGroup.appendChild(_makeFtInInput(op.offsetAlongWall, (v) => {
					op.offsetAlongWall = Math.max(0, v);
					renderWallOpeningsForms();
					redraw();
				}));
				grid.appendChild(posGroup);

				// Width
				const wGroup = document.createElement('div');
				wGroup.className = 'op-field';
				const wLabel = document.createElement('label');
				wLabel.textContent = 'Width';
				wGroup.appendChild(wLabel);
				const wRow = document.createElement('div');
				wRow.className = 'op-field-row';
				const wInput = document.createElement('input');
				wInput.type = 'number'; wInput.value = String(op.widthIn); wInput.min = '12'; wInput.step = '1';
				wInput.title = 'Width of the opening in inches';
				wInput.onchange = () => { op.widthIn = Math.max(12, parseFloat(wInput.value) || 36); renderWallOpeningsForms(); redraw(); };
				wRow.appendChild(wInput);
				const wUnit = document.createElement('span'); wUnit.className = 'op-unit'; wUnit.textContent = '\u2033';
				wRow.appendChild(wUnit);
				wGroup.appendChild(wRow);
				grid.appendChild(wGroup);

				// Clearance
				const cGroup = document.createElement('div');
				cGroup.className = 'op-field';
				const cLabel = document.createElement('label');
				cLabel.textContent = 'Clearance';
				cGroup.appendChild(cLabel);
				const cRow = document.createElement('div');
				cRow.className = 'op-field-row';
				const cInput = document.createElement('input');
				cInput.type = 'number'; cInput.value = String(op.clearanceIn); cInput.min = '0'; cInput.step = '1';
				cInput.title = 'How far into the room no lockers can be placed';
				cInput.onchange = () => { op.clearanceIn = Math.max(0, parseFloat(cInput.value) || 0); redraw(); };
				cRow.appendChild(cInput);
				const cUnit = document.createElement('span'); cUnit.className = 'op-unit'; cUnit.textContent = '\u2033';
				cRow.appendChild(cUnit);
				cGroup.appendChild(cRow);
				grid.appendChild(cGroup);

				card.appendChild(grid);
				container.appendChild(card);
			}
		}
	}

	// Initial render (empty)
	renderWallOpeningsForms();

	// ─── Canvas pointer events (select + drag) ───
	let dragging: LockerInstance | null = null;
	let dragOffsetX = 0;
	let dragOffsetY = 0;
	let draggingOpening: Opening | null = null;
	let isPanning = false;
	let panStartX = 0;
	let panStartY = 0;
	let panCamStartX = 0;
	let panCamStartY = 0;

	canvas.addEventListener('pointerdown', (e) => {
		const rect = canvas.getBoundingClientRect();
		const sx = e.clientX - rect.left;
		const sy = e.clientY - rect.top;
		const world = screenToWorld(sx, sy, state.camera, canvas.clientWidth, canvas.clientHeight);

		if (placementMode) {
			const wall = state.walls.find((w) => w.id === placementMode!.wallId);
			if (wall) {
				const offset = projectOntoWall(world.x, world.y, wall);
				addOpeningToWall(placementMode.wallId, placementMode.type, offset);
			}
			exitPlacementMode();
			return;
		}

		// Try to hit a locker (reverse order = top first)
		let hitLocker: LockerInstance | null = null;
		for (let i = state.lockers.length - 1; i >= 0; i--) {
			const l = state.lockers[i];
			const box = lockerAABB(l);
			if (world.x >= box.minX && world.x <= box.maxX && world.y >= box.minY && world.y <= box.maxY) {
				hitLocker = l;
				break;
			}
		}

		if (hitLocker) {
			state.selection = { type: 'locker', id: hitLocker.instanceId };
			if (state.editMode) {
				dragging = hitLocker;
				dragOffsetX = world.x - hitLocker.x;
				dragOffsetY = world.y - hitLocker.y;
				canvas.setPointerCapture(e.pointerId);
			}
			redraw();
			return;
		}

		// Try to hit an opening (select + start drag)
		const hitOp = hitTestOpening(world.x, world.y, state.openings, state.walls);
		if (hitOp) {
			state.selection = { type: 'opening', id: hitOp.id };
			draggingOpening = hitOp;
			canvas.setPointerCapture(e.pointerId);
			canvas.style.cursor = 'grabbing';
			redraw();
			return;
		}

		// Try to hit a wall
		for (const wall of state.walls) {
			const wpx1 = wall.start.x;
			const wpy1 = wall.start.y;
			const wpx2 = wall.end.x;
			const wpy2 = wall.end.y;
			const hitDist = distToSegment(world.x, world.y, wpx1, wpy1, wpx2, wpy2);
			if (hitDist < wall.thicknessIn / 2 + 4 / state.camera.pixelsPerInch) {
				state.selection = { type: 'wall', id: wall.id };
				redraw();
				return;
			}
		}

		// Pan
		state.selection = null;
		isPanning = true;
		panStartX = e.clientX;
		panStartY = e.clientY;
		panCamStartX = state.camera.centerX;
		panCamStartY = state.camera.centerY;
		canvas.setPointerCapture(e.pointerId);
		redraw();
	});

	const SNAP_THRESHOLD = 8;

	function snapLocker(target: LockerInstance): void {
		const box = lockerAABB(target);
		const snapDist = SNAP_THRESHOLD / state.camera.pixelsPerInch;
		let bestDx = Infinity;
		let bestDy = Infinity;

		for (const other of state.lockers) {
			if (other.instanceId === target.instanceId) continue;
			const ob = lockerAABB(other);

			// X-axis snaps (left-to-right, right-to-left, left-to-left, right-to-right)
			const xEdges = [
				{ from: box.maxX, to: ob.minX },
				{ from: box.minX, to: ob.maxX },
				{ from: box.minX, to: ob.minX },
				{ from: box.maxX, to: ob.maxX },
			];
			for (const edge of xEdges) {
				const d = edge.to - edge.from;
				if (Math.abs(d) < Math.abs(bestDx) && Math.abs(d) < snapDist) bestDx = d;
			}

			// Y-axis snaps
			const yEdges = [
				{ from: box.maxY, to: ob.minY },
				{ from: box.minY, to: ob.maxY },
				{ from: box.minY, to: ob.minY },
				{ from: box.maxY, to: ob.maxY },
			];
			for (const edge of yEdges) {
				const d = edge.to - edge.from;
				if (Math.abs(d) < Math.abs(bestDy) && Math.abs(d) < snapDist) bestDy = d;
			}
		}

		// Snap to wall inner faces
		for (const wall of state.walls) {
			const halfT = wall.thicknessIn / 2;
			const isHoriz = Math.abs(wall.end.y - wall.start.y) < 0.01;

			if (isHoriz) {
				const innerY = wall.start.y + (wall.id === 'Wall A' ? halfT : -halfT);
				// Snap top edge to wall inner face (Wall A), bottom edge (Wall C)
				const dTop = innerY - box.minY;
				const dBot = innerY - box.maxY;
				if (Math.abs(dTop) < Math.abs(bestDy) && Math.abs(dTop) < snapDist) bestDy = dTop;
				if (Math.abs(dBot) < Math.abs(bestDy) && Math.abs(dBot) < snapDist) bestDy = dBot;

				// Snap to wall endpoints (corners) on X
				const xMin = Math.min(wall.start.x, wall.end.x) + halfT;
				const xMax = Math.max(wall.start.x, wall.end.x) - halfT;
				const dL = xMin - box.minX;
				const dR = xMax - box.maxX;
				if (Math.abs(dL) < Math.abs(bestDx) && Math.abs(dL) < snapDist) bestDx = dL;
				if (Math.abs(dR) < Math.abs(bestDx) && Math.abs(dR) < snapDist) bestDx = dR;
			} else {
				const innerX = wall.start.x + (wall.id === 'Wall D' ? halfT : -halfT);
				const dLeft = innerX - box.minX;
				const dRight = innerX - box.maxX;
				if (Math.abs(dLeft) < Math.abs(bestDx) && Math.abs(dLeft) < snapDist) bestDx = dLeft;
				if (Math.abs(dRight) < Math.abs(bestDx) && Math.abs(dRight) < snapDist) bestDx = dRight;

				const yMin = Math.min(wall.start.y, wall.end.y) + halfT;
				const yMax = Math.max(wall.start.y, wall.end.y) - halfT;
				const dT = yMin - box.minY;
				const dB = yMax - box.maxY;
				if (Math.abs(dT) < Math.abs(bestDy) && Math.abs(dT) < snapDist) bestDy = dT;
				if (Math.abs(dB) < Math.abs(bestDy) && Math.abs(dB) < snapDist) bestDy = dB;
			}
		}

		if (Math.abs(bestDx) < snapDist) target.x += bestDx;
		if (Math.abs(bestDy) < snapDist) target.y += bestDy;
	}

	canvas.addEventListener('pointermove', (e) => {
		if (draggingOpening) {
			const wall = state.walls.find((w) => w.id === draggingOpening!.wallId);
			if (wall) {
				const rect = canvas.getBoundingClientRect();
				const sx = e.clientX - rect.left;
				const sy = e.clientY - rect.top;
				const world = screenToWorld(sx, sy, state.camera, canvas.clientWidth, canvas.clientHeight);
				const along = projectOntoWall(world.x, world.y, wall);
				const len = wallLength(wall);
				draggingOpening.offsetAlongWall = Math.max(0, Math.min(along - draggingOpening.widthIn / 2, len - draggingOpening.widthIn));
				redraw();
				renderWallOpeningsForms();
			}
		} else if (dragging) {
			const rect = canvas.getBoundingClientRect();
			const sx = e.clientX - rect.left;
			const sy = e.clientY - rect.top;
			const world = screenToWorld(sx, sy, state.camera, canvas.clientWidth, canvas.clientHeight);
			const oldX = dragging.x;
			const oldY = dragging.y;
			dragging.x = world.x - dragOffsetX;
			dragging.y = world.y - dragOffsetY;
			snapLocker(dragging);
			if (wouldOverlap(dragging, state.lockers, state.openings, state.walls)) {
				dragging.x = oldX;
				dragging.y = oldY;
			}
			redraw();
		} else if (isPanning) {
			const dx = (e.clientX - panStartX) / state.camera.pixelsPerInch;
			const dy = (e.clientY - panStartY) / state.camera.pixelsPerInch;
			state.camera.centerX = panCamStartX - dx;
			state.camera.centerY = panCamStartY - dy;
			redraw();
		}
	});

	canvas.addEventListener('pointerup', () => {
		if (draggingOpening) { canvas.style.cursor = ''; }
		dragging = null;
		draggingOpening = null;
		isPanning = false;
	});

	canvas.addEventListener('dblclick', (e) => {
		const rect = canvas.getBoundingClientRect();
		const sx = e.clientX - rect.left;
		const sy = e.clientY - rect.top;
		const world = screenToWorld(sx, sy, state.camera, canvas.clientWidth, canvas.clientHeight);

		for (let i = state.lockers.length - 1; i >= 0; i--) {
			const l = state.lockers[i];
			const box = lockerAABB(l);
			if (world.x >= box.minX && world.x <= box.maxX && world.y >= box.minY && world.y <= box.maxY) {
				const oldRot = l.rotationDeg;
				l.rotationDeg = (l.rotationDeg + 90) % 360;
				if (wouldOverlap(l, state.lockers, state.openings, state.walls)) {
					l.rotationDeg = oldRot;
				}
				state.selection = { type: 'locker', id: l.instanceId };
				redraw();
				return;
			}
		}
	});

	function distToSegment(px: number, py: number, x1: number, y1: number, x2: number, y2: number): number {
		const dx = x2 - x1;
		const dy = y2 - y1;
		const lenSq = dx * dx + dy * dy;
		if (lenSq === 0) return Math.hypot(px - x1, py - y1);
		let t = ((px - x1) * dx + (py - y1) * dy) / lenSq;
		t = Math.max(0, Math.min(1, t));
		return Math.hypot(px - (x1 + t * dx), py - (y1 + t * dy));
	}

	// ─── Layers list ───
	function updateLayers() {
		const list = document.getElementById('layers-list')!;
		let html = '';

		html += `<li class="${state.selection?.type === 'room' ? 'selected' : ''}" data-sel-type="room" data-sel-id="room">
			<span class="layer-icon" style="background:#888"></span> Room
		</li>`;

		for (const wall of state.walls) {
			const sel = state.selection?.type === 'wall' && state.selection.id === wall.id;
			const len = formatDimension(wallLength(wall), state.displayUnit, 0);
			html += `<li class="${sel ? 'selected' : ''}" data-sel-type="wall" data-sel-id="${wall.id}">
				<span class="layer-icon" style="background:#555"></span> ${wall.id} · ${len}
			</li>`;
		}

		for (const op of state.openings) {
			const sel = state.selection?.type === 'opening' && state.selection.id === op.id;
			const opColor = op.type === 'door' ? '#5a9fd4' : op.type === 'window' ? '#6dc46d' : '#d4a05a';
			const parentWall = state.walls.find((w) => w.id === op.wallId);
			const wallLabel = parentWall ? parentWall.id : op.wallId;
			const opLabel = op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle';
			html += `<li class="${sel ? 'selected' : ''}" data-sel-type="opening" data-sel-id="${op.id}">
				<span class="layer-icon" style="background:${opColor}"></span>
				${opLabel} · ${wallLabel}
			</li>`;
		}

		for (const locker of state.lockers) {
			const t = getTemplate(locker.templateId);
			const sel = state.selection?.type === 'locker' && state.selection.id === locker.instanceId;
			const color = t?.colors.find((c) => c.code === locker.config.colorCode);
			const dim = formatDimension(locker.config.widthIn, state.displayUnit, 0);
			html += `<li class="${sel ? 'selected' : ''}" data-sel-type="locker" data-sel-id="${locker.instanceId}">
				<span class="layer-icon" style="background:${color?.hex ?? '#ccc'}"></span>
				${t?.displayName ?? locker.templateId} · ${dim}
			</li>`;
		}

		list.innerHTML = html;

		const layersHint = document.getElementById('layers-hint');
		if (layersHint) layersHint.style.display = state.lockers.length ? 'none' : '';

		list.querySelectorAll('li').forEach((li) => {
			li.addEventListener('click', () => {
				const type = li.dataset.selType as Selection['type'];
				const id = li.dataset.selId!;
				state.selection = { type, id };
				redraw();
			});
		});
	}

	// ─── Selection config (left panel) ───
	const selConfig = document.getElementById('selection-config')!;
	const selConfigTitle = document.getElementById('sel-config-title')!;
	document.getElementById('sel-config-close')!.onclick = () => {
		state.selection = null;
		redraw();
	};

	function updateProperties() {
		const propsLocker = document.getElementById('props-locker')!;
		const propsWall = document.getElementById('props-wall')!;
		const propsOpening = document.getElementById('props-opening')!;
		propsLocker.style.display = 'none';
		propsWall.style.display = 'none';
		propsOpening.style.display = 'none';

		if (!state.selection || state.selection.type === 'room') {
			selConfig.style.display = 'none';
			return;
		}

		selConfig.style.display = '';

		if (state.selection.type === 'locker') {
			const locker = state.lockers.find((l) => l.instanceId === state.selection!.id);
			if (!locker) { selConfig.style.display = 'none'; return; }
			const template = getTemplate(locker.templateId);
			if (!template) { selConfig.style.display = 'none'; return; }

			selConfigTitle.textContent = template.displayName;
			propsLocker.style.display = '';
			document.getElementById('prop-model-name')!.textContent = template.displayName;

			const widthDiv = document.getElementById('prop-width-options')!;
			widthDiv.innerHTML = '';
			for (const w of template.geometry.widthOptionsIn) {
				const btn = document.createElement('button');
				btn.textContent = `${w}″`;
				btn.className = w === locker.config.widthIn ? 'active' : '';
				btn.onclick = () => {
					const oldW = locker.config.widthIn;
					const oldD = locker.config.depthIn;
					const oldX = locker.x;
					const oldY = locker.y;
					locker.config.widthIn = w;
					adjustLockerPosition(locker, oldW, oldD);
					if (wouldOverlap(locker, state.lockers, state.openings, state.walls)) {
						locker.config.widthIn = oldW;
						locker.x = oldX;
						locker.y = oldY;
					}
					redraw();
				};
				widthDiv.appendChild(btn);
			}

			const depthDiv = document.getElementById('prop-depth-options')!;
			depthDiv.innerHTML = '';
			for (const d of template.geometry.depthOptionsIn) {
				const btn = document.createElement('button');
				btn.textContent = `${d}″`;
				btn.className = d === locker.config.depthIn ? 'active' : '';
				btn.onclick = () => {
					const oldW = locker.config.widthIn;
					const oldD = locker.config.depthIn;
					const oldX = locker.x;
					const oldY = locker.y;
					locker.config.depthIn = d;
					adjustLockerPosition(locker, oldW, oldD);
					if (wouldOverlap(locker, state.lockers, state.openings, state.walls)) {
						locker.config.depthIn = oldD;
						locker.x = oldX;
						locker.y = oldY;
					}
					redraw();
				};
				depthDiv.appendChild(btn);
			}

			const colorSel = document.getElementById('prop-color-select') as HTMLSelectElement;
			colorSel.innerHTML = '';
			for (const c of template.colors) {
				const opt = document.createElement('option');
				opt.value = c.code;
				opt.textContent = c.label;
				opt.selected = c.code === locker.config.colorCode;
				colorSel.appendChild(opt);
			}
			colorSel.onchange = () => {
				locker.config.colorCode = colorSel.value;
				redraw();
			};

			const accDiv = document.getElementById('prop-accessories')!;
			accDiv.innerHTML = '';
			for (const acc of template.accessories) {
				const lbl = document.createElement('label');
				const cb = document.createElement('input');
				cb.type = 'checkbox';
				cb.checked = locker.config.accessoryIds.includes(acc.id);
				cb.onchange = () => {
					if (cb.checked) {
						locker.config.accessoryIds.push(acc.id);
					} else {
						locker.config.accessoryIds = locker.config.accessoryIds.filter((a) => a !== acc.id);
					}
					redraw();
				};
				lbl.appendChild(cb);
				lbl.appendChild(document.createTextNode(` ${acc.label} (+$${acc.price})`));
				accDiv.appendChild(lbl);
			}

			const price = priceLocker(template, locker.config);
			document.getElementById('prop-price')!.textContent = `$${price.toLocaleString()}`;

			document.getElementById('prop-rotate-locker')!.onclick = () => {
				const oldRot = locker.rotationDeg;
				locker.rotationDeg = (locker.rotationDeg + 90) % 360;
				if (wouldOverlap(locker, state.lockers, state.openings, state.walls)) {
					locker.rotationDeg = oldRot;
				}
				redraw();
			};

			document.getElementById('prop-delete-locker')!.onclick = () => {
				state.lockers = state.lockers.filter((l) => l.instanceId !== locker.instanceId);
				state.selection = null;
				redraw();
			};
		}

		if (state.selection.type === 'wall') {
			const wall = state.walls.find((w) => w.id === state.selection!.id);
			if (!wall) { selConfig.style.display = 'none'; return; }
			selConfigTitle.textContent = wall.id;
			propsWall.style.display = '';
			document.getElementById('prop-wall-id')!.textContent = wall.id;

			const lenInput = document.getElementById('prop-wall-length') as HTMLInputElement;
			lenInput.value = String(Math.round(wallLength(wall)));
			document.getElementById('prop-wall-length-unit')!.textContent = unitLabel(state.displayUnit);
			lenInput.onchange = () => {
				const newLen = parseFloat(lenInput.value) || wallLength(wall);
				const dimKey = wall.id === 'Wall A' ? 'wallA'
					: wall.id === 'Wall B' ? 'wallB'
					: wall.id === 'Wall C' ? 'wallC' : 'wallD';
				roomDims[dimKey] = newLen;
				if (dimKey === 'wallA') roomDims.wallC = newLen;
				if (dimKey === 'wallC') roomDims.wallA = newLen;
				if (dimKey === 'wallB') roomDims.wallD = newLen;
				if (dimKey === 'wallD') roomDims.wallB = newLen;
				writeAllDimInputs();
				state.walls = buildWalls(roomDims);
				state.lockers = [];
				state.openings = state.openings.filter((op) => {
					const w = state.walls.find((wl) => wl.id === op.wallId);
					return w && (op.offsetAlongWall + op.widthIn) <= wallLength(w);
				});
				state.selection = { type: 'wall', id: wall.id };
				renderWallOpeningsForms();
				zoomFit();
				redraw();
			};

			const thInput = document.getElementById('prop-wall-thickness') as HTMLInputElement;
			thInput.value = String(wall.thicknessIn);
			thInput.onchange = () => {
				const newTh = parseFloat(thInput.value) || 4.5;
				wall.thicknessIn = newTh;
				const thKey = wall.id === 'Wall A' ? 'thicknessA'
					: wall.id === 'Wall B' ? 'thicknessB'
					: wall.id === 'Wall C' ? 'thicknessC' : 'thicknessD';
				roomDims[thKey] = newTh;
				redraw();
			};
		}

		if (state.selection.type === 'opening') {
			const op = state.openings.find((o) => o.id === state.selection!.id);
			if (!op) { selConfig.style.display = 'none'; return; }
			selConfigTitle.textContent = `${op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle'} · ${op.wallId}`;
			propsOpening.style.display = '';

			document.getElementById('prop-opening-type')!.textContent = op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle';
			document.getElementById('prop-opening-wall')!.textContent = op.wallId;

			const wInput = document.getElementById('prop-opening-width') as HTMLInputElement;
			wInput.value = String(op.widthIn);
			wInput.onchange = () => {
				op.widthIn = Math.max(12, parseFloat(wInput.value) || op.widthIn);
				renderWallOpeningsForms();
				redraw();
			};

			const oInput = document.getElementById('prop-opening-offset') as HTMLInputElement;
			oInput.value = String(op.offsetAlongWall);
			oInput.onchange = () => {
				op.offsetAlongWall = Math.max(0, parseFloat(oInput.value) || 0);
				renderWallOpeningsForms();
				redraw();
			};

			const cInput = document.getElementById('prop-opening-clearance') as HTMLInputElement;
			cInput.value = String(op.clearanceIn);
			cInput.onchange = () => {
				op.clearanceIn = Math.max(0, parseFloat(cInput.value) || 0);
				renderWallOpeningsForms();
				redraw();
			};

			document.getElementById('btn-delete-opening')!.onclick = () => {
				state.openings = state.openings.filter((o) => o.id !== op.id);
				state.selection = null;
				renderWallOpeningsForms();
				redraw();
			};
		}
	}

	// ─── Fill wall ───
	document.getElementById('btn-fill-wall')!.onclick = () => {
		if (state.selection?.type !== 'wall') return;
		const wall = state.walls.find((w) => w.id === state.selection!.id);
		if (!wall) return;

		const t = getSelectedTemplate();
		const defaultConfig = {
			widthIn: t.geometry.defaultWidthIn,
			depthIn: t.geometry.defaultDepthIn,
			colorCode: t.colors[0].code,
			accessoryIds: [] as string[],
		};

		const wallOpenings = state.openings.filter((o) => o.wallId === wall.id);
		const newLockers = packWall(wall, t.templateId, defaultConfig, Date.now() % 100000, wallOpenings, state.lockers, state.walls);
		const valid = newLockers.filter((l) => !wouldOverlap(l, [...state.lockers, ...newLockers.filter((n) => n !== l)], state.openings, state.walls));
		state.lockers.push(...valid);
		if (valid.length > 0) {
			state.selection = { type: 'locker', id: valid[0].instanceId };
		}
		redraw();
	};

	// ─── Order summary ───
	interface LineItem {
		roomName: string;
		templateId: string;
		displayName: string;
		widthIn: number;
		depthIn: number;
		colorCode: string;
		colorLabel: string;
		accessoryIds: string[];
		accessories: { label: string; price: number }[];
		unitPrice: number;
		qty: number;
	}

	function buildLinesForLockers(lockers: LockerInstance[], roomName: string): LineItem[] {
		const lines: LineItem[] = [];
		for (const locker of lockers) {
			const t = getTemplate(locker.templateId);
			if (!t) continue;
			const price = priceLocker(t, locker.config);
			const color = t.colors.find((c) => c.code === locker.config.colorCode);
			const accs = locker.config.accessoryIds
				.map((id) => t.accessories.find((a) => a.id === id))
				.filter(Boolean) as { id: string; label: string; price: number }[];
			const sortedAcc = [...locker.config.accessoryIds].sort();
			const key = `${locker.templateId}|${locker.config.widthIn}|${locker.config.depthIn}|${locker.config.colorCode}|${sortedAcc.join(',')}`;
			const existing = lines.find((l) =>
				`${l.templateId}|${l.widthIn}|${l.depthIn}|${l.colorCode}|${[...l.accessoryIds].sort().join(',')}` === key
				&& l.roomName === roomName
			);
			if (existing) {
				existing.qty++;
			} else {
				lines.push({
					roomName,
					templateId: locker.templateId,
					displayName: t.displayName,
					widthIn: locker.config.widthIn,
					depthIn: locker.config.depthIn,
					colorCode: locker.config.colorCode,
					colorLabel: color?.label ?? locker.config.colorCode,
					accessoryIds: [...locker.config.accessoryIds],
					accessories: accs.map((a) => ({ label: a.label, price: a.price })),
					unitPrice: price,
					qty: 1,
				});
			}
		}
		return lines;
	}

	function getAllRoomLines(): LineItem[] {
		saveCurrentRoom();
		const allLines: LineItem[] = [];
		for (const room of savedRooms) {
			allLines.push(...buildLinesForLockers(room.lockers, room.roomName));
		}
		return allLines;
	}

	function updateOrderSummary() {
		const nameEl = document.getElementById('order-room-name')!;
		const tbody = document.getElementById('order-items-body')!;
		const subtotalEl = document.getElementById('order-subtotal')!;
		const totalEl = document.getElementById('order-total')!;
		const countEl = document.getElementById('order-locker-count')!;

		const allLines = getAllRoomLines();
		nameEl.textContent = '';

		if (allLines.length === 0) {
			tbody.innerHTML = '<tr><td colspan="3" class="ot-empty">No lockers placed yet.</td></tr>';
			subtotalEl.textContent = '$0.00';
			totalEl.innerHTML = '<strong>$0.00</strong>';
			countEl.textContent = '0 lockers';
			(window as any).__plannerAllLines = [];
			return;
		}

		(window as any).__plannerAllLines = allLines;

		let subtotal = 0;
		let totalLockers = 0;
		let html = '';
		let currentRoom = '';
		for (const line of allLines) {
			const rLabel = line.roomName || 'Unnamed Room';
			if (rLabel !== currentRoom) {
				currentRoom = rLabel;
				html += `<tr class="ot-room-header"><td colspan="3">${currentRoom}</td></tr>`;
			}
			const lineTotal = line.unitPrice * line.qty;
			subtotal += lineTotal;
			totalLockers += line.qty;
			let accHtml = '';
			if (line.accessories.length) {
				accHtml = line.accessories
					.map((a) => `<span class="ot-acc-line">+ ${a.label} <span class="ot-acc-price">+$${a.price}</span></span>`)
					.join('');
			}
			html += `<tr>
				<td>
					<span class="ot-item-name">${line.displayName}</span>
					<span class="ot-item-spec">${line.widthIn}″W × ${line.depthIn}″D · ${line.colorLabel}</span>
					${accHtml}
				</td>
				<td class="ot-item-qty">${line.qty}</td>
				<td class="ot-item-total">$${lineTotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}</td>
			</tr>`;
		}

		tbody.innerHTML = html;
		subtotalEl.textContent = `$${subtotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
		totalEl.innerHTML = `<strong>$${subtotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}</strong>`;
		countEl.textContent = `${totalLockers} locker${totalLockers !== 1 ? 's' : ''} across ${savedRooms.length || 1} room${savedRooms.length > 1 ? 's' : ''}`;
	}

	// ─── PDF Generation ───
	async function generateLayoutPDF(
		allLines: LineItem[],
		orderSummary: string,
		grandTotal: number,
		customerEmail: string,
	): Promise<Blob | null> {
		try {
			saveCurrentRoom();
			const origIndex = activeRoomIndex;

			const pdf = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'letter' });
			const pageW = pdf.internal.pageSize.getWidth();
			const pageH = pdf.internal.pageSize.getHeight();
			const margin = 40;

			const offCanvas = document.createElement('canvas');
			offCanvas.width = 1200;
			offCanvas.height = 800;
			const offCtx = offCanvas.getContext('2d')!;

			for (let ri = 0; ri < savedRooms.length; ri++) {
				if (ri > 0) pdf.addPage('letter', 'landscape');

				const room = savedRooms[ri];
				const roomLabel = room.roomName || `Room ${ri + 1}`;

				const tempState: PlannerState = {
					roomName: room.roomName,
					displayUnit: state.displayUnit,
					editMode: false,
					camera: { centerX: 0, centerY: 0, pixelsPerInch: 2 },
					walls: JSON.parse(JSON.stringify(room.walls)),
					openings: JSON.parse(JSON.stringify(room.openings)),
					lockers: JSON.parse(JSON.stringify(room.lockers)),
					selection: null,
				};

				let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
				for (const w of tempState.walls) {
					minX = Math.min(minX, w.start.x, w.end.x);
					minY = Math.min(minY, w.start.y, w.end.y);
					maxX = Math.max(maxX, w.start.x, w.end.x);
					maxY = Math.max(maxY, w.start.y, w.end.y);
				}
				if (isFinite(minX)) {
					const worldW = maxX - minX || 100;
					const worldH = maxY - minY || 100;
					tempState.camera.pixelsPerInch = Math.min((offCanvas.width - 60) / worldW, (offCanvas.height - 60) / worldH);
					tempState.camera.centerX = (minX + maxX) / 2;
					tempState.camera.centerY = (minY + maxY) / 2;
				}

				offCtx.fillStyle = '#fff';
				offCtx.fillRect(0, 0, offCanvas.width, offCanvas.height);
				render(offCtx, tempState);

				const imgData = offCanvas.toDataURL('image/png');
				const imgW = pageW - margin * 2;
				const imgH = (offCanvas.height / offCanvas.width) * imgW;

				pdf.setFontSize(16);
				pdf.setFont('helvetica', 'bold');
				pdf.text(roomLabel, margin, margin);
				pdf.addImage(imgData, 'PNG', margin, margin + 10, imgW, Math.min(imgH, pageH - margin * 2 - 80));

				pdf.setFontSize(8);
				pdf.setFont('helvetica', 'italic');
				pdf.setTextColor(180);
				pdf.text('PlayerStall Room Planner — playerstall.com', pageW / 2, pageH - 20, { align: 'center' });
				pdf.setTextColor(0);
			}

			pdf.addPage('letter', 'portrait');
			const pW = pdf.internal.pageSize.getWidth();
			let y = margin;
			pdf.setFontSize(18);
			pdf.setFont('helvetica', 'bold');
			pdf.text('Order Summary', margin, y);
			y += 28;
			pdf.setFontSize(10);
			pdf.setFont('helvetica', 'normal');
			pdf.text(`Customer: ${customerEmail}`, margin, y);
			y += 20;

			let currentRoom = '';
			for (const line of allLines) {
				const room = line.roomName || 'Unnamed Room';
				if (room !== currentRoom) {
					currentRoom = room;
					y += 8;
					pdf.setFont('helvetica', 'bold');
					pdf.setFontSize(11);
					pdf.text(room, margin, y);
					y += 16;
					pdf.setFont('helvetica', 'normal');
					pdf.setFontSize(10);
				}
				const accText = line.accessories.length ? ` + ${line.accessories.map((a) => a.label).join(', ')}` : '';
				const lineText = `${line.qty}x ${line.displayName} (${line.widthIn}"W x ${line.depthIn}"D, ${line.colorLabel}${accText})`;
				const priceText = `$${(line.unitPrice * line.qty).toFixed(2)}`;
				pdf.text(lineText, margin, y);
				pdf.text(priceText, pW - margin, y, { align: 'right' });
				y += 14;
				if (y > pdf.internal.pageSize.getHeight() - 60) {
					pdf.addPage('letter', 'portrait');
					y = margin;
				}
			}

			y += 12;
			pdf.setDrawColor(200);
			pdf.line(margin, y, pW - margin, y);
			y += 18;
			pdf.setFontSize(13);
			pdf.setFont('helvetica', 'bold');
			pdf.text('Estimated Total', margin, y);
			pdf.text(`$${grandTotal.toFixed(2)}`, pW - margin, y, { align: 'right' });

			y += 30;
			pdf.setFontSize(8);
			pdf.setFont('helvetica', 'italic');
			pdf.setTextColor(150);
			pdf.text('This layout is an estimate. Final pricing may vary based on customization and installation requirements.', margin, y, { maxWidth: pW - margin * 2 });
			pdf.setTextColor(0);

			loadRoom(origIndex);

			return pdf.output('blob');
		} catch (e) {
			console.error('PDF generation failed:', e);
			return null;
		}
	}

	// ─── Request Quote → add to site cart ───
	document.getElementById('btn-request-quote')!.onclick = async () => {
		const allLines = (window as any).__plannerAllLines as LineItem[] | undefined;
		if (!allLines || allLines.length === 0) {
			alert('Add lockers to your room first.');
			return;
		}
		const cart = JSON.parse(localStorage.getItem('playerstall_cart') || '[]');

		for (const line of allLines) {
			const roomLabel = line.roomName ? `Room: ${line.roomName}` : 'Room Planner';
			const specParts = [`${line.widthIn}″W × ${line.depthIn}″D`, line.colorLabel];
			if (line.accessories.length) {
				for (const a of line.accessories) {
					specParts.push(`${a.label} (+$${a.price})`);
				}
			}
			const model = `${roomLabel} · ${specParts.join(' · ')}`;
			const id = `planner-${line.roomName}-${line.templateId}-${line.widthIn}-${line.depthIn}-${line.colorLabel}-${line.accessories.map((a) => a.label).join('-')}`;

			const existing = cart.find((item: any) => item.id === id);
			if (existing) {
				existing.quantity += line.qty;
			} else {
				cart.push({
					id,
					name: line.displayName,
					price: line.unitPrice,
					image: '/images/stadium-locker.png',
					quantity: line.qty,
					model,
				});
			}
		}

		localStorage.setItem('playerstall_cart', JSON.stringify(cart));
		const totalItems = cart.reduce((sum: number, item: any) => sum + item.quantity, 0);
		window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: totalItems } }));

		const customerEmail = (document.getElementById('customer-email') as HTMLInputElement).value.trim();
		if (!customerEmail) {
			alert('Please enter your email address so we can get in touch with you.');
			return;
		}

		let orderSummary = '';
		let currentRoom = '';
		for (const line of allLines) {
			const room = line.roomName || 'Unnamed Room';
			if (room !== currentRoom) {
				currentRoom = room;
				orderSummary += `\n--- ${room} ---\n`;
			}
			const accText = line.accessories.length ? ` + ${line.accessories.map((a: any) => a.label).join(', ')}` : '';
			orderSummary += `${line.qty}x ${line.displayName} (${line.widthIn}"W x ${line.depthIn}"D, ${line.colorLabel}${accText}) - $${(line.unitPrice * line.qty).toFixed(2)}\n`;
		}
		const grandTotal = allLines.reduce((sum: number, l: any) => sum + l.unitPrice * l.qty, 0);
		orderSummary += `\nEstimated Total: $${grandTotal.toFixed(2)}`;

		const statusMsg = document.getElementById('order-status-msg')!;
		const btn = document.getElementById('btn-request-quote') as HTMLButtonElement;
		btn.disabled = true;
		btn.textContent = 'Generating PDF...';

		const pdfBlob = await generateLayoutPDF(allLines, orderSummary, grandTotal, customerEmail);

		btn.textContent = 'Sending...';

		let pdfBase64: string | undefined;
		if (pdfBlob) {
			pdfBase64 = await new Promise<string>((resolve) => {
				const reader = new FileReader();
				reader.onloadend = () => {
					const dataUrl = reader.result as string;
					resolve(dataUrl.split(',')[1]);
				};
				reader.readAsDataURL(pdfBlob);
			});
		}

		fetch('/api/send-room-plan', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				email: customerEmail,
				orderSummary,
				grandTotal: grandTotal.toFixed(2),
				pdfBase64,
			}),
		}).then(async (res) => {
			if (res.ok) {
				statusMsg.textContent = 'Thank you! We just emailed your room plan to ' + customerEmail + '. Our team received a copy too and will be in touch shortly.';
				statusMsg.style.color = '#0d0d0d';
				btn.textContent = 'Sent!';
				if (pdfBlob) {
					const url = URL.createObjectURL(pdfBlob);
					const a = document.createElement('a');
					a.href = url;
					a.download = 'room-planner-layout.pdf';
					document.body.appendChild(a);
					a.click();
					a.remove();
					URL.revokeObjectURL(url);
				}
			} else {
				let detail = '';
				try { const j = await res.json(); detail = j.error || ''; } catch {}
				statusMsg.textContent = 'Something went wrong' + (detail ? ': ' + detail : '') + '. Please try again or email us directly at sales@playerstall.com.';
				statusMsg.style.color = '#fe5900';
				btn.disabled = false;
				btn.textContent = 'Get In Touch With Us';
			}
		}).catch(() => {
			statusMsg.textContent = 'Could not connect. Please check your internet and try again, or email us directly at sales@playerstall.com.';
			statusMsg.style.color = '#fe5900';
			btn.disabled = false;
			btn.textContent = 'Get In Touch With Us';
		});
	};

	// ─── Toolbar state ───
	function updateToolbar() {
		btnEdit.classList.toggle('active', state.editMode);
		const zoomPct = Math.round(state.camera.pixelsPerInch / 2 * 100);
		document.getElementById('zoom-label')!.textContent = `${zoomPct}%`;
	}

	// ─── Mobile tabs ───
	const columns = document.querySelector('.planner-columns') as HTMLElement;
	document.querySelectorAll('.mob-tab').forEach((tab) => {
		tab.addEventListener('click', () => {
			document.querySelectorAll('.mob-tab').forEach((t) => t.classList.remove('active'));
			tab.classList.add('active');
			columns.dataset.activePanel = (tab as HTMLElement).dataset.panel!;
			if ((tab as HTMLElement).dataset.panel === 'canvas') {
				redraw();
			}
		});
	});

	// ─── Init ───
	savedRooms.push(snapshotCurrentRoom());
	renderRoomTabs();
	window.addEventListener('resize', () => redraw());
	requestAnimationFrame(() => {
		zoomFit();
		redraw();
	});
</script>
