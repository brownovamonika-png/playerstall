	// ─── Zoom ───
	const ZOOM_MIN = 0.15;
	const ZOOM_MAX = 20;

	function zoomBy(factor: number) {
		state.camera.pixelsPerInch = Math.max(ZOOM_MIN, Math.min(ZOOM_MAX, state.camera.pixelsPerInch * factor));
		redraw();
	}
	function zoomFit() {
		const cw = canvas.clientWidth;
		const ch = canvas.clientHeight;
		let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
		for (const w of state.walls) {
			minX = Math.min(minX, w.start.x, w.end.x);
			minY = Math.min(minY, w.start.y, w.end.y);
			maxX = Math.max(maxX, w.start.x, w.end.x);
			maxY = Math.max(maxY, w.start.y, w.end.y);
		}
		if (!isFinite(minX)) return;
		const worldW = maxX - minX || 100;
		const worldH = maxY - minY || 100;
		const pad = 24;
		state.camera.pixelsPerInch = Math.min((cw - pad) / worldW, (ch - pad) / worldH);
		state.camera.centerX = (minX + maxX) / 2;
		state.camera.centerY = (minY + maxY) / 2;
		redraw();
	}

