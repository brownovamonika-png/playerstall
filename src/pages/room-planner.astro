	document.getElementById('lt-add-btn')!.onclick = () => {
		const t = getTemplate(ltModel.value);
		if (!t) return;
		const qty = Math.max(1, parseInt(ltQty.value, 10) || 1);
		const widthIn = parseInt(ltWidth.value, 10) || t.geometry.defaultWidthIn;
		const depthIn = t.geometry.depthOptionsIn.length > 1
			? (parseInt(ltDepth.value, 10) || t.geometry.defaultDepthIn)
			: t.geometry.defaultDepthIn;
		const colorCode = ltColor.value || t.colors[0].code;
		const accessoryIds = getSelectedAccessoryIds();

		const cx = state.camera.centerX - widthIn / 2;
		const cy = state.camera.centerY - depthIn / 2;
		let lastId: string | null = null;

		for (let n = 0; n < qty; n++) {
			let placed = false;
			for (let ring = 0; ring < 60 && !placed; ring++) {
				const step = ring * Math.max(widthIn, depthIn);
				const spots = ring === 0
					? [{ dx: 0, dy: 0 }]
					: [
						{ dx: step, dy: 0 }, { dx: -step, dy: 0 },
						{ dx: 0, dy: step }, { dx: 0, dy: -step },
						{ dx: step, dy: step }, { dx: -step, dy: step },
						{ dx: step, dy: -step }, { dx: -step, dy: -step },
					];
				for (const { dx, dy } of spots) {
					const inst: LockerInstance = {
						instanceId: nextInstanceId(),
						templateId: t.templateId,
						config: { widthIn, depthIn, colorCode, accessoryIds: [...accessoryIds] },
						x: cx + dx, y: cy + dy, rotationDeg: 0,
					};
					if (!wouldOverlap(inst, state.lockers, state.openings, state.walls)) {
						state.lockers.push(inst);
						lastId = inst.instanceId;
						placed = true;
						break;
					}
				}
			}
		}

		if (lastId) state.selection = { type: 'locker', id: lastId };
		redraw();
	};

	// ─── Redraw ───
	const canvasHint = document.getElementById('canvas-empty-hint');
	function adjustLockerPosition(locker: any, oldWidthIn: number, oldDepthIn: number) {
		const isRotated = locker.rotationDeg === 90 || locker.rotationDeg === 270;
		const oldW = isRotated ? oldDepthIn : oldWidthIn;
		const oldD = isRotated ? oldWidthIn : oldDepthIn;
		const newW = isRotated ? locker.config.depthIn : locker.config.widthIn;
		const newD = isRotated ? locker.config.widthIn : locker.config.depthIn;

		const roomMinX = Math.min(...state.walls.map((w: any) => Math.min(w.start.x, w.end.x)));
		const roomMaxX = Math.max(...state.walls.map((w: any) => Math.max(w.start.x, w.end.x)));
		const roomMinY = Math.min(...state.walls.map((w: any) => Math.min(w.start.y, w.end.y)));
		const roomMaxY = Math.max(...state.walls.map((w: any) => Math.max(w.start.y, w.end.y)));
		const roomCenterX = (roomMinX + roomMaxX) / 2;
		const roomCenterY = (roomMinY + roomMaxY) / 2;

		if (newW !== oldW) {
			if (locker.x + oldW / 2 > roomCenterX) locker.x += oldW - newW;
		}
		if (newD !== oldD) {
			if (locker.y + oldD / 2 > roomCenterY) locker.y += oldD - newD;
		}
	}

	function updateCornerNotice() {
		const status = document.getElementById('corner-status')!;
		if (state.lockers.length === 0) {
			status.className = 'corner-status';
			return;
		}
		const occupied = getWallsWithLockers(state.walls, state.lockers);
		if (occupied.size === 0) {
			status.className = 'corner-status';
			return;
		}

		const corners: string[] = [];
		for (let i = 0; i < state.walls.length; i++) {
			const curr = state.walls[i];
			const next = state.walls[(i + 1) % state.walls.length];
			if (occupied.has(curr.id) && occupied.has(next.id)) {
				corners.push(curr.id + ' & ' + next.id);
			}
		}

		if (corners.length > 0) {
			status.className = 'corner-status active';
			status.innerHTML = '\u26A0 <strong>Right now:</strong> Corner clearance is active at ' + corners.join(', ') + ' because lockers are on both connecting walls.';
		} else {
			status.className = 'corner-status clear';
			const wallList = Array.from(occupied).join(', ');
			status.innerHTML = '\u2713 <strong>Right now:</strong> No corner clearance needed \u2014 your lockers are on ' + wallList + ' only.';
		}
	}

	let placementMode: { wallId: string; type: 'door' | 'window' | 'obstacle' } | null = null;

	function redraw() {
		render(ctx, state);
		if (placementMode) drawWallHighlight(ctx, state, placementMode.wallId);
		updateLayers();
		updateProperties();
		updateOrderSummary();
		updateToolbar();
		updateCornerNotice();
		const hasRoom = state.walls.some((w) => wallLength(w) > 0);
		if (canvasHint) canvasHint.style.display = hasRoom ? 'none' : '';
	}

	// ─── Zoom ───
	const ZOOM_MIN = 0.15;
	const ZOOM_MAX = 20;

	function zoomBy(factor: number) {
		state.camera.pixelsPerInch = Math.max(ZOOM_MIN, Math.min(ZOOM_MAX, state.camera.pixelsPerInch * factor));
		redraw();
	}
	function zoomFit() {
		const cw = canvas.clientWidth;
		const ch = canvas.clientHeight;
		let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
		for (const w of state.walls) {
			minX = Math.min(minX, w.start.x, w.end.x);
			minY = Math.min(minY, w.start.y, w.end.y);
			maxX = Math.max(maxX, w.start.x, w.end.x);
			maxY = Math.max(maxY, w.start.y, w.end.y);
		}
		if (!isFinite(minX)) return;
		const worldW = maxX - minX || 100;
		const worldH = maxY - minY || 100;
		const pad = 24;
		state.camera.pixelsPerInch = Math.min((cw - pad) / worldW, (ch - pad) / worldH);
		state.camera.centerX = (minX + maxX) / 2;
		state.camera.centerY = (minY + maxY) / 2;
		redraw();
	}

	document.getElementById('btn-zoom-in')!.onclick = () => zoomBy(1.25);
	document.getElementById('btn-zoom-out')!.onclick = () => zoomBy(0.8);
	document.getElementById('btn-zoom-fit')!.onclick = () => zoomFit();

	canvas.addEventListener('wheel', (e) => {
