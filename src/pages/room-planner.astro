---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Room Planner | Design Your Locker Room | PlayerStall"
	description="Interactive locker room planner. Draw walls, place lockers, configure options and pricing in real time. Free tool to design your space today."
>
	<section class="planner-hero">
		<div class="planner-hero-inner">
			<span class="planner-hero-subtitle">Free Online Tool</span>
			<h1>Locker Room Planner</h1>
			<p>Plan your perfect locker room in three simple steps. No account required. Just enter your room dimensions, add lockers, and request a quote when you're done.</p>
			<div class="hero-steps">
				<div class="hero-step">
					<span class="hero-step-num">1</span>
					<span class="hero-step-text">Enter your room size</span>
				</div>
				<div class="hero-step-arrow">→</div>
				<div class="hero-step">
					<span class="hero-step-num">2</span>
					<span class="hero-step-text">Add & arrange lockers</span>
				</div>
				<div class="hero-step-arrow">→</div>
				<div class="hero-step">
					<span class="hero-step-num">3</span>
					<span class="hero-step-text">Review & send to us</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Room setup -->
	<section class="room-setup" id="room-setup">
		<div class="room-setup-columns">
			<div class="room-setup-left">
				<div class="room-tabs-row" id="room-tabs-bar">
					<div class="room-tabs-list" id="room-tabs-list">
						<button type="button" class="room-tab active" data-room-idx="0">Room 1</button>
					</div>
					<button type="button" class="room-tab-add" id="btn-add-room">+ Add Room</button>
				</div>
				<span class="step-badge">Step 1</span>
				<h2 class="room-setup-title">Room Dimensions</h2>
				<p class="room-setup-desc">Measure your locker room and enter the length of each wall below. If a wall has a door or window, click the button under that wall to mark it so lockers won't be placed in those areas.</p>

				<div class="room-name-row">
					<label for="room-name" class="room-name-label">Name this room</label>
					<input type="text" id="room-name" class="room-name-input" placeholder="e.g. Home Locker Room, Visitors, Training Room…" maxlength="80" />
				</div>
				<p class="room-setup-hint">Tip: Give each room a name so you can tell them apart in your quote.</p>

				<div class="wall-cards">
				<!-- Wall A -->
				<div class="wall-card" data-wall="a">
					<div class="wall-card-header">
						<span class="wall-card-label">Wall A <span class="wall-card-side">(top)</span></span>
						<div class="wall-dim-pair">
							<input type="number" id="dim-wall-a-ft" class="room-dim-input dim-ft" placeholder="ft" min="0" step="1" />
							<span class="room-dim-unit">ft</span>
							<input type="number" id="dim-wall-a-in" class="room-dim-input dim-in" placeholder="in" min="0" max="11" step="1" />
							<span class="room-dim-unit">in</span>
						</div>
					</div>
					<div class="wall-openings-list" id="openings-wall-a"></div>
					<div class="wall-card-actions">
						<button type="button" class="wall-add-btn" data-wall-id="Wall A" data-type="door">+ Door</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall A" data-type="window">+ Window</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall A" data-type="obstacle">+ Obstacle</button>
					</div>
				</div>

				<!-- Wall B -->
				<div class="wall-card" data-wall="b">
					<div class="wall-card-header">
						<span class="wall-card-label">Wall B <span class="wall-card-side">(right)</span></span>
						<div class="wall-dim-pair">
							<input type="number" id="dim-wall-b-ft" class="room-dim-input dim-ft" placeholder="ft" min="0" step="1" />
							<span class="room-dim-unit">ft</span>
							<input type="number" id="dim-wall-b-in" class="room-dim-input dim-in" placeholder="in" min="0" max="11" step="1" />
							<span class="room-dim-unit">in</span>
						</div>
					</div>
					<div class="wall-openings-list" id="openings-wall-b"></div>
					<div class="wall-card-actions">
						<button type="button" class="wall-add-btn" data-wall-id="Wall B" data-type="door">+ Door</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall B" data-type="window">+ Window</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall B" data-type="obstacle">+ Obstacle</button>
					</div>
				</div>

				<!-- Wall C -->
				<div class="wall-card" data-wall="c">
					<div class="wall-card-header">
						<span class="wall-card-label">Wall C <span class="wall-card-side">(bottom)</span></span>
						<div class="wall-dim-pair">
							<input type="number" id="dim-wall-c-ft" class="room-dim-input dim-ft" placeholder="ft" min="0" step="1" />
							<span class="room-dim-unit">ft</span>
							<input type="number" id="dim-wall-c-in" class="room-dim-input dim-in" placeholder="in" min="0" max="11" step="1" />
							<span class="room-dim-unit">in</span>
						</div>
					</div>
					<div class="wall-openings-list" id="openings-wall-c"></div>
					<div class="wall-card-actions">
						<button type="button" class="wall-add-btn" data-wall-id="Wall C" data-type="door">+ Door</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall C" data-type="window">+ Window</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall C" data-type="obstacle">+ Obstacle</button>
					</div>
				</div>

				<!-- Wall D -->
				<div class="wall-card" data-wall="d">
					<div class="wall-card-header">
						<span class="wall-card-label">Wall D <span class="wall-card-side">(left)</span></span>
						<div class="wall-dim-pair">
							<input type="number" id="dim-wall-d-ft" class="room-dim-input dim-ft" placeholder="ft" min="0" step="1" />
							<span class="room-dim-unit">ft</span>
							<input type="number" id="dim-wall-d-in" class="room-dim-input dim-in" placeholder="in" min="0" max="11" step="1" />
							<span class="room-dim-unit">in</span>
						</div>
					</div>
					<div class="wall-openings-list" id="openings-wall-d"></div>
					<div class="wall-card-actions">
						<button type="button" class="wall-add-btn" data-wall-id="Wall D" data-type="door">+ Door</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall D" data-type="window">+ Window</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall D" data-type="obstacle">+ Obstacle</button>
					</div>
				</div>
			</div>

			<div class="room-btn-row">
				<button type="button" class="room-apply-btn" id="btn-apply-room">Draw My Room</button>
				<button type="button" class="room-reset-btn" id="btn-reset-room">Clear & Start Over</button>
			</div>

			<!-- Locker type selector -->
			<div class="locker-type-section" id="locker-type-section">
				<span class="step-badge">Step 2</span>
				<h2 class="room-setup-title">Add Lockers</h2>
				<p class="room-setup-desc">Pick a locker model, choose your size, color, and any accessories. Set the quantity and click Add. They'll appear on the layout below where you can drag them into position.</p>
				<div class="lt-with-preview">
					<div class="lt-preview" id="lt-preview">
						<img id="lt-preview-img" src="/images/model-s-locker-profile.png" alt="Locker preview" />
					</div>
					<div class="lt-config">
						<div class="lt-row">
							<div class="lt-field">
								<label>Model</label>
								<select id="lt-model"></select>
							</div>
							<div class="lt-field">
								<label>Width</label>
								<select id="lt-width"></select>
							</div>
							<div class="lt-field" id="lt-depth-field">
								<label>Depth</label>
								<select id="lt-depth"></select>
							</div>
							<div class="lt-field">
								<label>Color</label>
								<select id="lt-color"></select>
							</div>
							<div class="lt-field lt-field-qty">
								<label>Qty</label>
								<input type="number" id="lt-qty" value="1" min="1" max="100" step="1" />
							</div>
							<div class="lt-field lt-field-btn">
								<label>&nbsp;</label>
								<button type="button" class="lt-add-btn" id="lt-add-btn" style="margin-left:16px">Add to Layout</button>
							</div>
							<span class="lt-price" id="lt-price"></span>
						</div>
						<div class="lt-accessories-row" id="lt-accessories-row">
							<label class="lt-acc-label">Accessories</label>
							<div class="lt-acc-list" id="lt-acc-list"></div>
						</div>
					</div>
				</div>
			</div>
			</div>
		</div>
	</section>

	<section class="planner-app" id="planner-app">
		<!-- Toolbar -->
		<div class="planner-toolbar" id="planner-toolbar">
			<!-- Hidden: toolbar-left kept in DOM for JS bindings but not shown -->
			<div class="toolbar-left" style="display:none">
				<button type="button" class="tb-btn" id="btn-edit-mode" title="Switch to Edit mode to click and drag lockers into position">
					<span class="tb-icon">✎</span> Edit
				</button>
				<div class="tb-locker-group">
					<select id="locker-model-select" class="tb-model-select" title="Locker model"></select>
					<button type="button" class="tb-btn" id="btn-add-locker" title="Place locker(s) on the layout from the selected model">
						+ Locker
					</button>
					<input type="number" id="locker-qty" class="tb-qty" value="1" min="1" max="100" step="1" title="Quantity" />
				</div>
				<button type="button" class="tb-btn" id="btn-add-door" title="Add a door. Select a wall on the canvas or in Layers first.">
					+ Door
				</button>
				<button type="button" class="tb-btn" id="btn-add-window" title="Add a window. Select a wall on the canvas or in Layers first.">
					+ Window
				</button>
				<button type="button" class="tb-btn" id="btn-rotate-locker" title="Rotate selected locker 90°">
					Rotate
				</button>
				<button type="button" class="tb-btn tb-reset" id="btn-reset-lockers" title="Remove all lockers">
					Reset Lockers
				</button>
			</div>
			<div class="toolbar-center">
				<button type="button" class="tb-btn tb-sm" id="btn-zoom-out" title="Zoom out">−</button>
				<span class="tb-zoom-label" id="zoom-label">100%</span>
				<button type="button" class="tb-btn tb-sm" id="btn-zoom-in" title="Zoom in">+</button>
				<button type="button" class="tb-btn tb-sm" id="btn-zoom-fit" title="Fit room">⊞</button>
				<span class="tb-divider"></span>
				<button type="button" class="tb-btn tb-sm" id="btn-rotate-visible" title="Rotate selected locker 90°">↻</button>
				<span class="tb-divider"></span>
				<button type="button" class="tb-btn tb-3d" id="btn-view-3d" title="Preview your room in 3D">3D View</button>
			</div>
			<div class="toolbar-right">
				<select id="unit-select" class="tb-select" title="Display unit">
					<option value="in">Inches</option>
					<option value="ft">Feet</option>
					<option value="cm">cm</option>
					<option value="mm">mm</option>
				</select>
			</div>
		</div>

		<!-- Corner clearance guide -->
		<div class="corner-guide" id="corner-guide">
			<div class="corner-guide-header">
				<span class="corner-guide-title">Corner Clearance Guide</span>
			</div>
			<div class="corner-guide-rules">
				<div class="corner-rule corner-rule-warn">
					<span class="corner-rule-icon">&#9888;</span>
					<div>
						<strong>Lockers on two connecting walls?</strong><br />
						(e.g. Wall&nbsp;A + Wall&nbsp;B) &mdash; A 30&Prime; corner clearance is automatically reserved where the walls meet so the lockers don&rsquo;t overlap at the corner.
					</div>
				</div>
				<div class="corner-rule corner-rule-ok">
					<span class="corner-rule-icon">&#10003;</span>
					<div>
						<strong>Lockers on only one wall?</strong><br />
						No corner clearance is needed &mdash; you can use the full wall length for lockers.
					</div>
				</div>
			</div>
			<div class="corner-status" id="corner-status"></div>
		</div>

		<!-- Main 3-column layout -->
		<div class="planner-columns">
			<!-- LEFT: Layers + Selection Config -->
			<aside class="planner-layers" id="planner-layers">
				<h3 class="panel-heading">Layers</h3>
				<p class="layers-hint" id="layers-hint">This panel lists every item in your room: walls, doors, windows, and lockers. Click any item to select it on the canvas, then you can edit its size, color, or position. As you add lockers they will appear here.</p>
				<ul class="layers-list" id="layers-list">
					<!-- populated by JS -->
				</ul>

				<!-- Selection config (shown when something is selected) -->
				<div class="selection-config" id="selection-config" style="display:none;">
					<div class="sel-config-header">
						<span class="sel-config-title" id="sel-config-title">Selection</span>
						<button type="button" class="sel-config-close" id="sel-config-close" title="Close">&times;</button>
					</div>
					<div class="props-locker" id="props-locker" style="display:none;">
						<div class="prop-row">
							<label class="prop-label">Model</label>
							<span class="prop-value" id="prop-model-name"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">Width</label>
							<div class="prop-swatches" id="prop-width-options"></div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Depth</label>
							<div class="prop-swatches" id="prop-depth-options"></div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Color</label>
							<select id="prop-color-select" class="prop-select"></select>
						</div>
						<div class="prop-row">
							<label class="prop-label">Accessories</label>
							<div class="prop-accessories" id="prop-accessories"></div>
						</div>
						<div class="prop-row prop-price-row">
							<label class="prop-label">Unit Price</label>
							<span class="prop-price" id="prop-price">$0</span>
						</div>
						<div class="prop-row">
							<button type="button" class="tb-btn prop-rotate-btn" id="prop-rotate-locker">Rotate 90°</button>
							<button type="button" class="tb-btn prop-delete-btn" id="prop-delete-locker">Delete</button>
						</div>
					</div>
					<div class="props-wall" id="props-wall" style="display:none;">
						<div class="prop-row">
							<label class="prop-label">Wall</label>
							<span class="prop-value" id="prop-wall-id"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">Length</label>
							<div class="prop-input-row">
								<input type="number" id="prop-wall-length" class="prop-input" step="1" min="24" />
								<span class="prop-input-unit" id="prop-wall-length-unit">″</span>
							</div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Thickness</label>
							<div class="prop-input-row">
								<input type="number" id="prop-wall-thickness" class="prop-input" step="0.5" min="1" />
								<span class="prop-input-unit">″</span>
							</div>
						</div>
						<button type="button" class="tb-btn fill-wall-btn" id="btn-fill-wall">Fill with lockers</button>
					</div>
					<div class="props-opening" id="props-opening" style="display:none;">
						<div class="prop-row">
							<label class="prop-label">Type</label>
							<span class="prop-value" id="prop-opening-type"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">On wall</label>
							<span class="prop-value" id="prop-opening-wall"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">Width</label>
							<div class="prop-input-row">
								<input type="number" id="prop-opening-width" class="prop-input" step="1" min="12" />
								<span class="prop-input-unit">″</span>
							</div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Offset from start</label>
							<div class="prop-input-row">
								<input type="number" id="prop-opening-offset" class="prop-input" step="1" min="0" />
								<span class="prop-input-unit">″</span>
							</div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Clearance</label>
							<div class="prop-input-row">
								<input type="number" id="prop-opening-clearance" class="prop-input" step="1" min="0" />
								<span class="prop-input-unit">″</span>
							</div>
						</div>
						<button type="button" class="tb-btn delete-opening-btn" id="btn-delete-opening">Delete opening</button>
					</div>
				</div>
			</aside>

			<!-- CENTER: Canvas -->
			<div class="planner-canvas-wrap" id="planner-canvas-wrap">
				<div class="placement-tooltip" id="placement-tooltip" style="display:none">
					<span class="placement-tooltip-icon">&#9678;</span>
					<span class="placement-tooltip-text" id="placement-tooltip-text">Click on the wall to place</span>
					<button type="button" class="placement-tooltip-cancel" id="placement-cancel">&times; Cancel</button>
				</div>
				<canvas id="planner-canvas"></canvas>
				<div class="canvas-empty-hint" id="canvas-empty-hint">
					<div class="canvas-hint-icon">⊞</div>
					<div class="canvas-hint-title">Your layout will appear here</div>
					<div class="canvas-hint-body">Enter your room dimensions above and click <strong>Draw My Room</strong> to create the walls. Then add lockers. You can drag them around the canvas, double-click to rotate, and they'll snap together automatically.</div>
				</div>
			</div>

		</div>

		<!-- Mobile tab bar -->
		<nav class="planner-mobile-tabs" id="planner-mobile-tabs">
			<button type="button" class="mob-tab active" data-panel="canvas">Plan</button>
			<button type="button" class="mob-tab" data-panel="layers">Layers</button>
		</nav>
	</section>

	<!-- 3D Preview Modal -->
	<div class="view3d-overlay" id="view3d-overlay">
		<div class="view3d-header">
			<span class="view3d-title">3D Preview</span>
			<div class="view3d-controls">
				<button type="button" class="view3d-btn view3d-rotate-btn" id="btn-3d-rotate" title="Rotate selected locker 90°">↻ Rotate</button>
				<button type="button" class="view3d-btn" id="btn-3d-reset">Reset View</button>
				<button type="button" class="view3d-close" id="btn-3d-close">&times;</button>
			</div>
		</div>
		<canvas id="view3d-canvas"></canvas>
		<div class="view3d-hint">Drag background to orbit &middot; Click locker to select &middot; Drag locker to move &middot; Double-click or press R to rotate</div>
	</div>

	<!-- Order summary (below designer) -->
	<section class="order-section" id="order-section">
		<div class="order-section-header">
			<span class="step-badge">Step 3</span>
			<h2 class="room-setup-title" style="text-align:center;">Review Your Layout</h2>
			<p class="room-setup-desc" style="text-align:center; margin-bottom:30px;">Here's everything you've configured across all your rooms. When you're happy with the layout, send it to your cart or email it to us and we'll help you bring it to life.</p>
		</div>
		<div class="order-section-inner">
			<div class="order-panel" id="order-panel">
				<h3 class="order-panel-title">Order Summary</h3>
				<div class="order-room-name" id="order-room-name"></div>
				<table class="order-table">
					<thead>
						<tr>
							<th class="ot-product">Product</th>
							<th class="ot-qty">Qty</th>
							<th class="ot-total">Subtotal</th>
						</tr>
					</thead>
					<tbody id="order-items-body">
						<tr><td colspan="3" class="ot-empty">No lockers placed yet. Add lockers above to see your order here.</td></tr>
					</tbody>
					<tfoot>
						<tr class="ot-subtotal-row">
							<th colspan="2">Subtotal</th>
							<td id="order-subtotal">$0.00</td>
						</tr>
						<tr class="ot-total-row">
							<th colspan="2">Estimated Total</th>
							<td id="order-total"><strong>$0.00</strong></td>
						</tr>
					</tfoot>
				</table>
				<div class="order-locker-count" id="order-locker-count">0 lockers</div>
				<div class="order-email-row">
					<label class="order-email-label" for="customer-email">Your email</label>
					<input type="email" id="customer-email" class="order-email-input" placeholder="you@example.com" required />
				</div>
				<button type="button" class="order-request-btn" id="btn-request-quote">Get In Touch With Us</button>
				<p class="order-disclaimer" id="order-status-msg">We'll send a copy of your layout to your email and to our team so we can help you execute on your dream locker room.</p>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.planner-hero {
		background: #ffffff;
		color: #0d0d0d;
		padding: 80px 20px 40px;
		text-align: center;
	}
	.planner-hero-subtitle {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 6px;
		text-transform: uppercase;
		color: #8c8c8c;
		margin-bottom: 12px;
	}
	.planner-hero h1 {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(32px, 4vw, 52px);
		font-weight: 700;
		margin: 0;
		text-transform: uppercase;
		color: #0d0d0d;
		line-height: 1.1;
		letter-spacing: 2px;
	}
	.planner-hero p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		margin: 14px auto 0;
		color: #8c8c8c;
		max-width: 600px;
		line-height: 1.6;
	}

	.hero-steps {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
		margin-top: 32px;
	}
	.hero-step {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.hero-step-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: #0d0d0d;
		color: #fff;
		font-family: 'Oswald', sans-serif;
