		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2px;
		cursor: pointer;
		transition: background 0.3s;
	}
	.room-apply-btn:hover { background: #e04d00; }
	.room-reset-btn {
		background: transparent;
		color: #8c8c8c;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 14px 28px;
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2px;
		cursor: pointer;
		transition: all 0.3s;
	}
	.room-reset-btn:hover { border-color: #0d0d0d; color: #0d0d0d; }
	.locker-type-section {
		margin-top: 40px;
	}
	.step-badge {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: #fe5900;
		margin-bottom: 6px;
		text-align: center;
	}
	.section-divider {
		height: 1px;
		background: #e0e0e0;
		margin: 32px -20px 24px;
		width: calc(100% + 40px);
	}

	/* Locker type selection */
	.lt-with-preview {
		display: flex;
		gap: 24px;
		align-items: flex-start;
	}
	.lt-preview {
		flex: 0 0 140px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #f7f7f7;
		border: 1px solid #e0e0e0;
		padding: 10px;
		min-height: 120px;
	}
	.lt-preview img {
		max-width: 100%;
		max-height: 110px;
		object-fit: contain;
	}
	.lt-config {
		flex: 1;
		min-width: 0;
	}
	@media (max-width: 768px) {
		.lt-with-preview { flex-direction: column; }
		.lt-preview { flex: none; width: 100%; max-width: 160px; margin: 0 auto; }
	}
	.lt-row {
		display: flex;
		align-items: flex-end;
		gap: 16px;
		flex-wrap: nowrap;
	}
	.lt-field {
		display: flex;
		flex-direction: column;
		gap: 4px;
		flex: 1;
		min-width: 0;
	}
	.lt-field.lt-field-qty {
		flex: 0 0 70px;
	}
	.lt-field.lt-field-btn {
		flex: 0 0 auto;
	}
	.lt-field label {
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 1px;
	}
	.lt-field select, .lt-field input {
		background: #f7f7f7;
		color: #0d0d0d;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 8px 10px;
		font-size: 13px;
		width: 100%;
		font-family: 'Yantramanav', sans-serif;
		transition: border-color 0.3s;
	}
	.lt-field select:focus, .lt-field input:focus {
		border-color: #fe5900;
		outline: none;
	}
	.lt-field input[type="number"] { text-align: center; }
	.lt-field-btn { justify-content: flex-end; }
	.lt-add-btn {
		background: #fe5900;
		color: #fff;
		border: none;
		border-radius: 0;
		padding: 10px 24px;
		margin-left: 16px;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2px;
		cursor: pointer;
		white-space: nowrap;
	}
	.lt-add-btn:hover { background: #e04d00; }
	.lt-price {
		font-family: 'Oswald', sans-serif;
		font-size: 15px;
		font-weight: 600;
		color: #fe5900;
		align-self: flex-end;
		padding-bottom: 8px;
		white-space: nowrap;
	}
	:global(.lt-accessories-row) {
		margin-top: 18px;
		margin-bottom: 10px;
		display: flex;
		align-items: center;
		flex-wrap: nowrap;
		border: none;
		background: none;
		padding: 0;
	}
	:global(.lt-acc-label) {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #b6b6b6;
		letter-spacing: 0.5px;
		white-space: nowrap;
		margin-right: 10px;
		flex-shrink: 0;
	}
	:global(.lt-acc-list) {
		display: flex;
		flex-wrap: nowrap;
		flex: 1;
		justify-content: space-between;
	}
	:global(.lt-acc-list label) {
		display: flex;
		align-items: center;
		gap: 4px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		white-space: nowrap;
		padding: 0;
		cursor: pointer;
		transition: color 0.15s;
	}
	:global(.lt-acc-list label:hover) { color: #0d0d0d; }
	:global(.lt-acc-list input[type="checkbox"]) { accent-color: #fe5900; width: 12px; height: 12px; }

	.planner-app {
		display: flex;
		flex-direction: column;
		height: calc(100vh - 90px);
		min-height: 620px;
		background: #f0f0f0;
	}

	/* Corner clearance guide */
	.corner-guide {
		background: #fff;
		border: 1px solid #e8e8e8;
		border-radius: 10px;
		margin: 0 12px 12px;
		overflow: hidden;
		box-shadow: 0 1px 4px rgba(0,0,0,0.04);
	}
	.corner-guide-header {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 10px 16px;
		border-bottom: 1px solid #f0f0f0;
	}
	.corner-guide-icon {
		width: 20px;
		height: 20px;
		color: #fe5900;
		flex-shrink: 0;
	}
	.corner-guide-title {
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: #333;
	}
	.corner-guide-body {
		display: flex;
		gap: 0;
	}
	.corner-rule {
		flex: 1;
		display: flex;
		align-items: flex-start;
		gap: 12px;
		padding: 14px 16px;
	}
	.corner-rule + .corner-rule { border-left: 1px solid #f0f0f0; }
	.corner-rule strong {
		font-family: 'Oswald', sans-serif;
		font-size: 12.5px;
		font-weight: 600;
		letter-spacing: 0.3px;
		text-transform: uppercase;
		color: #333;
		display: block;
		margin-bottom: 3px;
	}
	.corner-rule-detail {
		display: block;
		font-size: 12px;
		line-height: 1.55;
		color: #777;
	}
	.corner-rule-badge {
		flex-shrink: 0;
		width: 36px;
		height: 36px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		font-size: 13px;
		line-height: 1;
	}
	.corner-rule-warn .corner-rule-badge {
		background: rgba(255, 89, 0, 0.09);
		color: #d35400;
	}
	.corner-rule-ok .corner-rule-badge {
		background: rgba(0, 128, 80, 0.08);
		color: #1a8a52;
		font-size: 16px;
	}
	.corner-status {
		padding: 10px 16px;
		font-size: 12px;
		font-weight: 500;
		border-top: 1px solid #f0f0f0;
		display: none;
		line-height: 1.5;
	}
	.corner-status.active {
		display: block;
		background: rgba(255, 89, 0, 0.05);
		color: #b84400;
	}
	.corner-status.clear {
		display: block;
		background: rgba(0, 128, 80, 0.04);
		color: #1a6b45;
	}
	@media (max-width: 640px) {
		.corner-guide-body { flex-direction: column; }
		.corner-rule + .corner-rule { border-left: none; border-top: 1px solid #f0f0f0; }
	}
	@media (max-width: 640px) {
		.corner-guide-rules { flex-direction: column; }
		.corner-rule { border-right: none; border-bottom: 1px solid #e0e0e0; }
		.corner-rule:last-child { border-bottom: none; }
	}

	/* Toolbar */
	.planner-toolbar {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 8px 16px;
		background: #0d0d0d;
		color: #fff;
		gap: 10px;
		flex-shrink: 0;
		position: relative;
	}
	.toolbar-left, .toolbar-center, .toolbar-right {
		display: flex;
		align-items: center;
		gap: 6px;
	}
	.toolbar-right {
		position: absolute;
		right: 16px;
	}
	.tb-btn {
		background: transparent;
		color: #ccc;
		border: 1px solid #444;
		border-radius: 0;
		padding: 6px 14px;
		font-size: 12px;
		cursor: pointer;
		font-family: 'Yantramanav', sans-serif;
		white-space: nowrap;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		transition: all 0.2s;
	}
	.tb-btn:hover { background: #333; color: #fff; }
	.tb-rotate { background: #fe5900; border-color: #fe5900; color: #fff; font-weight: 600; }
	.tb-rotate:hover { background: #e04f00; border-color: #e04f00; color: #fff; }
	.tb-reset { background: transparent; border-color: #fe5900; color: #fe5900; }
	.tb-reset:hover { background: #fe5900; color: #fff; }
	.tb-btn.active { background: #fe5900; border-color: #fe5900; color: #fff; }
	.tb-locker-group { display: flex; align-items: center; gap: 0; }
	.tb-model-select {
		background: #1a1a1a;
		color: #ccc;
		border: 1px solid #444;
		border-radius: 0;
		padding: 6px 8px;
		font-size: 12px;
		font-family: 'Yantramanav', sans-serif;
		cursor: pointer;
	}
	.tb-model-select:focus { outline: none; border-color: #fe5900; }
	.tb-locker-group .tb-btn { border-radius: 0; border-left: none; }
	.tb-qty {
		width: 42px;
		background: #1a1a1a;
		color: #ccc;
		border: 1px solid #444;
		border-left: none;
		border-radius: 0;
		padding: 6px 4px;
		font-size: 13px;
		text-align: center;
		font-family: 'Yantramanav', sans-serif;
	}
	.tb-qty:focus { outline: none; border-color: #fe5900; }
	.tb-sm { padding: 6px 8px; }
	.tb-zoom-label { font-size: 12px; min-width: 44px; text-align: center; }
	.tb-divider { width: 1px; height: 18px; background: #444; margin: 0 4px; }
	.tb-select {
		background: #1a1a1a;
		color: #ccc;
		border: 1px solid #444;
		border-radius: 0;
		padding: 5px 8px;
		font-size: 13px;
	}

	/* 3-column layout */
	.planner-columns {
		display: flex;
		flex: 1;
		overflow: hidden;
	}

	/* Layers + Config (left) */
	.planner-layers {
		width: 210px;
		min-width: 180px;
		background: #f7f7f7;
		color: #0d0d0d;
		overflow-y: auto;
		flex-shrink: 0;
		border-right: 1px solid #e0e0e0;
		display: flex;
		flex-direction: column;
	}
	.panel-heading {
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2px;
		padding: 14px 16px 8px;
		margin: 0;
		color: #8c8c8c;
	}
	.layers-hint {
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		color: #b6b6b6;
		padding: 0 16px 8px;
		margin: 0;
		line-height: 1.4;
	}
	.layers-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.layers-list li {
		padding: 8px 16px;
		font-size: 13px;
		cursor: pointer;
		border-bottom: 1px solid #e0e0e0;
		font-family: 'Yantramanav', sans-serif;
		display: flex;
		align-items: center;
		gap: 8px;
		transition: background 0.15s;
	}
	.layers-list li:hover { background: #eee; }
	.layers-list li.selected { background: #0d0d0d; color: #fff; }
	.layer-icon {
		display: inline-block;
		width: 10px;
		height: 10px;
		border-radius: 2px;
		flex-shrink: 0;
	}

	/* Selection config (left panel, below layers) */
	.selection-config {
		border-top: 1px solid #e0e0e0;
	}
	.sel-config-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 10px 16px;
		background: #eee;
	}
	.sel-config-title {
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: #8c8c8c;
	}
	.sel-config-close {
		background: none;
		border: none;
		color: #b6b6b6;
		font-size: 18px;
		cursor: pointer;
		padding: 0 4px;
		line-height: 1;
	}
	.sel-config-close:hover { color: #fe5900; }
	.prop-row {
		padding: 10px 16px;
		border-bottom: 1px solid #e0e0e0;
	}
	.prop-label {
		display: block;
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: #8c8c8c;
		margin-bottom: 5px;
		font-family: 'Oswald', sans-serif;
	}
	.prop-value { font-size: 14px; color: #0d0d0d; }
	.prop-swatches {
		display: flex;
		flex-wrap: wrap;
		gap: 4px;
	}
	.prop-swatches button {
		background: #eee;
		color: #0d0d0d;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 4px 10px;
		font-size: 12px;
		cursor: pointer;
		transition: all 0.15s;
	}
	.prop-swatches button:hover { background: #ddd; }
	.prop-swatches button.active { background: #0d0d0d; color: #fff; border-color: #0d0d0d; }
	.prop-select {
		width: 100%;
		background: #fff;
		color: #0d0d0d;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 5px 8px;
		font-size: 13px;
	}
	.prop-accessories label {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		color: #0d0d0d;
		padding: 3px 0;
		cursor: pointer;
	}
	.prop-accessories input[type="checkbox"] { accent-color: #fe5900; }
	.prop-price-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.prop-rotate-btn { flex: 1; }
	.prop-delete-btn { flex: 1; background: transparent !important; border-color: #fe5900 !important; color: #fe5900 !important; }
	.prop-delete-btn:hover { background: #fe5900 !important; color: #fff !important; }
	.prop-price {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 700;
		color: #0d0d0d;
	}
	.prop-input-row {
		display: flex;
		align-items: center;
		gap: 4px;
	}
	.prop-input-unit { font-size: 12px; color: #8c8c8c; flex-shrink: 0; }
	.prop-input {
		width: 80px;
		background: #fff;
		color: #0d0d0d;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 5px 8px;
		font-size: 13px;
		transition: border-color 0.3s;
	}
	.prop-input:focus { border-color: #fe5900; outline: none; }
	.fill-wall-btn {
		margin: 10px 16px;
		background: #fe5900;
		border-color: #fe5900;
	}
	.delete-opening-btn {
		margin: 10px 16px;
		background: transparent;
		border-color: #fe5900;
		color: #fe5900;
	}
	.delete-opening-btn:hover { background: #fe5900; color: #fff; }

	/* Placement tooltip */
	.placement-tooltip {
		position: absolute;
		top: 8px; left: 50%; transform: translateX(-50%);
		z-index: 20;
		background: #1a1a1a;
		color: #fff;
		padding: 8px 16px;
		border-radius: 6px;
		font-size: 13px;
		display: flex;
		align-items: center;
		gap: 8px;
		box-shadow: 0 4px 16px rgba(0,0,0,0.25);
		white-space: nowrap;
	}
	.placement-tooltip-icon { color: #fe5900; font-size: 16px; }
	.placement-tooltip-cancel {
		background: transparent; border: 1px solid rgba(255,255,255,0.3);
		color: #ccc; padding: 2px 10px; border-radius: 3px; font-size: 11px;
		cursor: pointer; margin-left: 8px;
	}
	.placement-tooltip-cancel:hover { background: rgba(255,255,255,0.1); color: #fff; }

	.placement-toast {
		position: absolute;
		bottom: 16px;
		left: 50%;
		transform: translateX(-50%);
		background: rgba(200, 30, 30, 0.9);
		color: #fff;
		padding: 8px 18px;
		border-radius: 6px;
		font-size: 13px;
		font-family: 'Yantramanav', sans-serif;
		pointer-events: none;
		z-index: 50;
		white-space: nowrap;
	}

	/* Canvas (center) */
	.planner-canvas-wrap {
		flex: 1;
		position: relative;
		overflow: hidden;
		background: #e9e9e9;
	}
	#planner-canvas {
		display: block;
		width: 100%;
		height: 100%;
		cursor: crosshair;
	}
	.canvas-empty-hint {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		text-align: center;
		max-width: 380px;
		pointer-events: none;
	}
	.canvas-hint-icon {
		font-size: 36px;
		color: #ccc;
		margin-bottom: 12px;
	}
	.canvas-hint-title {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #999;
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-bottom: 8px;
	}
	.canvas-hint-body {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #b6b6b6;
		line-height: 1.5;
	}
	.canvas-hint-body strong { color: #999; }


	/* Order summary panel */
	.order-panel {
		background: #f7f7f7;
		border: none;
		border-radius: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}
	.order-panel-title {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 2px;
		margin: 0;
		padding: 24px 24px 16px;
		border-bottom: 1px solid #e0e0e0;
	}
	.order-room-name {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		padding: 8px 24px 0;
		min-height: 20px;
		letter-spacing: 0.3px;
		text-transform: uppercase;
	}
	.order-table {
		width: 100%;
		border-collapse: collapse;
		margin: 0;
	}
	.order-table thead {
		border-bottom: 1px solid #e0e0e0;
	}
	.order-table th {
		padding: 12px 24px;
		font-family: 'Oswald', sans-serif;
		font-size: 11px;
		font-weight: 600;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 1px;
		text-align: left;
	}
	.order-table th.ot-qty { text-align: center; width: 40px; }
	.order-table th.ot-total { text-align: right; width: 80px; }
	.order-table tbody td {
		padding: 12px 24px;
		border-bottom: 1px solid #e0e0e0;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #0d0d0d;
		vertical-align: top;
	}
	.order-table tbody td.ot-empty {
		color: #b6b6b6;
		text-align: center;
		padding: 30px 24px;
	}
	:global(.ot-item-name) {
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: #0d0d0d;
	}
	:global(.ot-base-price) {
		font-weight: 400;
		color: #888;
		font-size: 11px;
		margin-left: 4px;
		letter-spacing: 0;
		text-transform: none;
	}
	:global(.ot-item-spec) {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		color: #8c8c8c;
		margin-top: 3px;
		line-height: 1.4;
	}
	:global(.ot-acc-list) {
		list-style: none;
		margin: 6px 0 0;
		padding: 0 0 0 10px;
		border-left: 2px solid #e0e0e0;
