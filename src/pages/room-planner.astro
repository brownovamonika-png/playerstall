	function getTargetLockers(): LockerInstance[] {
		if (selectAll3D) return state.lockers;
		if (state.selection?.type === 'locker') {
			const l = state.lockers.find(l => l.instanceId === state.selection!.id);
			return l ? [l] : [];
		}
		return [];
	}

	function update3DColorBar(): void {
		const targets = getTargetLockers();
		if (targets.length === 0 && !selectAll3D) { hideBars(); return; }
		if (selectAll3D && state.lockers.length === 0) { hideBars(); return; }

		const refLocker = selectAll3D ? state.lockers[0] : targets[0];
		if (!refLocker) { hideBars(); return; }
		const template = getTemplate(refLocker.templateId);
		if (!template) { hideBars(); return; }

		colorBar.style.display = 'flex';
		colorBarLabel.textContent = selectAll3D ? 'Locker Colors (All)' : 'Locker Colors';
		colorBarSwatches.innerHTML = '';
		for (const c of template.colors) {
			const btn = document.createElement('button');
			btn.type = 'button';
			btn.className = 'view3d-cswatch' + (c.code === refLocker.config.colorCode ? ' active' : '');
			btn.style.cssText = `background:${c.hex};width:28px;height:28px;min-width:28px;min-height:28px;`;
			btn.title = c.label;
			btn.onclick = () => {
				const affected = selectAll3D ? state.lockers : targets;
				for (const lk of affected) { lk.config.colorCode = c.code; rebuildLockerMesh3D(lk.instanceId); }
				colorBarSwatches.querySelectorAll('.view3d-cswatch').forEach(s => s.classList.remove('active'));
				btn.classList.add('active');
				if (selectAll3D) highlightAllLockers3D();
				redraw();
			};
			colorBarSwatches.appendChild(btn);
		}

		cushionBar.style.display = 'flex';
		cushionBarLabel.textContent = selectAll3D ? 'Cushion Colors (All)' : 'Cushion Colors';
		cushionBarSwatches.innerHTML = '';
		for (const c of CUSHION_COLORS) {
			const btn = document.createElement('button');
			btn.type = 'button';
			btn.className = 'view3d-cswatch' + (c.hex === refLocker.config.cushionColorHex ? ' active' : '');
			btn.style.cssText = `background:${c.hex};width:28px;height:28px;min-width:28px;min-height:28px;`;
			btn.title = c.label;
			btn.onclick = () => {
				const affected = selectAll3D ? state.lockers : targets;
				for (const lk of affected) { lk.config.cushionColorHex = c.hex; rebuildLockerMesh3D(lk.instanceId); }
				cushionBarSwatches.querySelectorAll('.view3d-cswatch').forEach(s => s.classList.remove('active'));
				btn.classList.add('active');
				if (selectAll3D) highlightAllLockers3D();
				redraw();
			};
			cushionBarSwatches.appendChild(btn);
		}

		if (template.accessories.length > 0) {
			accBar.style.display = 'flex';
			accToggles.innerHTML = '';
			for (const acc of template.accessories) {
				const btn = document.createElement('button');
				btn.type = 'button';
				const allOn = selectAll3D ? state.lockers.every(l => l.config.accessoryIds.includes(acc.id)) : refLocker.config.accessoryIds.includes(acc.id);
				btn.className = 'view3d-acc-toggle' + (allOn ? ' active' : '');
				btn.textContent = acc.label;
				btn.onclick = () => {
					const affected = selectAll3D ? state.lockers : targets;
					if (btn.classList.contains('active')) {
						for (const lk of affected) { lk.config.accessoryIds = lk.config.accessoryIds.filter(a => a !== acc.id); }
						btn.classList.remove('active');
					} else {
						for (const lk of affected) { if (!lk.config.accessoryIds.includes(acc.id)) lk.config.accessoryIds.push(acc.id); }
						btn.classList.add('active');
					}
					for (const lk of affected) rebuildLockerMesh3D(lk.instanceId);
					if (selectAll3D) highlightAllLockers3D();
					redraw();
				};
				accToggles.appendChild(btn);
			}
		} else {
			accBar.style.display = 'none';
		}

		if (template.geometry.widthOptionsIn.length > 1) {
			widthBar.style.display = 'flex';
			widthOptions.innerHTML = '';
			for (const w of template.geometry.widthOptionsIn) {
				const btn = document.createElement('button');
				btn.type = 'button';
				btn.className = 'view3d-size-opt' + (w === refLocker.config.widthIn ? ' active' : '');
				btn.textContent = w + '"';
				btn.onclick = () => {
					const affected = selectAll3D ? state.lockers : targets;
					for (const lk of affected) { lk.config.widthIn = w; rebuildLockerMesh3D(lk.instanceId); }
					widthOptions.querySelectorAll('.view3d-size-opt').forEach(s => s.classList.remove('active'));
					btn.classList.add('active');
					if (selectAll3D) highlightAllLockers3D();
					redraw();
				};
				widthOptions.appendChild(btn);
			}
		} else {
			widthBar.style.display = 'none';
		}

		if (template.geometry.depthOptionsIn.length > 1) {
			depthBar.style.display = 'flex';
			depthOptions.innerHTML = '';
			for (const d of template.geometry.depthOptionsIn) {
				const btn = document.createElement('button');
				btn.type = 'button';
				btn.className = 'view3d-size-opt' + (d === refLocker.config.depthIn ? ' active' : '');
				btn.textContent = d + '"';
				btn.onclick = () => {
					const affected = selectAll3D ? state.lockers : targets;
					for (const lk of affected) { lk.config.depthIn = d; rebuildLockerMesh3D(lk.instanceId); }
					depthOptions.querySelectorAll('.view3d-size-opt').forEach(s => s.classList.remove('active'));
					btn.classList.add('active');
					if (selectAll3D) highlightAllLockers3D();
					redraw();
				};
				depthOptions.appendChild(btn);
			}
		} else {
			depthBar.style.display = 'none';
		}
	}

	// ─── Reset lockers ───
	document.getElementById('btn-reset-lockers')!.onclick = () => {
		state.lockers = [];
		state.selection = null;
		redraw();
	};

	// ─── Model select dropdown ───
	const modelSelect = document.getElementById('locker-model-select') as HTMLSelectElement;
	for (const t of getAllTemplates()) {
		const opt = document.createElement('option');
		opt.value = t.templateId;
		opt.textContent = t.displayName;
		modelSelect.appendChild(opt);
	}

	function getSelectedTemplate() {
		return getTemplate(modelSelect.value) ?? getAllTemplates()[0];
	}

	// ─── Add locker(s) ───
	const btnAddLocker = document.getElementById('btn-add-locker')!;
	const qtyInput = document.getElementById('locker-qty') as HTMLInputElement;

	btnAddLocker.onclick = () => {
		const qty = Math.max(1, Math.min(100, parseInt(qtyInput.value, 10) || 1));
		const t = getSelectedTemplate();
		const w = t.geometry.defaultWidthIn;
		const d = t.geometry.defaultDepthIn;

		const cx = state.camera.centerX - w / 2;
		const cy = state.camera.centerY - d / 2;
		let lastPlacedId: string | null = null;

		for (let n = 0; n < qty; n++) {
			let placed = false;
			for (let ring = 0; ring < 60 && !placed; ring++) {
				const step = ring * Math.max(w, d);
				const candidates = ring === 0
					? [{ dx: 0, dy: 0 }]
					: [
						{ dx: step, dy: 0 }, { dx: -step, dy: 0 },
						{ dx: 0, dy: step }, { dx: 0, dy: -step },
						{ dx: step, dy: step }, { dx: -step, dy: step },
						{ dx: step, dy: -step }, { dx: -step, dy: -step },
					];
				for (const { dx, dy } of candidates) {
					const inst: LockerInstance = {
						instanceId: nextInstanceId(),
						templateId: t.templateId,
						config: {
							widthIn: w,
							depthIn: d,
							colorCode: t.colors[0].code,
							cushionColorHex: '#1A1A1A',
							accessoryIds: [],
						},
						x: cx + dx, y: cy + dy, rotationDeg: 0,
					};
					if (!wouldOverlap(inst, state.lockers, state.openings, state.walls)) {
						state.lockers.push(inst);
						lastPlacedId = inst.instanceId;
						placed = true;
						break;
					}
				}
			}
		}

		if (lastPlacedId) {
			state.selection = { type: 'locker', id: lastPlacedId };
		} else {
			const toast = document.getElementById('placement-toast');
			if (toast) {
				toast.textContent = 'Not enough space — try removing lockers or enlarging the room.';
				toast.style.display = 'block';
				setTimeout(() => { toast.style.display = 'none'; }, 3000);
			}
		}
		redraw();
	};

	// ─── Add door / window (works from form buttons AND toolbar) ───
	let _openingCounter = 0;

	function addOpeningToWall(wallId: string, type: 'door' | 'window' | 'obstacle', atOffset?: number) {
		const wall = state.walls.find((w) => w.id === wallId);
		if (!wall) return;
		const len = wallLength(wall);
		const defaultWidth = type === 'obstacle' ? 24 : 36;
		const defaultClearance = type === 'door' ? 36 : type === 'window' ? 24 : 12;
		if (len < defaultWidth) return;

		let offset: number;
		if (atOffset !== undefined) {
			offset = Math.max(0, Math.min(atOffset - defaultWidth / 2, len - defaultWidth));
		} else {
			const existingOnWall = state.openings.filter((o) => o.wallId === wallId);
			offset = 0;
			for (const ex of existingOnWall) {
				const end = ex.offsetAlongWall + ex.widthIn;
				if (end > offset) offset = end;
			}
			if (offset + defaultWidth > len) return;
		}

		const op: Opening = {
			id: `op_${++_openingCounter}`,
			type,
			wallId,
			offsetAlongWall: offset,
			widthIn: defaultWidth,
			clearanceIn: defaultClearance,
		};
		state.openings.push(op);
		state.selection = { type: 'opening', id: op.id };
		renderWallOpeningsForms();
		redraw();
	}

	// Toolbar buttons (require wall selection)
	/* ── Placement mode ─────────────────────────────────────── */
	const _placementTooltip = document.getElementById('placement-tooltip')!;
	const _placementTooltipText = document.getElementById('placement-tooltip-text')!;

	function enterPlacementMode(wallId: string, type: 'door' | 'window' | 'obstacle') {
		placementMode = { wallId, type };
		state.selection = { type: 'wall', id: wallId };
		const label = type === 'door' ? 'door' : type === 'window' ? 'window' : 'obstacle';
		_placementTooltipText.textContent = `Click on ${wallId} where you want to place this ${label}`;
		_placementTooltip.style.display = 'flex';
		canvas.style.cursor = 'crosshair';
		redraw();
	}

	function exitPlacementMode() {
		placementMode = null;
		_placementTooltip.style.display = 'none';
		canvas.style.cursor = '';
		redraw();
	}

	document.getElementById('placement-cancel')!.onclick = exitPlacementMode;
	document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && placementMode) exitPlacementMode(); });

	document.getElementById('btn-add-door')!.onclick = () => {
		if (state.selection?.type === 'wall') enterPlacementMode(state.selection.id, 'door');
	};
	document.getElementById('btn-add-window')!.onclick = () => {
		if (state.selection?.type === 'wall') enterPlacementMode(state.selection.id, 'window');
	};

	document.querySelectorAll('.wall-add-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const wallId = (btn as HTMLElement).dataset.wallId!;
			const type = (btn as HTMLElement).dataset.type as 'door' | 'window' | 'obstacle';
			enterPlacementMode(wallId, type);
		});
	});

	const _wallPositionLabels: Record<string, string> = {
		'Wall A': 'from left end',
		'Wall B': 'from top end',
		'Wall C': 'from right end',
		'Wall D': 'from bottom end',
	};

	function _inToFt(inches: number) { return { ft: Math.floor(inches / 12), inch: Math.round(inches % 12) }; }
	function _ftToIn(ft: number, inch: number) { return ft * 12 + inch; }

	function _makeFtInInput(valueInches: number, onChange: (newInches: number) => void) {
		const wrap = document.createElement('div');
		wrap.className = 'op-ftin-row';
		const { ft, inch } = _inToFt(valueInches);

		const ftInput = document.createElement('input');
		ftInput.type = 'number'; ftInput.value = String(ft); ftInput.min = '0'; ftInput.step = '1';
		wrap.appendChild(ftInput);
		const ftU = document.createElement('span'); ftU.className = 'op-ftin-unit'; ftU.textContent = 'ft';
		wrap.appendChild(ftU);

		const inInput = document.createElement('input');
		inInput.type = 'number'; inInput.value = String(inch); inInput.min = '0'; inInput.max = '11'; inInput.step = '1';
		wrap.appendChild(inInput);
		const inU = document.createElement('span'); inU.className = 'op-ftin-unit'; inU.textContent = 'in';
		wrap.appendChild(inU);

		const update = () => {
			const f = Math.max(0, parseInt(ftInput.value, 10) || 0);
			const i = Math.max(0, Math.min(11, parseInt(inInput.value, 10) || 0));
			onChange(_ftToIn(f, i));
		};
		ftInput.onchange = update;
		inInput.onchange = update;
		return wrap;
	}

	function _buildWallBar(wallId: string) {
		const wall = state.walls.find((w) => w.id === wallId);
		if (!wall) return null;
		const len = wallLength(wall);
		if (len <= 0) return null;
		const ops = state.openings.filter((o) => o.wallId === wallId);
		if (ops.length === 0) return null;

		const wrap = document.createElement('div');
		wrap.className = 'wall-bar-wrap';
		const bar = document.createElement('div');
		bar.className = 'wall-bar';

		for (const op of ops) {
			const pct = (op.offsetAlongWall / len) * 100;
			const wPct = (op.widthIn / len) * 100;
			const block = document.createElement('div');
			block.className = 'wall-bar-opening ' + op.type;
			block.style.left = pct + '%';
			block.style.width = Math.max(wPct, 2) + '%';
			const lbl = document.createElement('span');
			lbl.className = 'wall-bar-opening-label';
			lbl.textContent = op.type === 'door' ? 'D' : op.type === 'window' ? 'W' : 'O';
			block.appendChild(lbl);
			bar.appendChild(block);
		}
		wrap.appendChild(bar);

		const labels = document.createElement('div');
		labels.className = 'wall-bar-labels';
		const { ft: tFt, inch: tIn } = _inToFt(len);
		labels.innerHTML = '<span>0\u2032</span><span>' + tFt + '\u2032 ' + tIn + '\u2033</span>';
		wrap.appendChild(labels);
		return wrap;
	}

	/** Render the per-wall opening rows inside the Room Dimensions form. */
	function renderWallOpeningsForms() {
		const wallKeys = [
			{ wallId: 'Wall A', containerId: 'openings-wall-a' },
			{ wallId: 'Wall B', containerId: 'openings-wall-b' },
			{ wallId: 'Wall C', containerId: 'openings-wall-c' },
			{ wallId: 'Wall D', containerId: 'openings-wall-d' },
		];

		for (const { wallId, containerId } of wallKeys) {
			const container = document.getElementById(containerId)!;
			const wallOpenings = state.openings.filter((o) => o.wallId === wallId);
			container.innerHTML = '';

			const wallBar = _buildWallBar(wallId);
			if (wallBar) container.appendChild(wallBar);

			for (const op of wallOpenings) {
				const card = document.createElement('div');
				card.className = 'wall-opening-row';

				const header = document.createElement('div');
				header.className = 'op-header';
				const badge = document.createElement('span');
				badge.className = `op-badge ${op.type}`;
				badge.textContent = op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle';
				header.appendChild(badge);
				const removeBtn = document.createElement('button');
				removeBtn.className = 'op-remove';
				removeBtn.textContent = '\u2715';
				removeBtn.title = 'Remove this opening';
				removeBtn.onclick = () => {
					state.openings = state.openings.filter((o) => o.id !== op.id);
					if (state.selection?.type === 'opening' && state.selection.id === op.id) {
						state.selection = null;
					}
					renderWallOpeningsForms();
					redraw();
				};
				header.appendChild(removeBtn);
				card.appendChild(header);

				const grid = document.createElement('div');
				grid.className = 'op-fields';

				// Position — ft + in with clear label
				const posGroup = document.createElement('div');
				posGroup.className = 'op-field';
				const posLabel = document.createElement('label');
				posLabel.textContent = 'Position ' + (_wallPositionLabels[wallId] || '');
				posGroup.appendChild(posLabel);
				posGroup.appendChild(_makeFtInInput(op.offsetAlongWall, (v) => {
					op.offsetAlongWall = Math.max(0, v);
					renderWallOpeningsForms();
					redraw();
				}));
				grid.appendChild(posGroup);

				// Width
				const wGroup = document.createElement('div');
				wGroup.className = 'op-field';
				const wLabel = document.createElement('label');
				wLabel.textContent = 'Width';
				wGroup.appendChild(wLabel);
				const wRow = document.createElement('div');
				wRow.className = 'op-field-row';
				const wInput = document.createElement('input');
				wInput.type = 'number'; wInput.value = String(op.widthIn); wInput.min = '12'; wInput.step = '1';
				wInput.title = 'Width of the opening in inches';
				wInput.onchange = () => { op.widthIn = Math.max(12, parseFloat(wInput.value) || 36); renderWallOpeningsForms(); redraw(); };
				wRow.appendChild(wInput);
				const wUnit = document.createElement('span'); wUnit.className = 'op-unit'; wUnit.textContent = '\u2033';
				wRow.appendChild(wUnit);
				wGroup.appendChild(wRow);
				grid.appendChild(wGroup);

				// Clearance
				const cGroup = document.createElement('div');
				cGroup.className = 'op-field';
				const cLabel = document.createElement('label');
				cLabel.textContent = 'Clearance';
				cGroup.appendChild(cLabel);
				const cRow = document.createElement('div');
				cRow.className = 'op-field-row';
				const cInput = document.createElement('input');
				cInput.type = 'number'; cInput.value = String(op.clearanceIn); cInput.min = '0'; cInput.step = '1';
				cInput.title = 'How far into the room no lockers can be placed';
				cInput.onchange = () => { op.clearanceIn = Math.max(0, parseFloat(cInput.value) || 0); redraw(); };
				cRow.appendChild(cInput);
				const cUnit = document.createElement('span'); cUnit.className = 'op-unit'; cUnit.textContent = '\u2033';
				cRow.appendChild(cUnit);
				cGroup.appendChild(cRow);
				grid.appendChild(cGroup);

				card.appendChild(grid);
				container.appendChild(card);
			}
		}
	}

	// Initial render (empty)
	renderWallOpeningsForms();

	// ─── Canvas pointer events (select + drag) ───
	let dragging: LockerInstance | null = null;
	let dragOffsetX = 0;
	let dragOffsetY = 0;
	let draggingOpening: Opening | null = null;
	let isPanning = false;
	let panStartX = 0;
	let panStartY = 0;
	let panCamStartX = 0;
	let panCamStartY = 0;

	canvas.addEventListener('pointerdown', (e) => {
		const rect = canvas.getBoundingClientRect();
		const sx = e.clientX - rect.left;
		const sy = e.clientY - rect.top;
		const world = screenToWorld(sx, sy, state.camera, canvas.clientWidth, canvas.clientHeight);

		if (placementMode) {
			const wall = state.walls.find((w) => w.id === placementMode!.wallId);
			if (wall) {
				const offset = projectOntoWall(world.x, world.y, wall);
				addOpeningToWall(placementMode.wallId, placementMode.type, offset);
			}
			exitPlacementMode();
			return;
		}

		// Try to hit a locker (reverse order = top first)
		let hitLocker: LockerInstance | null = null;
		for (let i = state.lockers.length - 1; i >= 0; i--) {
			const l = state.lockers[i];
			const box = lockerAABB(l);
			if (world.x >= box.minX && world.x <= box.maxX && world.y >= box.minY && world.y <= box.maxY) {
				hitLocker = l;
				break;
			}
		}

		if (hitLocker) {
			state.selection = { type: 'locker', id: hitLocker.instanceId };
			if (state.editMode) {
				dragging = hitLocker;
				dragOffsetX = world.x - hitLocker.x;
				dragOffsetY = world.y - hitLocker.y;
				canvas.setPointerCapture(e.pointerId);
			}
			redraw();
			return;
		}

		// Try to hit an opening (select + start drag)
		const hitOp = hitTestOpening(world.x, world.y, state.openings, state.walls);
		if (hitOp) {
			state.selection = { type: 'opening', id: hitOp.id };
			draggingOpening = hitOp;
			canvas.setPointerCapture(e.pointerId);
			canvas.style.cursor = 'grabbing';
			redraw();
			return;
		}

		// Try to hit a wall
		for (const wall of state.walls) {
			const wpx1 = wall.start.x;
			const wpy1 = wall.start.y;
			const wpx2 = wall.end.x;
			const wpy2 = wall.end.y;
			const hitDist = distToSegment(world.x, world.y, wpx1, wpy1, wpx2, wpy2);
			if (hitDist < wall.thicknessIn / 2 + 4 / state.camera.pixelsPerInch) {
				state.selection = { type: 'wall', id: wall.id };
				redraw();
				return;
			}
		}

		// Pan
		state.selection = null;
		isPanning = true;
		panStartX = e.clientX;
		panStartY = e.clientY;
		panCamStartX = state.camera.centerX;
		panCamStartY = state.camera.centerY;
		canvas.setPointerCapture(e.pointerId);
		redraw();
	});

	const SNAP_THRESHOLD = 8;

	function snapLocker(target: LockerInstance): void {
		const box = lockerAABB(target);
		const snapDist = SNAP_THRESHOLD / state.camera.pixelsPerInch;
		let bestDx = Infinity;
		let bestDy = Infinity;

		for (const other of state.lockers) {
			if (other.instanceId === target.instanceId) continue;
			const ob = lockerAABB(other);

			// X-axis snaps (left-to-right, right-to-left, left-to-left, right-to-right)
			const xEdges = [
				{ from: box.maxX, to: ob.minX },
				{ from: box.minX, to: ob.maxX },
				{ from: box.minX, to: ob.minX },
				{ from: box.maxX, to: ob.maxX },
			];
			for (const edge of xEdges) {
				const d = edge.to - edge.from;
				if (Math.abs(d) < Math.abs(bestDx) && Math.abs(d) < snapDist) bestDx = d;
			}

			// Y-axis snaps
			const yEdges = [
				{ from: box.maxY, to: ob.minY },
				{ from: box.minY, to: ob.maxY },
				{ from: box.minY, to: ob.minY },
				{ from: box.maxY, to: ob.maxY },
			];
			for (const edge of yEdges) {
				const d = edge.to - edge.from;
				if (Math.abs(d) < Math.abs(bestDy) && Math.abs(d) < snapDist) bestDy = d;
			}
		}

		// Snap to wall inner faces
		for (const wall of state.walls) {
			const halfT = wall.thicknessIn / 2;
			const isHoriz = Math.abs(wall.end.y - wall.start.y) < 0.01;

			if (isHoriz) {
				const innerY = wall.start.y + (wall.id === 'Wall A' ? halfT : -halfT);
				// Snap top edge to wall inner face (Wall A), bottom edge (Wall C)
				const dTop = innerY - box.minY;
				const dBot = innerY - box.maxY;
				if (Math.abs(dTop) < Math.abs(bestDy) && Math.abs(dTop) < snapDist) bestDy = dTop;
				if (Math.abs(dBot) < Math.abs(bestDy) && Math.abs(dBot) < snapDist) bestDy = dBot;

				// Snap to wall endpoints (corners) on X
				const xMin = Math.min(wall.start.x, wall.end.x) + halfT;
				const xMax = Math.max(wall.start.x, wall.end.x) - halfT;
				const dL = xMin - box.minX;
				const dR = xMax - box.maxX;
				if (Math.abs(dL) < Math.abs(bestDx) && Math.abs(dL) < snapDist) bestDx = dL;
				if (Math.abs(dR) < Math.abs(bestDx) && Math.abs(dR) < snapDist) bestDx = dR;
			} else {
				const innerX = wall.start.x + (wall.id === 'Wall D' ? halfT : -halfT);
				const dLeft = innerX - box.minX;
				const dRight = innerX - box.maxX;
				if (Math.abs(dLeft) < Math.abs(bestDx) && Math.abs(dLeft) < snapDist) bestDx = dLeft;
				if (Math.abs(dRight) < Math.abs(bestDx) && Math.abs(dRight) < snapDist) bestDx = dRight;

				const yMin = Math.min(wall.start.y, wall.end.y) + halfT;
				const yMax = Math.max(wall.start.y, wall.end.y) - halfT;
				const dT = yMin - box.minY;
				const dB = yMax - box.maxY;
				if (Math.abs(dT) < Math.abs(bestDy) && Math.abs(dT) < snapDist) bestDy = dT;
				if (Math.abs(dB) < Math.abs(bestDy) && Math.abs(dB) < snapDist) bestDy = dB;
			}
		}

		if (Math.abs(bestDx) < snapDist) target.x += bestDx;
		if (Math.abs(bestDy) < snapDist) target.y += bestDy;
	}

	canvas.addEventListener('pointermove', (e) => {
		if (draggingOpening) {
			const wall = state.walls.find((w) => w.id === draggingOpening!.wallId);
			if (wall) {
				const rect = canvas.getBoundingClientRect();
				const sx = e.clientX - rect.left;
				const sy = e.clientY - rect.top;
				const world = screenToWorld(sx, sy, state.camera, canvas.clientWidth, canvas.clientHeight);
				const along = projectOntoWall(world.x, world.y, wall);
				const len = wallLength(wall);
				draggingOpening.offsetAlongWall = Math.max(0, Math.min(along - draggingOpening.widthIn / 2, len - draggingOpening.widthIn));
				redraw();
				renderWallOpeningsForms();
			}
		} else if (dragging) {
			const rect = canvas.getBoundingClientRect();
			const sx = e.clientX - rect.left;
			const sy = e.clientY - rect.top;
			const world = screenToWorld(sx, sy, state.camera, canvas.clientWidth, canvas.clientHeight);
			const oldX = dragging.x;
			const oldY = dragging.y;
			dragging.x = world.x - dragOffsetX;
			dragging.y = world.y - dragOffsetY;
			clampLockerToRoom(dragging, state.walls);
			snapLocker(dragging);
			clampLockerToRoom(dragging, state.walls);
			if (wouldOverlap(dragging, state.lockers, state.openings, state.walls)) {
				dragging.x = oldX;
				dragging.y = oldY;
			}
			redraw();
		} else if (isPanning) {
			const dx = (e.clientX - panStartX) / state.camera.pixelsPerInch;
			const dy = (e.clientY - panStartY) / state.camera.pixelsPerInch;
			state.camera.centerX = panCamStartX - dx;
			state.camera.centerY = panCamStartY - dy;
			redraw();
		}
	});

	canvas.addEventListener('pointerup', () => {
		if (draggingOpening) { canvas.style.cursor = ''; }
		dragging = null;
		draggingOpening = null;
		isPanning = false;
	});

	canvas.addEventListener('dblclick', (e) => {
		const rect = canvas.getBoundingClientRect();
		const sx = e.clientX - rect.left;
		const sy = e.clientY - rect.top;
		const world = screenToWorld(sx, sy, state.camera, canvas.clientWidth, canvas.clientHeight);

		for (let i = state.lockers.length - 1; i >= 0; i--) {
			const l = state.lockers[i];
			const box = lockerAABB(l);
			if (world.x >= box.minX && world.x <= box.maxX && world.y >= box.minY && world.y <= box.maxY) {
				const oldRot = l.rotationDeg;
				l.rotationDeg = (l.rotationDeg + 90) % 360;
				if (wouldOverlap(l, state.lockers, state.openings, state.walls)) {
					l.rotationDeg = oldRot;
				}
				state.selection = { type: 'locker', id: l.instanceId };
				redraw();
				return;
			}
		}
	});

	function distToSegment(px: number, py: number, x1: number, y1: number, x2: number, y2: number): number {
		const dx = x2 - x1;
		const dy = y2 - y1;
		const lenSq = dx * dx + dy * dy;
		if (lenSq === 0) return Math.hypot(px - x1, py - y1);
		let t = ((px - x1) * dx + (py - y1) * dy) / lenSq;
		t = Math.max(0, Math.min(1, t));
		return Math.hypot(px - (x1 + t * dx), py - (y1 + t * dy));
	}

	// ─── Layers list ───
	function updateLayers() {
		const list = document.getElementById('layers-list')!;
		let html = '';

		html += `<li class="${state.selection?.type === 'room' ? 'selected' : ''}" data-sel-type="room" data-sel-id="room">
			<span class="layer-icon" style="background:#888"></span> Room
		</li>`;

		for (const wall of state.walls) {
			const sel = state.selection?.type === 'wall' && state.selection.id === wall.id;
			const len = formatDimension(wallLength(wall), state.displayUnit, 0);
			html += `<li class="${sel ? 'selected' : ''}" data-sel-type="wall" data-sel-id="${wall.id}">
				<span class="layer-icon" style="background:#555"></span> ${wall.id} · ${len}
			</li>`;
		}

		for (const op of state.openings) {
			const sel = state.selection?.type === 'opening' && state.selection.id === op.id;
			const opColor = op.type === 'door' ? '#5a9fd4' : op.type === 'window' ? '#6dc46d' : '#d4a05a';
			const parentWall = state.walls.find((w) => w.id === op.wallId);
			const wallLabel = parentWall ? parentWall.id : op.wallId;
			const opLabel = op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle';
			html += `<li class="${sel ? 'selected' : ''}" data-sel-type="opening" data-sel-id="${op.id}">
				<span class="layer-icon" style="background:${opColor}"></span>
				${opLabel} · ${wallLabel}
			</li>`;
		}

		for (const locker of state.lockers) {
			const t = getTemplate(locker.templateId);
			const sel = state.selection?.type === 'locker' && state.selection.id === locker.instanceId;
			const color = t?.colors.find((c) => c.code === locker.config.colorCode);
			const dim = formatDimension(locker.config.widthIn, state.displayUnit, 0);
			html += `<li class="${sel ? 'selected' : ''}" data-sel-type="locker" data-sel-id="${locker.instanceId}">
				<span class="layer-icon" style="background:${color?.hex ?? '#ccc'}"></span>
				${t?.displayName ?? locker.templateId} · ${dim}
			</li>`;
		}

		list.innerHTML = html;

		const layersHint = document.getElementById('layers-hint');
		if (layersHint) layersHint.style.display = state.lockers.length ? 'none' : '';

		list.querySelectorAll('li').forEach((li) => {
			li.addEventListener('click', () => {
				const type = li.dataset.selType as Selection['type'];
				const id = li.dataset.selId!;
				state.selection = { type, id };
				redraw();
