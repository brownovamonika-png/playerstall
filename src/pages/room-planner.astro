			const locker = state.lockers.find((l) => l.instanceId === state.selection!.id);
			if (!locker) { selConfig.style.display = 'none'; return; }
			const template = getTemplate(locker.templateId);
			if (!template) { selConfig.style.display = 'none'; return; }

			selConfigTitle.textContent = template.displayName;
			propsLocker.style.display = '';
