				btn.onclick = () => {
					const oldW = locker.config.widthIn;
					const oldD = locker.config.depthIn;
					const oldX = locker.x;
					const oldY = locker.y;
					locker.config.widthIn = w;
					adjustLockerPosition(locker, oldW, oldD);
					if (wouldOverlap(locker, state.lockers, state.openings, state.walls)) {
						locker.config.widthIn = oldW;
						locker.x = oldX;
						locker.y = oldY;
					}
					redraw();
				};
				widthDiv.appendChild(btn);
			}

			const depthDiv = document.getElementById('prop-depth-options')!;
			depthDiv.innerHTML = '';
			for (const d of template.geometry.depthOptionsIn) {
				const btn = document.createElement('button');
				btn.textContent = `${d}″`;
				btn.className = d === locker.config.depthIn ? 'active' : '';
				btn.onclick = () => {
					const oldW = locker.config.widthIn;
					const oldD = locker.config.depthIn;
					const oldX = locker.x;
					const oldY = locker.y;
					locker.config.depthIn = d;
					adjustLockerPosition(locker, oldW, oldD);
					if (wouldOverlap(locker, state.lockers, state.openings, state.walls)) {
						locker.config.depthIn = oldD;
						locker.x = oldX;
						locker.y = oldY;
					}
					redraw();
				};
				depthDiv.appendChild(btn);
			}

			const colorSel = document.getElementById('prop-color-select') as HTMLSelectElement;
			colorSel.innerHTML = '';
			for (const c of template.colors) {
				const opt = document.createElement('option');
				opt.value = c.code;
				opt.textContent = c.label;
				opt.selected = c.code === locker.config.colorCode;
				colorSel.appendChild(opt);
			}
			colorSel.onchange = () => {
				locker.config.colorCode = colorSel.value;
				rebuildLockerMesh3D(locker.instanceId);
				redraw();
			};

			const accDiv = document.getElementById('prop-accessories')!;
			accDiv.innerHTML = '';
			for (const acc of template.accessories) {
				const lbl = document.createElement('label');
				const cb = document.createElement('input');
				cb.type = 'checkbox';
				cb.checked = locker.config.accessoryIds.includes(acc.id);
				cb.onchange = () => {
					if (cb.checked) {
						locker.config.accessoryIds.push(acc.id);
					} else {
						locker.config.accessoryIds = locker.config.accessoryIds.filter((a) => a !== acc.id);
					}
					rebuildLockerMesh3D(locker.instanceId);
					redraw();
				};
				lbl.appendChild(cb);
				lbl.appendChild(document.createTextNode(` ${acc.label} (+$${acc.price})`));
				accDiv.appendChild(lbl);
			}

			const price = priceLocker(template, locker.config);
			document.getElementById('prop-price')!.textContent = `$${price.toLocaleString()}`;

			document.getElementById('prop-rotate-locker')!.onclick = () => {
				const oldRot = locker.rotationDeg;
				locker.rotationDeg = (locker.rotationDeg + 90) % 360;
				if (wouldOverlap(locker, state.lockers, state.openings, state.walls)) {
					locker.rotationDeg = oldRot;
				}
				redraw();
			};

			document.getElementById('prop-delete-locker')!.onclick = () => {
				state.lockers = state.lockers.filter((l) => l.instanceId !== locker.instanceId);
				state.selection = null;
				redraw();
			};
		}

		if (state.selection.type === 'wall') {
			const wall = state.walls.find((w) => w.id === state.selection!.id);
			if (!wall) { selConfig.style.display = 'none'; return; }
			selConfigTitle.textContent = wall.id;
			propsWall.style.display = '';
			document.getElementById('prop-wall-id')!.textContent = wall.id;

			const lenInput = document.getElementById('prop-wall-length') as HTMLInputElement;
			lenInput.value = String(Math.round(wallLength(wall)));
			document.getElementById('prop-wall-length-unit')!.textContent = unitLabel(state.displayUnit);
			lenInput.onchange = () => {
				const newLen = parseFloat(lenInput.value) || wallLength(wall);
				const dimKey = wall.id === 'Wall A' ? 'wallA'
					: wall.id === 'Wall B' ? 'wallB'
					: wall.id === 'Wall C' ? 'wallC' : 'wallD';
				roomDims[dimKey] = newLen;
				if (dimKey === 'wallA') roomDims.wallC = newLen;
				if (dimKey === 'wallC') roomDims.wallA = newLen;
				if (dimKey === 'wallB') roomDims.wallD = newLen;
				if (dimKey === 'wallD') roomDims.wallB = newLen;
				writeAllDimInputs();
				state.walls = buildWalls(roomDims);
				state.lockers = [];
				state.openings = state.openings.filter((op) => {
					const w = state.walls.find((wl) => wl.id === op.wallId);
					return w && (op.offsetAlongWall + op.widthIn) <= wallLength(w);
				});
				state.selection = { type: 'wall', id: wall.id };
				renderWallOpeningsForms();
				zoomFit();
				redraw();
			};

			const thInput = document.getElementById('prop-wall-thickness') as HTMLInputElement;
			thInput.value = String(wall.thicknessIn);
			thInput.onchange = () => {
				const newTh = parseFloat(thInput.value) || 4.5;
				wall.thicknessIn = newTh;
				const thKey = wall.id === 'Wall A' ? 'thicknessA'
					: wall.id === 'Wall B' ? 'thicknessB'
					: wall.id === 'Wall C' ? 'thicknessC' : 'thicknessD';
				roomDims[thKey] = newTh;
				redraw();
			};
		}

		if (state.selection.type === 'opening') {
			const op = state.openings.find((o) => o.id === state.selection!.id);
			if (!op) { selConfig.style.display = 'none'; return; }
			selConfigTitle.textContent = `${op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle'} · ${op.wallId}`;
			propsOpening.style.display = '';

			document.getElementById('prop-opening-type')!.textContent = op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle';
			document.getElementById('prop-opening-wall')!.textContent = op.wallId;

			const wInput = document.getElementById('prop-opening-width') as HTMLInputElement;
			wInput.value = String(op.widthIn);
			wInput.onchange = () => {
				op.widthIn = Math.max(12, parseFloat(wInput.value) || op.widthIn);
				renderWallOpeningsForms();
				redraw();
			};

			const oInput = document.getElementById('prop-opening-offset') as HTMLInputElement;
			oInput.value = String(op.offsetAlongWall);
			oInput.onchange = () => {
				op.offsetAlongWall = Math.max(0, parseFloat(oInput.value) || 0);
				renderWallOpeningsForms();
				redraw();
			};

			const cInput = document.getElementById('prop-opening-clearance') as HTMLInputElement;
			cInput.value = String(op.clearanceIn);
			cInput.onchange = () => {
				op.clearanceIn = Math.max(0, parseFloat(cInput.value) || 0);
				renderWallOpeningsForms();
				redraw();
			};

			document.getElementById('btn-delete-opening')!.onclick = () => {
				state.openings = state.openings.filter((o) => o.id !== op.id);
				state.selection = null;
				renderWallOpeningsForms();
				redraw();
			};
		}
	}

	// ─── Fill wall ───
	document.getElementById('btn-fill-wall')!.onclick = () => {
		if (state.selection?.type !== 'wall') return;
		const wall = state.walls.find((w) => w.id === state.selection!.id);
		if (!wall) return;

		const t = getSelectedTemplate();
		const defaultConfig = {
			widthIn: t.geometry.defaultWidthIn,
			depthIn: t.geometry.defaultDepthIn,
			colorCode: t.colors[0].code,
			cushionColorHex: '#1A1A1A',
			accessoryIds: [] as string[],
		};

		const wallOpenings = state.openings.filter((o) => o.wallId === wall.id);
		const newLockers = packWall(wall, t.templateId, defaultConfig, Date.now() % 100000, wallOpenings, state.lockers, state.walls);
		const valid = newLockers.filter((l) => !wouldOverlap(l, [...state.lockers, ...newLockers.filter((n) => n !== l)], state.openings, state.walls));
		state.lockers.push(...valid);
		if (valid.length > 0) {
			state.selection = { type: 'locker', id: valid[0].instanceId };
		}
		redraw();
	};

	// ─── Order summary ───
	interface LineItem {
		roomName: string;
		templateId: string;
		displayName: string;
		widthIn: number;
		depthIn: number;
		colorCode: string;
		colorLabel: string;
		accessoryIds: string[];
		accessories: { label: string; price: number }[];
		basePrice: number;
		unitPrice: number;
		qty: number;
	}

	function buildLinesForLockers(lockers: LockerInstance[], roomName: string): LineItem[] {
		const lines: LineItem[] = [];
		for (const locker of lockers) {
			const t = getTemplate(locker.templateId);
			if (!t) continue;
			const price = priceLocker(t, locker.config);
			const base = (t.pricing.basePriceByWidthIn[String(locker.config.widthIn)] ?? 0) + (t.pricing.depthSurcharge[String(locker.config.depthIn)] ?? 0);
			const color = t.colors.find((c) => c.code === locker.config.colorCode);
			const accs = locker.config.accessoryIds
				.map((id) => t.accessories.find((a) => a.id === id))
				.filter(Boolean) as { id: string; label: string; price: number }[];
			const sortedAcc = [...locker.config.accessoryIds].sort();
			const key = `${locker.templateId}|${locker.config.widthIn}|${locker.config.depthIn}|${locker.config.colorCode}|${sortedAcc.join(',')}`;
			const existing = lines.find((l) =>
				`${l.templateId}|${l.widthIn}|${l.depthIn}|${l.colorCode}|${[...l.accessoryIds].sort().join(',')}` === key
				&& l.roomName === roomName
			);
			if (existing) {
				existing.qty++;
			} else {
				lines.push({
					roomName,
					templateId: locker.templateId,
					displayName: t.displayName,
					widthIn: locker.config.widthIn,
					depthIn: locker.config.depthIn,
					colorCode: locker.config.colorCode,
					colorLabel: color?.label ?? locker.config.colorCode,
					accessoryIds: [...locker.config.accessoryIds],
					accessories: accs.map((a) => ({ label: a.label, price: a.price })),
					basePrice: base,
					unitPrice: price,
					qty: 1,
				});
			}
		}
		return lines;
	}

	function getAllRoomLines(): LineItem[] {
		saveCurrentRoom();
		const allLines: LineItem[] = [];
		for (const room of savedRooms) {
			allLines.push(...buildLinesForLockers(room.lockers, room.roomName));
		}
		return allLines;
	}

	function updateOrderSummary() {
		const nameEl = document.getElementById('order-room-name')!;
		const tbody = document.getElementById('order-items-body')!;
		const subtotalEl = document.getElementById('order-subtotal')!;
		const totalEl = document.getElementById('order-total')!;
		const countEl = document.getElementById('order-locker-count')!;

		const allLines = getAllRoomLines();
		nameEl.textContent = '';

		if (allLines.length === 0) {
			tbody.innerHTML = '<tr><td colspan="3" class="ot-empty">No lockers placed yet.</td></tr>';
			subtotalEl.textContent = '$0.00';
			totalEl.innerHTML = '<strong>$0.00</strong>';
			countEl.textContent = '0 lockers';
			(window as any).__plannerAllLines = [];
			return;
		}

		(window as any).__plannerAllLines = allLines;

		let subtotal = 0;
		let totalLockers = 0;
		let html = '';
		let currentRoom = '';
		for (const line of allLines) {
			const rLabel = line.roomName || 'Unnamed Room';
			if (rLabel !== currentRoom) {
				currentRoom = rLabel;
				html += `<tr class="ot-room-header"><td colspan="3">${currentRoom}</td></tr>`;
			}
			const lineTotal = line.unitPrice * line.qty;
			subtotal += lineTotal;
			totalLockers += line.qty;
			let accHtml = '';
			if (line.accessories.length) {
				accHtml = `<ul class="ot-acc-list">${line.accessories.map((a) => `<li>${a.label} <span class="ot-acc-price">+$${a.price}</span></li>`).join('')}</ul>`;
			}
			html += `<tr>
				<td>
					<span class="ot-item-name">${line.displayName} <span class="ot-base-price">$${line.basePrice.toLocaleString('en-US', { minimumFractionDigits: 2 })}</span></span>
					<span class="ot-item-spec">${line.widthIn}″W × ${line.depthIn}″D · ${line.colorLabel}</span>
					${accHtml}
				</td>
				<td class="ot-item-qty">${line.qty}</td>
				<td class="ot-item-total">$${lineTotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}</td>
			</tr>`;
		}

		tbody.innerHTML = html;
		subtotalEl.textContent = `$${subtotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
		totalEl.innerHTML = `<strong>$${subtotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}</strong>`;
		countEl.textContent = `${totalLockers} locker${totalLockers !== 1 ? 's' : ''} across ${savedRooms.length || 1} room${savedRooms.length > 1 ? 's' : ''}`;
	}

	function blobToBase64(blob: Blob): Promise<string> {
		return new Promise((resolve, reject) => {
			const reader = new FileReader();
			reader.onloadend = () => resolve((reader.result as string).split(',')[1]);
			reader.onerror = () => reject(new Error('read failed'));
			reader.readAsDataURL(blob);
		});
	}

	function downloadBlob(blob: Blob, filename: string) {
		const url = URL.createObjectURL(blob);
		const a = document.createElement('a');
		a.href = url;
		a.download = filename;
		document.body.appendChild(a);
		a.click();
		a.remove();
		URL.revokeObjectURL(url);
	}

	// ─── Request Quote → add to site cart ───
	document.getElementById('btn-request-quote')!.onclick = async () => {
		const allLines = (window as any).__plannerAllLines as LineItem[] | undefined;
		if (!allLines || allLines.length === 0) {
			alert('Add lockers to your room first.');
			return;
		}
		const cart = JSON.parse(localStorage.getItem('playerstall_cart') || '[]');

		for (const line of allLines) {
			const roomLabel = line.roomName ? `Room: ${line.roomName}` : 'Room Planner';
			const specParts = [`${line.widthIn}″W × ${line.depthIn}″D`, line.colorLabel];
			if (line.accessories.length) {
				for (const a of line.accessories) {
					specParts.push(`${a.label} (+$${a.price})`);
				}
			}
			const model = `${roomLabel} · ${specParts.join(' · ')}`;
			const id = `planner-${line.roomName}-${line.templateId}-${line.widthIn}-${line.depthIn}-${line.colorLabel}-${line.accessories.map((a) => a.label).join('-')}`;

			const existing = cart.find((item: any) => item.id === id);
			if (existing) {
				existing.quantity += line.qty;
			} else {
				cart.push({
					id,
					name: line.displayName,
					price: line.unitPrice,
					image: '/images/stadium-locker.png',
					quantity: line.qty,
					model,
					planner: true,
					basePrice: line.basePrice,
					widthIn: line.widthIn,
					depthIn: line.depthIn,
					colorLabel: line.colorLabel,
					roomName: line.roomName || '',
					accessories: line.accessories,
				});
			}
		}

		localStorage.setItem('playerstall_cart', JSON.stringify(cart));
		const totalItems = cart.reduce((sum: number, item: any) => sum + item.quantity, 0);
		window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: totalItems } }));

		const customerEmail = (document.getElementById('customer-email') as HTMLInputElement).value.trim();
		if (!customerEmail) {
			alert('Please enter your email address so we can get in touch with you.');
			return;
		}

		let orderSummary = '';
		let currentRoom = '';
		for (const line of allLines) {
			const room = line.roomName || 'Unnamed Room';
			if (room !== currentRoom) {
				currentRoom = room;
				orderSummary += `\n--- ${room} ---\n`;
			}
			const accText = line.accessories.length ? ` + ${line.accessories.map((a: any) => a.label).join(', ')}` : '';
			orderSummary += `${line.qty}x ${line.displayName} (${line.widthIn}"W x ${line.depthIn}"D, ${line.colorLabel}${accText}) - $${(line.unitPrice * line.qty).toFixed(2)}\n`;
		}
		const grandTotal = allLines.reduce((sum: number, l: any) => sum + l.unitPrice * l.qty, 0);
		orderSummary += `\nEstimated Total: $${grandTotal.toFixed(2)}`;

		let timingBlock = '';
		for (let ri = 0; ri < savedRooms.length; ri++) {
			const r = savedRooms[ri];
			const lbl = needByTimelineLabel(r.needByTimeline || '');
			if (!lbl) continue;
			const rm = r.roomName || `Room ${ri + 1}`;
			timingBlock += `${rm}: ${lbl}\n`;
		}
		let fundingBlock = '';
		for (let ri = 0; ri < savedRooms.length; ri++) {
			const r = savedRooms[ri];
			const lbl = fundingStatusLabel(r.fundingStatus || '');
			if (!lbl) continue;
			const rm = r.roomName || `Room ${ri + 1}`;
			fundingBlock += `${rm}: ${lbl}\n`;
		}
		if (fundingBlock) {
			orderSummary = `Funding / budget:\n${fundingBlock}\n` + orderSummary;
		}
		if (timingBlock) {
			orderSummary = `Preferred delivery timing:\n${timingBlock}\n` + orderSummary;
		}

		const statusMsg = document.getElementById('order-status-msg')!;
		const btn = document.getElementById('btn-request-quote') as HTMLButtonElement;
		btn.disabled = true;
		btn.textContent = 'Generating PDFs...';

		const origIndex = activeRoomIndex;
		saveCurrentRoom();
		const estimateLines = allLines.map((l) => ({
			roomName: l.roomName,
			displayName: l.displayName,
			widthIn: l.widthIn,
			depthIn: l.depthIn,
			colorLabel: l.colorLabel,
			accessories: l.accessories,
			unitPrice: l.unitPrice,
			qty: l.qty,
		}));
		const estimateBlob = generateEstimatePdfBlob(estimateLines, customerEmail, grandTotal);
		let layoutBlob: Blob | null = null;
		try {
			layoutBlob = await generateLayoutPdfBlob(savedRooms, state.displayUnit);
		} catch (e) {
			console.error('Layout PDF failed:', e);
		}
		try {
			loadRoom(origIndex);
		} catch (_) {}

		btn.textContent = 'Sending...';

		let estimatePdfBase64: string | undefined;
		let layoutPdfBase64: string | undefined;
		try {
			if (estimateBlob) estimatePdfBase64 = await blobToBase64(estimateBlob);
			if (layoutBlob) layoutPdfBase64 = await blobToBase64(layoutBlob);
		} catch (_) {}

		fetch('/api/send-room-plan', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				email: customerEmail,
				orderSummary,
				grandTotal: grandTotal.toFixed(2),
				estimatePdfBase64,
				layoutPdfBase64,
			}),
		}).then(async (res) => {
			if (res.ok) {
				statusMsg.textContent =
					'Thank you! We emailed two PDFs to ' +
					customerEmail +
					': your project estimate and your layout (floor plans + 3D). Our team received copies too.';
				statusMsg.style.color = '#0d0d0d';
				btn.textContent = 'Sent!';
				if (estimateBlob) downloadBlob(estimateBlob, 'PlayerStall-Room-Estimate.pdf');
				if (layoutBlob) setTimeout(() => downloadBlob(layoutBlob, 'PlayerStall-Room-Layout.pdf'), 400);
			} else {
				let detail = '';
				try { const j = await res.json(); detail = j.error || ''; } catch {}
				statusMsg.textContent = 'Something went wrong' + (detail ? ': ' + detail : '') + '. Please try again or email us directly at sales@playerstall.com.';
				statusMsg.style.color = '#fe5900';
				btn.disabled = false;
				btn.textContent = 'Get In Touch With Us';
			}
		}).catch(() => {
			statusMsg.textContent = 'Could not connect. Please check your internet and try again, or email us directly at sales@playerstall.com.';
			statusMsg.style.color = '#fe5900';
			btn.disabled = false;
			btn.textContent = 'Get In Touch With Us';
		});
	};

	// ─── Toolbar state ───
	function updateToolbar() {
		btnEdit.classList.toggle('active', state.editMode);
		const zoomPct = Math.round(state.camera.pixelsPerInch / 2 * 100);
		document.getElementById('zoom-label')!.textContent = `${zoomPct}%`;
	}

	// ─── Mobile tabs ───
	const columns = document.querySelector('.planner-columns') as HTMLElement;
	document.querySelectorAll('.mob-tab').forEach((tab) => {
		tab.addEventListener('click', () => {
			document.querySelectorAll('.mob-tab').forEach((t) => t.classList.remove('active'));
			tab.classList.add('active');
			columns.dataset.activePanel = (tab as HTMLElement).dataset.panel!;
			if ((tab as HTMLElement).dataset.panel === 'canvas') {
				redraw();
			}
		});
	});

	// ─── Init ───
	if (!restoreRooms()) {
		savedRooms.push(snapshotCurrentRoom());
	}
	renderRoomTabs();
	window.addEventListener('resize', () => redraw());
	window.addEventListener('beforeunload', () => { saveCurrentRoom(); });
	requestAnimationFrame(() => {
		zoomFit();
		redraw();
	});

	/* ── Guide Agent ─────────────────────────────────── */
	(function initGuide() {
		const STEPS = [
			{
				title: 'Welcome!',
				desc: "Let's build your dream locker room step by step. This guide will walk you through the entire process. Click <strong>Next</strong> to begin!",
				target: null
			},
			{
				title: 'Set Room Dimensions',
				desc: 'Enter the length of each wall (A–D) in the cards below. If a wall has a door, window, or obstacle, click the button under that wall to mark it.',
				target: '#room-setup'
			},
			{
				title: 'Draw Your Room',
				desc: "Once your dimensions are set, click <strong>Draw My Room</strong> to generate the floor plan on the canvas below.",
				target: '#btn-apply-room'
			},
			{
				title: 'Choose a Locker',
				desc: 'Pick a locker model, set the width, depth, and color. Choose your quantity and click <strong>Add to Layout</strong>.',
				target: '#locker-type-section'
			},
			{
				title: 'Place Your Lockers',
				desc: 'Your lockers appear on the canvas. <strong>Drag</strong> them to reposition, <strong>double-click</strong> to rotate, and they\'ll snap to walls automatically.',
				target: '#planner-canvas'
			},
			{
				title: 'Open 3D View',
				desc: 'Click the <strong>3D View</strong> button in the toolbar to see your locker room come to life. You can orbit, select, and customize lockers in 3D.',
				target: '#btn-view-3d'
			},
			{
				title: 'Customize Colors & Options',
				desc: 'In the 3D view, change locker colors, cushion colors, add a <strong>4″ base</strong>, <strong>edgebanding</strong>, upload your <strong>floor logo</strong>, and more. Use <strong>Select All</strong> for bulk changes.',
				target: null
			},
			{
				title: 'Review Your Layout',
				desc: 'Scroll down to the <strong>Order Summary</strong> to see all your lockers, quantities, and pricing across every room.',
				target: '#order-section'
			},
			{
				title: 'Get Your Quote!',
				desc: 'Enter your email and click <strong>Get In Touch With Us</strong>. We\'ll send a detailed summary so our team can help bring your locker room to life!',
				target: '#btn-request-quote'
			}
		];

		const fab = document.getElementById('guide-fab')!;
		const panel = document.getElementById('guide-panel')!;
		const btnMin = document.getElementById('guide-minimize')!;
		const btnPrev = document.getElementById('guide-prev') as HTMLButtonElement;
		const btnNext = document.getElementById('guide-next') as HTMLButtonElement;
		const stepTitle = document.getElementById('guide-step-title')!;
		const stepDesc = document.getElementById('guide-step-desc')!;
		const stepCount = document.getElementById('guide-step-count')!;
		const progressBar = document.getElementById('guide-progress-bar')!;

		let current = 0;
		let _highlightEl: Element | null = null;
		const STORAGE_KEY = 'ps_guide_collapsed';

		function renderStep() {
			const s = STEPS[current];
			stepTitle.textContent = s.title;
			stepDesc.innerHTML = s.desc;
			stepCount.textContent = `Step ${current + 1} of ${STEPS.length}`;
			progressBar.style.width = `${((current + 1) / STEPS.length) * 100}%`;
			btnPrev.disabled = current === 0;
			btnNext.textContent = current === STEPS.length - 1 ? 'Done ✓' : 'Next →';

			if (_highlightEl) {
				_highlightEl.classList.remove('guide-highlight', 'guide-pulse');
				_highlightEl = null;
			}
			if (s.target) {
				const el = document.querySelector(s.target);
				if (el) {
					_highlightEl = el;
					el.classList.add('guide-highlight', 'guide-pulse');
					el.scrollIntoView({ behavior: 'smooth', block: 'center' });
				}
			}
		}

		function goTo(step: number) {
			current = Math.max(0, Math.min(STEPS.length - 1, step));
			renderStep();
		}

		function advanceIfBefore(step: number) {
			if (current < step) goTo(step);
		}

		function show() {
			panel.classList.remove('hidden');
			fab.classList.add('hidden');
			localStorage.removeItem(STORAGE_KEY);
			renderStep();
		}

		function hide() {
			panel.classList.add('hidden');
			fab.classList.remove('hidden');
			localStorage.setItem(STORAGE_KEY, '1');
			if (_highlightEl) {
				_highlightEl.classList.remove('guide-highlight', 'guide-pulse');
				_highlightEl = null;
			}
		}

		btnMin.onclick = hide;
		fab.onclick = show;

		btnPrev.onclick = () => goTo(current - 1);
		btnNext.onclick = () => {
			if (current === STEPS.length - 1) { hide(); return; }
			goTo(current + 1);
		};

		// Auto-advance hooks
		const origApplyRoom = document.getElementById('btn-apply-room')!.onclick as Function | null;
		document.getElementById('btn-apply-room')!.addEventListener('click', () => {
			setTimeout(() => {
				if (state.walls.length > 0) advanceIfBefore(3);
			}, 100);
		});

		const origAddBtn = document.getElementById('lt-add-btn')!;
		origAddBtn.addEventListener('click', () => {
			setTimeout(() => {
				if (state.lockers.length > 0) advanceIfBefore(4);
			}, 100);
		});

		document.getElementById('btn-view-3d')!.addEventListener('click', () => {
			setTimeout(() => advanceIfBefore(6), 200);
		});

		document.getElementById('btn-3d-close')!.addEventListener('click', () => {
			setTimeout(() => advanceIfBefore(7), 100);
		});

		const orderSection = document.getElementById('order-section');
		if (orderSection) {
			const obs = new IntersectionObserver((entries) => {
				if (entries[0].isIntersecting) advanceIfBefore(7);
			}, { threshold: 0.2 });
			obs.observe(orderSection);
		}

		// Wall dimension auto-advance
		document.querySelectorAll('.wall-input').forEach(input => {
			input.addEventListener('change', () => {
				const aVal = (document.querySelector('[data-wall="wallA"]') as HTMLInputElement)?.value;
				const bVal = (document.querySelector('[data-wall="wallB"]') as HTMLInputElement)?.value;
				if (parseFloat(aVal) > 0 && parseFloat(bVal) > 0) advanceIfBefore(2);
			});
		});

		// Initialize
		if (localStorage.getItem(STORAGE_KEY) === '1') {
			panel.classList.add('hidden');
			fab.classList.remove('hidden');
		} else {
			fab.classList.add('hidden');
			panel.classList.remove('hidden');
			renderStep();
		}
	})();
</script>
