---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageDescription = 'Quick ship Stadium, Elite, and Model X lockers in 2–4 weeks (24" width). Custom-built lockers in 10–12 weeks. Premium wood, full color options. 30+ years of craftsmanship.';
---

<BaseLayout
	title="Shipping | PlayerStall"
	description={pageDescription}
>
	<!-- Hero Section (same as Shop) -->
	<section class="ship-hero-section">
		<div class="ship-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Shipping options for custom sports lockers" class="ship-hero-bg-image" />
		</div>
		<div class="ship-hero-background-overlay"></div>
		<div class="ship-hero-container">
			<div class="ship-breadcrumbs">
				<a href="/">Home</a>
				<span>Shipping</span>
			</div>
			<h1 class="ship-page-title">Shipping</h1>
		</div>
	</section>

	<!-- Quick Ship Lockers Section (same style as Custom Order) -->
	<section class="ship-quick-section">
		<div class="ship-quick-container">
			<div class="ship-quick-section-header">
				<p class="ship-quick-section-subtitle">DELIVERY TIMEFRAMES</p>
				<h2 class="ship-quick-section-title">QUICK SHIP LOCKERS</h2>
			</div>
			<div class="ship-quick-inner-centered">
				<div class="ship-quick-content-block">
					<a href="/services" class="ship-quick-position">Stadium, Elite &amp; Model X</a>
					<div class="ship-quick-meta">
						24&quot; width · 2–4 weeks · Lock box &amp; vented front included
					</div>
					<p class="ship-quick-bio">When you need lockers fast, we keep Stadium, Elite, and Model X ready to ship in 2–4 weeks. Each comes in one finish—black, dark grey, or light grey—at 24&quot; width with lock box and vented front standard. Same solid wood construction and 5-year warranty as our custom builds. We run production year-round so these are available when you need them, and we pass the savings on in our pricing.</p>
					<p class="ship-quick-includes-label">Each quick ship locker includes:</p>
					<ul class="ship-quick-includes">
						<li>Lock box</li>
						<li>Vented front panel</li>
						<li>Hooks</li>
						<li>24&quot; wide × 24&quot; deep (Stadium); 24&quot; width (Elite, Model X)</li>
						<li>5-year warranty</li>
					</ul>
					<div class="ship-quick-products">
						<article class="ship-quick-product">
							<div class="ship-quick-product-image">
								<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Stadium quick ship wood locker" loading="lazy" />
							</div>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name"><a href="/product-stadium-locker">Stadium</a></h3>
								<p class="ship-quick-product-price">$749</p>
								<p class="ship-quick-product-color">Black</p>
								<button type="button" class="ship-add-to-cart" data-product-id="stadium-quick-ship" data-product-name="Stadium Quick Ship" data-product-price="749" data-product-image="https://playerstall.b-cdn.net/images/legendary-locker.png">Add to cart</button>
							</div>
						</article>
						<article class="ship-quick-product">
							<div class="ship-quick-product-image">
								<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Elite quick ship wood locker" loading="lazy" />
							</div>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name"><a href="/product-elite-locker">Elite</a></h3>
								<p class="ship-quick-product-price">$749</p>
								<p class="ship-quick-product-color">Dark grey</p>
								<button type="button" class="ship-add-to-cart" data-product-id="elite-quick-ship" data-product-name="Elite Quick Ship" data-product-price="749" data-product-image="https://playerstall.b-cdn.net/images/legendary-locker.png">Add to cart</button>
							</div>
						</article>
						<article class="ship-quick-product">
							<div class="ship-quick-product-image">
								<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Model X quick ship wood locker" loading="lazy" />
							</div>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name"><a href="/product-legendary-locker">Model X</a></h3>
								<p class="ship-quick-product-price">$749</p>
								<p class="ship-quick-product-color">Light grey</p>
								<button type="button" class="ship-add-to-cart" data-product-id="model-x-quick-ship" data-product-name="Model X Quick Ship" data-product-price="749" data-product-image="https://playerstall.b-cdn.net/images/legendary-locker.png">Add to cart</button>
							</div>
						</article>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Custom Order Section (same style as homepage Materials We Use) -->
	<section id="custom-order" class="ship-custom-section">
		<div class="ship-custom-container">
			<div class="ship-custom-section-header ship-custom-section-header-spaced">
				<p class="ship-custom-section-subtitle">DELIVERY TIMEFRAMES</p>
				<h2 class="ship-custom-section-title">CUSTOM ORDER</h2>
			</div>
			<div class="ship-custom-inner-centered">
				<div class="ship-custom-content">
					<a href="/services" class="ship-custom-position">Explore custom lockers</a>
					<div class="ship-custom-meta">
						10–12 weeks | Any size &amp; configuration | Team colors, logos, name plates
					</div>
					<p class="ship-custom-bio">Need lockers built to your exact specs? Our custom order option gives you full control: any width and height, custom colors and wood finishes, team logos and graphics, name plates, and interior layouts. Every detail is tailored to your facility and brand. Includes a free design consultation so we can match your timeline and budget. Ideal for new builds, renovations, or programs that want a one-of-a-kind locker room.</p>
					<div class="ship-custom-buttons">
						<a href="/services" class="ship-custom-btn ship-custom-btn-outline">Explore options</a>
						<a href="/contact" class="ship-custom-btn ship-custom-btn-filled">Get custom quote</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	document.querySelectorAll('.ship-add-to-cart').forEach(function(btn) {
		btn.addEventListener('click', function() {
			const id = this.getAttribute('data-product-id') || '';
			const name = this.getAttribute('data-product-name') || '';
			const price = parseFloat(this.getAttribute('data-product-price') || '0') || 0;
			const image = this.getAttribute('data-product-image') || '';

			const cart = JSON.parse(localStorage.getItem('playerstall_cart') || '[]');
			const existing = cart.find(function(item) { return item.id === id; });
			if (existing) {
				existing.quantity += 1;
			} else {
				cart.push({ id, name, price, image, quantity: 1 });
			}
			localStorage.setItem('playerstall_cart', JSON.stringify(cart));

			const totalItems = cart.reduce(function(sum, item) { return sum + item.quantity; }, 0);
			window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: totalItems } }));

			const label = btn.textContent;
			btn.textContent = 'Added!';
			btn.classList.add('ship-add-to-cart-added');
			setTimeout(function() {
				btn.textContent = label;
				btn.classList.remove('ship-add-to-cart-added');
			}, 1500);
		});
	});
</script>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	/* Hero (mirrors shop) */
	.ship-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}
	.ship-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}
	.ship-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}
	.ship-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}
	.ship-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}
	.ship-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}
	.ship-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}
	.ship-breadcrumbs a:hover {
		color: #fe5900;
	}
	.ship-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}
	.ship-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	/* Quick ship section (same style as Custom Order) */
	.ship-quick-section {
		position: relative;
		padding: 100px 0;
		background: #ffffff;
		overflow: hidden;
	}
	.ship-quick-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		position: relative;
		z-index: 10;
	}
	.ship-quick-section-header {
		text-align: center;
		margin-bottom: 60px;
	}
	.ship-quick-section-subtitle {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 6px;
		text-transform: uppercase;
		color: #8c8c8c;
		margin-bottom: 10px;
	}
	.ship-quick-section-title {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(32px, 4vw, 52px);
		font-weight: 700;
		text-transform: uppercase;
		color: #0d0d0d;
		line-height: 1.1;
		margin: 0;
	}
	.ship-quick-inner-centered {
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
	}
	.ship-quick-position {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 4px;
		text-transform: uppercase;
		color: #8c8c8c;
		text-decoration: none;
	}
	.ship-quick-position:hover {
		color: #fe5900;
	}
	.ship-quick-meta {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 25px;
	}
	.ship-quick-bio {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		line-height: 1.8;
		color: #666666;
		margin-bottom: 24px;
	}
	.ship-quick-includes-label {
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #0d0d0d;
		margin: 0 0 12px;
	}
	.ship-quick-includes {
		list-style: none;
		margin: 0 auto 40px;
		padding: 0;
		display: inline-block;
		text-align: left;
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #666666;
		line-height: 1.8;
	}
	.ship-quick-includes li {
		position: relative;
		padding-left: 1.25em;
		margin-bottom: 6px;
	}
	.ship-quick-includes li::before {
		content: "·";
		position: absolute;
		left: 0;
		color: #fe5900;
		font-weight: 600;
	}
	.ship-quick-products {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
		align-items: start;
		text-align: center;
	}
	.ship-quick-product {
		background: #fff;
		border: 1px solid #eee;
		overflow: hidden;
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	.ship-quick-product:hover {
		border-color: #ddd;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
	}
	.ship-quick-product-image {
		aspect-ratio: 4 / 3;
		background: #f9f9f9;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 24px;
	}
	.ship-quick-product-image img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}
	.ship-quick-product-details {
		padding: 24px 20px 28px;
	}
	.ship-quick-product-name {
		font-family: 'Oswald', sans-serif;
		font-size: 22px;
		font-weight: 600;
		text-transform: uppercase;
		color: #0d0d0d;
		margin: 0 0 8px;
		line-height: 1.2;
	}
	.ship-quick-product-name a {
		color: inherit;
		text-decoration: none;
		transition: color 0.2s;
	}
	.ship-quick-product-name a:hover {
		color: #fe5900;
	}
	.ship-quick-product-price {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		margin: 0 0 4px;
	}
	.ship-quick-product-color {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 20px;
		text-transform: capitalize;
	}
	.ship-add-to-cart {
		display: inline-block;
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		background: #fe5900;
		color: #ffffff;
		border: none;
		padding: 12px 24px;
		cursor: pointer;
		transition: background 0.2s;
	}
	.ship-add-to-cart:hover {
		background: #e04f00;
	}
	.ship-add-to-cart-added {
		background: #0d0d0d;
	}
	/* Custom order section (same style as homepage Materials We Use) */
	.ship-custom-section {
		position: relative;
		padding: 100px 0;
		background: #ffffff;
		overflow: hidden;
	}
	.ship-custom-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		position: relative;
		z-index: 10;
	}
	.ship-custom-section-header {
		text-align: center;
		margin-bottom: 60px;
	}
	.ship-custom-section-header-spaced {
		margin-top: 60px;
	}
	.ship-custom-section-subtitle {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 6px;
		text-transform: uppercase;
		color: #8c8c8c;
		margin-bottom: 10px;
	}
	.ship-custom-section-title {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(32px, 4vw, 52px);
		font-weight: 700;
		text-transform: uppercase;
		color: #0d0d0d;
		line-height: 1.1;
		margin: 0;
	}
	.ship-custom-inner-centered {
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
	}
	.ship-custom-position {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 4px;
		text-transform: uppercase;
		color: #8c8c8c;
		text-decoration: none;
	}
	.ship-custom-position:hover {
		color: #fe5900;
	}
	.ship-custom-meta {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 25px;
	}
	.ship-custom-bio {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		line-height: 1.8;
		color: #666666;
		margin-bottom: 30px;
	}
	.ship-custom-buttons {
		text-align: center;
		margin-top: 30px;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 16px;
	}
	.ship-custom-btn {
		display: inline-block;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		text-decoration: none;
		padding: 12px 24px;
		border: 2px solid transparent;
		transition: background 0.2s, border-color 0.2s, color 0.2s;
	}
	.ship-custom-btn-outline {
		border-color: #0d0d0d;
		color: #0d0d0d;
	}
	.ship-custom-btn-outline:hover {
		background: #0d0d0d;
		color: #ffffff;
	}
	.ship-custom-btn-filled {
		background: #000000;
		color: #ffffff;
		border-color: #000000;
	}
	.ship-custom-btn-filled:hover {
		background: #fe5900;
		border-color: #fe5900;
		color: #ffffff;
	}

	@media (max-width: 1024px) {
		.ship-quick-products {
			grid-template-columns: 1fr;
			gap: 40px;
			max-width: 400px;
			margin: 0 auto;
		}
	}
	@media (max-width: 768px) {
		.ship-hero-section {
			min-height: 260px;
			padding-bottom: 50px;
		}
		.ship-page-title {
			font-size: 42px;
		}
		.ship-quick-section-title,
		.ship-custom-section-title {
			font-size: 32px;
		}
		.ship-quick-product-name {
			font-size: 20px;
		}
		.ship-custom-buttons {
			flex-direction: column;
		}
	}
	@media (max-width: 640px) {
		.ship-page-title {
			font-size: 32px;
		}
	}
</style>
