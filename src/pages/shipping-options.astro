---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageDescription = 'Custom-built wood sports lockers in 8–12 weeks. Any size, any configuration. Team colors, logos, name plates. Premium wood, full color options. 30+ years of craftsmanship.';
---

<BaseLayout
	title="Shipping | PlayerStall"
	description={pageDescription}
>
	<!-- Hero -->
	<section class="ship-hero-section">
		<div class="ship-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Shipping options for custom sports lockers" class="ship-hero-bg-image" />
		</div>
		<div class="ship-hero-background-overlay"></div>
		<div class="ship-hero-container">
			<div class="ship-breadcrumbs">
				<a href="/">Home</a>
				<span>Shipping</span>
			</div>
			<h1 class="ship-page-title">Shipping</h1>
		</div>
	</section>

	<!-- Two options at top (like By Sport page) -->
	<section class="ship-options-section">
		<div class="ship-options-container">
			<p class="ship-options-intro">Choose your delivery option below.</p>
			<div class="ship-options-list">
				<a href="/shipping-options/custom" class="ship-options-list-item">
					<span class="ship-options-list-label">Custom</span>
					<span class="ship-options-list-desc">8–12 weeks · Any size &amp; configuration · Team colors, logos, name plates.</span>
				</a>
				<a href="#packaging-assembly" class="ship-options-list-item">
					<span class="ship-options-list-label">Packaging &amp; assembly</span>
					<span class="ship-options-list-desc">Individual flat-pack boxes · IKEA-style instructions · ~25–30 min assembly per locker.</span>
				</a>
			</div>
		</div>
	</section>

	<!-- Quick Ship section removed – archived to archives/quick-ship/quick-ship.astro -->

	<!-- Custom Order Section (Materials We Use style) -->
	<section id="custom-order" class="home-shop-section">
		<div class="home-shop-container">
			<div class="home-shop-section-header">
				<p class="home-shop-section-subtitle">DELIVERY TIMEFRAMES</p>
				<h2 class="home-shop-section-title">CUSTOM ORDER</h2>
			</div>
			<div class="ts-spotlight-inner-centered">
				<div class="ts-spotlight-content">
					<a href="/products" class="ts-spotlight-position">Explore custom lockers</a>
					<div class="ts-spotlight-meta">
						8–12 weeks | Any size &amp; configuration | Team colors, logos, name plates
					</div>
					<p class="ts-spotlight-bio">Need lockers built to your exact specs? Our custom order option gives you full control: any width and height, custom colors and wood finishes, team logos and graphics, name plates, and interior layouts. Every detail is tailored to your facility and brand. Includes a free design consultation so we can match your timeline and budget. Ideal for new builds, renovations, or programs that want a one-of-a-kind locker room.</p>
					<div class="ship-custom-buttons">
						<a href="/shop" class="ship-custom-btn ship-custom-btn-outline">Explore options</a>
						<a href="/request-a-quote" class="ship-custom-btn ship-custom-btn-filled">Get custom quote</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Packaging & assembly instructions -->
	<section id="packaging-assembly" class="home-shop-section ship-instructions-section">
		<div class="home-shop-container">
			<div class="home-shop-section-header">
				<p class="home-shop-section-subtitle">PACKAGING &amp; ASSEMBLY</p>
				<h2 class="home-shop-section-title">SHIPPING INSTRUCTIONS</h2>
			</div>
			<div class="ts-spotlight-inner-centered">
				<div class="ts-spotlight-content ship-instructions-content">
					<p class="ship-instructions-lead">Our lockers are shipped <strong>individually packed</strong> in most cases—each unit arrives in its own sturdy, flat-pack box, similar to premium flat-pack furniture. This keeps every locker protected in transit and makes handling and assembly straightforward.</p>
					<p class="ship-instructions-body">Each box contains all panels, hardware, and a <strong>full set of step-by-step instructions</strong> in an easy-to-follow, IKEA-style format. Plan for <strong>approximately 25–30 minutes</strong> to assemble each locker once the box is opened. No special tools are required beyond what we include or you typically have on hand.</p>

					<h3 class="ship-instructions-subtitle">Typical box dimensions</h3>
					<p class="ship-instructions-body">Exact package size depends on the locker model and configuration. Below are two representative examples of how our lockers ship flat-packed.</p>

					<div class="ship-instructions-boxes">
						<div class="ship-instructions-box-card">
							<figure class="ship-instructions-figure">
								<img src="/images/locker-packaging-flatpack-1.png" alt="Flat-packed locker packaging – stacked panels, dimensions 75.59&quot; length × 23.62&quot; width × 4.25&quot; height" loading="lazy" />
								<figcaption class="ship-instructions-caption">Representative flat-pack (smaller footprint)</figcaption>
							</figure>
							<ul class="ship-instructions-dims">
								<li><strong>Length:</strong> 75.59&quot;</li>
								<li><strong>Width:</strong> 23.62&quot;</li>
								<li><strong>Height:</strong> 4.25&quot;</li>
							</ul>
						</div>
						<div class="ship-instructions-box-card">
							<figure class="ship-instructions-figure">
								<img src="/images/locker-packaging-flatpack-2.png" alt="Flat-packed locker in shipping box – dimensions 81.87&quot; length × 27.62&quot; width × 6.98&quot; height" loading="lazy" />
								<figcaption class="ship-instructions-caption">Representative flat-pack (larger footprint)</figcaption>
							</figure>
							<ul class="ship-instructions-dims">
								<li><strong>Length:</strong> 81.87&quot;</li>
								<li><strong>Width:</strong> 27.62&quot;</li>
								<li><strong>Height:</strong> 6.98&quot;</li>
							</ul>
						</div>
					</div>

					<div class="ship-instructions-summary">
						<p><strong>Included with each locker:</strong> flat-packed components in one box, full IKEA-style assembly instructions, and hardware. Assembly time: about 25–30 minutes per locker.</p>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	/* Hero */
	.ship-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}
	.ship-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}
	.ship-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}
	.ship-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}
	.ship-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}
	.ship-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}
	.ship-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}
	.ship-breadcrumbs a:hover {
		color: #fe5900;
	}
	.ship-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}
	.ship-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	/* Options list at top (like By Sport page) */
	.ship-options-section {
		padding: 60px 0;
		background: #ffffff;
	}
	.ship-options-container {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 20px;
	}
	.ship-options-intro {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		line-height: 1.7;
		color: #666666;
		margin: 0 0 1.5rem 0;
	}
	.ship-options-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.ship-options-list-item {
		display: block;
		padding: 1rem 0;
		border-bottom: 1px solid #e8e8e8;
		text-decoration: none;
		color: inherit;
		transition: background 0.2s, color 0.2s;
	}
	.ship-options-list-item:hover {
		background: #f7f7f7;
		color: #fe5900;
	}
	.ship-options-list-label {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		text-transform: uppercase;
		display: block;
		margin-bottom: 0.25rem;
	}
	.ship-options-list-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		line-height: 1.5;
	}

	/* Materials We Use style (same as home page) */
	.home-shop-section {
		position: relative;
		padding: 100px 0;
		background: #ffffff;
		overflow: hidden;
	}
	.home-shop-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		position: relative;
		z-index: 10;
	}
	.home-shop-section-header {
		text-align: center;
		margin-bottom: 60px;
	}
	.home-shop-section-header-spaced {
		margin-top: 140px;
	}
	.home-shop-section-subtitle {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 6px;
		text-transform: uppercase;
		color: #8c8c8c;
		margin-bottom: 10px;
	}
	.home-shop-section-title {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(32px, 4vw, 52px);
		font-weight: 700;
		text-transform: uppercase;
		color: #0d0d0d;
		line-height: 1.1;
		margin: 0;
	}
	.ts-spotlight-inner-centered {
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
	}
	.ts-spotlight-position {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 4px;
		text-transform: uppercase;
		color: #8c8c8c;
		text-decoration: none;
	}
	.ts-spotlight-position:hover {
		color: #fe5900;
	}
	.ts-spotlight-meta {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 25px;
	}
	.ts-spotlight-meta a {
		color: #fe5900;
		text-decoration: none;
	}
	.ts-spotlight-meta a:hover {
		text-decoration: underline;
	}
	.ts-spotlight-bio {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		line-height: 1.8;
		color: #666666;
		margin-bottom: 30px;
	}

	.ship-quick-accessories-hint {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 32px;
		text-align: center;
	}
	.ship-quick-product-image-btn {
		display: block;
		width: 100%;
		padding: 0;
		border: none;
		background: none;
		cursor: pointer;
		text-align: left;
	}
	.ship-quick-acc-modal {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 20px;
	}
	.ship-quick-acc-modal[hidden] {
		display: none;
	}
	.ship-quick-acc-modal-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
	}
	.ship-quick-acc-modal-box {
		position: relative;
		z-index: 1;
		background: #fff;
		border-radius: 8px;
		padding: 32px 24px 24px;
		max-width: 460px;
		width: 100%;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
	}
	.ship-quick-acc-modal-close {
		position: absolute;
		top: 12px;
		right: 12px;
		width: 36px;
		height: 36px;
		border: none;
		background: #eee;
		color: #0d0d0d;
		font-size: 24px;
		line-height: 1;
		cursor: pointer;
		border-radius: 4px;
		transition: background 0.2s;
	}
	.ship-quick-acc-modal-close:hover {
		background: #fe5900;
		color: #fff;
	}
	.ship-quick-acc-modal .ship-quick-accessories {
		margin-bottom: 0;
		text-align: center;
	}
	.ship-quick-accessories {
		margin-bottom: 48px;
		text-align: center;
	}
	.ship-quick-accessories-label {
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #0d0d0d;
		margin: 0 0 16px;
	}
	.ship-quick-accessories-window {
		max-width: 420px;
		margin: 0 auto;
		background: #f9f9f9;
		border: 1px solid #eee;
		padding: 24px;
		border-radius: 4px;
	}
	.ship-quick-accessories-slider {
		position: relative;
		overflow: hidden;
		border-radius: 4px;
		background: #fff;
	}
	.ship-quick-accessories-track {
		display: flex;
		width: 400%;
		transition: transform 0.35s ease;
	}
	.ship-quick-accessories-slide {
		flex: 0 0 25%;
		width: 25%;
	}
	.ship-quick-accessories-image {
		aspect-ratio: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 20px;
		background: #fff;
	}
	.ship-quick-accessories-image img {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
	}
	.ship-quick-accessories-image--lock-box img {
		max-width: 115px;
		max-height: 115px;
	}
	.ship-quick-accessories-prev,
	.ship-quick-accessories-next {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		width: 40px;
		height: 40px;
		border: none;
		background: rgba(0,0,0,0.5);
		color: #fff;
		font-size: 24px;
		line-height: 1;
		cursor: pointer;
		z-index: 2;
		transition: background 0.2s;
		border-radius: 4px;
	}
	.ship-quick-accessories-prev:hover,
	.ship-quick-accessories-next:hover {
		background: #fe5900;
	}
	.ship-quick-accessories-prev { left: 8px; }
	.ship-quick-accessories-next { right: 8px; }
	.ship-quick-accessories-dots {
		display: flex;
		justify-content: center;
		gap: 8px;
		padding: 12px 0;
	}
	.ship-quick-acc-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		border: 2px solid #8c8c8c;
		background: transparent;
		cursor: pointer;
		transition: background 0.2s, border-color 0.2s;
		padding: 0;
	}
	.ship-quick-acc-dot.active,
	.ship-quick-acc-dot:hover {
		background: #fe5900;
		border-color: #fe5900;
	}
	.ship-quick-accessories-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		line-height: 1.6;
		color: #666;
		margin: 0;
		padding-top: 12px;
		min-height: 2.5em;
	}

	.ship-quick-line {
		margin-bottom: 96px;
	}
	.ship-quick-line:last-of-type {
		margin-bottom: 0;
	}
	.ship-quick-line-title {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(26px, 3.2vw, 42px);
		font-weight: 700;
		text-transform: uppercase;
		color: #0d0d0d;
		margin: 0 0 32px;
		line-height: 1.1;
	}
	.ship-quick-line-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		line-height: 2;
		letter-spacing: 0.02em;
		color: #666;
		margin: 0 0 28px;
	}
	.ship-quick-products {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
		align-items: start;
		text-align: center;
	}
	.ship-quick-products-row-2 {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
		align-items: start;
		text-align: center;
		margin-top: 32px;
	}
	.ship-quick-product {
		background: #fff;
		border: 1px solid #eee;
		overflow: hidden;
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	.ship-quick-product:hover {
		border-color: #ddd;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
	}
	.ship-quick-product-image {
		aspect-ratio: 4 / 3;
		background: #f9f9f9;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 24px;
	}
	.ship-quick-product-image img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}
	.ship-quick-product-details {
		padding: 24px 20px 28px;
	}
	.ship-quick-product-name {
		font-family: 'Oswald', sans-serif;
		font-size: 22px;
		font-weight: 600;
		text-transform: uppercase;
		color: #0d0d0d;
		margin: 0 0 8px;
		line-height: 1.2;
	}
	.ship-quick-product-name a {
		color: inherit;
		text-decoration: none;
		transition: color 0.2s;
	}
	.ship-quick-product-name a:hover {
		color: #fe5900;
	}
	.ship-quick-product-price {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		margin: 0 0 4px;
	}
	.ship-quick-product-color {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 20px;
		text-transform: capitalize;
	}
	.ship-add-to-cart {
		display: inline-block;
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		background: #fe5900;
		color: #ffffff;
		border: none;
		padding: 12px 24px;
		cursor: pointer;
		transition: background 0.2s;
	}
	.ship-add-to-cart:hover {
		background: #e04f00;
	}
	.ship-add-to-cart-added {
		background: #0d0d0d;
	}
	.ship-view-details {
		display: inline-block;
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		background: transparent;
		color: #0d0d0d;
		border: 2px solid #0d0d0d;
		padding: 12px 24px;
		text-decoration: none;
		transition: background 0.2s, color 0.2s, border-color 0.2s;
	}
	.ship-view-details:hover {
		background: #fe5900;
		border-color: #fe5900;
		color: #ffffff;
	}

	.ship-custom-buttons {
		text-align: center;
		margin-top: 30px;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 16px;
	}
	.ship-custom-btn {
		display: inline-block;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		text-decoration: none;
		padding: 12px 24px;
		border: 2px solid transparent;
		transition: background 0.2s, border-color 0.2s, color 0.2s;
	}
	.ship-custom-btn-outline {
		border-color: #0d0d0d;
		color: #0d0d0d;
	}
	.ship-custom-btn-outline:hover {
		background: #0d0d0d;
		color: #ffffff;
	}
	.ship-custom-btn-filled {
		background: #000000;
		color: #ffffff;
		border-color: #000000;
	}
	.ship-custom-btn-filled:hover {
		background: #fe5900;
		border-color: #fe5900;
		color: #ffffff;
	}

	/* Packaging & assembly instructions */
	.ship-instructions-section {
		background: #f7f7f7;
	}
	.ship-instructions-content {
		max-width: 820px;
		margin: 0 auto;
		text-align: left;
	}
	.ship-instructions-lead {
		font-family: 'Yantramanav', sans-serif;
		font-size: 17px;
		line-height: 1.7;
		color: #0d0d0d;
		margin: 0 0 1rem;
	}
	.ship-instructions-body {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		line-height: 1.75;
		color: #555;
		margin: 0 0 1.5rem;
	}
	.ship-instructions-subtitle {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #0d0d0d;
		margin: 2rem 0 0.75rem;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid #fe5900;
	}
	.ship-instructions-boxes {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		margin: 2rem 0;
