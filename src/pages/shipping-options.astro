---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageDescription = 'Quick ship Model S, Model Z, and Model X lockers in 2–4 weeks (24" width). Custom-built lockers in 10–12 weeks. Premium wood, full color options. 30+ years of craftsmanship.';
---

<BaseLayout
	title="Shipping | PlayerStall"
	description={pageDescription}
>
	<!-- Hero -->
	<section class="ship-hero-section">
		<div class="ship-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Shipping options for custom sports lockers" class="ship-hero-bg-image" />
		</div>
		<div class="ship-hero-background-overlay"></div>
		<div class="ship-hero-container">
			<div class="ship-breadcrumbs">
				<a href="/">Home</a>
				<span>Shipping</span>
			</div>
			<h1 class="ship-page-title">Shipping</h1>
		</div>
	</section>

	<!-- Two options at top (like By Sport page) -->
	<section class="ship-options-section">
		<div class="ship-options-container">
			<p class="ship-options-intro">Choose your delivery option below.</p>
			<div class="ship-options-list">
				<a href="/shipping-options/quick-ship" class="ship-options-list-item">
					<span class="ship-options-list-label">Quick Ship</span>
					<span class="ship-options-list-desc">2–4 weeks · Model S, Model Z &amp; Model X · Lock box &amp; vented front included.</span>
				</a>
				<a href="/shipping-options/custom" class="ship-options-list-item">
					<span class="ship-options-list-label">Custom</span>
					<span class="ship-options-list-desc">10–12 weeks · Any size &amp; configuration · Team colors, logos, name plates.</span>
				</a>
			</div>
		</div>
	</section>

	<!-- Quick Ship Lockers Section (Materials We Use style) -->
	<section id="quick-ship" class="home-shop-section">
		<div class="home-shop-container">
			<div class="home-shop-section-header">
				<p class="home-shop-section-subtitle">DELIVERY TIMEFRAMES</p>
				<h2 class="home-shop-section-title">QUICK SHIP LOCKERS</h2>
			</div>
			<div class="ts-spotlight-inner-centered">
				<div class="ts-spotlight-content">
					<a href="/products" class="ts-spotlight-position">Model S, Model Z &amp; Model X</a>
					<div class="ts-spotlight-meta">
						24&quot; width · 2–4 weeks · Lock box &amp; vented front included
					</div>
					<p class="ts-spotlight-bio">When you need lockers fast, we keep Model S, Model Z, and Model X ready to ship in 2–4 weeks. Each comes in one finish—black, dark grey, or light grey—at 24&quot; width with lock box and vented front standard. Same solid wood construction and 5-year warranty as our custom builds. We run production year-round so these are available when you need them, and we pass the savings on in our pricing.</p>
					<p class="ship-quick-accessories-hint">Click any locker image below to see what’s included.</p>
					<div class="ship-quick-line">
						<h3 class="ship-quick-line-title">Colored melamine</h3>
						<p class="ship-quick-line-desc">Durable, moisture-resistant finish in black, dark grey, or light grey. Easy to clean and built for heavy use in locker rooms. Melamine holds up to bumps, spills, and daily wear while keeping a consistent, professional look across your space.</p>
					<div class="ship-quick-products">
						<article class="ship-quick-product">
							<button type="button" class="ship-quick-product-image ship-quick-product-image-btn" aria-label="View what’s included with Stadium">
								<img src="/images/stadium-locker.png" alt="Model S quick ship wood locker" loading="lazy" />
							</button>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name"><a href="/product-stadium-locker">Model S</a></h3>
								<p class="ship-quick-product-price">$749</p>
								<p class="ship-quick-product-color">Black</p>
								<button type="button" class="ship-add-to-cart" data-product-id="stadium-quick-ship" data-product-name="Model S Quick Ship" data-product-price="749" data-product-image="/images/stadium-locker.png">Add to cart</button>
							</div>
						</article>
						<article class="ship-quick-product">
							<button type="button" class="ship-quick-product-image ship-quick-product-image-btn" aria-label="View what’s included with Elite">
								<img src="/images/elite-locker.png" alt="Model Z quick ship wood locker" loading="lazy" />
							</button>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name"><a href="/product-elite-locker">Model Z</a></h3>
								<p class="ship-quick-product-price">$749</p>
								<p class="ship-quick-product-color">Dark grey</p>
								<button type="button" class="ship-add-to-cart" data-product-id="elite-quick-ship" data-product-name="Model Z Quick Ship" data-product-price="749" data-product-image="/images/elite-locker.png">Add to cart</button>
							</div>
						</article>
						<article class="ship-quick-product">
							<button type="button" class="ship-quick-product-image ship-quick-product-image-btn" aria-label="View what’s included with Model X">
								<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Model X quick ship wood locker" loading="lazy" />
							</button>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name"><a href="/product-legendary-locker">Model X</a></h3>
								<p class="ship-quick-product-price">$749</p>
								<p class="ship-quick-product-color">Light grey</p>
								<button type="button" class="ship-add-to-cart" data-product-id="model-x-quick-ship" data-product-name="Model X Quick Ship" data-product-price="749" data-product-image="https://playerstall.b-cdn.net/images/legendary-locker.png">Add to cart</button>
							</div>
						</article>
					</div>
					</div>
					<div class="ship-quick-line">
						<h3 class="ship-quick-line-title">Maple cabinetry grade plywood</h3>
						<p class="ship-quick-line-desc">Premium hardwood tops for a classic look and long-lasting durability. Maple is used for the top of the locker, where it adds strength and a natural wood finish that pairs well with any team colors or facility style.</p>
					<div class="ship-quick-products ship-quick-products-row-2">
						<article class="ship-quick-product">
							<button type="button" class="ship-quick-product-image ship-quick-product-image-btn" aria-label="View what’s included with Semi Pro">
								<img src="https://playerstall.b-cdn.net/images/semi-pro-locker-new.png" alt="Semi Pro wood locker" loading="lazy" />
							</button>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name"><a href="/product-semi-pro-locker">Semi Pro</a></h3>
								<p class="ship-quick-product-price">$349</p>
								<p class="ship-quick-product-color">Custom order</p>
								<a href="/product-semi-pro-locker" class="ship-view-details">View details</a>
							</div>
						</article>
						<article class="ship-quick-product">
							<button type="button" class="ship-quick-product-image ship-quick-product-image-btn" aria-label="View what’s included with Varsity">
								<img src="/images/varsity-locker.png" alt="Varsity wood locker" loading="lazy" />
							</button>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name"><a href="/product-varsity-locker">Varsity</a></h3>
								<p class="ship-quick-product-price">$449</p>
								<p class="ship-quick-product-color">Custom order</p>
								<a href="/product-varsity-locker" class="ship-view-details">View details</a>
							</div>
						</article>
						<article class="ship-quick-product">
							<button type="button" class="ship-quick-product-image ship-quick-product-image-btn" aria-label="View what’s included with Pro">
								<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Pro wood locker" loading="lazy" />
							</button>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name"><a href="/product-pro-locker">Pro</a></h3>
								<p class="ship-quick-product-price">$649</p>
								<p class="ship-quick-product-color">Custom order</p>
								<a href="/product-pro-locker" class="ship-view-details">View details</a>
							</div>
						</article>
						<article class="ship-quick-product">
							<button type="button" class="ship-quick-product-image ship-quick-product-image-btn" aria-label="View what’s included with Stadium">
								<img src="/images/stadium-locker.png" alt="Model S wood locker" loading="lazy" />
							</button>
							<div class="ship-quick-product-details">
								<h3 class="ship-quick-product-name"><a href="/product-stadium-locker">Model S</a></h3>
								<p class="ship-quick-product-price">$649</p>
								<p class="ship-quick-product-color">Custom order</p>
								<a href="/product-stadium-locker" class="ship-view-details">View details</a>
							</div>
						</article>
					</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Accessories modal (opens when clicking a locker image) -->
	<div id="ship-quick-acc-modal" class="ship-quick-acc-modal" role="dialog" aria-modal="true" aria-labelledby="ship-quick-acc-modal-title" hidden>
		<div class="ship-quick-acc-modal-backdrop"></div>
		<div class="ship-quick-acc-modal-box">
			<button type="button" class="ship-quick-acc-modal-close" aria-label="Close">&times;</button>
			<div class="ship-quick-accessories">
				<p id="ship-quick-acc-modal-title" class="ship-quick-accessories-label">Each quick ship locker includes</p>
				<div class="ship-quick-accessories-window">
					<div class="ship-quick-accessories-slider">
						<div class="ship-quick-accessories-track" id="ship-quick-acc-track">
							<div class="ship-quick-accessories-slide">
								<div class="ship-quick-accessories-image ship-quick-accessories-image--lock-box"><img src="/images/lock-box.png" alt="Lock box" loading="lazy" /></div>
							</div>
							<div class="ship-quick-accessories-slide">
								<div class="ship-quick-accessories-image"><img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Vented front panel" loading="lazy" /></div>
							</div>
							<div class="ship-quick-accessories-slide">
								<div class="ship-quick-accessories-image"><img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Hooks" loading="lazy" /></div>
							</div>
							<div class="ship-quick-accessories-slide">
								<div class="ship-quick-accessories-image"><img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Dimensions and warranty" loading="lazy" /></div>
							</div>
						</div>
						<button type="button" class="ship-quick-accessories-prev" id="ship-quick-acc-prev" aria-label="Previous">‹</button>
						<button type="button" class="ship-quick-accessories-next" id="ship-quick-acc-next" aria-label="Next">›</button>
						<div class="ship-quick-accessories-dots" id="ship-quick-acc-dots">
							<button type="button" class="ship-quick-acc-dot active" data-index="0" aria-label="Slide 1"></button>
							<button type="button" class="ship-quick-acc-dot" data-index="1" aria-label="Slide 2"></button>
							<button type="button" class="ship-quick-acc-dot" data-index="2" aria-label="Slide 3"></button>
							<button type="button" class="ship-quick-acc-dot" data-index="3" aria-label="Slide 4"></button>
						</div>
					</div>
					<div class="ship-quick-accessories-desc" id="ship-quick-acc-desc">Secure lock box with slow-closing hinge for valuables. Included with every quick ship locker.</div>
				</div>
				<div class="ship-quick-accessories-captions" id="ship-quick-acc-captions" hidden>
					<p data-index="0">Secure lock box with slow-closing hinge for valuables. Included with every quick ship locker.</p>
					<p data-index="1">Vented front panel for airflow to keep gear dry and reduce odor. Standard on all quick ship models.</p>
					<p data-index="2">Interior hooks for bags, helmets, and everyday gear. Standard layout included.</p>
					<p data-index="3">24&quot; width (Model S 24&quot; deep). Full 5-year warranty on every quick ship locker.</p>
				</div>
			</div>
		</div>
	</div>

	<!-- Custom Order Section (Materials We Use style) -->
	<section id="custom-order" class="home-shop-section">
		<div class="home-shop-container">
			<div class="home-shop-section-header home-shop-section-header-spaced">
				<p class="home-shop-section-subtitle">DELIVERY TIMEFRAMES</p>
				<h2 class="home-shop-section-title">CUSTOM ORDER</h2>
			</div>
			<div class="ts-spotlight-inner-centered">
				<div class="ts-spotlight-content">
					<a href="/products" class="ts-spotlight-position">Explore custom lockers</a>
					<div class="ts-spotlight-meta">
						10–12 weeks | Any size &amp; configuration | Team colors, logos, name plates
					</div>
					<p class="ts-spotlight-bio">Need lockers built to your exact specs? Our custom order option gives you full control: any width and height, custom colors and wood finishes, team logos and graphics, name plates, and interior layouts. Every detail is tailored to your facility and brand. Includes a free design consultation so we can match your timeline and budget. Ideal for new builds, renovations, or programs that want a one-of-a-kind locker room.</p>
					<div class="ship-custom-buttons">
						<a href="/products" class="ship-custom-btn ship-custom-btn-outline">Explore options</a>
						<a href="/contact" class="ship-custom-btn ship-custom-btn-filled">Get custom quote</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	document.querySelectorAll('.ship-add-to-cart').forEach(function(btn) {
		btn.addEventListener('click', function() {
			const id = this.getAttribute('data-product-id') || '';
			const name = this.getAttribute('data-product-name') || '';
			const price = parseFloat(this.getAttribute('data-product-price') || '0') || 0;
			const image = this.getAttribute('data-product-image') || '';
			const cart = JSON.parse(localStorage.getItem('playerstall_cart') || '[]');
			const existing = cart.find(function(item) { return item.id === id; });
			if (existing) existing.quantity += 1;
			else cart.push({ id, name, price, image, quantity: 1 });
			localStorage.setItem('playerstall_cart', JSON.stringify(cart));
			const totalItems = cart.reduce(function(sum, item) { return sum + item.quantity; }, 0);
			window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: totalItems } }));
			const label = btn.textContent;
			btn.textContent = 'Added!';
			btn.classList.add('ship-add-to-cart-added');
			setTimeout(function() { btn.textContent = label; btn.classList.remove('ship-add-to-cart-added'); }, 1500);
		});
	});
	(function() {
		var track = document.getElementById('ship-quick-acc-track');
		var desc = document.getElementById('ship-quick-acc-desc');
		var captions = document.getElementById('ship-quick-acc-captions');
		var prev = document.getElementById('ship-quick-acc-prev');
		var next = document.getElementById('ship-quick-acc-next');
		var dots = document.getElementById('ship-quick-acc-dots');
		if (!track || !desc || !captions) return;
		var slides = track.querySelectorAll('.ship-quick-accessories-slide');
		var captionsList = captions.querySelectorAll('p[data-index]');
		var index = 0;
		var total = slides.length;
		function goTo(i) {
			index = (i + total) % total;
			track.style.transform = 'translateX(-' + index * 100 + '%)';
			desc.textContent = captionsList[index] ? captionsList[index].textContent : '';
			if (dots) {
				dots.querySelectorAll('.ship-quick-acc-dot').forEach(function(dot, j) {
					dot.classList.toggle('active', j === index);
					dot.setAttribute('aria-current', j === index ? 'true' : null);
				});
			}
		}
		if (prev) prev.addEventListener('click', function() { goTo(index - 1); });
		if (next) next.addEventListener('click', function() { goTo(index + 1); });
		if (dots) dots.querySelectorAll('.ship-quick-acc-dot').forEach(function(dot) {
			dot.addEventListener('click', function() { goTo(parseInt(dot.getAttribute('data-index'), 10)); });
		});
	})();
	(function() {
		var modal = document.getElementById('ship-quick-acc-modal');
		var backdrop = modal && modal.querySelector('.ship-quick-acc-modal-backdrop');
		var closeBtn = modal && modal.querySelector('.ship-quick-acc-modal-close');
		function openModal() {
			if (modal) {
				modal.hidden = false;
				modal.removeAttribute('hidden');
				document.body.style.overflow = 'hidden';
			}
		}
		function closeModal() {
			if (modal) {
				modal.hidden = true;
				modal.setAttribute('hidden', '');
				document.body.style.overflow = '';
			}
		}
		document.querySelectorAll('.ship-quick-product-image-btn').forEach(function(btn) {
			btn.addEventListener('click', openModal);
		});
		if (closeBtn) closeBtn.addEventListener('click', closeModal);
		if (backdrop) backdrop.addEventListener('click', closeModal);
	})();
</script>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	/* Hero */
	.ship-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}
	.ship-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}
	.ship-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}
	.ship-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}
	.ship-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}
	.ship-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}
	.ship-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}
	.ship-breadcrumbs a:hover {
		color: #fe5900;
	}
	.ship-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}
	.ship-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	/* Options list at top (like By Sport page) */
	.ship-options-section {
		padding: 60px 0;
		background: #ffffff;
	}
	.ship-options-container {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 20px;
	}
	.ship-options-intro {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		line-height: 1.7;
		color: #666666;
		margin: 0 0 1.5rem 0;
	}
	.ship-options-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.ship-options-list-item {
		display: block;
		padding: 1rem 0;
		border-bottom: 1px solid #e8e8e8;
		text-decoration: none;
		color: inherit;
		transition: background 0.2s, color 0.2s;
	}
	.ship-options-list-item:hover {
		background: #f7f7f7;
		color: #fe5900;
	}
	.ship-options-list-label {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		text-transform: uppercase;
		display: block;
		margin-bottom: 0.25rem;
	}
	.ship-options-list-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		line-height: 1.5;
	}

	/* Materials We Use style (same as home page) */
	.home-shop-section {
		position: relative;
		padding: 100px 0;
		background: #ffffff;
		overflow: hidden;
	}
	.home-shop-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		position: relative;
		z-index: 10;
	}
	.home-shop-section-header {
		text-align: center;
		margin-bottom: 60px;
	}
	.home-shop-section-header-spaced {
		margin-top: 140px;
	}
	.home-shop-section-subtitle {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 6px;
		text-transform: uppercase;
		color: #8c8c8c;
		margin-bottom: 10px;
	}
	.home-shop-section-title {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(32px, 4vw, 52px);
		font-weight: 700;
		text-transform: uppercase;
		color: #0d0d0d;
		line-height: 1.1;
		margin: 0;
	}
	.ts-spotlight-inner-centered {
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
	}
	.ts-spotlight-position {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 4px;
		text-transform: uppercase;
		color: #8c8c8c;
		text-decoration: none;
	}
	.ts-spotlight-position:hover {
		color: #fe5900;
	}
	.ts-spotlight-meta {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 25px;
	}
	.ts-spotlight-meta a {
		color: #fe5900;
		text-decoration: none;
	}
	.ts-spotlight-meta a:hover {
		text-decoration: underline;
	}
	.ts-spotlight-bio {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		line-height: 1.8;
		color: #666666;
		margin-bottom: 30px;
	}

	.ship-quick-accessories-hint {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 32px;
		text-align: center;
	}
	.ship-quick-product-image-btn {
		display: block;
		width: 100%;
		padding: 0;
		border: none;
		background: none;
		cursor: pointer;
		text-align: left;
	}
	.ship-quick-acc-modal {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
