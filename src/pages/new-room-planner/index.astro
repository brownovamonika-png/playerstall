</style>

<script>
	import { createInitialState, buildWalls, defaultDimensions, needByTimelineLabel, fundingStatusLabel } from '../../room-planner/state';
	import type { RoomDimensions } from '../../room-planner/state';
	import { render } from '../../room-planner/render';
	import { wallLength } from '../../room-planner/geometry';
	import type { PlannerState, Opening } from '../../room-planner/types';

	let roomDims: RoomDimensions = defaultDimensions();
	const state: PlannerState = createInitialState(roomDims);

	interface SavedRoom {
		roomName: string;
		needByTimeline: string;
		fundingStatus: string;
		sportType: string;
		roomDims: RoomDimensions;
		openings: Opening[];
	}
	const savedRooms: SavedRoom[] = [];
	let activeRoomIndex = 0;

	function snapshotCurrentRoom(): SavedRoom {
		return {
			roomName: state.roomName,
			needByTimeline: state.needByTimeline,
			fundingStatus: state.fundingStatus,
			sportType: state.sportType,
			roomDims: { ...roomDims },
			openings: JSON.parse(JSON.stringify(state.openings)),
		};
	}

	function saveCurrentRoom() {
		savedRooms[activeRoomIndex] = snapshotCurrentRoom();
	}

	function loadRoom(index: number) {
		const room = savedRooms[index];
		if (!room) return;
		roomDims = { ...room.roomDims };
		state.roomName = room.roomName;
		state.needByTimeline = room.needByTimeline || '';
		state.fundingStatus = room.fundingStatus || '';
		state.sportType = (room.sportType || '') as any;
		state.walls = buildWalls(roomDims);
		state.openings = JSON.parse(JSON.stringify(room.openings));
		state.lockers = [];
		state.selection = null;
		roomNameInput.value = state.roomName;
		(document.getElementById('need-by-timeline') as HTMLSelectElement).value = state.needByTimeline || '';
		(document.getElementById('funding-status') as HTMLSelectElement).value = state.fundingStatus || '';
		(document.getElementById('sport-type') as HTMLSelectElement).value = state.sportType || '';
		writeAllDimInputs();
		renderWallOpeningsForms();
	}

	function removeRoom(index: number) {
		if (savedRooms.length <= 1) return;
		savedRooms.splice(index, 1);
		if (activeRoomIndex >= savedRooms.length) {
			activeRoomIndex = savedRooms.length - 1;
		} else if (index < activeRoomIndex) {
			activeRoomIndex--;
		} else if (index === activeRoomIndex) {
			activeRoomIndex = Math.min(index, savedRooms.length - 1);
		}
		loadRoom(activeRoomIndex);
		renderRoomTabs();
	}

	function renderRoomTabs() {
		const list = document.getElementById('room-tabs-list')!;
		list.innerHTML = '';
		const canRemove = savedRooms.length > 1;
		for (let i = 0; i < savedRooms.length; i++) {
			if (i > 0) {
				const sep = document.createElement('span');
				sep.className = 'room-tab-sep';
				sep.textContent = '/';
				list.appendChild(sep);
			}
			const isActive = i === activeRoomIndex;
			const label = (i === activeRoomIndex ? state.roomName : savedRooms[i].roomName) || `Room ${i + 1}`;
			const btn = document.createElement('button');
			btn.type = 'button';
			btn.className = `room-tab${isActive ? ' active' : ''}`;
			btn.dataset.roomIdx = String(i);

			const nameSpan = document.createElement('span');
			nameSpan.textContent = label;
			btn.appendChild(nameSpan);
			nameSpan.onclick = (e) => { e.stopPropagation(); switchToRoom(i); };

			if (canRemove) {
				const xBtn = document.createElement('span');
				xBtn.className = 'room-tab-x';
				xBtn.textContent = '\u00d7';
				xBtn.title = 'Remove room';
				xBtn.onclick = (e) => { e.stopPropagation(); removeRoom(i); };
				btn.appendChild(xBtn);
			}

			list.appendChild(btn);
		}
		const roomLabelEl = document.getElementById('room-name-label');
		if (roomLabelEl) roomLabelEl.textContent = `Name Room ${activeRoomIndex + 1}`;
	}

	function switchToRoom(index: number) {
		if (index === activeRoomIndex) return;
		saveCurrentRoom();
		activeRoomIndex = index;
		loadRoom(index);
		renderRoomTabs();
	}

	document.getElementById('btn-add-room')!.onclick = () => {
		saveCurrentRoom();
		const newIndex = savedRooms.length;
		savedRooms.push({
			roomName: '',
			needByTimeline: '',
			fundingStatus: '',
			sportType: '',
			roomDims: defaultDimensions(),
			openings: [],
		});
		activeRoomIndex = newIndex;
		loadRoom(newIndex);
		renderRoomTabs();
	};

	// Room name, timeline & sport
	const roomNameInput = document.getElementById('room-name') as HTMLInputElement;
	const needBySelect = document.getElementById('need-by-timeline') as HTMLSelectElement;
	const fundingSelect = document.getElementById('funding-status') as HTMLSelectElement;
	const sportTypeSelect = document.getElementById('sport-type') as HTMLSelectElement;
	roomNameInput.oninput = () => {
		state.roomName = roomNameInput.value.trim();
		renderRoomTabs();
	};
	needBySelect.onchange = () => {
		state.needByTimeline = needBySelect.value;
		saveCurrentRoom();
	};
	fundingSelect.onchange = () => {
		state.fundingStatus = fundingSelect.value;
		saveCurrentRoom();
	};
	sportTypeSelect.onchange = () => {
		state.sportType = sportTypeSelect.value as any;
		saveCurrentRoom();
	};

	// Room dimension inputs
	const dimFtA = document.getElementById('dim-wall-a-ft') as HTMLInputElement;
	const dimInA = document.getElementById('dim-wall-a-in') as HTMLInputElement;
	const dimFtB = document.getElementById('dim-wall-b-ft') as HTMLInputElement;
	const dimInB = document.getElementById('dim-wall-b-in') as HTMLInputElement;
	const dimFtC = document.getElementById('dim-wall-c-ft') as HTMLInputElement;
	const dimInC = document.getElementById('dim-wall-c-in') as HTMLInputElement;
	const dimFtD = document.getElementById('dim-wall-d-ft') as HTMLInputElement;
	const dimInD = document.getElementById('dim-wall-d-in') as HTMLInputElement;

	function readFtIn(ft: HTMLInputElement, inches: HTMLInputElement): number {
		return (parseFloat(ft.value) || 0) * 12 + (parseFloat(inches.value) || 0);
	}

	function writeFtIn(totalInches: number, ft: HTMLInputElement, inches: HTMLInputElement) {
		const f = Math.floor(totalInches / 12);
		const i = Math.round(totalInches % 12);
		ft.value = f > 0 ? String(f) : '';
		inches.value = i > 0 ? String(i) : '';
	}

	function readRoomDims(): RoomDimensions {
		return {
			wallA: readFtIn(dimFtA, dimInA),
			wallB: readFtIn(dimFtB, dimInB),
			wallC: readFtIn(dimFtC, dimInC),
			wallD: readFtIn(dimFtD, dimInD),
			thicknessA: roomDims.thicknessA,
			thicknessB: roomDims.thicknessB,
			thicknessC: roomDims.thicknessC,
			thicknessD: roomDims.thicknessD,
		};
	}

	function writeAllDimInputs() {
		writeFtIn(roomDims.wallA, dimFtA, dimInA);
		writeFtIn(roomDims.wallB, dimFtB, dimInB);
		writeFtIn(roomDims.wallC, dimFtC, dimInC);
		writeFtIn(roomDims.wallD, dimFtD, dimInD);
	}
	writeAllDimInputs();

	// Preview canvas
	const previewWrap = document.getElementById('room-preview-wrap')!;
	const previewCanvas = document.getElementById('room-preview-canvas') as HTMLCanvasElement;
	const previewCtx = previewCanvas.getContext('2d')!;

	function renderPreview() {
		const hasRoom = state.walls.some((w) => wallLength(w) > 0);
		previewWrap.style.display = hasRoom ? '' : 'none';
		if (!hasRoom) return;

		let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
		for (const w of state.walls) {
			minX = Math.min(minX, w.start.x, w.end.x);
			minY = Math.min(minY, w.start.y, w.end.y);
			maxX = Math.max(maxX, w.start.x, w.end.x);
			maxY = Math.max(maxY, w.start.y, w.end.y);
		}
		if (!isFinite(minX)) return;
		const worldW = maxX - minX || 100;
		const worldH = maxY - minY || 100;
		const pad = 40;
		state.camera.pixelsPerInch = Math.min(
			(previewCanvas.clientWidth - pad) / worldW,
			(previewCanvas.clientHeight - pad) / worldH,
		);
		state.camera.centerX = (minX + maxX) / 2;
		state.camera.centerY = (minY + maxY) / 2;
		render(previewCtx, state);
	}

	function applyRoom() {
		roomDims = readRoomDims();
		state.walls = buildWalls(roomDims);
		state.lockers = [];
		state.openings = state.openings.filter((op) => {
			const wall = state.walls.find((w) => w.id === op.wallId);
			return wall && (op.offsetAlongWall + op.widthIn) <= wallLength(wall);
		});
		state.selection = null;
		renderWallOpeningsForms();
		renderPreview();
	}

	document.getElementById('btn-apply-room')!.onclick = applyRoom;

	document.getElementById('btn-reset-room')!.onclick = () => {
		roomDims = defaultDimensions();
		writeAllDimInputs();
		state.roomName = '';
		roomNameInput.value = '';
		state.needByTimeline = '';
		needBySelect.value = '';
		state.fundingStatus = '';
		fundingSelect.value = '';
		state.sportType = '';
		sportTypeSelect.value = '';
		state.walls = buildWalls(roomDims);
		state.lockers = [];
		state.openings = [];
		state.selection = null;
		saveCurrentRoom();
		renderRoomTabs();
		renderWallOpeningsForms();
		renderPreview();
	};

	// Wall openings
	let _openingCounter = 0;

	function addOpeningToWall(wallId: string, type: 'door' | 'window' | 'obstacle') {
		const wall = state.walls.find((w) => w.id === wallId);
		if (!wall) return;
		const len = wallLength(wall);
		const defaultWidth = type === 'obstacle' ? 24 : 36;
		const defaultClearance = type === 'door' ? 36 : type === 'window' ? 24 : 12;
		if (len < defaultWidth) return;

		const existingOnWall = state.openings.filter((o) => o.wallId === wallId);
		let offset = 0;
		for (const ex of existingOnWall) {
			const end = ex.offsetAlongWall + ex.widthIn;
			if (end > offset) offset = end;
		}
		if (offset + defaultWidth > len) return;

		const op: Opening = {
			id: `op_${++_openingCounter}`,
			type,
			wallId,
			offsetAlongWall: offset,
			widthIn: defaultWidth,
			clearanceIn: defaultClearance,
		};
		state.openings.push(op);
		renderWallOpeningsForms();
		renderPreview();
	}

	document.querySelectorAll('.wall-add-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const wallId = (btn as HTMLElement).dataset.wallId!;
			const type = (btn as HTMLElement).dataset.type as 'door' | 'window' | 'obstacle';
			addOpeningToWall(wallId, type);
		});
	});

	const _wallPositionLabels: Record<string, string> = {
		'Wall A': 'from left end', 'Wall B': 'from top end',
		'Wall C': 'from right end', 'Wall D': 'from bottom end',
	};
	function _inToFt(inches: number) { return { ft: Math.floor(inches / 12), inch: Math.round(inches % 12) }; }
	function _ftToIn(ft: number, inch: number) { return ft * 12 + inch; }

	function _makeFtInInput(valueInches: number, onChange: (v: number) => void) {
		const wrap = document.createElement('div');
		wrap.className = 'op-ftin-row';
		const { ft, inch } = _inToFt(valueInches);
		const ftInput = document.createElement('input');
		ftInput.type = 'number'; ftInput.value = String(ft); ftInput.min = '0'; ftInput.step = '1';
		wrap.appendChild(ftInput);
		const ftU = document.createElement('span'); ftU.className = 'op-ftin-unit'; ftU.textContent = 'ft';
		wrap.appendChild(ftU);
		const inInput = document.createElement('input');
		inInput.type = 'number'; inInput.value = String(inch); inInput.min = '0'; inInput.max = '11'; inInput.step = '1';
		wrap.appendChild(inInput);
		const inU = document.createElement('span'); inU.className = 'op-ftin-unit'; inU.textContent = 'in';
		wrap.appendChild(inU);
		const update = () => { onChange(_ftToIn(Math.max(0, parseInt(ftInput.value, 10) || 0), Math.max(0, Math.min(11, parseInt(inInput.value, 10) || 0)))); };
		ftInput.onchange = update; inInput.onchange = update;
		return wrap;
	}

	function _buildWallBar(wallId: string) {
		const wall = state.walls.find((w) => w.id === wallId);
		if (!wall) return null;
		const len = wallLength(wall);
		if (len <= 0) return null;
		const ops = state.openings.filter((o) => o.wallId === wallId);
		if (ops.length === 0) return null;
		const wrap = document.createElement('div'); wrap.className = 'wall-bar-wrap';
		const bar = document.createElement('div'); bar.className = 'wall-bar';
		for (const op of ops) {
			const pct = (op.offsetAlongWall / len) * 100;
			const wPct = (op.widthIn / len) * 100;
			const block = document.createElement('div');
			block.className = 'wall-bar-opening ' + op.type;
			block.style.left = pct + '%'; block.style.width = Math.max(wPct, 2) + '%';
			const lbl = document.createElement('span'); lbl.className = 'wall-bar-opening-label';
			lbl.textContent = op.type === 'door' ? 'D' : op.type === 'window' ? 'W' : 'O';
			block.appendChild(lbl); bar.appendChild(block);
		}
		wrap.appendChild(bar);
		const labels = document.createElement('div'); labels.className = 'wall-bar-labels';
		const { ft: tFt, inch: tIn } = _inToFt(len);
		labels.innerHTML = '<span>0\u2032</span><span>' + tFt + '\u2032 ' + tIn + '\u2033</span>';
		wrap.appendChild(labels);
		return wrap;
	}

	function renderWallOpeningsForms() {
		const wallKeys = [
			{ wallId: 'Wall A', containerId: 'openings-wall-a' },
			{ wallId: 'Wall B', containerId: 'openings-wall-b' },
			{ wallId: 'Wall C', containerId: 'openings-wall-c' },
			{ wallId: 'Wall D', containerId: 'openings-wall-d' },
		];
		for (const { wallId, containerId } of wallKeys) {
			const container = document.getElementById(containerId)!;
			const wallOpenings = state.openings.filter((o) => o.wallId === wallId);
			container.innerHTML = '';
			const wallBar = _buildWallBar(wallId);
			if (wallBar) container.appendChild(wallBar);
			for (const op of wallOpenings) {
				const card = document.createElement('div'); card.className = 'wall-opening-row';
				const header = document.createElement('div'); header.className = 'op-header';
				const badge = document.createElement('span'); badge.className = `op-badge ${op.type}`;
				badge.textContent = op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle';
				header.appendChild(badge);
				const removeBtn = document.createElement('button'); removeBtn.className = 'op-remove';
				removeBtn.textContent = '\u2715'; removeBtn.title = 'Remove this opening';
				removeBtn.onclick = () => { state.openings = state.openings.filter((o) => o.id !== op.id); renderWallOpeningsForms(); renderPreview(); };
				header.appendChild(removeBtn); card.appendChild(header);
				const grid = document.createElement('div'); grid.className = 'op-fields';

				const posGroup = document.createElement('div'); posGroup.className = 'op-field';
				const posLabel = document.createElement('label');
				posLabel.textContent = 'Position ' + (_wallPositionLabels[wallId] || '');
				posGroup.appendChild(posLabel);
				posGroup.appendChild(_makeFtInInput(op.offsetAlongWall, (v) => { op.offsetAlongWall = Math.max(0, v); renderWallOpeningsForms(); renderPreview(); }));
				grid.appendChild(posGroup);

				const wGroup = document.createElement('div'); wGroup.className = 'op-field';
				const wLabel = document.createElement('label'); wLabel.textContent = 'Width'; wGroup.appendChild(wLabel);
				const wRow = document.createElement('div'); wRow.className = 'op-field-row';
				const wInput = document.createElement('input');
				wInput.type = 'number'; wInput.value = String(op.widthIn); wInput.min = '12'; wInput.step = '1';
				wInput.onchange = () => { op.widthIn = Math.max(12, parseFloat(wInput.value) || 36); renderWallOpeningsForms(); renderPreview(); };
				wRow.appendChild(wInput);
				const wUnit = document.createElement('span'); wUnit.className = 'op-unit'; wUnit.textContent = '\u2033';
				wRow.appendChild(wUnit); wGroup.appendChild(wRow); grid.appendChild(wGroup);

				const cGroup = document.createElement('div'); cGroup.className = 'op-field';
				const cLabel = document.createElement('label'); cLabel.textContent = 'Clearance'; cGroup.appendChild(cLabel);
				const cRow = document.createElement('div'); cRow.className = 'op-field-row';
				const cInput = document.createElement('input');
				cInput.type = 'number'; cInput.value = String(op.clearanceIn); cInput.min = '0'; cInput.step = '1';
				cInput.onchange = () => { op.clearanceIn = Math.max(0, parseFloat(cInput.value) || 0); renderPreview(); };
				cRow.appendChild(cInput);
				const cUnit = document.createElement('span'); cUnit.className = 'op-unit'; cUnit.textContent = '\u2033';
				cRow.appendChild(cUnit); cGroup.appendChild(cRow); grid.appendChild(cGroup);

				card.appendChild(grid); container.appendChild(card);
			}
		}
	}

	renderWallOpeningsForms();

	// Email modal
	const overlay = document.getElementById('email-modal-overlay')!;
	const emailInput = document.getElementById('setup-email') as HTMLInputElement;
	const emailError = document.getElementById('email-error')!;

	document.getElementById('email-modal-close')!.onclick = () => {
		overlay.style.display = 'none';
	};
	overlay.addEventListener('click', (e) => {
		if (e.target === overlay) overlay.style.display = 'none';
	});

	// Next button: validate rooms, then show email modal
	document.getElementById('btn-next')!.onclick = () => {
		applyRoom();
		saveCurrentRoom();

		const hasAnyRoom = savedRooms.some((r) => {
			return r.roomDims.wallA > 0 && r.roomDims.wallB > 0;
		});
		if (!hasAnyRoom) {
			alert('Please enter wall dimensions for at least one room (Walls A and B are required).');
			return;
		}

		overlay.style.display = 'flex';
		emailInput.focus();
	};

	// Email submit: save to localStorage, send to Formspree, and navigate
	function submitEmail() {
		const email = emailInput.value.trim();
		if (!email || !email.includes('@') || !email.includes('.')) {
			emailError.style.display = '';
			emailInput.focus();
			return;
		}
		emailError.style.display = 'none';

		saveCurrentRoom();

		const roomSummary = savedRooms.map((r, i) => {
			const name = r.roomName || `Room ${i + 1}`;
			const dims = r.roomDims;
			const ft = (v: number) => `${Math.floor(v / 12)}' ${Math.round(v % 12)}"`;
			return `${name}: ${ft(dims.wallA)} × ${ft(dims.wallB)}`;
		}).join(', ');

		const timingSummary = savedRooms
			.map((r, i) => {
				const lbl = needByTimelineLabel(r.needByTimeline || '');
				if (!lbl) return '';
				const name = r.roomName || `Room ${i + 1}`;
				return `${name}: ${lbl}`;
			})
			.filter(Boolean)
			.join('; ');

		const fundingSummary = savedRooms
			.map((r, i) => {
				const lbl = fundingStatusLabel(r.fundingStatus || '');
				if (!lbl) return '';
				const name = r.roomName || `Room ${i + 1}`;
				return `${name}: ${lbl}`;
			})
			.filter(Boolean)
			.join('; ');

		fetch('https://formspree.io/f/mgopozqe', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
			body: JSON.stringify({
				email,
				_subject: 'Room Planner — New Lead',
				source: 'Room Planner (Step 1)',
				rooms: roomSummary,
				...(timingSummary ? { delivery_timing: timingSummary } : {}),
				...(fundingSummary ? { funding_budget: fundingSummary } : {}),
			}),
		}).catch(() => {});

		const payload = {
			email,
			floorColor: state.floorColor,
			wallColor: state.wallColor,
			rooms: savedRooms.map((r) => ({
				roomName: r.roomName,
				needByTimeline: r.needByTimeline,
				fundingStatus: r.fundingStatus,
				sportType: r.sportType,
				roomDims: r.roomDims,
				openings: r.openings,
			})),
		};

		localStorage.setItem('ps_planner_setup', JSON.stringify(payload));
		window.location.href = '/new-room-planner/design';
	}

	document.getElementById('btn-email-submit')!.onclick = submitEmail;
	emailInput.addEventListener('keydown', (e) => {
		if (e.key === 'Enter') submitEmail();
	});

	// Init
	savedRooms.push(snapshotCurrentRoom());
	renderRoomTabs();
	window.addEventListener('resize', () => renderPreview());

	/* ── Guide Agent (Step 1) ─────────────────────────────────── */
	(function initGuide() {
		const STEPS = [
			{
				title: 'Welcome!',
				desc: "First we'll capture your room size and openings. Then you'll move on to add lockers. Click <strong>Next</strong> to begin.",
				target: null
			},
			{
				title: 'When, funding & sport',
				desc: 'Tell us <strong>when you need the lockers</strong>, your <strong>funding</strong> situation, <strong>sport</strong>, and a <strong>room name</strong> so we can tailor your quote.',
				target: '.room-fields-group'
			},
			{
				title: 'Measure each wall',
				desc: 'Enter the <strong>length</strong> of walls A–D. Use <strong>Door</strong>, <strong>Window</strong>, or <strong>Obstacle</strong> so lockers are not placed in those areas.',
				target: '.wall-cards'
			},
			{
				title: 'Draw your floor plan',
				desc: 'Click <strong>Draw My Room</strong> to build the floor plan from your dimensions.',
				target: '#btn-apply-room'
			},
			{
				title: 'Preview your room',
				desc: 'After drawing, a <strong>preview</strong> appears below. Adjust walls or openings and click <strong>Draw My Room</strong> again to refresh.',
				target: '#room-preview-wrap'
			},
			{
				title: 'Continue to design',
				desc: 'Click <strong>Next</strong>, enter your email, and you\'ll open the locker designer. You can add multiple rooms with <strong>+ Add Room</strong> first if needed.',
				target: '#btn-next'
			}
		];

		const fab = document.getElementById('guide-fab')!;
		const panel = document.getElementById('guide-panel')!;
		const btnMin = document.getElementById('guide-minimize')!;
		const btnPrev = document.getElementById('guide-prev') as HTMLButtonElement;
		const btnNextGuide = document.getElementById('guide-next') as HTMLButtonElement;
		const stepTitle = document.getElementById('guide-step-title')!;
		const stepDesc = document.getElementById('guide-step-desc')!;
		const stepCount = document.getElementById('guide-step-count')!;
		const progressBar = document.getElementById('guide-progress-bar')!;

		let current = 0;
		let _highlightEl: Element | null = null;
		const STORAGE_KEY = 'ps_guide_setup_collapsed';

		function renderStep() {
			const s = STEPS[current];
			stepTitle.textContent = s.title;
			stepDesc.innerHTML = s.desc;
			stepCount.textContent = `Step ${current + 1} of ${STEPS.length}`;
			progressBar.style.width = `${((current + 1) / STEPS.length) * 100}%`;
			btnPrev.disabled = current === 0;
			btnNextGuide.textContent = current === STEPS.length - 1 ? 'Done ✓' : 'Next →';

			if (_highlightEl) {
				_highlightEl.classList.remove('guide-highlight', 'guide-pulse');
				_highlightEl = null;
			}
			if (s.target) {
				const el = document.querySelector(s.target);
				if (el) {
					_highlightEl = el;
					el.classList.add('guide-highlight', 'guide-pulse');
					el.scrollIntoView({ behavior: 'smooth', block: 'center' });
				}
			}
		}

		function goTo(step: number) {
			current = Math.max(0, Math.min(STEPS.length - 1, step));
			renderStep();
		}

		function advanceIfBefore(step: number) {
			if (current < step) goTo(step);
		}

		function show() {
			panel.classList.remove('hidden');
			fab.classList.add('hidden');
			localStorage.removeItem(STORAGE_KEY);
			renderStep();
		}

		function hide() {
			panel.classList.add('hidden');
			fab.classList.remove('hidden');
			localStorage.setItem(STORAGE_KEY, '1');
			if (_highlightEl) {
				_highlightEl.classList.remove('guide-highlight', 'guide-pulse');
				_highlightEl = null;
			}
		}

		btnMin.onclick = hide;
		fab.onclick = show;

		btnPrev.onclick = () => goTo(current - 1);
		btnNextGuide.onclick = () => {
			if (current === STEPS.length - 1) { hide(); return; }
			goTo(current + 1);
		};

		document.getElementById('btn-apply-room')!.addEventListener('click', () => {
			setTimeout(() => {
				if (previewWrap.style.display !== 'none') advanceIfBefore(4);
			}, 50);
		});

		document.getElementById('btn-next')!.addEventListener('click', () => {
			setTimeout(() => {
				if (overlay.style.display === 'flex') advanceIfBefore(5);
			}, 100);
		});

		if (localStorage.getItem(STORAGE_KEY) === '1') {
			panel.classList.add('hidden');
			fab.classList.remove('hidden');
		} else {
			fab.classList.add('hidden');
			panel.classList.remove('hidden');
			renderStep();
		}
	})();
</script>
