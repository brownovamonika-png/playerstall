---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Room Planner | Design Your Locker Room | PlayerStall"
	description="Interactive locker room planner. Draw walls, place lockers, configure options and pricing in real time. Free tool to design your space today."
>
	<section class="planner-hero">
		<div class="planner-hero-inner">
			<span class="planner-hero-subtitle">Free Online Tool</span>
			<h1>Locker Room Planner</h1>
			<p>Plan your perfect locker room in three simple steps. No account required. Just enter your room dimensions, add lockers, and request a quote when you're done.</p>
			<div class="hero-steps">
				<div class="hero-step active-step">
					<span class="hero-step-num">1</span>
					<span class="hero-step-text">Enter your room size</span>
				</div>
				<div class="hero-step-arrow">&rarr;</div>
				<div class="hero-step">
					<span class="hero-step-num">2</span>
					<span class="hero-step-text">Add & arrange lockers</span>
				</div>
				<div class="hero-step-arrow">&rarr;</div>
				<div class="hero-step">
					<span class="hero-step-num">3</span>
					<span class="hero-step-text">Review & send to us</span>
				</div>
			</div>
		</div>
	</section>

	<section class="room-setup" id="room-setup">
		<div class="room-setup-columns">
			<div class="room-setup-left">
				<div class="room-tabs-row" id="room-tabs-bar">
					<div class="room-tabs-list" id="room-tabs-list">
						<button type="button" class="room-tab active" data-room-idx="0">Room 1</button>
					</div>
					<button type="button" class="room-tab-add" id="btn-add-room">+ Add Room</button>
				</div>
				<span class="step-badge">Step 1</span>
				<h2 class="room-setup-title">Room Dimensions</h2>
				<p class="room-setup-desc">Measure your locker room and enter the length of each wall below. If a wall has a door or window, click the button under that wall to mark it so lockers won't be placed in those areas.</p>

				<div class="room-fields-group">
					<div class="room-field">
						<label for="need-by-timeline" class="room-field-label">When do you need the lockers?</label>
						<select id="need-by-timeline" class="room-field-input sport-select" aria-describedby="need-by-hint-step1">
							<option value="">Select timeframe…</option>
							<option value="asap">ASAP / under 2 months</option>
							<option value="1-3">1–3 months</option>
							<option value="3-6">3–6 months</option>
							<option value="6plus">6+ months</option>
							<option value="flexible">Flexible / still planning</option>
							<option value="unsure">Not sure yet</option>
						</select>
					</div>
					<div class="room-field">
						<label for="funding-status" class="room-field-label">Funding / budget</label>
						<select id="funding-status" class="room-field-input sport-select" aria-describedby="need-by-hint-step1">
							<option value="">Select an option…</option>
							<option value="have_funds">Have funds / budget approved</option>
							<option value="fundraising">Currently fundraising</option>
							<option value="need_help">Need help with fundraising</option>
						</select>
					</div>
					<div class="room-field">
						<label for="sport-type" class="room-field-label">Sport</label>
						<select id="sport-type" class="room-field-input sport-select">
							<option value="">Select a sport…</option>
							<option value="football">Football</option>
							<option value="hockey">Hockey</option>
							<option value="basketball">Basketball</option>
							<option value="baseball">Baseball</option>
							<option value="soccer">Soccer</option>
							<option value="lacrosse">Lacrosse</option>
							<option value="other">Other / Multi-Sport</option>
						</select>
					</div>
					<div class="room-field">
						<label for="room-name" class="room-field-label" id="room-name-label">Name Room 1</label>
						<input type="text" id="room-name" class="room-field-input" placeholder="e.g. Home Locker Room, Visitors…" maxlength="80" />
					</div>
				</div>
				<p class="room-setup-hint" id="need-by-hint-step1">Timeline helps us prioritize production. Funding helps us tailor your quote and payment options.</p>

				<div class="wall-cards">
				<!-- Wall A -->
				<div class="wall-card" data-wall="a">
					<div class="wall-card-header">
						<span class="wall-card-label">Wall A <span class="wall-card-side">(top)</span></span>
						<div class="wall-dim-pair">
							<input type="number" id="dim-wall-a-ft" class="room-dim-input dim-ft" placeholder="ft" min="0" step="1" />
							<span class="room-dim-unit">ft</span>
							<input type="number" id="dim-wall-a-in" class="room-dim-input dim-in" placeholder="in" min="0" max="11" step="1" />
							<span class="room-dim-unit">in</span>
						</div>
					</div>
					<div class="wall-openings-list" id="openings-wall-a"></div>
					<div class="wall-card-actions">
						<button type="button" class="wall-add-btn" data-wall-id="Wall A" data-type="door">+ Door</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall A" data-type="window">+ Window</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall A" data-type="obstacle">+ Obstacle</button>
					</div>
				</div>

				<!-- Wall B -->
				<div class="wall-card" data-wall="b">
					<div class="wall-card-header">
						<span class="wall-card-label">Wall B <span class="wall-card-side">(right)</span></span>
						<div class="wall-dim-pair">
							<input type="number" id="dim-wall-b-ft" class="room-dim-input dim-ft" placeholder="ft" min="0" step="1" />
							<span class="room-dim-unit">ft</span>
							<input type="number" id="dim-wall-b-in" class="room-dim-input dim-in" placeholder="in" min="0" max="11" step="1" />
							<span class="room-dim-unit">in</span>
						</div>
					</div>
					<div class="wall-openings-list" id="openings-wall-b"></div>
					<div class="wall-card-actions">
						<button type="button" class="wall-add-btn" data-wall-id="Wall B" data-type="door">+ Door</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall B" data-type="window">+ Window</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall B" data-type="obstacle">+ Obstacle</button>
					</div>
				</div>

				<!-- Wall C -->
				<div class="wall-card" data-wall="c">
					<div class="wall-card-header">
						<span class="wall-card-label">Wall C <span class="wall-card-side">(bottom)</span></span>
						<div class="wall-dim-pair">
							<input type="number" id="dim-wall-c-ft" class="room-dim-input dim-ft" placeholder="ft" min="0" step="1" />
							<span class="room-dim-unit">ft</span>
							<input type="number" id="dim-wall-c-in" class="room-dim-input dim-in" placeholder="in" min="0" max="11" step="1" />
							<span class="room-dim-unit">in</span>
						</div>
					</div>
					<div class="wall-openings-list" id="openings-wall-c"></div>
					<div class="wall-card-actions">
						<button type="button" class="wall-add-btn" data-wall-id="Wall C" data-type="door">+ Door</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall C" data-type="window">+ Window</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall C" data-type="obstacle">+ Obstacle</button>
					</div>
				</div>

				<!-- Wall D -->
				<div class="wall-card" data-wall="d">
					<div class="wall-card-header">
						<span class="wall-card-label">Wall D <span class="wall-card-side">(left)</span></span>
						<div class="wall-dim-pair">
							<input type="number" id="dim-wall-d-ft" class="room-dim-input dim-ft" placeholder="ft" min="0" step="1" />
							<span class="room-dim-unit">ft</span>
							<input type="number" id="dim-wall-d-in" class="room-dim-input dim-in" placeholder="in" min="0" max="11" step="1" />
							<span class="room-dim-unit">in</span>
						</div>
					</div>
					<div class="wall-openings-list" id="openings-wall-d"></div>
					<div class="wall-card-actions">
						<button type="button" class="wall-add-btn" data-wall-id="Wall D" data-type="door">+ Door</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall D" data-type="window">+ Window</button>
						<button type="button" class="wall-add-btn" data-wall-id="Wall D" data-type="obstacle">+ Obstacle</button>
					</div>
				</div>
			</div>

			<div class="room-btn-row">
				<button type="button" class="room-apply-btn" id="btn-apply-room">Draw My Room</button>
				<button type="button" class="room-reset-btn" id="btn-reset-room">Clear &amp; Start Over</button>
			</div>

			<!-- Mini canvas preview -->
			<div class="room-preview-wrap" id="room-preview-wrap" style="display:none;">
				<canvas id="room-preview-canvas"></canvas>
			</div>

			<div class="room-btn-row next-row">
				<button type="button" class="room-next-btn" id="btn-next">Next &rarr;</button>
			</div>
			</div>
		</div>
	</section>

	<!-- Email modal -->
	<div class="email-modal-overlay" id="email-modal-overlay">
		<div class="email-modal">
			<button type="button" class="email-modal-close" id="email-modal-close">&times;</button>
			<h2 class="email-modal-title">Almost There</h2>
			<p class="email-modal-desc">Enter your email so we can save your layout and send you a copy when it's ready.</p>
			<div class="email-modal-field">
				<label for="setup-email">Email address</label>
				<input type="email" id="setup-email" class="email-modal-input" placeholder="you@example.com" required />
			</div>
			<p class="email-modal-error" id="email-error" style="display:none;">Please enter a valid email address.</p>
			<button type="button" class="email-modal-submit" id="btn-email-submit">Continue to Design &rarr;</button>
			<p class="email-modal-privacy">We'll only use your email to send your locker room plan. No spam, ever.</p>
		</div>
	</div>

	<!-- Guide Agent (Step 1 — room setup) -->
	<div class="guide-fab" id="guide-fab" title="Open step-by-step guide">?</div>
	<div class="guide-panel" id="guide-panel">
		<div class="guide-header">
			<span class="guide-title">Locker Room Guide</span>
			<button type="button" class="guide-minimize" id="guide-minimize" title="Minimize guide">&minus;</button>
		</div>
		<div class="guide-progress">
			<div class="guide-progress-bar" id="guide-progress-bar"></div>
		</div>
		<div class="guide-step-count" id="guide-step-count">Step 1 of 6</div>
		<div class="guide-body" id="guide-body">
			<div class="guide-step-title" id="guide-step-title"></div>
			<div class="guide-step-desc" id="guide-step-desc"></div>
		</div>
		<div class="guide-nav">
			<button type="button" class="guide-nav-btn" id="guide-prev" disabled>&larr; Back</button>
			<button type="button" class="guide-nav-btn guide-nav-next" id="guide-next">Next &rarr;</button>
		</div>
	</div>
</BaseLayout>

<style>
	.planner-hero {
		background: #ffffff;
		color: #0d0d0d;
		padding: 80px 20px 40px;
		text-align: center;
	}
	.planner-hero-subtitle {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 6px;
		text-transform: uppercase;
		color: #8c8c8c;
		margin-bottom: 12px;
	}
	.planner-hero h1 {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(32px, 4vw, 52px);
		font-weight: 700;
		margin: 0;
		text-transform: uppercase;
		color: #0d0d0d;
		line-height: 1.1;
		letter-spacing: 2px;
	}
	.planner-hero p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		margin: 14px auto 0;
		color: #8c8c8c;
		max-width: 600px;
		line-height: 1.6;
	}

	.hero-steps {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
		margin-top: 32px;
	}
	.hero-step {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.hero-step-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: #0d0d0d;
		color: #fff;
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		flex-shrink: 0;
	}
	.hero-step-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
	}
	.hero-step-arrow {
		color: #ccc;
		font-size: 18px;
	}
	.active-step .hero-step-num {
		background: #fe5900;
	}
	@media (max-width: 640px) {
		.hero-steps { flex-direction: column; gap: 10px; }
		.hero-step-arrow { transform: rotate(90deg); }
	}

	/* Room tabs */
	:global(.room-tabs-row) {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		margin-bottom: 32px;
	}
	:global(.room-tabs-list) {
		display: flex;
		gap: 8px;
		align-items: center;
	}
	:global(.room-tab) {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 400;
		letter-spacing: 1px;
		text-transform: uppercase;
		padding: 8px 18px;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		background: #fff;
		color: #8c8c8c;
		cursor: pointer;
		white-space: nowrap;
		transition: all 0.2s;
	}
	:global(.room-tab:hover) {
		border-color: #0d0d0d;
		color: #0d0d0d;
	}
	:global(.room-tab.active) {
		background: #0d0d0d;
		border-color: #0d0d0d;
		color: #fff;
	}
	:global(.room-tab-sep) { display: none; }
	:global(.room-tab-x) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 14px;
		height: 14px;
		border-radius: 50%;
		border: none;
		background: none;
		color: #ccc;
		font-size: 10px;
		line-height: 1;
		cursor: pointer;
		padding: 0;
		margin-left: 2px;
		transition: all 0.2s;
	}
	:global(.room-tab.active .room-tab-x) { color: rgba(255,255,255,0.5); }
	:global(.room-tab.active .room-tab-x:hover) { color: #fe5900; }
	:global(.room-tab-x:hover) { color: #fe5900; }
	:global(.room-tab-add) {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		font-weight: 500;
		letter-spacing: 0.5px;
		padding: 8px 18px;
		border: 1px dashed #ccc;
		border-radius: 0;
		background: #fff;
		color: #8c8c8c;
		cursor: pointer;
		white-space: nowrap;
		margin-left: 4px;
		transition: color 0.2s;
	}
	:global(.room-tab-add:hover) { border-color: #0d0d0d; color: #0d0d0d; }

	/* Room setup form */
	.room-setup {
		background: #ffffff;
		color: #0d0d0d;
		padding: 0 20px 60px;
	}
	.room-setup-columns {
		max-width: 1300px;
		margin: 0 auto;
	}
	.room-setup-title {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(24px, 3vw, 36px);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 2px;
		margin: 0 0 10px;
		color: #0d0d0d;
		line-height: 1.1;
		text-align: center;
	}
	.room-setup-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 32px;
		letter-spacing: 0.3px;
		text-align: center;
	}
	/* Match Locker Room Planner (/room-planner) field row */
	.room-fields-group {
		display: flex;
		gap: 16px;
		justify-content: center;
		margin-bottom: 22px;
	}
	.room-field {
		display: flex;
		flex-direction: column;
		gap: 5px;
	}
	.room-field-label {
		font-family: 'Oswald', sans-serif;
		font-size: 11px;
		font-weight: 600;
		color: #555;
		text-transform: uppercase;
		letter-spacing: 1px;
	}
	.room-field-input {
		width: 220px;
		background: #f7f7f7;
		border: 1px solid #e0e0e0;
		border-radius: 4px;
		color: #0d0d0d;
		padding: 10px 14px;
		font-size: 14px;
		font-family: 'Yantramanav', sans-serif;
		transition: border-color 0.2s;
		box-sizing: border-box;
	}
	.room-field-input::placeholder { color: #b6b6b6; }
	.room-field-input:focus { border-color: #fe5900; outline: none; }
	.sport-select { appearance: auto; cursor: pointer; }
	.room-setup-hint {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #b6b6b6;
		margin: -8px auto 20px;
		max-width: 520px;
		font-style: italic;
		text-align: center;
		line-height: 1.45;
	}
	.wall-cards {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 16px;
	}
	@media (max-width: 640px) {
		.wall-cards { grid-template-columns: 1fr; }
	}
	@media (max-width: 520px) {
		.room-fields-group {
			flex-direction: column;
			align-items: center;
			gap: 12px;
		}
		.room-field-input {
			width: 100%;
			max-width: 280px;
		}
	}
	.wall-card {
		background: #f7f7f7;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 16px;
		transition: border-color 0.2s;
	}
	.wall-card:hover { border-color: #ccc; }
	.wall-card-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
		margin-bottom: 10px;
	}
	.wall-card-label {
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: #0d0d0d;
		white-space: nowrap;
	}
	.wall-card-side { color: #8c8c8c; font-size: 11px; }
	.wall-dim-pair {
		display: flex;
		align-items: center;
		gap: 4px;
		flex-shrink: 0;
	}
	.wall-dim-pair .dim-ft { width: 48px; }
	.wall-dim-pair .dim-in { width: 48px; }
	.wall-openings-list { display: flex; flex-direction: column; gap: 8px; }
	.wall-opening-row {
		background: #ffffff;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 10px 12px;
		font-size: 12px;
		color: #0d0d0d;
	}
	.op-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 8px;
	}
	.op-badge {
		font-family: 'Oswald', sans-serif;
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 1px;
		padding: 3px 10px;
		border-radius: 0;
		color: #fff;
	}
	.op-badge.door { background: #0d0d0d; }
	.op-badge.window { background: #555; }
	.op-badge.obstacle { background: #8c8c8c; }
	.op-remove {
		background: none;
		border: none;
		color: #b6b6b6;
		font-size: 14px;
		cursor: pointer;
		padding: 0 4px;
		line-height: 1;
	}
	.op-remove:hover { color: #fe5900; }
	.op-fields {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 8px;
	}
	.op-field label {
		display: block;
		font-size: 10px;
		color: #8c8c8c;
		margin-bottom: 3px;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}
	.op-field-row {
		display: flex;
		align-items: center;
		gap: 3px;
	}
	.op-field-row input {
		width: 100%;
		background: #f7f7f7;
		color: #0d0d0d;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 5px 8px;
		font-size: 12px;
		transition: border-color 0.3s;
	}
	.op-field-row input:focus { border-color: #fe5900; outline: none; }
	.op-unit { color: #8c8c8c; font-size: 11px; flex-shrink: 0; }
	.op-ftin-row { display: flex; align-items: center; gap: 3px; }
	.op-ftin-row input { width: 44px; background: #f7f7f7; color: #0d0d0d; border: 1px solid #e0e0e0; border-radius: 0; padding: 5px 6px; font-size: 12px; text-align: center; transition: border-color 0.3s; }
	.op-ftin-row input:focus { border-color: #fe5900; outline: none; }
	.op-ftin-unit { color: #8c8c8c; font-size: 10px; flex-shrink: 0; }
	.wall-bar-wrap { margin-bottom: 8px; }
	.wall-bar { position: relative; height: 18px; background: #e0e0e0; border-radius: 2px; overflow: hidden; }
	.wall-bar-opening { position: absolute; top: 0; height: 100%; border-radius: 1px; opacity: 0.85; cursor: pointer; transition: opacity 0.15s; }
	.wall-bar-opening:hover { opacity: 1; }
	.wall-bar-opening.door { background: #5a9fd4; }
	.wall-bar-opening.window { background: #6dc46d; }
