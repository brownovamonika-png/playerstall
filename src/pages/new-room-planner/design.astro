	// ─── Rotate selected locker ───
	function rotateSelectedLocker() {
		if (state.selection?.type !== 'locker') return;
		const locker = state.lockers.find((l) => l.instanceId === state.selection!.id);
		if (!locker) return;
		const oldRot = locker.rotationDeg;
		locker.rotationDeg = (locker.rotationDeg + 90) % 360;
		if (wouldOverlap(locker, state.lockers, state.openings, state.walls)) locker.rotationDeg = oldRot;
		redraw();
