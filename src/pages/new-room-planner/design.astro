---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Design Your Locker Room | Room Planner | PlayerStall"
	description="Place lockers, configure options, and preview your locker room in 2D and 3D. Free interactive tool from PlayerStall."
>
	<section class="planner-hero">
		<div class="planner-hero-inner">
			<a href="/new-room-planner" class="back-link">&larr; Back to Room Setup</a>
			<span class="planner-hero-subtitle">Free Online Tool</span>
			<h1>Locker Room Planner</h1>
			<div class="hero-steps">
				<div class="hero-step done-step">
					<span class="hero-step-num">&check;</span>
					<span class="hero-step-text">Enter your room size</span>
				</div>
				<div class="hero-step-arrow">&rarr;</div>
				<div class="hero-step active-step">
					<span class="hero-step-num">2</span>
					<span class="hero-step-text">Add & arrange lockers</span>
				</div>
				<div class="hero-step-arrow">&rarr;</div>
				<div class="hero-step">
					<span class="hero-step-num">3</span>
					<span class="hero-step-text">Review & send to us</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Room tabs (for multi-room switching) — same as step-by-step setup + classic planner -->
	<section class="room-setup" id="room-setup">
		<div class="room-setup-columns">
			<div class="room-tabs-row" id="room-tabs-bar">
				<div class="room-tabs-list" id="room-tabs-list">
					<button type="button" class="room-tab active" data-room-idx="0">Room 1</button>
				</div>
				<button type="button" class="room-tab-add" id="btn-add-room">+ Add Room</button>
				<button type="button" class="room-save-btn" id="btn-save-room" title="Save all rooms">
					<svg class="room-save-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
					Save
					<span class="room-save-check" id="room-save-check"></span>
				</button>
			</div>

	<div class="room-fields-group">
		<div class="room-field">
			<label for="sport-type" class="room-field-label">Sport</label>
			<select id="sport-type" class="room-field-input sport-select">
				<option value="">Select a sport…</option>
				<option value="football">Football</option>
				<option value="hockey">Hockey</option>
				<option value="basketball">Basketball</option>
				<option value="baseball">Baseball</option>
				<option value="soccer">Soccer</option>
				<option value="lacrosse">Lacrosse</option>
				<option value="other">Other / Multi-Sport</option>
			</select>
		</div>
	</div>

		<!-- Locker type selector -->
		<div class="locker-type-section" id="locker-type-section">
			<span class="step-badge">Step 2</span>
			<h2 class="room-setup-title">Add Lockers</h2>
				<p class="room-setup-desc">Pick a locker model, choose your size, color, and any accessories. Set the quantity and click Add. They'll appear on the layout below where you can drag them into position.</p>
				<div class="lt-with-preview">
					<div class="lt-preview" id="lt-preview">
						<img id="lt-preview-img" src="/images/model-s-locker-profile.png" alt="Locker preview" />
					</div>
					<div class="lt-config">
						<div class="lt-row">
							<div class="lt-field">
								<label>Model</label>
								<select id="lt-model"></select>
							</div>
							<div class="lt-field">
								<label>Width</label>
								<select id="lt-width"></select>
							</div>
							<div class="lt-field" id="lt-depth-field">
								<label>Depth</label>
								<select id="lt-depth"></select>
							</div>
							<div class="lt-field">
								<label>Color</label>
								<select id="lt-color"></select>
							</div>
							<div class="lt-field lt-field-qty">
								<label>Qty</label>
								<input type="number" id="lt-qty" value="1" min="1" max="100" step="1" />
							</div>
							<div class="lt-field lt-field-btn">
								<label>&nbsp;</label>
								<button type="button" class="lt-add-btn" id="lt-add-btn" style="margin-left:16px">Add to Layout</button>
							</div>
							<span class="lt-price" id="lt-price"></span>
						</div>
						<div class="lt-accessories-row" id="lt-accessories-row">
							<label class="lt-acc-label">Accessories</label>
							<div class="lt-acc-list" id="lt-acc-list"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="planner-app" id="planner-app">
		<!-- Toolbar -->
		<div class="planner-toolbar" id="planner-toolbar">
			<div class="toolbar-left" style="display:none">
				<button type="button" class="tb-btn" id="btn-edit-mode" title="Switch to Edit mode">
					<span class="tb-icon">✎</span> Edit
				</button>
				<div class="tb-locker-group">
					<select id="locker-model-select" class="tb-model-select" title="Locker model"></select>
					<button type="button" class="tb-btn" id="btn-add-locker" title="Place locker(s) on the layout">
						+ Locker
					</button>
					<input type="number" id="locker-qty" class="tb-qty" value="1" min="1" max="100" step="1" title="Quantity" />
				</div>
				<button type="button" class="tb-btn" id="btn-add-door" title="Add a door">
					+ Door
				</button>
				<button type="button" class="tb-btn" id="btn-add-window" title="Add a window">
					+ Window
				</button>
				<button type="button" class="tb-btn tb-rotate" id="btn-rotate-locker" title="Rotate selected locker 90°">
					↻ Rotate
				</button>
				<button type="button" class="tb-btn tb-reset" id="btn-reset-lockers" title="Remove all lockers">
					Reset Lockers
				</button>
			</div>
			<div class="toolbar-center">
				<button type="button" class="tb-btn tb-sm" id="btn-zoom-out" title="Zoom out">&minus;</button>
				<span class="tb-zoom-label" id="zoom-label">100%</span>
				<button type="button" class="tb-btn tb-sm" id="btn-zoom-in" title="Zoom in">+</button>
				<button type="button" class="tb-btn tb-sm" id="btn-zoom-fit" title="Fit room">&boxplus;</button>
				<span class="tb-divider"></span>
				<button type="button" class="tb-btn tb-rotate" id="btn-rotate-visible" title="Rotate selected locker 90°">↻ Rotate</button>
				<span class="tb-divider"></span>
				<button type="button" class="tb-btn tb-3d" id="btn-view-3d" title="Preview your room in 3D">3D View</button>
				<span class="tb-divider"></span>
				<button type="button" class="tb-btn tb-save" id="btn-toolbar-save" title="Save all rooms">
					<svg class="tb-save-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
					Save
				</button>
			</div>
			<div class="toolbar-right">
				<select id="unit-select" class="tb-select" title="Display unit">
					<option value="in">Inches</option>
					<option value="ft">Feet</option>
					<option value="cm">cm</option>
					<option value="mm">mm</option>
				</select>
			</div>
		</div>

		<!-- Corner clearance guide -->
		<div class="corner-guide" id="corner-guide">
			<div class="corner-guide-header">
				<svg class="corner-guide-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V3h18"/><path d="M7 21V7h14" opacity=".35"/></svg>
				<span class="corner-guide-title">Corner Clearance</span>
			</div>
			<div class="corner-guide-body">
				<div class="corner-rule corner-rule-warn">
					<span class="corner-rule-badge">30&Prime;</span>
					<div>
						<strong>Adjacent walls</strong>
						<span class="corner-rule-detail">When lockers sit on two connecting walls (e.g. A&nbsp;+&nbsp;B), a 30&Prime; clearance is auto-reserved at the corner.</span>
					</div>
				</div>
				<div class="corner-rule corner-rule-ok">
					<span class="corner-rule-badge">&check;</span>
					<div>
						<strong>Single wall</strong>
						<span class="corner-rule-detail">No clearance needed &mdash; the full wall length is available for lockers.</span>
					</div>
				</div>
			</div>
			<div class="corner-status" id="corner-status"></div>
		</div>

		<!-- Main 3-column layout -->
		<div class="planner-columns">
			<!-- LEFT: Layers + Selection Config -->
			<aside class="planner-layers" id="planner-layers">
				<h3 class="panel-heading">Layers</h3>
				<p class="layers-hint" id="layers-hint">This panel lists every item in your room: walls, doors, windows, and lockers. Click any item to select it on the canvas, then you can edit its size, color, or position. As you add lockers they will appear here.</p>
				<ul class="layers-list" id="layers-list"></ul>

				<div class="selection-config" id="selection-config" style="display:none;">
					<div class="sel-config-header">
						<span class="sel-config-title" id="sel-config-title">Selection</span>
						<button type="button" class="sel-config-close" id="sel-config-close" title="Close">&times;</button>
					</div>
					<div class="props-locker" id="props-locker" style="display:none;">
						<div class="prop-row">
							<label class="prop-label">Model</label>
							<span class="prop-value" id="prop-model-name"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">Width</label>
							<div class="prop-swatches" id="prop-width-options"></div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Depth</label>
							<div class="prop-swatches" id="prop-depth-options"></div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Color</label>
							<select id="prop-color-select" class="prop-select"></select>
						</div>
						<div class="prop-row">
							<label class="prop-label">Accessories</label>
							<div class="prop-accessories" id="prop-accessories"></div>
						</div>
						<div class="prop-row prop-price-row">
							<label class="prop-label">Unit Price</label>
							<span class="prop-price" id="prop-price">$0</span>
						</div>
						<div class="prop-row">
							<button type="button" class="tb-btn prop-rotate-btn" id="prop-rotate-locker">Rotate 90&deg;</button>
							<button type="button" class="tb-btn prop-delete-btn" id="prop-delete-locker">Delete</button>
						</div>
					</div>
					<div class="props-wall" id="props-wall" style="display:none;">
						<div class="prop-row">
							<label class="prop-label">Wall</label>
							<span class="prop-value" id="prop-wall-id"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">Length</label>
							<div class="prop-input-row">
								<input type="number" id="prop-wall-length" class="prop-input" step="1" min="24" />
								<span class="prop-input-unit" id="prop-wall-length-unit">&Prime;</span>
							</div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Thickness</label>
							<div class="prop-input-row">
								<input type="number" id="prop-wall-thickness" class="prop-input" step="0.5" min="1" />
								<span class="prop-input-unit">&Prime;</span>
							</div>
						</div>
						<button type="button" class="tb-btn fill-wall-btn" id="btn-fill-wall">Fill with lockers</button>
					</div>
					<div class="props-opening" id="props-opening" style="display:none;">
						<div class="prop-row">
							<label class="prop-label">Type</label>
							<span class="prop-value" id="prop-opening-type"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">On wall</label>
							<span class="prop-value" id="prop-opening-wall"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">Width</label>
							<div class="prop-input-row">
								<input type="number" id="prop-opening-width" class="prop-input" step="1" min="12" />
								<span class="prop-input-unit">&Prime;</span>
							</div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Offset from start</label>
							<div class="prop-input-row">
								<input type="number" id="prop-opening-offset" class="prop-input" step="1" min="0" />
								<span class="prop-input-unit">&Prime;</span>
							</div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Clearance</label>
							<div class="prop-input-row">
								<input type="number" id="prop-opening-clearance" class="prop-input" step="1" min="0" />
								<span class="prop-input-unit">&Prime;</span>
							</div>
						</div>
						<button type="button" class="tb-btn delete-opening-btn" id="btn-delete-opening">Delete opening</button>
					</div>
				</div>
			</aside>

			<!-- CENTER: Canvas -->
			<div class="planner-canvas-wrap" id="planner-canvas-wrap">
				<div class="placement-tooltip" id="placement-tooltip" style="display:none">
					<span class="placement-tooltip-icon">&#9678;</span>
					<span class="placement-tooltip-text" id="placement-tooltip-text">Click on the wall to place</span>
					<button type="button" class="placement-tooltip-cancel" id="placement-cancel">&times; Cancel</button>
				</div>
				<canvas id="planner-canvas"></canvas>
				<div id="placement-toast" class="placement-toast" style="display:none"></div>
				<div class="canvas-empty-hint" id="canvas-empty-hint" style="display:none;">
					<div class="canvas-hint-icon">&boxplus;</div>
					<div class="canvas-hint-title">Your layout will appear here</div>
					<div class="canvas-hint-body">Your room is loading from the previous step. If nothing appears, <a href="/new-room-planner">go back</a> and re-enter your dimensions.</div>
				</div>
			</div>
		</div>

		<!-- Mobile tab bar -->
		<nav class="planner-mobile-tabs" id="planner-mobile-tabs">
			<button type="button" class="mob-tab active" data-panel="canvas">Plan</button>
			<button type="button" class="mob-tab" data-panel="layers">Layers</button>
		</nav>
	</section>

	<!-- 3D Preview Modal -->
	<div class="view3d-overlay" id="view3d-overlay">
		<div class="view3d-header">
			<span class="view3d-title">3D Preview <span class="view3d-room-name" id="view3d-room-name"></span></span>
			<div class="view3d-controls">
				<button type="button" class="view3d-btn view3d-rotate-btn" id="btn-3d-rotate" title="Rotate selected locker 90°">&circlearrowright; Rotate</button>
				<button type="button" class="view3d-btn view3d-select-all-btn" id="btn-3d-select-all" title="Select all lockers to change them at once">Select All</button>
				<span class="view3d-sep"></span>
				<div class="view3d-delete-group">
					<input type="number" class="view3d-delete-count" id="input-3d-delete-count" min="1" value="1" title="Number of lockers to delete" />
					<button type="button" class="view3d-btn view3d-delete-btn" id="btn-3d-delete" title="Delete lockers from the end">Delete Locker</button>
				</div>
				<span class="view3d-sep"></span>
				<button type="button" class="view3d-btn view3d-logo-btn" id="btn-3d-logo" title="Upload your team logo for the floor">Floor Logo</button>
				<input type="file" id="logo-file-input" accept="image/png,image/jpeg,image/svg+xml,image/webp,image/gif" style="display:none" />
				<button type="button" class="view3d-btn view3d-logo-remove" id="btn-3d-logo-remove" style="display:none" title="Remove floor logo">&times; Logo</button>
				<button type="button" class="view3d-btn" id="btn-3d-reset">Reset View</button>
				<span class="view3d-sep"></span>
				<button type="button" class="view3d-btn view3d-save-btn" id="btn-3d-save" title="Save all rooms">
					<svg class="view3d-save-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
					Save
				</button>
				<button type="button" class="view3d-close" id="btn-3d-close">&times;</button>
			</div>
		</div>
		<div class="view3d-swatch-row" id="view3d-swatch-row">
			<div class="view3d-bar-stack">
				<div class="view3d-bar-row">
					<div class="view3d-color-bar" id="view3d-color-bar" style="display:none">
						<span class="view3d-color-label" id="view3d-color-label">Locker Colors</span>
						<div class="view3d-color-swatches" id="view3d-color-swatches"></div>
					</div>
					<div class="view3d-color-bar" id="view3d-cushion-bar" style="display:none">
						<span class="view3d-color-label" id="view3d-cushion-label">Cushion Colors</span>
						<div class="view3d-color-swatches" id="view3d-cushion-swatches"></div>
					</div>
				</div>
				<div class="view3d-bar-row">
					<div class="view3d-color-bar" id="view3d-base-bar">
						<span class="view3d-color-label">4&Prime; Base</span>
						<div class="view3d-base-row">
							<button type="button" class="view3d-base-toggle" id="btn-base-toggle">Add 4&Prime; Base</button>
							<div class="view3d-color-swatches" id="view3d-base-swatches" style="display:none"></div>
						</div>
					</div>
					<div class="view3d-color-bar" id="view3d-edgeband-bar">
						<span class="view3d-color-label">Edgebanding</span>
						<div class="view3d-base-row">
							<button type="button" class="view3d-base-toggle" id="btn-edgeband-toggle">Add Edgebanding</button>
							<div class="view3d-color-swatches" id="view3d-edgeband-swatches" style="display:none"></div>
						</div>
					</div>
				</div>
			</div>
			<div class="view3d-bar-stack view3d-size-stack">
				<div class="view3d-color-bar view3d-size-bar" id="view3d-depth-bar" style="display:none">
					<span class="view3d-color-label">Depth</span>
					<div class="view3d-size-options" id="view3d-depth-options"></div>
				</div>
				<div class="view3d-color-bar view3d-size-bar" id="view3d-width-bar" style="display:none">
					<span class="view3d-color-label">Width</span>
					<div class="view3d-size-options" id="view3d-width-options"></div>
				</div>
				<div class="view3d-color-bar view3d-acc-bar" id="view3d-acc-bar" style="display:none">
					<span class="view3d-color-label">Accessories</span>
					<div class="view3d-acc-toggles" id="view3d-acc-toggles"></div>
				</div>
			</div>
			<div class="view3d-bar-stack view3d-floor-wall-stack">
				<div class="view3d-color-bar" id="view3d-floor-bar">
					<span class="view3d-color-label">Floor Color</span>
					<div class="view3d-color-swatches" id="view3d-floor-swatches"></div>
				</div>
				<div class="view3d-color-bar" id="view3d-wall-bar">
					<span class="view3d-color-label">Wall Color</span>
					<div class="view3d-color-swatches" id="view3d-wall-swatches"></div>
				</div>
			</div>
		</div>
		<div class="view3d-canvas-wrap">
			<canvas id="view3d-canvas"></canvas>
			<button type="button" class="view3d-room-arrow view3d-room-arrow-left" id="btn-3d-prev" title="Previous room" disabled>&lsaquo;</button>
			<button type="button" class="view3d-room-arrow view3d-room-arrow-right" id="btn-3d-next" title="Next room" disabled>&rsaquo;</button>
			<div class="view3d-room-indicator" id="view3d-room-indicator">ROOM 1 OF 1</div>
		</div>
		<div class="view3d-bottom-cta">
			<button type="button" class="view3d-continue-step3-btn" id="btn-3d-continue-review" disabled>
				Continue to Step 3: Review &amp; Send &rarr;
			</button>
		</div>
		<div class="view3d-hint">Drag background to orbit &middot; Click locker to select &middot; Drag locker to move &middot; Double-click or press R to rotate</div>
	</div>

	<!-- Continue to Review -->
	<section class="continue-section" id="continue-section">
		<div class="continue-inner">
			<p class="continue-summary" id="continue-summary">0 lockers placed</p>
			<button type="button" class="continue-btn" id="btn-continue-review">Continue to Review &rarr;</button>
		</div>
	</section>

	<!-- Guide Agent -->
	<div class="guide-fab" id="guide-fab" title="Open step-by-step guide">?</div>
	<div class="guide-panel" id="guide-panel">
		<div class="guide-header">
			<span class="guide-title">Locker Room Guide</span>
			<button type="button" class="guide-minimize" id="guide-minimize" title="Minimize guide">&minus;</button>
		</div>
		<div class="guide-progress">
			<div class="guide-progress-bar" id="guide-progress-bar"></div>
		</div>
		<div class="guide-step-count" id="guide-step-count">Step 1 of 6</div>
		<div class="guide-body" id="guide-body">
			<div class="guide-step-title" id="guide-step-title"></div>
			<div class="guide-step-desc" id="guide-step-desc"></div>
		</div>
		<div class="guide-nav">
			<button type="button" class="guide-nav-btn" id="guide-prev" disabled>&larr; Back</button>
			<button type="button" class="guide-nav-btn guide-nav-next" id="guide-next">Next &rarr;</button>
		</div>
	</div>
</BaseLayout>

<style>
	.planner-hero {
		background: #ffffff;
		color: #0d0d0d;
		padding: 80px 20px 40px;
		text-align: center;
	}
	.planner-hero-inner {
		max-width: 900px;
		margin: 0 auto;
	}
	.planner-hero-subtitle {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 6px;
		text-transform: uppercase;
		color: #8c8c8c;
		margin-bottom: 12px;
	}
