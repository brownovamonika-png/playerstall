	function populateFloorWallSwatches(): void {
		floorBarSwatches.innerHTML = '';
		for (const c of FLOOR_COLORS) {
			const btn = document.createElement('button');
			btn.type = 'button';
			btn.className = 'view3d-cswatch' + (c.hex === state.floorColor ? ' active' : '');
			btn.dataset.color = c.hex;
			btn.style.cssText = `background:${c.hex};width:28px;height:28px;min-width:28px;min-height:28px;`;
			btn.title = c.label;
			btn.onclick = () => {
				state.floorColor = c.hex;
				floorBarSwatches.querySelectorAll('.view3d-cswatch').forEach(s => s.classList.remove('active'));
				btn.classList.add('active');
				syncFloorSwatches();
				redraw();
			};
			floorBarSwatches.appendChild(btn);
		}

		wallBarSwatches.innerHTML = '';
		for (const c of WALL_COLORS) {
			const btn = document.createElement('button');
			btn.type = 'button';
			btn.className = 'view3d-cswatch' + (c.hex === state.wallColor ? ' active' : '');
			btn.dataset.color = c.hex;
			btn.style.cssText = `background:${c.hex};width:28px;height:28px;min-width:28px;min-height:28px;${c.hex === '#ffffff' ? 'border:1px solid #666;' : ''}`;
			btn.title = c.label;
			btn.onclick = () => {
				state.wallColor = c.hex;
				wallBarSwatches.querySelectorAll('.view3d-cswatch').forEach(s => s.classList.remove('active'));
				btn.classList.add('active');
				syncWallSwatches();
				redraw();
			};
			wallBarSwatches.appendChild(btn);
		}
	}

	function syncFloorSwatches() {
		document.querySelectorAll('#view3d-floor-swatches .view3d-cswatch').forEach(s => {
			const el = s as HTMLElement;
			el.classList.toggle('active', el.dataset.color === state.floorColor);
		});
		updateFloorColor3D(state.floorColor);
	}
	function syncWallSwatches() {
		document.querySelectorAll('#view3d-wall-swatches .view3d-cswatch').forEach(s => {
			const el = s as HTMLElement;
			el.classList.toggle('active', el.dataset.color === state.wallColor);
		});
		updateWallColor3D(state.wallColor);
	}

	function update3DColorBar(): void {
		if (!state.selection || state.selection.type !== 'locker') {
			colorBar.style.display = 'none';
			cushionBar.style.display = 'none';
			return;
		}
		const locker = state.lockers.find(l => l.instanceId === state.selection!.id);
		if (!locker) { colorBar.style.display = 'none'; cushionBar.style.display = 'none'; return; }
		const template = getTemplate(locker.templateId);
		if (!template) { colorBar.style.display = 'none'; cushionBar.style.display = 'none'; return; }

		colorBar.style.display = 'flex';
		colorBarLabel.textContent = 'Locker Colors';

		colorBarSwatches.innerHTML = '';
		for (const c of template.colors) {
			const btn = document.createElement('button');
			btn.type = 'button';
			btn.className = 'view3d-cswatch' + (c.code === locker.config.colorCode ? ' active' : '');
			btn.style.cssText = `background:${c.hex};width:28px;height:28px;min-width:28px;min-height:28px;`;
			btn.title = c.label;
			btn.onclick = () => {
				locker.config.colorCode = c.code;
				colorBarSwatches.querySelectorAll('.view3d-cswatch').forEach(s => s.classList.remove('active'));
				btn.classList.add('active');
				rebuildLockerMesh3D(locker.instanceId);
				redraw();
			};
			colorBarSwatches.appendChild(btn);
		}

		cushionBar.style.display = 'flex';
		cushionBarLabel.textContent = 'Cushion Colors';

		cushionBarSwatches.innerHTML = '';
		for (const c of CUSHION_COLORS) {
			const btn = document.createElement('button');
			btn.type = 'button';
			btn.className = 'view3d-cswatch' + (c.hex === locker.config.cushionColorHex ? ' active' : '');
			btn.style.cssText = `background:${c.hex};width:28px;height:28px;min-width:28px;min-height:28px;`;
			btn.title = c.label;
			btn.onclick = () => {
				locker.config.cushionColorHex = c.hex;
				cushionBarSwatches.querySelectorAll('.view3d-cswatch').forEach(s => s.classList.remove('active'));
				btn.classList.add('active');
				rebuildLockerMesh3D(locker.instanceId);
				redraw();
			};
			cushionBarSwatches.appendChild(btn);
		}
	}

	document.getElementById('btn-3d-close')!.onclick = () => { swatchRow.style.display = 'none'; colorBar.style.display = 'none'; cushionBar.style.display = 'none'; overlay3d.style.display = 'none'; dispose3DPreview(); };

	// ─── Reset lockers ───
	document.getElementById('btn-reset-lockers')!.onclick = () => { state.lockers = []; state.selection = null; redraw(); };

	// ─── Model select dropdown (hidden toolbar) ───
	const modelSelect = document.getElementById('locker-model-select') as HTMLSelectElement;
	for (const t of getAllTemplates()) {
		const opt = document.createElement('option');
		opt.value = t.templateId;
		opt.textContent = t.displayName;
		modelSelect.appendChild(opt);
	}
	function getSelectedTemplate() { return getTemplate(modelSelect.value) ?? getAllTemplates()[0]; }

	// ─── Add locker(s) (hidden toolbar) ───
	const btnAddLocker = document.getElementById('btn-add-locker')!;
	const qtyInput = document.getElementById('locker-qty') as HTMLInputElement;
	btnAddLocker.onclick = () => {
		const qty = Math.max(1, Math.min(100, parseInt(qtyInput.value, 10) || 1));
		const t = getSelectedTemplate();
		const w = t.geometry.defaultWidthIn;
		const d = t.geometry.defaultDepthIn;
		const cx = state.camera.centerX - w / 2;
		const cy = state.camera.centerY - d / 2;
		let lastPlacedId: string | null = null;
		for (let n = 0; n < qty; n++) {
			let placed = false;
			for (let ring = 0; ring < 60 && !placed; ring++) {
				const step = ring * Math.max(w, d);
				const candidates = ring === 0 ? [{ dx: 0, dy: 0 }]
					: [{ dx: step, dy: 0 }, { dx: -step, dy: 0 }, { dx: 0, dy: step }, { dx: 0, dy: -step },
						{ dx: step, dy: step }, { dx: -step, dy: step }, { dx: step, dy: -step }, { dx: -step, dy: -step }];
				for (const { dx, dy } of candidates) {
					const inst: LockerInstance = {
						instanceId: nextInstanceId(), templateId: t.templateId,
						config: { widthIn: w, depthIn: d, colorCode: t.colors[0].code, accessoryIds: [], cushionColorHex: '#1A1A1A' },
						x: cx + dx, y: cy + dy, rotationDeg: 0,
					};
					if (!wouldOverlap(inst, state.lockers, state.openings, state.walls)) {
						state.lockers.push(inst); lastPlacedId = inst.instanceId; placed = true; break;
					}
				}
			}
		}
		if (lastPlacedId) {
			state.selection = { type: 'locker', id: lastPlacedId };
		} else {
			const toast = document.getElementById('placement-toast');
			if (toast) {
				toast.textContent = 'Not enough space — try removing lockers or enlarging the room.';
				toast.style.display = 'block';
				setTimeout(() => { toast.style.display = 'none'; }, 3000);
			}
		}
		redraw();
	};

	// ─── Add door / window ───
	let _openingCounter = 1000;
	function addOpeningToWall(wallId: string, type: 'door' | 'window' | 'obstacle', atOffset?: number) {
		const wall = state.walls.find((w) => w.id === wallId);
		if (!wall) return;
		const len = wallLength(wall);
		const defaultWidth = type === 'obstacle' ? 24 : 36;
		const defaultClearance = type === 'door' ? 36 : type === 'window' ? 24 : 12;
		if (len < defaultWidth) return;
		let offset: number;
		if (atOffset !== undefined) {
			offset = Math.max(0, Math.min(atOffset - defaultWidth / 2, len - defaultWidth));
		} else {
			const existingOnWall = state.openings.filter((o) => o.wallId === wallId);
			offset = 0;
			for (const ex of existingOnWall) { const end = ex.offsetAlongWall + ex.widthIn; if (end > offset) offset = end; }
			if (offset + defaultWidth > len) return;
		}
		const op: Opening = { id: `op_${++_openingCounter}`, type, wallId, offsetAlongWall: offset, widthIn: defaultWidth, clearanceIn: defaultClearance };
		state.openings.push(op);
		state.selection = { type: 'opening', id: op.id };
		redraw();
	}

	/* ── Placement mode ─────────────────────────────────────── */
	const _placementTooltip = document.getElementById('placement-tooltip')!;
	const _placementTooltipText = document.getElementById('placement-tooltip-text')!;

	function enterPlacementMode(wallId: string | null, type: 'door' | 'window' | 'obstacle') {
		placementMode = { wallId, type };
		if (wallId) state.selection = { type: 'wall', id: wallId };
		const label = type === 'door' ? 'door' : type === 'window' ? 'window' : 'obstacle';
		_placementTooltipText.textContent = wallId
			? `Click on ${wallId} where you want to place this ${label}`
			: `Click on any wall where you want to place this ${label}`;
		_placementTooltip.style.display = 'flex';
		canvas.style.cursor = 'crosshair';
		redraw();
	}
	function exitPlacementMode() {
		placementMode = null;
		_placementTooltip.style.display = 'none';
		canvas.style.cursor = '';
		redraw();
	}
	document.getElementById('placement-cancel')!.onclick = exitPlacementMode;
	document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && placementMode) exitPlacementMode(); });

	document.getElementById('btn-add-door')!.onclick = () => {
		const wid = state.selection?.type === 'wall' ? state.selection.id : null;
		enterPlacementMode(wid, 'door');
	};
	document.getElementById('btn-add-window')!.onclick = () => {
		const wid = state.selection?.type === 'wall' ? state.selection.id : null;
		enterPlacementMode(wid, 'window');
	};

	// ─── Canvas pointer events ───
	let dragging: LockerInstance | null = null;
	let dragOffsetX = 0, dragOffsetY = 0;
	let draggingOpening: Opening | null = null;
	let isPanning = false;
	let panStartX = 0, panStartY = 0, panCamStartX = 0, panCamStartY = 0;

	canvas.addEventListener('pointerdown', (e) => {
		const rect = canvas.getBoundingClientRect();
		const sx = e.clientX - rect.left;
		const sy = e.clientY - rect.top;
		const world = screenToWorld(sx, sy, state.camera, canvas.clientWidth, canvas.clientHeight);

		if (placementMode) {
			let targetWall = placementMode.wallId ? state.walls.find((w) => w.id === placementMode!.wallId) : null;
			if (!targetWall) {
				let bestDist = Infinity;
				for (const w of state.walls) {
					const along = projectOntoWall(world.x, world.y, w);
					const len = wallLength(w);
					const dx = w.end.x - w.start.x, dy = w.end.y - w.start.y;
					const ux = dx / len, uy = dy / len;
					const px = w.start.x + ux * along, py = w.start.y + uy * along;
					const d = Math.sqrt((world.x - px) ** 2 + (world.y - py) ** 2);
					if (d < bestDist) { bestDist = d; targetWall = w; }
				}
			}
			if (targetWall) {
				const off = projectOntoWall(world.x, world.y, targetWall);
				addOpeningToWall(targetWall.id, placementMode.type, off);
			}
			exitPlacementMode();
			return;
		}

		let hitLocker: LockerInstance | null = null;
		for (let i = state.lockers.length - 1; i >= 0; i--) {
			const l = state.lockers[i];
			const box = lockerAABB(l);
			if (world.x >= box.minX && world.x <= box.maxX && world.y >= box.minY && world.y <= box.maxY) { hitLocker = l; break; }
		}
		if (hitLocker) {
			state.selection = { type: 'locker', id: hitLocker.instanceId };
			if (state.editMode) { dragging = hitLocker; dragOffsetX = world.x - hitLocker.x; dragOffsetY = world.y - hitLocker.y; canvas.setPointerCapture(e.pointerId); }
			redraw(); return;
		}
		const hitOp = hitTestOpening(world.x, world.y, state.openings, state.walls);
		if (hitOp) {
			state.selection = { type: 'opening', id: hitOp.id };
			draggingOpening = hitOp;
			canvas.setPointerCapture(e.pointerId);
			canvas.style.cursor = 'grabbing';
			redraw(); return;
		}
		for (const wall of state.walls) {
			const hitDist = distToSegment(world.x, world.y, wall.start.x, wall.start.y, wall.end.x, wall.end.y);
			if (hitDist < wall.thicknessIn / 2 + 4 / state.camera.pixelsPerInch) {
				state.selection = { type: 'wall', id: wall.id }; redraw(); return;
			}
		}
		state.selection = null;
		isPanning = true; panStartX = e.clientX; panStartY = e.clientY;
		panCamStartX = state.camera.centerX; panCamStartY = state.camera.centerY;
		canvas.setPointerCapture(e.pointerId); redraw();
	});

	const SNAP_THRESHOLD = 8;
	function snapLocker(target: LockerInstance): void {
		const box = lockerAABB(target);
		const snapDist = SNAP_THRESHOLD / state.camera.pixelsPerInch;
		let bestDx = Infinity, bestDy = Infinity;
		for (const other of state.lockers) {
			if (other.instanceId === target.instanceId) continue;
			const ob = lockerAABB(other);
			for (const edge of [{ from: box.maxX, to: ob.minX }, { from: box.minX, to: ob.maxX }, { from: box.minX, to: ob.minX }, { from: box.maxX, to: ob.maxX }]) {
				const d = edge.to - edge.from; if (Math.abs(d) < Math.abs(bestDx) && Math.abs(d) < snapDist) bestDx = d;
			}
			for (const edge of [{ from: box.maxY, to: ob.minY }, { from: box.minY, to: ob.maxY }, { from: box.minY, to: ob.minY }, { from: box.maxY, to: ob.maxY }]) {
				const d = edge.to - edge.from; if (Math.abs(d) < Math.abs(bestDy) && Math.abs(d) < snapDist) bestDy = d;
			}
		}
		for (const wall of state.walls) {
			const halfT = wall.thicknessIn / 2;
			const isHoriz = Math.abs(wall.end.y - wall.start.y) < 0.01;
			if (isHoriz) {
				const innerY = wall.start.y + (wall.id === 'Wall A' ? halfT : -halfT);
				const dTop = innerY - box.minY; const dBot = innerY - box.maxY;
				if (Math.abs(dTop) < Math.abs(bestDy) && Math.abs(dTop) < snapDist) bestDy = dTop;
				if (Math.abs(dBot) < Math.abs(bestDy) && Math.abs(dBot) < snapDist) bestDy = dBot;
				const xMin = Math.min(wall.start.x, wall.end.x) + halfT;
				const xMax = Math.max(wall.start.x, wall.end.x) - halfT;
				const dL = xMin - box.minX; const dR = xMax - box.maxX;
				if (Math.abs(dL) < Math.abs(bestDx) && Math.abs(dL) < snapDist) bestDx = dL;
				if (Math.abs(dR) < Math.abs(bestDx) && Math.abs(dR) < snapDist) bestDx = dR;
			} else {
				const innerX = wall.start.x + (wall.id === 'Wall D' ? halfT : -halfT);
				const dLeft = innerX - box.minX; const dRight = innerX - box.maxX;
				if (Math.abs(dLeft) < Math.abs(bestDx) && Math.abs(dLeft) < snapDist) bestDx = dLeft;
				if (Math.abs(dRight) < Math.abs(bestDx) && Math.abs(dRight) < snapDist) bestDx = dRight;
				const yMin = Math.min(wall.start.y, wall.end.y) + halfT;
				const yMax = Math.max(wall.start.y, wall.end.y) - halfT;
				const dT = yMin - box.minY; const dB = yMax - box.maxY;
				if (Math.abs(dT) < Math.abs(bestDy) && Math.abs(dT) < snapDist) bestDy = dT;
				if (Math.abs(dB) < Math.abs(bestDy) && Math.abs(dB) < snapDist) bestDy = dB;
			}
		}
		if (Math.abs(bestDx) < snapDist) target.x += bestDx;
		if (Math.abs(bestDy) < snapDist) target.y += bestDy;
	}

	canvas.addEventListener('pointermove', (e) => {
		if (draggingOpening) {
			const wall = state.walls.find((w) => w.id === draggingOpening!.wallId);
			if (wall) {
				const rect = canvas.getBoundingClientRect();
				const world = screenToWorld(e.clientX - rect.left, e.clientY - rect.top, state.camera, canvas.clientWidth, canvas.clientHeight);
				const along = projectOntoWall(world.x, world.y, wall);
				const len = wallLength(wall);
				draggingOpening.offsetAlongWall = Math.max(0, Math.min(along - draggingOpening.widthIn / 2, len - draggingOpening.widthIn));
				redraw();
			}
		} else if (dragging) {
			const rect = canvas.getBoundingClientRect();
			const world = screenToWorld(e.clientX - rect.left, e.clientY - rect.top, state.camera, canvas.clientWidth, canvas.clientHeight);
			const oldX = dragging.x, oldY = dragging.y;
			dragging.x = world.x - dragOffsetX; dragging.y = world.y - dragOffsetY;
			clampLockerToRoom(dragging, state.walls);
			snapLocker(dragging);
			clampLockerToRoom(dragging, state.walls);
			if (wouldOverlap(dragging, state.lockers, state.openings, state.walls)) { dragging.x = oldX; dragging.y = oldY; }
			redraw();
		} else if (isPanning) {
			state.camera.centerX = panCamStartX - (e.clientX - panStartX) / state.camera.pixelsPerInch;
			state.camera.centerY = panCamStartY - (e.clientY - panStartY) / state.camera.pixelsPerInch;
			redraw();
		}
	});
	canvas.addEventListener('pointerup', () => { if (draggingOpening) { canvas.style.cursor = ''; } dragging = null; draggingOpening = null; isPanning = false; });
	canvas.addEventListener('dblclick', (e) => {
		const rect = canvas.getBoundingClientRect();
		const world = screenToWorld(e.clientX - rect.left, e.clientY - rect.top, state.camera, canvas.clientWidth, canvas.clientHeight);
		for (let i = state.lockers.length - 1; i >= 0; i--) {
			const l = state.lockers[i]; const box = lockerAABB(l);
			if (world.x >= box.minX && world.x <= box.maxX && world.y >= box.minY && world.y <= box.maxY) {
				const oldRot = l.rotationDeg; l.rotationDeg = (l.rotationDeg + 90) % 360;
				if (wouldOverlap(l, state.lockers, state.openings, state.walls)) l.rotationDeg = oldRot;
				state.selection = { type: 'locker', id: l.instanceId }; redraw(); return;
			}
		}
	});

	function distToSegment(px: number, py: number, x1: number, y1: number, x2: number, y2: number): number {
		const dx = x2 - x1, dy = y2 - y1, lenSq = dx * dx + dy * dy;
		if (lenSq === 0) return Math.hypot(px - x1, py - y1);
		let t = ((px - x1) * dx + (py - y1) * dy) / lenSq;
		t = Math.max(0, Math.min(1, t));
		return Math.hypot(px - (x1 + t * dx), py - (y1 + t * dy));
	}

	// ─── Layers list ───
	function updateLayers() {
		const list = document.getElementById('layers-list')!;
		let html = '';
		html += `<li class="${state.selection?.type === 'room' ? 'selected' : ''}" data-sel-type="room" data-sel-id="room"><span class="layer-icon" style="background:#888"></span> Room</li>`;
		for (const wall of state.walls) {
			const sel = state.selection?.type === 'wall' && state.selection.id === wall.id;
			html += `<li class="${sel ? 'selected' : ''}" data-sel-type="wall" data-sel-id="${wall.id}"><span class="layer-icon" style="background:#555"></span> ${wall.id} \u00b7 ${formatDimension(wallLength(wall), state.displayUnit, 0)}</li>`;
		}
		for (const op of state.openings) {
			const sel = state.selection?.type === 'opening' && state.selection.id === op.id;
			const opColor = op.type === 'door' ? '#5a9fd4' : op.type === 'window' ? '#6dc46d' : '#d4a05a';
			const wallLabel = state.walls.find((w) => w.id === op.wallId)?.id ?? op.wallId;
			const opLabel = op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle';
			html += `<li class="${sel ? 'selected' : ''}" data-sel-type="opening" data-sel-id="${op.id}"><span class="layer-icon" style="background:${opColor}"></span> ${opLabel} \u00b7 ${wallLabel}</li>`;
		}
		for (const locker of state.lockers) {
			const t = getTemplate(locker.templateId);
			const sel = state.selection?.type === 'locker' && state.selection.id === locker.instanceId;
			const color = t?.colors.find((c) => c.code === locker.config.colorCode);
			html += `<li class="${sel ? 'selected' : ''}" data-sel-type="locker" data-sel-id="${locker.instanceId}"><span class="layer-icon" style="background:${color?.hex ?? '#ccc'}"></span> ${t?.displayName ?? locker.templateId} \u00b7 ${formatDimension(locker.config.widthIn, state.displayUnit, 0)}</li>`;
		}
		list.innerHTML = html;
		const layersHint = document.getElementById('layers-hint');
		if (layersHint) layersHint.style.display = state.lockers.length ? 'none' : '';
		list.querySelectorAll('li').forEach((li) => {
			li.addEventListener('click', () => { state.selection = { type: li.dataset.selType as Selection['type'], id: li.dataset.selId! }; redraw(); });
		});
	}

	// ─── Selection config ───
	const selConfig = document.getElementById('selection-config')!;
	const selConfigTitle = document.getElementById('sel-config-title')!;
	document.getElementById('sel-config-close')!.onclick = () => { state.selection = null; redraw(); };

	function updateProperties() {
		const propsLocker = document.getElementById('props-locker')!;
		const propsWall = document.getElementById('props-wall')!;
		const propsOpening = document.getElementById('props-opening')!;
		propsLocker.style.display = 'none'; propsWall.style.display = 'none'; propsOpening.style.display = 'none';
		if (!state.selection || state.selection.type === 'room') { selConfig.style.display = 'none'; return; }
		selConfig.style.display = '';

		if (state.selection.type === 'locker') {
			const locker = state.lockers.find((l) => l.instanceId === state.selection!.id);
			if (!locker) { selConfig.style.display = 'none'; return; }
			const template = getTemplate(locker.templateId);
			if (!template) { selConfig.style.display = 'none'; return; }
			selConfigTitle.textContent = template.displayName;
			propsLocker.style.display = '';
			document.getElementById('prop-model-name')!.textContent = template.displayName;
			const widthDiv = document.getElementById('prop-width-options')!;
			widthDiv.innerHTML = '';
			for (const w of template.geometry.widthOptionsIn) {
				const btn = document.createElement('button');
				btn.textContent = `${w}\u2033`; btn.className = w === locker.config.widthIn ? 'active' : '';
				btn.onclick = () => { const oldW = locker.config.widthIn, oldD = locker.config.depthIn, oldX = locker.x, oldY = locker.y; locker.config.widthIn = w; adjustLockerPosition(locker, oldW, oldD); if (wouldOverlap(locker, state.lockers, state.openings, state.walls)) { locker.config.widthIn = oldW; locker.x = oldX; locker.y = oldY; } redraw(); };
				widthDiv.appendChild(btn);
			}
			const depthDiv = document.getElementById('prop-depth-options')!;
			depthDiv.innerHTML = '';
			for (const d of template.geometry.depthOptionsIn) {
				const btn = document.createElement('button');
				btn.textContent = `${d}\u2033`; btn.className = d === locker.config.depthIn ? 'active' : '';
				btn.onclick = () => { const oldW = locker.config.widthIn, oldD = locker.config.depthIn, oldX = locker.x, oldY = locker.y; locker.config.depthIn = d; adjustLockerPosition(locker, oldW, oldD); if (wouldOverlap(locker, state.lockers, state.openings, state.walls)) { locker.config.depthIn = oldD; locker.x = oldX; locker.y = oldY; } redraw(); };
				depthDiv.appendChild(btn);
			}
			const colorSel = document.getElementById('prop-color-select') as HTMLSelectElement;
			colorSel.innerHTML = '';
			for (const c of template.colors) {
				const opt = document.createElement('option');
				opt.value = c.code;
				opt.textContent = c.label;
				opt.selected = c.code === locker.config.colorCode;
				colorSel.appendChild(opt);
			}
			colorSel.onchange = () => {
				locker.config.colorCode = colorSel.value;
				rebuildLockerMesh3D(locker.instanceId);
				redraw();
			};
			const accDiv = document.getElementById('prop-accessories')!;
			accDiv.innerHTML = '';
			for (const acc of template.accessories) {
				const lbl = document.createElement('label'); const cb = document.createElement('input'); cb.type = 'checkbox'; cb.checked = locker.config.accessoryIds.includes(acc.id);
				cb.onchange = () => {
					if (cb.checked) {
						locker.config.accessoryIds.push(acc.id);
					} else {
						locker.config.accessoryIds = locker.config.accessoryIds.filter((a) => a !== acc.id);
					}
					rebuildLockerMesh3D(locker.instanceId);
					redraw();
				};
				lbl.appendChild(cb); lbl.appendChild(document.createTextNode(` ${acc.label} (+$${acc.price})`)); accDiv.appendChild(lbl);
			}
			document.getElementById('prop-price')!.textContent = `$${priceLocker(template, locker.config).toLocaleString()}`;
			document.getElementById('prop-rotate-locker')!.onclick = () => { const oldRot = locker.rotationDeg; locker.rotationDeg = (locker.rotationDeg + 90) % 360; if (wouldOverlap(locker, state.lockers, state.openings, state.walls)) locker.rotationDeg = oldRot; redraw(); };
			document.getElementById('prop-delete-locker')!.onclick = () => { state.lockers = state.lockers.filter((l) => l.instanceId !== locker.instanceId); state.selection = null; redraw(); };
		}

		if (state.selection.type === 'wall') {
			const wall = state.walls.find((w) => w.id === state.selection!.id);
			if (!wall) { selConfig.style.display = 'none'; return; }
			selConfigTitle.textContent = wall.id; propsWall.style.display = '';
			document.getElementById('prop-wall-id')!.textContent = wall.id;
			const lenInput = document.getElementById('prop-wall-length') as HTMLInputElement;
			lenInput.value = String(Math.round(wallLength(wall)));
			document.getElementById('prop-wall-length-unit')!.textContent = unitLabel(state.displayUnit);
			lenInput.onchange = () => {
				const newLen = parseFloat(lenInput.value) || wallLength(wall);
				const dimKey = wall.id === 'Wall A' ? 'wallA' : wall.id === 'Wall B' ? 'wallB' : wall.id === 'Wall C' ? 'wallC' : 'wallD';
				roomDims[dimKey] = newLen;
				if (dimKey === 'wallA') roomDims.wallC = newLen; if (dimKey === 'wallC') roomDims.wallA = newLen;
				if (dimKey === 'wallB') roomDims.wallD = newLen; if (dimKey === 'wallD') roomDims.wallB = newLen;
				state.walls = buildWalls(roomDims); state.lockers = [];
				state.openings = state.openings.filter((op) => { const w = state.walls.find((wl) => wl.id === op.wallId); return w && (op.offsetAlongWall + op.widthIn) <= wallLength(w); });
				state.selection = { type: 'wall', id: wall.id }; zoomFit(); redraw();
			};
			const thInput = document.getElementById('prop-wall-thickness') as HTMLInputElement;
			thInput.value = String(wall.thicknessIn);
			thInput.onchange = () => { wall.thicknessIn = parseFloat(thInput.value) || 4.5; const thKey = wall.id === 'Wall A' ? 'thicknessA' : wall.id === 'Wall B' ? 'thicknessB' : wall.id === 'Wall C' ? 'thicknessC' : 'thicknessD'; roomDims[thKey] = wall.thicknessIn; redraw(); };
		}

		if (state.selection.type === 'opening') {
			const op = state.openings.find((o) => o.id === state.selection!.id);
			if (!op) { selConfig.style.display = 'none'; return; }
			selConfigTitle.textContent = `${op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle'} \u00b7 ${op.wallId}`;
			propsOpening.style.display = '';
			document.getElementById('prop-opening-type')!.textContent = op.type === 'door' ? 'Door' : op.type === 'window' ? 'Window' : 'Obstacle';
			document.getElementById('prop-opening-wall')!.textContent = op.wallId;
			(document.getElementById('prop-opening-width') as HTMLInputElement).value = String(op.widthIn);
			(document.getElementById('prop-opening-width') as HTMLInputElement).onchange = function () { op.widthIn = Math.max(12, parseFloat(this.value) || op.widthIn); redraw(); };
			(document.getElementById('prop-opening-offset') as HTMLInputElement).value = String(op.offsetAlongWall);
			(document.getElementById('prop-opening-offset') as HTMLInputElement).onchange = function () { op.offsetAlongWall = Math.max(0, parseFloat(this.value) || 0); redraw(); };
			(document.getElementById('prop-opening-clearance') as HTMLInputElement).value = String(op.clearanceIn);
			(document.getElementById('prop-opening-clearance') as HTMLInputElement).onchange = function () { op.clearanceIn = Math.max(0, parseFloat(this.value) || 0); redraw(); };
			document.getElementById('btn-delete-opening')!.onclick = () => { state.openings = state.openings.filter((o) => o.id !== op.id); state.selection = null; redraw(); };
		}
	}

	// ─── Fill wall ───
	document.getElementById('btn-fill-wall')!.onclick = () => {
		if (state.selection?.type !== 'wall') return;
		const wall = state.walls.find((w) => w.id === state.selection!.id);
		if (!wall) return;
		const t = getSelectedTemplate();
		const defaultConfig = { widthIn: t.geometry.defaultWidthIn, depthIn: t.geometry.defaultDepthIn, colorCode: t.colors[0].code, accessoryIds: [] as string[], cushionColorHex: '#1A1A1A' };
		const wallOpenings = state.openings.filter((o) => o.wallId === wall.id);
		const newLockers = packWall(wall, t.templateId, defaultConfig, Date.now() % 100000, wallOpenings, state.lockers, state.walls);
		const valid = newLockers.filter((l) => !wouldOverlap(l, [...state.lockers, ...newLockers.filter((n) => n !== l)], state.openings, state.walls));
		state.lockers.push(...valid);
		if (valid.length > 0) state.selection = { type: 'locker', id: valid[0].instanceId };
		redraw();
	};

	// ─── Order summary ───
	interface LineItem { roomName: string; templateId: string; displayName: string; widthIn: number; depthIn: number; colorCode: string; colorLabel: string; accessoryIds: string[]; accessories: { label: string; price: number }[]; unitPrice: number; qty: number; }
	function buildLinesForLockers(lockers: LockerInstance[], roomName: string): LineItem[] {
		const lines: LineItem[] = [];
		for (const locker of lockers) {
			const t = getTemplate(locker.templateId); if (!t) continue;
			const price = priceLocker(t, locker.config);
			const color = t.colors.find((c) => c.code === locker.config.colorCode);
			const accs = locker.config.accessoryIds.map((id) => t.accessories.find((a) => a.id === id)).filter(Boolean) as { id: string; label: string; price: number }[];
			const sortedAcc = [...locker.config.accessoryIds].sort();
			const key = `${locker.templateId}|${locker.config.widthIn}|${locker.config.depthIn}|${locker.config.colorCode}|${sortedAcc.join(',')}`;
			const existing = lines.find((l) => `${l.templateId}|${l.widthIn}|${l.depthIn}|${l.colorCode}|${[...l.accessoryIds].sort().join(',')}` === key && l.roomName === roomName);
			if (existing) { existing.qty++; }
			else { lines.push({ roomName, templateId: locker.templateId, displayName: t.displayName, widthIn: locker.config.widthIn, depthIn: locker.config.depthIn, colorCode: locker.config.colorCode, colorLabel: color?.label ?? locker.config.colorCode, accessoryIds: [...locker.config.accessoryIds], accessories: accs.map((a) => ({ label: a.label, price: a.price })), unitPrice: price, qty: 1 }); }
		}
		return lines;
	}
	function getAllRoomLines(): LineItem[] {
		saveCurrentRoom();
		const allLines: LineItem[] = [];
		for (const room of savedRooms) allLines.push(...buildLinesForLockers(room.lockers, room.roomName));
		return allLines;
	}
	function updateOrderSummary() {
		const nameEl = document.getElementById('order-room-name')!;
		const tbody = document.getElementById('order-items-body')!;
		const subtotalEl = document.getElementById('order-subtotal')!;
		const totalEl = document.getElementById('order-total')!;
		const countEl = document.getElementById('order-locker-count')!;
		const allLines = getAllRoomLines();
		nameEl.textContent = '';
		if (allLines.length === 0) {
			tbody.innerHTML = '<tr><td colspan="3" class="ot-empty">No lockers placed yet.</td></tr>';
			subtotalEl.textContent = '$0.00'; totalEl.innerHTML = '<strong>$0.00</strong>'; countEl.textContent = '0 lockers';
			(window as any).__plannerAllLines = []; return;
		}
		(window as any).__plannerAllLines = allLines;
		let subtotal = 0, totalLockers = 0, html = '', currentRoom = '';
		for (const line of allLines) {
			const rLabel = line.roomName || 'Unnamed Room';
			if (rLabel !== currentRoom) { currentRoom = rLabel; html += `<tr class="ot-room-header"><td colspan="3">${currentRoom}</td></tr>`; }
			const lineTotal = line.unitPrice * line.qty; subtotal += lineTotal; totalLockers += line.qty;
			let accHtml = '';
			if (line.accessories.length) accHtml = line.accessories.map((a) => `<span class="ot-acc-line">+ ${a.label} <span class="ot-acc-price">+$${a.price}</span></span>`).join('');
			html += `<tr><td><span class="ot-item-name">${line.displayName}</span><span class="ot-item-spec">${line.widthIn}\u2033W \u00d7 ${line.depthIn}\u2033D \u00b7 ${line.colorLabel}</span>${accHtml}</td><td class="ot-item-qty">${line.qty}</td><td class="ot-item-total">$${lineTotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}</td></tr>`;
		}
		tbody.innerHTML = html;
		subtotalEl.textContent = `$${subtotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
		totalEl.innerHTML = `<strong>$${subtotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}</strong>`;
		countEl.textContent = `${totalLockers} locker${totalLockers !== 1 ? 's' : ''} across ${savedRooms.length || 1} room${savedRooms.length > 1 ? 's' : ''}`;
	}

	// ─── PDF Generation ───
	async function generateLayoutPDF(allLines: LineItem[], orderSummary: string, grandTotal: number, customerEmail: string): Promise<Blob | null> {
		const origIndex = activeRoomIndex;
		try {
			saveCurrentRoom();
			const pdf = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'letter' });
			const pageW = pdf.internal.pageSize.getWidth();
			const pageH = pdf.internal.pageSize.getHeight();
			const margin = 40;
			const offCanvas = document.createElement('canvas'); offCanvas.width = 1200; offCanvas.height = 800;
			const offCtx = offCanvas.getContext('2d')!;
			for (let ri = 0; ri < savedRooms.length; ri++) {
				if (ri > 0) pdf.addPage('letter', 'landscape');
				const room = savedRooms[ri]; const roomLabel = room.roomName || `Room ${ri + 1}`;
				const tempState: PlannerState = { roomName: room.roomName, sportType: (room.sportType || '') as any, displayUnit: state.displayUnit, editMode: false, camera: { centerX: 0, centerY: 0, pixelsPerInch: 2 }, walls: JSON.parse(JSON.stringify(room.walls)), openings: JSON.parse(JSON.stringify(room.openings)), lockers: JSON.parse(JSON.stringify(room.lockers)), selection: null, floorColor: room.floorColor || '#8B7355', wallColor: room.wallColor || '#ffffff' };
				let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
				for (const w of tempState.walls) { minX = Math.min(minX, w.start.x, w.end.x); minY = Math.min(minY, w.start.y, w.end.y); maxX = Math.max(maxX, w.start.x, w.end.x); maxY = Math.max(maxY, w.start.y, w.end.y); }
				if (isFinite(minX)) { tempState.camera.pixelsPerInch = Math.min((offCanvas.width - 60) / (maxX - minX || 100), (offCanvas.height - 60) / (maxY - minY || 100)); tempState.camera.centerX = (minX + maxX) / 2; tempState.camera.centerY = (minY + maxY) / 2; }
				offCtx.fillStyle = '#fff'; offCtx.fillRect(0, 0, offCanvas.width, offCanvas.height); render(offCtx, tempState);
				const imgData = offCanvas.toDataURL('image/png');
				const imgW = pageW - margin * 2; const imgH = (offCanvas.height / offCanvas.width) * imgW;
				pdf.setFontSize(16); pdf.setFont('helvetica', 'bold'); pdf.text(roomLabel, margin, margin);
				pdf.addImage(imgData, 'PNG', margin, margin + 10, imgW, Math.min(imgH, pageH - margin * 2 - 80));
				pdf.setFontSize(8); pdf.setFont('helvetica', 'italic'); pdf.setTextColor(180);
				pdf.text('PlayerStall Room Planner \u2014 playerstall.com', pageW / 2, pageH - 20, { align: 'center' }); pdf.setTextColor(0);
			}
			pdf.addPage('letter', 'portrait');
			const pW = pdf.internal.pageSize.getWidth(); let y = margin;
			pdf.setFontSize(18); pdf.setFont('helvetica', 'bold'); pdf.text('Order Summary', margin, y); y += 28;
			pdf.setFontSize(10); pdf.setFont('helvetica', 'normal'); pdf.text(`Customer: ${customerEmail}`, margin, y); y += 20;
			let curRoom = '';
			for (const line of allLines) {
				const room = line.roomName || 'Unnamed Room';
				if (room !== curRoom) { curRoom = room; y += 8; pdf.setFont('helvetica', 'bold'); pdf.setFontSize(11); pdf.text(room, margin, y); y += 16; pdf.setFont('helvetica', 'normal'); pdf.setFontSize(10); }
				const accText = line.accessories.length ? ` + ${line.accessories.map((a) => a.label).join(', ')}` : '';
				pdf.text(`${line.qty}x ${line.displayName} (${line.widthIn}"W x ${line.depthIn}"D, ${line.colorLabel}${accText})`, margin, y);
				pdf.text(`$${(line.unitPrice * line.qty).toFixed(2)}`, pW - margin, y, { align: 'right' }); y += 14;
				if (y > pdf.internal.pageSize.getHeight() - 60) { pdf.addPage('letter', 'portrait'); y = margin; }
			}
			y += 12; pdf.setDrawColor(200); pdf.line(margin, y, pW - margin, y); y += 18;
			pdf.setFontSize(13); pdf.setFont('helvetica', 'bold');
			pdf.text('Estimated Total', margin, y); pdf.text(`$${grandTotal.toFixed(2)}`, pW - margin, y, { align: 'right' });
			y += 30; pdf.setFontSize(8); pdf.setFont('helvetica', 'italic'); pdf.setTextColor(150);
			pdf.text('This layout is an estimate. Final pricing may vary based on customization and installation requirements.', margin, y, { maxWidth: pW - margin * 2 }); pdf.setTextColor(0);
			loadRoom(origIndex);
			return pdf.output('blob');
		} catch (e) { console.error('PDF generation failed:', e); try { loadRoom(origIndex); } catch (_) {} return null; }
	}

	// ─── Request Quote ───
	document.getElementById('btn-request-quote')!.onclick = async () => {
		const allLines = (window as any).__plannerAllLines as LineItem[] | undefined;
		if (!allLines || allLines.length === 0) { alert('Add lockers to your room first.'); return; }
		const cart = JSON.parse(localStorage.getItem('playerstall_cart') || '[]');
		for (const line of allLines) {
			const roomLabel = line.roomName ? `Room: ${line.roomName}` : 'Room Planner';
			const specParts = [`${line.widthIn}\u2033W \u00d7 ${line.depthIn}\u2033D`, line.colorLabel];
			if (line.accessories.length) for (const a of line.accessories) specParts.push(`${a.label} (+$${a.price})`);
			const model = `${roomLabel} \u00b7 ${specParts.join(' \u00b7 ')}`;
			const id = `planner-${line.roomName}-${line.templateId}-${line.widthIn}-${line.depthIn}-${line.colorLabel}-${line.accessories.map((a) => a.label).join('-')}`;
			const existing = cart.find((item: any) => item.id === id);
			if (existing) existing.quantity += line.qty;
			else cart.push({ id, name: line.displayName, price: line.unitPrice, image: '/images/stadium-locker.png', quantity: line.qty, model });
		}
		localStorage.setItem('playerstall_cart', JSON.stringify(cart));
		window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: cart.reduce((sum: number, item: any) => sum + item.quantity, 0) } }));

		const customerEmail = (document.getElementById('customer-email') as HTMLInputElement).value.trim();
		if (!customerEmail) { alert('Please enter your email address so we can get in touch with you.'); return; }

		let orderSummary = ''; let curRoom = '';
		for (const line of allLines) {
			const room = line.roomName || 'Unnamed Room';
			if (room !== curRoom) { curRoom = room; orderSummary += `\n--- ${room} ---\n`; }
			const accText = line.accessories.length ? ` + ${line.accessories.map((a: any) => a.label).join(', ')}` : '';
			orderSummary += `${line.qty}x ${line.displayName} (${line.widthIn}"W x ${line.depthIn}"D, ${line.colorLabel}${accText}) - $${(line.unitPrice * line.qty).toFixed(2)}\n`;
		}
		const grandTotal = allLines.reduce((sum: number, l: any) => sum + l.unitPrice * l.qty, 0);
		orderSummary += `\nEstimated Total: $${grandTotal.toFixed(2)}`;

		const statusMsg = document.getElementById('order-status-msg')!;
		const btn = document.getElementById('btn-request-quote') as HTMLButtonElement;
		btn.disabled = true; btn.textContent = 'Generating PDF...';
		const pdfBlob = await generateLayoutPDF(allLines, orderSummary, grandTotal, customerEmail);
		btn.textContent = 'Sending...';

		let pdfBase64: string | undefined;
		if (pdfBlob) {
			pdfBase64 = await new Promise<string>((resolve) => {
				const reader = new FileReader();
				reader.onloadend = () => resolve((reader.result as string).split(',')[1]);
				reader.readAsDataURL(pdfBlob);
			});
		}

		fetch('/api/send-room-plan', {
			method: 'POST', headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ email: customerEmail, orderSummary, grandTotal: grandTotal.toFixed(2), pdfBase64 }),
		}).then(async (res) => {
			if (res.ok) {
				statusMsg.textContent = 'Thank you! We just emailed your room plan to ' + customerEmail + '. Our team received a copy too and will be in touch shortly.';
				statusMsg.style.color = '#0d0d0d'; btn.textContent = 'Sent!';
				if (pdfBlob) {
					const url = URL.createObjectURL(pdfBlob); const a = document.createElement('a');
					a.href = url; a.download = 'room-planner-layout.pdf'; document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(url);
				}
			} else {
				let detail = ''; try { const j = await res.json(); detail = j.error || ''; } catch {}
				statusMsg.textContent = 'Something went wrong' + (detail ? ': ' + detail : '') + '. Please try again or email us directly at sales@playerstall.com.';
				statusMsg.style.color = '#fe5900'; btn.disabled = false; btn.textContent = 'Get In Touch With Us';
			}
		}).catch(() => {
			statusMsg.textContent = 'Could not connect. Please check your internet and try again, or email us directly at sales@playerstall.com.';
			statusMsg.style.color = '#fe5900'; btn.disabled = false; btn.textContent = 'Get In Touch With Us';
		});
	};

	// ─── Toolbar state ───
	function updateToolbar() {
		btnEdit.classList.toggle('active', state.editMode);
		document.getElementById('zoom-label')!.textContent = `${Math.round(state.camera.pixelsPerInch / 2 * 100)}%`;
		const tl = document.querySelector('.toolbar-left') as HTMLElement;
		if (tl) tl.style.display = state.editMode ? 'flex' : 'none';
	}

	// ─── Mobile tabs ───
	const columns = document.querySelector('.planner-columns') as HTMLElement;
	document.querySelectorAll('.mob-tab').forEach((tab) => {
		tab.addEventListener('click', () => {
			document.querySelectorAll('.mob-tab').forEach((t) => t.classList.remove('active'));
			tab.classList.add('active');
			columns.dataset.activePanel = (tab as HTMLElement).dataset.panel!;
			if ((tab as HTMLElement).dataset.panel === 'canvas') redraw();
		});
	});

	// ─── Init ───
	renderRoomTabs();
	window.addEventListener('resize', () => redraw());

	let initialFitDone = false;
	function tryInitialFit() {
		if (initialFitDone) return;
		if (canvas.clientWidth > 0 && canvas.clientHeight > 0) {
			initialFitDone = true;
			zoomFit();
			redraw();
		}
	}

	requestAnimationFrame(tryInitialFit);
	setTimeout(tryInitialFit, 100);
	setTimeout(tryInitialFit, 500);

	const resizeObs = new ResizeObserver(() => {
		if (!initialFitDone) tryInitialFit();
		else redraw();
	});
	resizeObs.observe(canvas);
</script>
