---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Design Your Locker Room | Room Planner | PlayerStall"
	description="Place lockers, configure options, and preview your locker room in 2D and 3D. Free interactive tool from PlayerStall."
>
	<section class="planner-hero">
		<div class="planner-hero-inner">
			<a href="/new-room-planner" class="back-link">&larr; Back to Room Setup</a>
			<h1>Design Your Locker Room</h1>
			<div class="hero-steps">
				<div class="hero-step done-step">
					<span class="hero-step-num">&check;</span>
					<span class="hero-step-text">Room size entered</span>
				</div>
				<div class="hero-step-arrow">&rarr;</div>
				<div class="hero-step active-step">
					<span class="hero-step-num">2</span>
					<span class="hero-step-text">Add & arrange lockers</span>
				</div>
				<div class="hero-step-arrow">&rarr;</div>
				<div class="hero-step">
					<span class="hero-step-num">3</span>
					<span class="hero-step-text">Review & send to us</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Room tabs (for multi-room switching) -->
	<section class="room-setup" id="room-setup">
		<div class="room-setup-columns">
			<div class="room-carousel" id="room-carousel">
				<button type="button" class="room-arrow room-arrow-left" id="btn-room-prev" title="Previous room" disabled>&lsaquo;</button>
				<div class="room-indicator">
					<span class="room-indicator-count" id="room-indicator-count">ROOM 1 OF 1</span>
					<span class="room-indicator-sep">—</span>
					<span class="room-indicator-name" id="room-indicator-name"></span>
					<span class="room-indicator-x" id="btn-remove-room" title="Remove this room" style="display:none">&times;</span>
				</div>
				<button type="button" class="room-arrow room-arrow-right" id="btn-room-next" title="Next room" disabled>&rsaquo;</button>
			</div>
			<div class="room-dots-row">
				<div class="room-dots" id="room-dots"></div>
				<button type="button" class="room-dot-add" id="btn-add-room" title="Add another room">+</button>
				<button type="button" class="room-save-btn" id="btn-save-room" title="Save all rooms">
					<svg class="room-save-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
					Save
					<span class="room-save-check" id="room-save-check"></span>
				</button>
			</div>

	<div class="room-fields-group">
		<div class="room-field">
			<label for="sport-type" class="room-field-label">Sport</label>
			<select id="sport-type" class="room-field-input sport-select">
				<option value="">Select a sport…</option>
				<option value="football">Football</option>
				<option value="hockey">Hockey</option>
				<option value="basketball">Basketball</option>
				<option value="baseball">Baseball</option>
				<option value="soccer">Soccer</option>
				<option value="lacrosse">Lacrosse</option>
				<option value="other">Other / Multi-Sport</option>
			</select>
		</div>
	</div>

		<!-- Locker type selector -->
		<div class="locker-type-section" id="locker-type-section">
			<span class="step-badge">Step 2</span>
			<h2 class="room-setup-title">Add Lockers</h2>
				<p class="room-setup-desc">Pick a locker model, choose your size, color, and any accessories. Set the quantity and click Add. They'll appear on the layout below where you can drag them into position.</p>
				<div class="lt-with-preview">
					<div class="lt-preview" id="lt-preview">
						<img id="lt-preview-img" src="/images/model-s-locker-profile.png" alt="Locker preview" />
					</div>
					<div class="lt-config">
						<div class="lt-row">
							<div class="lt-field">
								<label>Model</label>
								<select id="lt-model"></select>
							</div>
							<div class="lt-field">
								<label>Width</label>
								<select id="lt-width"></select>
							</div>
							<div class="lt-field" id="lt-depth-field">
								<label>Depth</label>
								<select id="lt-depth"></select>
							</div>
							<div class="lt-field">
								<label>Color</label>
								<select id="lt-color"></select>
							</div>
							<div class="lt-field lt-field-qty">
								<label>Qty</label>
								<input type="number" id="lt-qty" value="1" min="1" max="100" step="1" />
							</div>
							<div class="lt-field lt-field-btn">
								<label>&nbsp;</label>
								<button type="button" class="lt-add-btn" id="lt-add-btn" style="margin-left:16px">Add to Layout</button>
							</div>
							<span class="lt-price" id="lt-price"></span>
						</div>
						<div class="lt-accessories-row" id="lt-accessories-row">
							<label class="lt-acc-label">Accessories</label>
							<div class="lt-acc-list" id="lt-acc-list"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="planner-app" id="planner-app">
		<!-- Toolbar -->
		<div class="planner-toolbar" id="planner-toolbar">
			<div class="toolbar-left" style="display:none">
				<button type="button" class="tb-btn" id="btn-edit-mode" title="Switch to Edit mode">
					<span class="tb-icon">✎</span> Edit
				</button>
				<div class="tb-locker-group">
					<select id="locker-model-select" class="tb-model-select" title="Locker model"></select>
					<button type="button" class="tb-btn" id="btn-add-locker" title="Place locker(s) on the layout">
						+ Locker
					</button>
					<input type="number" id="locker-qty" class="tb-qty" value="1" min="1" max="100" step="1" title="Quantity" />
				</div>
				<button type="button" class="tb-btn" id="btn-add-door" title="Add a door">
					+ Door
				</button>
				<button type="button" class="tb-btn" id="btn-add-window" title="Add a window">
					+ Window
				</button>
				<button type="button" class="tb-btn tb-rotate" id="btn-rotate-locker" title="Rotate selected locker 90°">
					↻ Rotate
				</button>
				<button type="button" class="tb-btn tb-reset" id="btn-reset-lockers" title="Remove all lockers">
					Reset Lockers
				</button>
			</div>
			<div class="toolbar-center">
				<button type="button" class="tb-btn tb-sm" id="btn-zoom-out" title="Zoom out">&minus;</button>
				<span class="tb-zoom-label" id="zoom-label">100%</span>
				<button type="button" class="tb-btn tb-sm" id="btn-zoom-in" title="Zoom in">+</button>
				<button type="button" class="tb-btn tb-sm" id="btn-zoom-fit" title="Fit room">&boxplus;</button>
				<span class="tb-divider"></span>
				<button type="button" class="tb-btn tb-rotate" id="btn-rotate-visible" title="Rotate selected locker 90°">↻ Rotate</button>
				<span class="tb-divider"></span>
				<button type="button" class="tb-btn tb-3d" id="btn-view-3d" title="Preview your room in 3D">3D View</button>
				<span class="tb-divider"></span>
				<button type="button" class="tb-btn tb-save" id="btn-toolbar-save" title="Save all rooms">
					<svg class="tb-save-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
					Save
				</button>
			</div>
			<div class="toolbar-right">
				<select id="unit-select" class="tb-select" title="Display unit">
					<option value="in">Inches</option>
					<option value="ft">Feet</option>
					<option value="cm">cm</option>
					<option value="mm">mm</option>
				</select>
			</div>
		</div>

		<!-- Corner clearance guide -->
		<div class="corner-guide" id="corner-guide">
			<div class="corner-guide-header">
				<svg class="corner-guide-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V3h18"/><path d="M7 21V7h14" opacity=".35"/></svg>
				<span class="corner-guide-title">Corner Clearance</span>
			</div>
			<div class="corner-guide-body">
				<div class="corner-rule corner-rule-warn">
					<span class="corner-rule-badge">30&Prime;</span>
					<div>
						<strong>Adjacent walls</strong>
						<span class="corner-rule-detail">When lockers sit on two connecting walls (e.g. A&nbsp;+&nbsp;B), a 30&Prime; clearance is auto-reserved at the corner.</span>
					</div>
				</div>
				<div class="corner-rule corner-rule-ok">
					<span class="corner-rule-badge">&check;</span>
					<div>
						<strong>Single wall</strong>
						<span class="corner-rule-detail">No clearance needed &mdash; the full wall length is available for lockers.</span>
					</div>
				</div>
			</div>
			<div class="corner-status" id="corner-status"></div>
		</div>

		<!-- Main 3-column layout -->
		<div class="planner-columns">
			<!-- LEFT: Layers + Selection Config -->
			<aside class="planner-layers" id="planner-layers">
				<h3 class="panel-heading">Layers</h3>
				<p class="layers-hint" id="layers-hint">This panel lists every item in your room: walls, doors, windows, and lockers. Click any item to select it on the canvas, then you can edit its size, color, or position. As you add lockers they will appear here.</p>
				<ul class="layers-list" id="layers-list"></ul>

				<div class="selection-config" id="selection-config" style="display:none;">
					<div class="sel-config-header">
						<span class="sel-config-title" id="sel-config-title">Selection</span>
						<button type="button" class="sel-config-close" id="sel-config-close" title="Close">&times;</button>
					</div>
					<div class="props-locker" id="props-locker" style="display:none;">
						<div class="prop-row">
							<label class="prop-label">Model</label>
							<span class="prop-value" id="prop-model-name"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">Width</label>
							<div class="prop-swatches" id="prop-width-options"></div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Depth</label>
							<div class="prop-swatches" id="prop-depth-options"></div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Color</label>
							<select id="prop-color-select" class="prop-select"></select>
						</div>
						<div class="prop-row">
							<label class="prop-label">Accessories</label>
							<div class="prop-accessories" id="prop-accessories"></div>
						</div>
						<div class="prop-row prop-price-row">
							<label class="prop-label">Unit Price</label>
							<span class="prop-price" id="prop-price">$0</span>
						</div>
						<div class="prop-row">
							<button type="button" class="tb-btn prop-rotate-btn" id="prop-rotate-locker">Rotate 90&deg;</button>
							<button type="button" class="tb-btn prop-delete-btn" id="prop-delete-locker">Delete</button>
						</div>
					</div>
					<div class="props-wall" id="props-wall" style="display:none;">
						<div class="prop-row">
							<label class="prop-label">Wall</label>
							<span class="prop-value" id="prop-wall-id"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">Length</label>
							<div class="prop-input-row">
								<input type="number" id="prop-wall-length" class="prop-input" step="1" min="24" />
								<span class="prop-input-unit" id="prop-wall-length-unit">&Prime;</span>
							</div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Thickness</label>
							<div class="prop-input-row">
								<input type="number" id="prop-wall-thickness" class="prop-input" step="0.5" min="1" />
								<span class="prop-input-unit">&Prime;</span>
							</div>
						</div>
						<button type="button" class="tb-btn fill-wall-btn" id="btn-fill-wall">Fill with lockers</button>
					</div>
					<div class="props-opening" id="props-opening" style="display:none;">
						<div class="prop-row">
							<label class="prop-label">Type</label>
							<span class="prop-value" id="prop-opening-type"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">On wall</label>
							<span class="prop-value" id="prop-opening-wall"></span>
						</div>
						<div class="prop-row">
							<label class="prop-label">Width</label>
							<div class="prop-input-row">
								<input type="number" id="prop-opening-width" class="prop-input" step="1" min="12" />
								<span class="prop-input-unit">&Prime;</span>
							</div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Offset from start</label>
							<div class="prop-input-row">
								<input type="number" id="prop-opening-offset" class="prop-input" step="1" min="0" />
								<span class="prop-input-unit">&Prime;</span>
							</div>
						</div>
						<div class="prop-row">
							<label class="prop-label">Clearance</label>
							<div class="prop-input-row">
								<input type="number" id="prop-opening-clearance" class="prop-input" step="1" min="0" />
								<span class="prop-input-unit">&Prime;</span>
							</div>
						</div>
						<button type="button" class="tb-btn delete-opening-btn" id="btn-delete-opening">Delete opening</button>
					</div>
				</div>
			</aside>

			<!-- CENTER: Canvas -->
			<div class="planner-canvas-wrap" id="planner-canvas-wrap">
				<div class="placement-tooltip" id="placement-tooltip" style="display:none">
					<span class="placement-tooltip-icon">&#9678;</span>
					<span class="placement-tooltip-text" id="placement-tooltip-text">Click on the wall to place</span>
					<button type="button" class="placement-tooltip-cancel" id="placement-cancel">&times; Cancel</button>
				</div>
				<canvas id="planner-canvas"></canvas>
				<div id="placement-toast" class="placement-toast" style="display:none"></div>
				<div class="canvas-empty-hint" id="canvas-empty-hint" style="display:none;">
					<div class="canvas-hint-icon">&boxplus;</div>
					<div class="canvas-hint-title">Your layout will appear here</div>
					<div class="canvas-hint-body">Your room is loading from the previous step. If nothing appears, <a href="/new-room-planner">go back</a> and re-enter your dimensions.</div>
				</div>
			</div>
		</div>

		<!-- Mobile tab bar -->
		<nav class="planner-mobile-tabs" id="planner-mobile-tabs">
			<button type="button" class="mob-tab active" data-panel="canvas">Plan</button>
			<button type="button" class="mob-tab" data-panel="layers">Layers</button>
		</nav>
	</section>

	<!-- 3D Preview Modal -->
	<div class="view3d-overlay" id="view3d-overlay">
		<div class="view3d-header">
			<span class="view3d-title">3D Preview <span class="view3d-room-name" id="view3d-room-name"></span></span>
			<div class="view3d-controls">
				<button type="button" class="view3d-btn view3d-rotate-btn" id="btn-3d-rotate" title="Rotate selected locker 90°">&circlearrowright; Rotate</button>
				<span class="view3d-sep"></span>
				<button type="button" class="view3d-btn view3d-logo-btn" id="btn-3d-logo" title="Upload your team logo for the floor">Floor Logo</button>
				<input type="file" id="logo-file-input" accept="image/png,image/jpeg,image/svg+xml,image/webp,image/gif" style="display:none" />
				<button type="button" class="view3d-btn view3d-logo-remove" id="btn-3d-logo-remove" style="display:none" title="Remove floor logo">&times; Logo</button>
				<button type="button" class="view3d-btn" id="btn-3d-reset">Reset View</button>
				<span class="view3d-sep"></span>
				<button type="button" class="view3d-btn view3d-save-btn" id="btn-3d-save" title="Save all rooms">
					<svg class="view3d-save-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
					Save
				</button>
				<button type="button" class="view3d-close" id="btn-3d-close">&times;</button>
			</div>
		</div>
		<div class="view3d-swatch-row" id="view3d-swatch-row">
			<div class="view3d-color-bar" id="view3d-color-bar" style="display:none">
				<span class="view3d-color-label" id="view3d-color-label">Locker Colors</span>
				<div class="view3d-color-swatches" id="view3d-color-swatches"></div>
			</div>
			<div class="view3d-color-bar" id="view3d-cushion-bar" style="display:none">
				<span class="view3d-color-label" id="view3d-cushion-label">Cushion Colors</span>
				<div class="view3d-color-swatches" id="view3d-cushion-swatches"></div>
			</div>
			<div class="view3d-color-bar" id="view3d-floor-bar">
				<span class="view3d-color-label">Floor Color</span>
				<div class="view3d-color-swatches" id="view3d-floor-swatches"></div>
			</div>
			<div class="view3d-color-bar" id="view3d-wall-bar">
				<span class="view3d-color-label">Wall Color</span>
				<div class="view3d-color-swatches" id="view3d-wall-swatches"></div>
			</div>
		</div>
		<div class="view3d-canvas-wrap">
			<canvas id="view3d-canvas"></canvas>
			<button type="button" class="view3d-room-arrow view3d-room-arrow-left" id="btn-3d-prev" title="Previous room" disabled>&lsaquo;</button>
			<button type="button" class="view3d-room-arrow view3d-room-arrow-right" id="btn-3d-next" title="Next room" disabled>&rsaquo;</button>
			<div class="view3d-room-indicator" id="view3d-room-indicator">ROOM 1 OF 1</div>
		</div>
		<div class="view3d-hint">Drag background to orbit &middot; Click locker to select &middot; Drag locker to move &middot; Double-click or press R to rotate</div>
	</div>

	<!-- Order summary (below designer) -->
	<section class="order-section" id="order-section">
		<div class="order-section-header">
			<span class="step-badge">Step 3</span>
			<h2 class="room-setup-title" style="text-align:center;">Review Your Layout</h2>
			<p class="room-setup-desc" style="text-align:center; margin-bottom:30px;">Here's everything you've configured across all your rooms. When you're happy with the layout, send it to your cart or email it to us and we'll help you bring it to life.</p>
		</div>
		<div class="order-section-inner">
			<div class="order-panel" id="order-panel">
				<h3 class="order-panel-title">Order Summary</h3>
				<div class="order-room-name" id="order-room-name"></div>
				<table class="order-table">
					<thead>
						<tr>
							<th class="ot-product">Product</th>
							<th class="ot-qty">Qty</th>
							<th class="ot-total">Subtotal</th>
						</tr>
					</thead>
					<tbody id="order-items-body">
						<tr><td colspan="3" class="ot-empty">No lockers placed yet. Add lockers above to see your order here.</td></tr>
					</tbody>
					<tfoot>
						<tr class="ot-subtotal-row">
							<th colspan="2">Subtotal</th>
							<td id="order-subtotal">$0.00</td>
						</tr>
						<tr class="ot-total-row">
							<th colspan="2">Estimated Total</th>
							<td id="order-total"><strong>$0.00</strong></td>
						</tr>
					</tfoot>
				</table>
				<div class="order-locker-count" id="order-locker-count">0 lockers</div>
				<div class="order-email-row">
					<label class="order-email-label" for="customer-email">Your email</label>
					<input type="email" id="customer-email" class="order-email-input" placeholder="you@example.com" required />
				</div>
				<button type="button" class="order-request-btn" id="btn-request-quote">Get In Touch With Us</button>
				<p class="order-disclaimer" id="order-status-msg">We'll send a copy of your layout to your email and to our team so we can help you execute on your dream locker room.</p>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.planner-hero {
		background: #ffffff;
		color: #0d0d0d;
		padding: 60px 20px 30px;
		text-align: center;
	}
	.planner-hero h1 {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(28px, 3.5vw, 44px);
		font-weight: 700;
		margin: 0;
		text-transform: uppercase;
		color: #0d0d0d;
		line-height: 1.1;
		letter-spacing: 2px;
	}
	.back-link {
		display: inline-block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		text-decoration: none;
		margin-bottom: 12px;
		letter-spacing: 0.5px;
		transition: color 0.2s;
	}
	.back-link:hover { color: #fe5900; }

	.hero-steps {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
		margin-top: 24px;
	}
	.hero-step {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.hero-step-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: #0d0d0d;
		color: #fff;
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		flex-shrink: 0;
	}
	.hero-step-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
	}
	.hero-step-arrow { color: #ccc; font-size: 18px; }
	.active-step .hero-step-num { background: #fe5900; }
	.done-step .hero-step-num { background: #4caf50; }
	.done-step .hero-step-text { color: #8c8c8c; }
	@media (max-width: 640px) {
		.hero-steps { flex-direction: column; gap: 10px; }
		.hero-step-arrow { transform: rotate(90deg); }
	}

	/* Room carousel */
	:global(.room-carousel) {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
		margin-bottom: 12px;
	}
	:global(.room-arrow) {
		width: 44px; height: 44px; border-radius: 50%; border: none;
		background: rgba(0,0,0,0.07); color: #333; font-size: 28px; line-height: 1;
		cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
		transition: background 0.2s, color 0.2s; flex-shrink: 0; padding: 0;
	}
	:global(.room-arrow:hover:not(:disabled)) { background: rgba(0,0,0,0.14); color: #000; }
	:global(.room-arrow:disabled) { opacity: 0.25; cursor: default; }
	:global(.room-indicator) {
		display: flex; align-items: center; gap: 8px;
		font-family: 'Oswald', sans-serif; font-size: 14px; font-weight: 600;
		text-transform: uppercase; letter-spacing: 1.5px; color: #8c8c8c; white-space: nowrap;
	}
	:global(.room-indicator-sep) { color: #ccc; }
	:global(.room-indicator-name) { color: #fe5900; font-weight: 600; }
	:global(.room-indicator-x) {
		display: inline-flex; align-items: center; justify-content: center;
		width: 20px; height: 20px; border-radius: 50%; border: none; background: none;
		color: #ccc; font-size: 16px; line-height: 1; cursor: pointer; padding: 0; margin-left: 2px;
		transition: color 0.2s;
	}
	:global(.room-indicator-x:hover) { color: #fe5900; }
	:global(.room-dots-row) {
		display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 24px;
	}
	:global(.room-dots) { display: flex; gap: 8px; align-items: center; }
	:global(.room-dot) {
		width: 10px; height: 10px; border-radius: 50%; border: none; background: #ddd;
		cursor: pointer; padding: 0; transition: background 0.2s, transform 0.2s;
	}
	:global(.room-dot:hover) { background: #bbb; transform: scale(1.2); }
	:global(.room-dot.active) { background: #fe5900; transform: scale(1.2); }
	:global(.room-dot-add) {
		width: 24px; height: 24px; border-radius: 50%; border: 1px dashed #ccc;
		background: #fff; color: #8c8c8c; font-size: 16px; line-height: 1;
		cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
		padding: 0; transition: border-color 0.2s, color 0.2s;
	}
	:global(.room-dot-add:hover) { border-color: #0d0d0d; color: #0d0d0d; }
	:global(.room-save-btn) {
		display: inline-flex; align-items: center; gap: 6px; margin-left: 12px;
		padding: 5px 16px; border: 1px solid #888; border-radius: 20px;
		background: #888; color: #fff; font-family: 'Oswald', sans-serif;
		font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
		cursor: pointer; transition: background 0.2s, border-color 0.2s; white-space: nowrap;
	}
	:global(.room-save-btn:hover) { background: #555; border-color: #555; }
	:global(.room-save-btn.saved) { background: #555; border-color: #555; }
	:global(.room-save-icon) { width: 14px; height: 14px; flex-shrink: 0; }
	:global(.room-save-check) { font-size: 14px; opacity: 0; transition: opacity 0.3s; }
	:global(.room-save-check.show) { opacity: 1; }

	.room-setup {
		background: #ffffff;
		color: #0d0d0d;
		padding: 0 20px 20px;
	}
	.room-setup-columns {
		max-width: 1300px;
		margin: 0 auto;
	}
	.room-setup-title {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(24px, 3vw, 36px);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 2px;
		margin: 0 0 10px;
		color: #0d0d0d;
		line-height: 1.1;
		text-align: center;
	}
	.room-setup-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 32px;
		letter-spacing: 0.3px;
		text-align: center;
	}
	.step-badge {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: #fe5900;
		margin-bottom: 6px;
	}

	/* Room fields group (sport selector + optional room name) */
	.room-fields-group {
		display: flex;
		gap: 16px;
		justify-content: center;
		margin-bottom: 22px;
	}
	.room-field {
		display: flex;
		flex-direction: column;
		gap: 5px;
	}
	.room-field-label {
		font-family: 'Oswald', sans-serif;
		font-size: 11px;
		font-weight: 600;
		color: #555;
		text-transform: uppercase;
		letter-spacing: 1px;
	}
	.room-field-input {
		width: 220px;
		background: #f7f7f7;
		border: 1px solid #e0e0e0;
		border-radius: 4px;
		color: #0d0d0d;
		padding: 10px 14px;
		font-size: 14px;
		font-family: 'Yantramanav', sans-serif;
		transition: border-color 0.2s;
		box-sizing: border-box;
	}
	.room-field-input::placeholder { color: #b6b6b6; }
	.room-field-input:focus { border-color: #fe5900; outline: none; }
	.sport-select { cursor: pointer; }
	@media (max-width: 520px) {
		.room-fields-group { flex-direction: column; align-items: center; gap: 12px; }
	}

	/* Locker type selection */
	.lt-with-preview {
		display: flex;
		gap: 24px;
		align-items: flex-start;
	}
	.lt-preview {
		flex: 0 0 140px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #f7f7f7;
		border: 1px solid #e0e0e0;
		padding: 10px;
		min-height: 120px;
	}
	.lt-preview img { max-width: 100%; max-height: 110px; object-fit: contain; }
	.lt-config { flex: 1; min-width: 0; }
	@media (max-width: 768px) {
		.lt-with-preview { flex-direction: column; }
		.lt-preview { flex: none; width: 100%; max-width: 160px; margin: 0 auto; }
	}
	.lt-row {
		display: flex;
		align-items: flex-end;
		gap: 16px;
		flex-wrap: nowrap;
	}
	.lt-field {
		display: flex;
		flex-direction: column;
		gap: 4px;
		flex: 1;
		min-width: 0;
	}
	.lt-field.lt-field-qty { flex: 0 0 70px; }
	.lt-field.lt-field-btn { flex: 0 0 auto; }
	.lt-field label {
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 1px;
	}
	.lt-field select, .lt-field input {
		background: #f7f7f7;
		color: #0d0d0d;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 8px 10px;
		font-size: 13px;
		width: 100%;
		font-family: 'Yantramanav', sans-serif;
		transition: border-color 0.3s;
	}
	.lt-field select:focus, .lt-field input:focus { border-color: #fe5900; outline: none; }
	.lt-field input[type="number"] { text-align: center; }
	.lt-field-btn { justify-content: flex-end; }
	.lt-add-btn {
		background: #fe5900;
		color: #fff;
		border: none;
		border-radius: 0;
		padding: 10px 24px;
		margin-left: 16px;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2px;
		cursor: pointer;
		white-space: nowrap;
	}
	.lt-add-btn:hover { background: #e04d00; }
	.lt-price {
		font-family: 'Oswald', sans-serif;
		font-size: 15px;
		font-weight: 600;
		color: #fe5900;
		align-self: flex-end;
		padding-bottom: 8px;
		white-space: nowrap;
	}
	:global(.lt-accessories-row) {
		margin-top: 18px;
		margin-bottom: 10px;
		display: flex;
		align-items: center;
		flex-wrap: nowrap;
		border: none;
		background: none;
		padding: 0;
	}
	:global(.lt-acc-label) {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #b6b6b6;
		letter-spacing: 0.5px;
		white-space: nowrap;
		margin-right: 10px;
		flex-shrink: 0;
	}
	:global(.lt-acc-list) {
		display: flex;
		flex-wrap: nowrap;
		flex: 1;
		justify-content: space-between;
	}
	:global(.lt-acc-list label) {
		display: flex;
		align-items: center;
		gap: 4px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		white-space: nowrap;
		padding: 0;
		cursor: pointer;
		transition: color 0.15s;
	}
	:global(.lt-acc-list label:hover) { color: #0d0d0d; }
	:global(.lt-acc-list input[type="checkbox"]) { accent-color: #fe5900; width: 12px; height: 12px; }

	.planner-app {
		display: flex;
		flex-direction: column;
		height: calc(100vh - 90px);
		min-height: 620px;
		background: #f0f0f0;
	}

	/* Corner clearance guide */
	.corner-guide {
		background: #fff;
		border: 1px solid #e8e8e8;
		border-radius: 10px;
		margin: 0 12px 12px;
		overflow: hidden;
		box-shadow: 0 1px 4px rgba(0,0,0,0.04);
	}
	.corner-guide-header {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 10px 16px;
		border-bottom: 1px solid #f0f0f0;
	}
	.corner-guide-icon { width: 20px; height: 20px; color: #fe5900; flex-shrink: 0; }
	.corner-guide-title {
		font-family: 'Oswald', sans-serif;
		font-size: 13px; font-weight: 600;
		letter-spacing: 1px; text-transform: uppercase; color: #333;
	}
	.corner-guide-body { display: flex; gap: 0; }
	.corner-rule {
		flex: 1; display: flex; align-items: flex-start;
		gap: 12px; padding: 14px 16px;
	}
	.corner-rule + .corner-rule { border-left: 1px solid #f0f0f0; }
	.corner-rule strong {
		font-family: 'Oswald', sans-serif; font-size: 12.5px; font-weight: 600;
		letter-spacing: 0.3px; text-transform: uppercase; color: #333;
		display: block; margin-bottom: 3px;
	}
	.corner-rule-detail { display: block; font-size: 12px; line-height: 1.55; color: #777; }
	.corner-rule-badge {
		flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		font-weight: 700; font-size: 13px; line-height: 1;
	}
	.corner-rule-warn .corner-rule-badge { background: rgba(255,89,0,0.09); color: #d35400; }
	.corner-rule-ok .corner-rule-badge { background: rgba(0,128,80,0.08); color: #1a8a52; font-size: 16px; }
	.corner-status {
		padding: 10px 16px; font-size: 12px; font-weight: 500;
		border-top: 1px solid #f0f0f0; display: none; line-height: 1.5;
	}
	.corner-status.active { display: block; background: rgba(255,89,0,0.05); color: #b84400; }
	.corner-status.clear { display: block; background: rgba(0,128,80,0.04); color: #1a6b45; }
	@media (max-width: 640px) {
		.corner-guide-body { flex-direction: column; }
		.corner-rule + .corner-rule { border-left: none; border-top: 1px solid #f0f0f0; }
	}

	/* Toolbar */
	.planner-toolbar {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 8px 16px;
		background: #0d0d0d;
		color: #fff;
		gap: 10px;
		flex-shrink: 0;
		position: relative;
	}
	.toolbar-left, .toolbar-center, .toolbar-right {
		display: flex;
		align-items: center;
		gap: 6px;
	}
	.toolbar-right { position: absolute; right: 16px; }
	.tb-btn {
		background: transparent;
		color: #ccc;
		border: 1px solid #444;
		border-radius: 0;
		padding: 6px 14px;
		font-size: 12px;
		cursor: pointer;
		font-family: 'Yantramanav', sans-serif;
		white-space: nowrap;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		transition: all 0.2s;
	}
	.tb-btn:hover { background: #333; color: #fff; }
	.tb-rotate { background: #fe5900; border-color: #fe5900; color: #fff; font-weight: 600; }
	.tb-rotate:hover { background: #e04f00; border-color: #e04f00; color: #fff; }
	.tb-reset { background: transparent; border-color: #fe5900; color: #fe5900; }
	.tb-reset:hover { background: #fe5900; color: #fff; }
	.tb-btn.active { background: #fe5900; border-color: #fe5900; color: #fff; }
	.tb-locker-group { display: flex; align-items: center; gap: 0; }
	.tb-model-select {
		background: #1a1a1a;
		color: #ccc;
		border: 1px solid #444;
		border-radius: 0;
		padding: 6px 8px;
		font-size: 12px;
		font-family: 'Yantramanav', sans-serif;
		cursor: pointer;
	}
	.tb-model-select:focus { outline: none; border-color: #fe5900; }
	.tb-locker-group .tb-btn { border-radius: 0; border-left: none; }
	.tb-qty {
		width: 42px;
		background: #1a1a1a;
		color: #ccc;
		border: 1px solid #444;
		border-left: none;
		border-radius: 0;
		padding: 6px 4px;
		font-size: 13px;
		text-align: center;
		font-family: 'Yantramanav', sans-serif;
	}
	.tb-qty:focus { outline: none; border-color: #fe5900; }
	.tb-sm { padding: 6px 8px; }
	.tb-zoom-label { font-size: 12px; min-width: 44px; text-align: center; }
	.tb-divider { width: 1px; height: 18px; background: #444; margin: 0 4px; }
	.tb-select {
		background: #1a1a1a;
		color: #ccc;
		border: 1px solid #444;
		border-radius: 0;
		padding: 5px 8px;
		font-size: 13px;
	}

	/* 3-column layout */
	.planner-columns { display: flex; flex: 1; overflow: hidden; }

	/* Layers + Config (left) */
	.planner-layers {
		width: 210px;
		min-width: 180px;
		background: #f7f7f7;
		color: #0d0d0d;
		overflow-y: auto;
		flex-shrink: 0;
		border-right: 1px solid #e0e0e0;
		display: flex;
		flex-direction: column;
	}
	.panel-heading {
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2px;
		padding: 14px 16px 8px;
		margin: 0;
		color: #8c8c8c;
	}
	.layers-hint {
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		color: #b6b6b6;
		padding: 0 16px 8px;
		margin: 0;
		line-height: 1.4;
	}
	.layers-list { list-style: none; margin: 0; padding: 0; }
	.layers-list li {
		padding: 8px 16px;
		font-size: 13px;
		cursor: pointer;
		border-bottom: 1px solid #e0e0e0;
		font-family: 'Yantramanav', sans-serif;
		display: flex;
		align-items: center;
		gap: 8px;
		transition: background 0.15s;
	}
	.layers-list li:hover { background: #eee; }
	.layers-list li.selected { background: #0d0d0d; color: #fff; }
	.layer-icon {
		display: inline-block;
		width: 10px;
		height: 10px;
		border-radius: 2px;
		flex-shrink: 0;
	}

	/* Selection config */
	.selection-config { border-top: 1px solid #e0e0e0; }
	.sel-config-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 10px 16px;
		background: #eee;
	}
	.sel-config-title {
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: #8c8c8c;
	}
	.sel-config-close {
		background: none;
		border: none;
		color: #b6b6b6;
		font-size: 18px;
		cursor: pointer;
		padding: 0 4px;
		line-height: 1;
	}
	.sel-config-close:hover { color: #fe5900; }
	.prop-row { padding: 10px 16px; border-bottom: 1px solid #e0e0e0; }
	.prop-label {
		display: block;
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: #8c8c8c;
		margin-bottom: 5px;
		font-family: 'Oswald', sans-serif;
	}
	.prop-value { font-size: 14px; color: #0d0d0d; }
	.prop-swatches { display: flex; flex-wrap: wrap; gap: 4px; }
	.prop-swatches button {
		background: #eee;
		color: #0d0d0d;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 4px 10px;
		font-size: 12px;
		cursor: pointer;
		transition: all 0.15s;
	}
	.prop-swatches button:hover { background: #ddd; }
	.prop-swatches button.active { background: #0d0d0d; color: #fff; border-color: #0d0d0d; }
	.prop-select {
		width: 100%;
		background: #fff;
		color: #0d0d0d;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 5px 8px;
		font-size: 13px;
	}
	.prop-accessories label {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		color: #0d0d0d;
		padding: 3px 0;
		cursor: pointer;
	}
	.prop-accessories input[type="checkbox"] { accent-color: #fe5900; }
	.prop-price-row { display: flex; align-items: center; justify-content: space-between; }
	.prop-rotate-btn { flex: 1; }
	.prop-delete-btn { flex: 1; background: transparent !important; border-color: #fe5900 !important; color: #fe5900 !important; }
	.prop-delete-btn:hover { background: #fe5900 !important; color: #fff !important; }
	.prop-price {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 700;
		color: #0d0d0d;
	}
	.prop-input-row { display: flex; align-items: center; gap: 4px; }
	.prop-input-unit { font-size: 12px; color: #8c8c8c; flex-shrink: 0; }
	.prop-input {
		width: 80px;
		background: #fff;
		color: #0d0d0d;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		padding: 5px 8px;
		font-size: 13px;
		transition: border-color 0.3s;
	}
	.prop-input:focus { border-color: #fe5900; outline: none; }
	.fill-wall-btn { margin: 10px 16px; background: #fe5900; border-color: #fe5900; }
	.delete-opening-btn {
		margin: 10px 16px;
		background: transparent;
		border-color: #fe5900;
		color: #fe5900;
	}
	.delete-opening-btn:hover { background: #fe5900; color: #fff; }

	/* Placement tooltip */
	.placement-tooltip { position: absolute; top: 8px; left: 50%; transform: translateX(-50%); z-index: 20; background: #1a1a1a; color: #fff; padding: 8px 16px; border-radius: 6px; font-size: 13px; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 16px rgba(0,0,0,0.25); white-space: nowrap; }
	.placement-tooltip-icon { color: #fe5900; font-size: 16px; }
	.placement-tooltip-cancel { background: transparent; border: 1px solid rgba(255,255,255,0.3); color: #ccc; padding: 2px 10px; border-radius: 3px; font-size: 11px; cursor: pointer; margin-left: 8px; }
	.placement-tooltip-cancel:hover { background: rgba(255,255,255,0.1); color: #fff; }
	.placement-toast {
		position: absolute;
		bottom: 16px;
		left: 50%;
		transform: translateX(-50%);
		background: rgba(200, 30, 30, 0.9);
		color: #fff;
		padding: 8px 18px;
		border-radius: 6px;
		font-size: 13px;
		font-family: 'Yantramanav', sans-serif;
		pointer-events: none;
		z-index: 50;
		white-space: nowrap;
	}

	/* Canvas (center) */
	.planner-canvas-wrap {
		flex: 1;
		position: relative;
		overflow: hidden;
		background: #e9e9e9;
	}
	#planner-canvas { display: block; width: 100%; height: 100%; cursor: crosshair; }
	.canvas-empty-hint {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		text-align: center;
		max-width: 380px;
		pointer-events: none;
	}
	.canvas-empty-hint a { pointer-events: auto; color: #fe5900; }
	.canvas-hint-icon { font-size: 36px; color: #ccc; margin-bottom: 12px; }
	.canvas-hint-title {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #999;
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-bottom: 8px;
	}
