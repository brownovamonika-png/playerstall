</style>

<script>
	import { createInitialState, nextInstanceId, buildWalls, defaultDimensions } from '../../room-planner/state';
	import type { RoomDimensions } from '../../room-planner/state';
	import { render, screenToWorld, setFloorLogo2D, removeFloorLogo2D } from '../../room-planner/render';
	import { getAllTemplates, getTemplate } from '../../room-planner/catalog';
	import { priceLocker } from '../../room-planner/pricing';
	import { lockerAABB, wouldOverlap, packWall, wallLength, openingExclusionAABB, getWallsWithLockers, projectOntoWall, hitTestOpening, clampLockerToRoom } from '../../room-planner/geometry';
	import { drawWallHighlight } from '../../room-planner/render';
	import { formatDimension, unitLabel } from '../../room-planner/units';
	import { CUSHION_COLORS } from '../../room-planner/types';
	import type { PlannerState, LockerInstance, Opening, Selection, DisplayUnit } from '../../room-planner/types';
	import { jsPDF } from 'jspdf';
	import { launch3DPreview, dispose3DPreview, resetCamera, rotateSelected3D, hasSelection3D, updateFloorColor3D, updateWallColor3D, setFloorLogo, removeFloorLogo, rebuildLockerMesh3D } from '../../room-planner/render3d';

	// ─── Load setup data from localStorage ───
	const raw = localStorage.getItem('ps_planner_setup');
	if (!raw) {
		console.warn('[RoomPlanner] No setup data in localStorage, redirecting to setup page');
		window.location.href = '/new-room-planner';
		throw new Error('No setup data');
	}

	let setupData: { email: string; floorColor?: string; wallColor?: string; rooms: { roomName: string; roomDims: RoomDimensions; openings: Opening[] }[] };
	try {
		setupData = JSON.parse(raw);
	} catch (e) {
		console.error('[RoomPlanner] Failed to parse setup data:', e);
		localStorage.removeItem('ps_planner_setup');
		window.location.href = '/new-room-planner';
		throw e;
	}

	if (!setupData.rooms || setupData.rooms.length === 0) {
		console.error('[RoomPlanner] Setup data has no rooms:', setupData);
		window.location.href = '/new-room-planner';
		throw new Error('No rooms in setup data');
	}

	console.log('[RoomPlanner] Loaded setup data:', setupData.rooms.length, 'room(s), wallA:', setupData.rooms[0].roomDims.wallA, 'wallB:', setupData.rooms[0].roomDims.wallB);

	const canvas = document.getElementById('planner-canvas') as HTMLCanvasElement;
	const ctx = canvas.getContext('2d')!;

	const firstRoom = setupData.rooms[0];
	let roomDims: RoomDimensions = { ...firstRoom.roomDims };
	const state: PlannerState = createInitialState(roomDims);
	state.roomName = firstRoom.roomName;
	state.walls = buildWalls(roomDims);
	state.openings = JSON.parse(JSON.stringify(firstRoom.openings));
	state.floorColor = setupData.floorColor || '#b0aba4';
	state.wallColor = setupData.wallColor || '#ffffff';

	// Pre-fill email
	const emailInput = document.getElementById('customer-email') as HTMLInputElement;
	if (emailInput && setupData.email) {
		emailInput.value = setupData.email;
	}

	// ─── Multi-room management ───
	interface SavedRoom {
		roomName: string;
		sportType: string;
		floorColor: string;
		wallColor: string;
		customLogoDataUrl: string | null;
		roomDims: RoomDimensions;
		walls: PlannerState['walls'];
		openings: PlannerState['openings'];
		lockers: PlannerState['lockers'];
	}
	const savedRooms: SavedRoom[] = [];
	let activeRoomIndex = 0;

	// Initialize all rooms from setup data
	for (const room of setupData.rooms) {
		const dims = { ...room.roomDims };
		savedRooms.push({
			roomName: room.roomName,
			sportType: '',
			roomDims: dims,
			walls: buildWalls(dims),
			openings: JSON.parse(JSON.stringify(room.openings)),
			lockers: [],
		});
	}

	function snapshotCurrentRoom(): SavedRoom {
		return {
			roomName: state.roomName,
			sportType: state.sportType,
			floorColor: state.floorColor,
			wallColor: state.wallColor,
			customLogoDataUrl: _savedLogoDataUrl,
			roomDims: { ...roomDims },
			walls: JSON.parse(JSON.stringify(state.walls)),
			openings: JSON.parse(JSON.stringify(state.openings)),
			lockers: JSON.parse(JSON.stringify(state.lockers)),
		};
	}

	function saveCurrentRoom() {
		savedRooms[activeRoomIndex] = snapshotCurrentRoom();
		persistRooms();
	}

	const ROOMS_STORAGE_KEY = 'playerstall_rooms_design';

	function persistRooms() {
		try {
			const data = { activeRoomIndex, rooms: savedRooms };
			localStorage.setItem(ROOMS_STORAGE_KEY, JSON.stringify(data));
		} catch (_) { /* quota exceeded */ }
	}

	function loadRoom(index: number) {
		const room = savedRooms[index];
		if (!room) return;
		roomDims = { ...room.roomDims };
		state.roomName = room.roomName;
		state.sportType = (room.sportType || '') as any;
		state.floorColor = room.floorColor || '#8B7355';
		state.wallColor = room.wallColor || '#ffffff';
		state.walls = JSON.parse(JSON.stringify(room.walls));
		state.openings = JSON.parse(JSON.stringify(room.openings));
		state.lockers = JSON.parse(JSON.stringify(room.lockers));
		state.selection = null;
		sportSelect.value = state.sportType;
		applySportLogo(state.sportType);
		_savedLogoDataUrl = room.customLogoDataUrl || null;
		if (_savedLogoDataUrl && !SPORT_LOGO_MAP[state.sportType]) {
			setFloorLogo2D(_savedLogoDataUrl, () => redraw());
			setFloorLogo(_savedLogoDataUrl);
			btnLogoRemove.style.display = '';
		}
		rebuildOpeningCounter();
		syncFloorSwatches();
		syncWallSwatches();
		zoomFit();
		redraw();
	}

	function rebuildOpeningCounter() {
		let maxId = 0;
		for (const op of state.openings) {
			const m = op.id.match(/^op_(\d+)$/);
			if (m) maxId = Math.max(maxId, parseInt(m[1], 10));
		}
		_openingCounter = maxId;
	}

	function renderCarouselNav() {
		const total = savedRooms.length;
		const idx = activeRoomIndex;
		const name = state.roomName || '';

		document.getElementById('room-indicator-count')!.textContent = `ROOM ${idx + 1} OF ${total}`;

		const nameEl = document.getElementById('room-indicator-name')!;
		const sepEl = document.querySelector('.room-indicator-sep') as HTMLElement;
		if (name) {
			nameEl.textContent = name;
			nameEl.style.display = '';
			sepEl.style.display = '';
		} else {
			nameEl.textContent = '';
			nameEl.style.display = 'none';
			sepEl.style.display = 'none';
		}

		const removeBtn = document.getElementById('btn-remove-room');
		if (removeBtn) removeBtn.style.display = total > 1 ? '' : 'none';

		(document.getElementById('btn-room-prev') as HTMLButtonElement).disabled = idx <= 0;
		(document.getElementById('btn-room-next') as HTMLButtonElement).disabled = idx >= total - 1;

		const dotsContainer = document.getElementById('room-dots')!;
		dotsContainer.innerHTML = '';
		for (let i = 0; i < total; i++) {
			const dot = document.createElement('button');
			dot.type = 'button';
			dot.className = `room-dot${i === idx ? ' active' : ''}`;
			dot.title = savedRooms[i]?.roomName || `Room ${i + 1}`;
			dot.onclick = () => switchToRoom(i);
			dotsContainer.appendChild(dot);
		}
	}

	const renderRoomTabs = renderCarouselNav;

	function switchToRoom(index: number) {
		if (index === activeRoomIndex) return;
		saveCurrentRoom();
		activeRoomIndex = index;
		loadRoom(index);
		renderCarouselNav();
	}

	document.getElementById('btn-room-prev')!.onclick = () => {
		if (activeRoomIndex > 0) switchToRoom(activeRoomIndex - 1);
	};
	document.getElementById('btn-room-next')!.onclick = () => {
		if (activeRoomIndex < savedRooms.length - 1) switchToRoom(activeRoomIndex + 1);
	};
	const removeBtnEl = document.getElementById('btn-remove-room');
	if (removeBtnEl) {
		removeBtnEl.onclick = () => {
			if (savedRooms.length <= 1) return;
			savedRooms.splice(activeRoomIndex, 1);
			if (activeRoomIndex >= savedRooms.length) activeRoomIndex = savedRooms.length - 1;
			loadRoom(activeRoomIndex);
			renderCarouselNav();
		};
	}
	const MAX_ROOMS = 5;
	const addRoomBtn = document.getElementById('btn-add-room');
	if (addRoomBtn) {
		addRoomBtn.onclick = () => {
