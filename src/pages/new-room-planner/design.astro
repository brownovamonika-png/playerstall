	const FLOOR_COLORS = [
		{ hex: '#b0aba4', label: 'Concrete' },
		{ hex: '#8b6f47', label: 'Darker Wood' },
		{ hex: '#c4a882', label: 'Lighter Wood' },
		{ hex: '#2a2a2a', label: 'Black Rubber' },
	];
	const WALL_COLORS = [
		{ hex: '#ffffff', label: 'White' },
		{ hex: '#d4c5a9', label: 'Tan' },
		{ hex: '#5c5c5c', label: 'Dark Grey' },
		{ hex: '#1a1a1a', label: 'Black' },
