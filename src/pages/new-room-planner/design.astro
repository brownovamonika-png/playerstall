		btn3dPrev.disabled = idx <= 0;
		btn3dNext.disabled = idx >= total - 1;
		btn3dPrev.style.display = total > 1 ? '' : 'none';
		btn3dNext.style.display = total > 1 ? '' : 'none';
		roomIndicator3d.style.display = total > 1 ? '' : 'none';
		roomIndicator3d.textContent = name ? `ROOM ${idx + 1} OF ${total} — ${name}` : `ROOM ${idx + 1} OF ${total}`;
		roomNameLabel3d.textContent = name ? '— ' + name : '';
