		const count = Math.max(1, parseInt(deleteCountInput.value) || 1);
		if (state.lockers.length === 0) return;
		const toRemove = Math.min(count, state.lockers.length);
		const removedIds = state.lockers.slice(-toRemove).map(l => l.instanceId);
		removeLockers3D(removedIds);
		state.lockers.splice(state.lockers.length - toRemove, toRemove);
		state.selection = null;
		selectAll3D = false;
		btnSelectAll.classList.remove('active');
		hideBars();
