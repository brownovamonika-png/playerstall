---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Review Your Layout | Room Planner | PlayerStall"
	description="Review your locker room layout, see your order summary, and send it to our team. Free interactive tool from PlayerStall."
>
	<section class="planner-hero">
		<div class="planner-hero-inner">
			<a href="/new-room-planner/design" class="back-link">&larr; Back to Design</a>
			<span class="planner-hero-subtitle">Free Online Tool</span>
			<h1>Locker Room Planner</h1>
			<p class="planner-hero-lead">Review your layout, confirm pricing, and send everything to our team.</p>
			<div class="hero-steps">
				<div class="hero-step done-step">
					<span class="hero-step-num">&check;</span>
					<span class="hero-step-text">Enter your room size</span>
				</div>
				<div class="hero-step-arrow">&rarr;</div>
				<div class="hero-step done-step">
					<span class="hero-step-num">&check;</span>
					<span class="hero-step-text">Add & arrange lockers</span>
				</div>
				<div class="hero-step-arrow">&rarr;</div>
				<div class="hero-step active-step">
					<span class="hero-step-num">3</span>
					<span class="hero-step-text">Review & send to us</span>
				</div>
			</div>
		</div>
	</section>

	<section class="order-section">
		<div class="order-section-header">
			<p class="order-desc">Here's everything you've configured across all your rooms. When you submit, you'll get <strong>two PDFs</strong> by email: a polished <strong>project estimate</strong> with pricing, and a <strong>layout pack</strong> with floor plans plus 3D views for fundraising or sharing. We'll help you bring it to life.</p>
		</div>
		<div class="order-section-inner">
			<div class="order-panel" id="order-panel">
				<h3 class="order-panel-title">Order Summary</h3>
				<div class="order-room-name" id="order-room-name"></div>
				<table class="order-table">
					<thead>
						<tr>
							<th class="ot-product">Product</th>
							<th class="ot-qty">Qty</th>
							<th class="ot-total">Subtotal</th>
						</tr>
					</thead>
					<tbody id="order-items-body">
						<tr><td colspan="3" class="ot-empty">Loading&hellip;</td></tr>
					</tbody>
					<tfoot>
						<tr class="ot-subtotal-row">
							<th colspan="2">Subtotal</th>
							<td id="order-subtotal">$0.00</td>
						</tr>
						<tr class="ot-total-row">
							<th colspan="2">Estimated Total</th>
							<td id="order-total"><strong>$0.00</strong></td>
						</tr>
					</tfoot>
				</table>
				<div class="order-locker-count" id="order-locker-count">0 lockers</div>
				<div class="order-email-row">
					<label class="order-email-label" for="customer-email">Your email</label>
					<input type="email" id="customer-email" class="order-email-input" placeholder="you@example.com" required />
				</div>
				<button type="button" class="order-request-btn" id="btn-request-quote">Get In Touch With Us</button>
				<p class="order-disclaimer" id="order-status-msg">We'll send a copy of your layout to your email and to our team so we can help you execute on your dream locker room.</p>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.planner-hero {
		background: #ffffff;
		color: #0d0d0d;
		padding: 80px 20px 40px;
		text-align: center;
	}
	.planner-hero-inner {
		max-width: 900px;
		margin: 0 auto;
	}
	.planner-hero-subtitle {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 6px;
		text-transform: uppercase;
		color: #8c8c8c;
		margin-bottom: 12px;
	}
	.planner-hero h1 {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(32px, 4vw, 52px);
		font-weight: 700;
		margin: 0;
		text-transform: uppercase;
		color: #0d0d0d;
		line-height: 1.1;
		letter-spacing: 2px;
	}
	.planner-hero-lead {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		margin: 14px auto 0;
		color: #8c8c8c;
		max-width: 600px;
		line-height: 1.6;
	}
	.back-link {
		display: inline-block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		text-decoration: none;
		margin-bottom: 16px;
		letter-spacing: 0.5px;
		transition: color 0.2s;
	}
	.back-link:hover { color: #fe5900; }

	.hero-steps {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
		margin-top: 32px;
		flex-wrap: wrap;
	}
	.hero-step {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.hero-step-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: #0d0d0d;
		color: #fff;
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		flex-shrink: 0;
	}
	.hero-step-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
	}
	.hero-step-arrow { color: #ccc; font-size: 18px; }
	.active-step .hero-step-num { background: #fe5900; }
	.done-step .hero-step-num { background: #4caf50; }
	.done-step .hero-step-text { color: #8c8c8c; }
	@media (max-width: 640px) {
		.hero-steps { flex-direction: column; gap: 10px; }
		.hero-step-arrow { transform: rotate(90deg); }
	}

	.order-section { background: #ffffff; padding: 40px 20px 60px; }
	.order-section-header { max-width: 700px; margin: 0 auto; padding: 0 20px 24px; }
	.order-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #8c8c8c;
		text-align: center;
		line-height: 1.6;
		margin: 0;
	}
	.order-section-inner { max-width: 700px; margin: 0 auto; }

	.order-panel {
		background: #f7f7f7;
		border: none;
		border-radius: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}
	.order-panel-title {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 2px;
		margin: 0;
		padding: 24px 24px 16px;
		border-bottom: 1px solid #e0e0e0;
	}
	.order-room-name {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		padding: 8px 24px 0;
		min-height: 20px;
		letter-spacing: 0.3px;
	}
	.order-table { width: 100%; border-collapse: collapse; margin: 0; }
	.order-table thead { border-bottom: 1px solid #e0e0e0; }
	.order-table th {
		padding: 12px 24px;
		font-family: 'Oswald', sans-serif;
		font-size: 11px;
		font-weight: 600;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 1px;
		text-align: left;
	}
	.order-table th.ot-qty { text-align: center; width: 40px; }
	.order-table th.ot-total { text-align: right; width: 80px; }
	.order-table tbody td {
		padding: 12px 24px;
		border-bottom: 1px solid #e0e0e0;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #0d0d0d;
		vertical-align: top;
	}
	.order-table tbody td.ot-empty {
		color: #b6b6b6;
		text-align: center;
		padding: 30px 24px;
	}
	.ot-item-name {
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: #0d0d0d;
	}
	.ot-item-spec {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		color: #8c8c8c;
		margin-top: 3px;
		line-height: 1.4;
	}
	.ot-acc-line {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		color: #666;
		line-height: 1.5;
		padding-left: 2px;
	}
	.ot-acc-price { color: #8c8c8c; }
	.ot-item-qty {
		text-align: center;
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		color: #0d0d0d;
	}
	.ot-item-total {
		text-align: right;
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		color: #0d0d0d;
		white-space: nowrap;
	}
	.order-table tfoot th {
		padding: 12px 24px;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 1px;
		text-align: left;
		border: none;
	}
	.order-table tfoot td {
		padding: 12px 24px;
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		color: #0d0d0d;
		text-align: right;
		border: none;
	}
	.ot-total-row th,
	.ot-total-row td {
		border-top: 1px solid #ccc !important;
		padding-top: 14px !important;
	}
	.ot-total-row td strong {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: #0d0d0d;
	}
	.order-locker-count {
		padding: 10px 24px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		letter-spacing: 0.5px;
	}
	.order-email-row { padding: 0 24px; margin-top: 16px; }
	.order-email-label {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		margin-bottom: 6px;
	}
	.order-email-input {
		width: 100%;
		padding: 10px 14px;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		background: #fff;
		box-sizing: border-box;
	}
	.order-email-input:focus { border-color: #fe5900; outline: none; }
	.order-email-input::placeholder { color: #b6b6b6; }
	.order-request-btn {
		margin: 12px 24px 24px;
		padding: 16px 24px;
		background: #0d0d0d;
		color: #fff;
		border: none;
		border-radius: 0;
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2px;
		cursor: pointer;
		transition: background 0.3s;
	}
	.order-request-btn:hover { background: #fe5900; }
	.order-disclaimer {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #b6b6b6;
		text-align: center;
		padding: 0 24px 20px;
		line-height: 1.5;
	}
	.ot-room-header td {
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 1.5px;
		color: #8c8c8c;
		padding: 16px 24px 6px !important;
		border-bottom: none !important;
		background: transparent;
	}

	@media (max-width: 768px) {
		.planner-hero { padding: 40px 20px 20px; }
		.order-section { padding: 20px 20px 40px; }
	}
</style>

<script>
	import { getTemplate, resolveLockerColor } from '../../room-planner/catalog';
	import { priceLocker } from '../../room-planner/pricing';
	import { buildWalls, needByTimelineLabel, fundingStatusLabel } from '../../room-planner/state';
	import type { PlannerState, LockerInstance } from '../../room-planner/types';
	import { generateEstimatePdfBlob } from '../../room-planner/pdfEstimate';
	import { generateLayoutPdfBlob } from '../../room-planner/pdfLayoutDoc';

	const ROOMS_STORAGE_KEY = 'playerstall_rooms_design';

	interface SavedRoom {
		roomName: string;
		needByTimeline?: string;
		fundingStatus?: string;
		sportType: string;
		floorColor: string;
		wallColor: string;
		showBase: boolean;
		baseColor: string;
		edgebandColor?: string;
		customLogoDataUrl: string | null;
		roomDims: { wallA: number; wallB: number; wallC: number; wallD: number };
		walls: PlannerState['walls'];
		openings: PlannerState['openings'];
		lockers: LockerInstance[];
	}

	const raw = localStorage.getItem(ROOMS_STORAGE_KEY);
	if (!raw) {
		window.location.href = '/new-room-planner/design';
		throw new Error('No room data');
	}

	let data: { activeRoomIndex: number; rooms: SavedRoom[] };
	try { data = JSON.parse(raw); } catch {
		window.location.href = '/new-room-planner/design';
		throw new Error('Bad room data');
	}

	if (!data.rooms || data.rooms.length === 0) {
		window.location.href = '/new-room-planner/design';
		throw new Error('No rooms');
	}

	const savedRooms = data.rooms;

	const setupRaw = localStorage.getItem('ps_planner_setup');
	let customerEmailDefault = '';
	if (setupRaw) {
		try { customerEmailDefault = JSON.parse(setupRaw).email || ''; } catch {}
	}

	const emailInput = document.getElementById('customer-email') as HTMLInputElement;
	if (emailInput && customerEmailDefault) emailInput.value = customerEmailDefault;

	interface LineItem { roomName: string; templateId: string; displayName: string; widthIn: number; depthIn: number; colorCode: string; colorLabel: string; accessoryIds: string[]; accessories: { label: string; price: number }[]; unitPrice: number; qty: number; }

	function buildLinesForLockers(lockers: LockerInstance[], roomName: string): LineItem[] {
		const lines: LineItem[] = [];
		for (const locker of lockers) {
			const t = getTemplate(locker.templateId); if (!t) continue;
			const price = priceLocker(t, locker.config);
			const color = resolveLockerColor(t, locker.config.colorCode);
			const accs = locker.config.accessoryIds.map((id) => t.accessories.find((a) => a.id === id)).filter(Boolean) as { id: string; label: string; price: number }[];
			const sortedAcc = [...locker.config.accessoryIds].sort();
			const key = `${locker.templateId}|${locker.config.widthIn}|${locker.config.depthIn}|${locker.config.colorCode}|${sortedAcc.join(',')}`;
			const existing = lines.find((l) => `${l.templateId}|${l.widthIn}|${l.depthIn}|${l.colorCode}|${[...l.accessoryIds].sort().join(',')}` === key && l.roomName === roomName);
			if (existing) { existing.qty++; }
			else { lines.push({ roomName, templateId: locker.templateId, displayName: t.displayName, widthIn: locker.config.widthIn, depthIn: locker.config.depthIn, colorCode: locker.config.colorCode, colorLabel: color?.label ?? locker.config.colorCode, accessoryIds: [...locker.config.accessoryIds], accessories: accs.map((a) => ({ label: a.label, price: a.price })), unitPrice: price, qty: 1 }); }
		}
		return lines;
	}

	function getAllRoomLines(): LineItem[] {
		const allLines: LineItem[] = [];
		for (const room of savedRooms) allLines.push(...buildLinesForLockers(room.lockers, room.roomName));
		return allLines;
	}

	// Build and render order summary
	const allLines = getAllRoomLines();
	const tbody = document.getElementById('order-items-body')!;
	const subtotalEl = document.getElementById('order-subtotal')!;
	const totalEl = document.getElementById('order-total')!;
	const countEl = document.getElementById('order-locker-count')!;

	if (allLines.length === 0) {
		tbody.innerHTML = '<tr><td colspan="3" class="ot-empty">No lockers placed yet. Go back and add lockers first.</td></tr>';
		subtotalEl.textContent = '$0.00'; totalEl.innerHTML = '<strong>$0.00</strong>'; countEl.textContent = '0 lockers';
	} else {
		let subtotal = 0, totalLockers = 0, html = '', currentRoom = '';
		for (const line of allLines) {
			const rLabel = line.roomName || 'Unnamed Room';
			if (rLabel !== currentRoom) { currentRoom = rLabel; html += `<tr class="ot-room-header"><td colspan="3">${currentRoom}</td></tr>`; }
			const lineTotal = line.unitPrice * line.qty; subtotal += lineTotal; totalLockers += line.qty;
			let accHtml = '';
			if (line.accessories.length) accHtml = line.accessories.map((a) => `<span class="ot-acc-line">+ ${a.label} <span class="ot-acc-price">+$${a.price}</span></span>`).join('');
			html += `<tr><td><span class="ot-item-name">${line.displayName}</span><span class="ot-item-spec">${line.widthIn}\u2033W \u00d7 ${line.depthIn}\u2033D \u00b7 ${line.colorLabel}</span>${accHtml}</td><td class="ot-item-qty">${line.qty}</td><td class="ot-item-total">$${lineTotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}</td></tr>`;
		}
		tbody.innerHTML = html;
		subtotalEl.textContent = `$${subtotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
		totalEl.innerHTML = `<strong>$${subtotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}</strong>`;
		countEl.textContent = `${totalLockers} locker${totalLockers !== 1 ? 's' : ''} across ${savedRooms.length} room${savedRooms.length > 1 ? 's' : ''}`;
	}

	function blobToBase64(blob: Blob): Promise<string> {
		return new Promise((resolve, reject) => {
			const reader = new FileReader();
			reader.onloadend = () => resolve((reader.result as string).split(',')[1]);
			reader.onerror = () => reject(new Error('read failed'));
			reader.readAsDataURL(blob);
		});
	}

	function downloadBlob(blob: Blob, filename: string) {
		const url = URL.createObjectURL(blob);
		const a = document.createElement('a');
		a.href = url;
		a.download = filename;
		document.body.appendChild(a);
		a.click();
		a.remove();
		URL.revokeObjectURL(url);
	}

	// ─── Request Quote ───
	document.getElementById('btn-request-quote')!.onclick = async () => {
		if (allLines.length === 0) { alert('No lockers to submit. Go back and add lockers first.'); return; }

		const cart = JSON.parse(localStorage.getItem('playerstall_cart') || '[]');
		for (const line of allLines) {
			const roomLabel = line.roomName ? `Room: ${line.roomName}` : 'Room Planner';
			const specParts = [`${line.widthIn}\u2033W \u00d7 ${line.depthIn}\u2033D`, line.colorLabel];
			if (line.accessories.length) for (const a of line.accessories) specParts.push(`${a.label} (+$${a.price})`);
			const model = `${roomLabel} \u00b7 ${specParts.join(' \u00b7 ')}`;
			const id = `planner-${line.roomName}-${line.templateId}-${line.widthIn}-${line.depthIn}-${line.colorLabel}-${line.accessories.map((a) => a.label).join('-')}`;
			const existing = cart.find((item: any) => item.id === id);
			if (existing) existing.quantity += line.qty;
			else cart.push({ id, name: line.displayName, price: line.unitPrice, image: '/images/stadium-locker.png', quantity: line.qty, model });
		}
		localStorage.setItem('playerstall_cart', JSON.stringify(cart));
		window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: cart.reduce((sum: number, item: any) => sum + item.quantity, 0) } }));

		const customerEmail = (document.getElementById('customer-email') as HTMLInputElement).value.trim();
		if (!customerEmail) { alert('Please enter your email address so we can get in touch with you.'); return; }

		let orderSummary = ''; let curRoom = '';
		for (const line of allLines) {
			const room = line.roomName || 'Unnamed Room';
			if (room !== curRoom) { curRoom = room; orderSummary += `\n--- ${room} ---\n`; }
			const accText = line.accessories.length ? ` + ${line.accessories.map((a: any) => a.label).join(', ')}` : '';
			orderSummary += `${line.qty}x ${line.displayName} (${line.widthIn}"W x ${line.depthIn}"D, ${line.colorLabel}${accText}) - $${(line.unitPrice * line.qty).toFixed(2)}\n`;
		}
		const grandTotal = allLines.reduce((sum: number, l: any) => sum + l.unitPrice * l.qty, 0);
		orderSummary += `\nEstimated Total: $${grandTotal.toFixed(2)}`;

		let timingBlock = '';
		for (let ri = 0; ri < savedRooms.length; ri++) {
			const r = savedRooms[ri];
			const lbl = needByTimelineLabel(r.needByTimeline || '');
			if (!lbl) continue;
			const rm = r.roomName || `Room ${ri + 1}`;
			timingBlock += `${rm}: ${lbl}\n`;
		}
		let fundingBlock = '';
		for (let ri = 0; ri < savedRooms.length; ri++) {
			const r = savedRooms[ri];
			const lbl = fundingStatusLabel(r.fundingStatus || '');
			if (!lbl) continue;
			const rm = r.roomName || `Room ${ri + 1}`;
			fundingBlock += `${rm}: ${lbl}\n`;
		}
		if (fundingBlock) {
			orderSummary = `Funding / budget:\n${fundingBlock}\n` + orderSummary;
		}
		if (timingBlock) {
			orderSummary = `Preferred delivery timing:\n${timingBlock}\n` + orderSummary;
		}

		const statusMsg = document.getElementById('order-status-msg')!;
		const btn = document.getElementById('btn-request-quote') as HTMLButtonElement;
		btn.disabled = true; btn.textContent = 'Generating PDFs...';
		const estimateLines = allLines.map((l) => ({
			roomName: l.roomName,
			displayName: l.displayName,
			widthIn: l.widthIn,
			depthIn: l.depthIn,
			colorLabel: l.colorLabel,
			accessories: l.accessories,
			unitPrice: l.unitPrice,
			qty: l.qty,
		}));
		const estimateBlob = generateEstimatePdfBlob(estimateLines, customerEmail, grandTotal);
		const layoutBlob = await generateLayoutPdfBlob(savedRooms, 'in');
		btn.textContent = 'Sending...';

		let estimatePdfBase64: string | undefined;
		let layoutPdfBase64: string | undefined;
		try {
			if (estimateBlob) estimatePdfBase64 = await blobToBase64(estimateBlob);
			if (layoutBlob) layoutPdfBase64 = await blobToBase64(layoutBlob);
		} catch (_) { /* continue without attachment */ }

		fetch('/api/send-room-plan', {
			method: 'POST', headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				email: customerEmail,
				orderSummary,
				grandTotal: grandTotal.toFixed(2),
				estimatePdfBase64,
				layoutPdfBase64,
			}),
		}).then(async (res) => {
			if (res.ok) {
				statusMsg.textContent =
					'Thank you! We emailed two PDFs to ' +
					customerEmail +
					': your project estimate and your layout (floor plans + 3D). Our team received copies too.';
				statusMsg.style.color = '#0d0d0d'; btn.textContent = 'Sent!';
				if (estimateBlob) downloadBlob(estimateBlob, 'PlayerStall-Room-Estimate.pdf');
				if (layoutBlob) {
					setTimeout(() => downloadBlob(layoutBlob, 'PlayerStall-Room-Layout.pdf'), 400);
				}
			} else {
				let detail = ''; try { const j = await res.json(); detail = j.error || ''; } catch {}
				statusMsg.textContent = 'Something went wrong' + (detail ? ': ' + detail : '') + '. Please try again or email us directly at sales@playerstall.com.';
				statusMsg.style.color = '#fe5900'; btn.disabled = false; btn.textContent = 'Get In Touch With Us';
			}
		}).catch(() => {
			statusMsg.textContent = 'Could not connect. Please check your internet and try again, or email us directly at sales@playerstall.com.';
			statusMsg.style.color = '#fe5900'; btn.disabled = false; btn.textContent = 'Get In Touch With Us';
		});
	};
</script>
