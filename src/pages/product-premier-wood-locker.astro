---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Elite Wood Locker - 24-Inch Wide, 76 Inches High, 24 Inches Deep | PlayerStall"
	description="Elite wood locker built from MPW-6C plywood with melamine coating – ultra-durable, water-resistant, scratch-resistant panels engineered for high-traffic athletic locker rooms."
>
	<!-- Hero Section -->
	<section class="product-hero-section">
		<div class="product-hero-background-overlay"></div>
		<div class="product-hero-container">
			<div class="product-breadcrumbs">
				<a href="/">Home</a>
				<span class="breadcrumbs-sep">/</span>
				<a href="/services">Products</a>
				<span class="breadcrumbs-sep">/</span>
				<span class="breadcrumbs-current">Elite Locker</span>
			</div>
			<div class="product-background-text">locker</div>
		</div>
	</section>

	<!-- Product Main -->
	<section class="product-main-section">
		<div class="product-container">
			<div class="product-layout">
				<!-- Left: Gallery -->
				<div class="product-gallery">
					<div class="product-gallery-main">
						<img
							src="/images/grid_locker_gray_curved-75a91a17-f394-49fb-8c61-0029ab3bc6b7.png"
							alt="Premier wood open access locker with curved profile in light grey"
							class="product-main-image"
						/>
						<span class="product-enlarge-hint">Enlarge Image</span>
					</div>
					<div class="product-gallery-thumbs">
						<button type="button" class="thumb active" aria-label="View image 1">
							<img src="/images/grid_locker_gray_curved-75a91a17-f394-49fb-8c61-0029ab3bc6b7.png" alt="Locker view 1" />
						</button>
						<button type="button" class="thumb" aria-label="View image 2">
							<img src="/images/wood-locer-room-front-2.png" alt="Locker view 2" />
						</button>
						<button type="button" class="thumb" aria-label="View image 3">
							<img src="/images/phenolic-locker-no-background.jpg" alt="Locker view 3" />
						</button>
					</div>
				</div>

				<!-- Right: Details -->
				<div class="product-detail">
					<h1 class="product-title">Elite Locker – 24&quot; Wide, 76 Inches High, 24 Inches Deep</h1>

					<p class="product-model">Model # 40024ST-BE</p>

					<p class="product-lead-time">Lead time: usually ships within 3-4 weeks</p>

					<div class="product-price-block">
						<span class="product-price" data-base-price="599">$599.00</span>
					</div>

					<div class="product-options">
						<div class="product-option">
							<label class="option-label">Width:</label>
							<span class="option-value">24&quot; (standard)</span>
							<div class="option-swatches">
								<button type="button" class="swatch width-swatch active" data-base-price="599" title="24 inch width" aria-pressed="true">24&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="699" title="30 inch width">30&quot;</button>
							</div>
						</div>
						<div class="product-option">
							<label class="option-label">Color:</label>
							<span class="option-value">Maple</span>
							<div class="option-swatches">
								<button type="button" class="swatch active" title="Black" aria-pressed="true">Black</button>
								<button type="button" class="swatch" title="Light Grey">Light Grey</button>
								<button type="button" class="swatch" title="Dark Grey">Dark Grey</button>
								<button type="button" class="swatch" title="Maple">Maple</button>
							</div>
						</div>
						<div class="product-option">
							<label class="option-label">Accessories:</label>
							<span class="option-value">Select add-ons to update price</span>
							<div class="accessories-grid">
								<button type="button" class="accessory-box" data-price="40" title="Vented front">
									<span class="accessory-square"></span>
									<span class="accessory-label">Vented front (+$40)</span>
								</button>
								<button type="button" class="accessory-box" data-price="80" title="Lock box">
									<span class="accessory-square"></span>
									<span class="accessory-label">Lock box (+$80)</span>
								</button>
								<button type="button" class="accessory-box" data-price="75" title="Top cushion">
									<span class="accessory-square"></span>
									<span class="accessory-label">Top cushion (+$75)</span>
								</button>
								<button type="button" class="accessory-box" data-price="75" title="Bottom cushion">
									<span class="accessory-square"></span>
									<span class="accessory-label">Bottom cushion (+$75)</span>
								</button>
								<button type="button" class="accessory-box" data-price="150" title="Top &amp; bottom cushions">
									<span class="accessory-square"></span>
									<span class="accessory-label">Top &amp; bottom cushions (+$150)</span>
								</button>
								<button type="button" class="accessory-box" data-price="10" title="Name plate">
									<span class="accessory-square"></span>
									<span class="accessory-label">Name plate (+$10)</span>
								</button>
								<button type="button" class="accessory-box" data-price="25" title="Skate hooks">
									<span class="accessory-square"></span>
									<span class="accessory-label">Skate hooks</span>
								</button>
								<button type="button" class="accessory-box" data-price="75" title="Custom logo">
									<span class="accessory-square"></span>
									<span class="accessory-label">Custom logo</span>
								</button>
							</div>
						</div>
						<div class="product-specs-inline">
							<p><strong>Width options:</strong> 24&quot; or 30&quot;</p>
							<p><strong>Standard size shown:</strong> 24&quot; W x 76&quot; H x 24&quot; D</p>
							<p><strong>Base:</strong> optional 4&quot; high base can be added</p>
							<p><strong>Weight:</strong> 175 lbs</p>
						</div>
					</div>

					<div class="product-volume-discounts">
						<h3 class="volume-title">Volume Discounts</h3>
						<table class="volume-table">
							<thead>
								<tr>
									<th>Quantity</th>
									<th>Price</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td>2 - 5</td>
									<td>$850.00</td>
								</tr>
								<tr>
									<td>6 +</td>
									<td>$799.00</td>
								</tr>
								<tr>
									<td colspan="2"><a href="/contact" class="volume-contact-link">Contact us for bulk pricing</a></td>
								</tr>
							</tbody>
						</table>
					</div>

					<div class="product-actions">
						<label class="quantity-label" for="product-qty">Quantity:</label>
						<input type="number" id="product-qty" class="product-qty-input" value="1" min="1" max="999" />
						<button type="button" class="btn btn-primary product-add-cart">Add to Cart</button>
					</div>
				</div>
			</div>

			<!-- More Information -->
			<div class="product-info-section" id="moreinfo">
				<h2 class="product-info-heading">Premier Open Access &amp; Gear</h2>

				<h3 class="product-info-subheading">Features</h3>
				<ul class="product-features-list">
					<li>Built from MPW-6C plywood with a premium melamine surface for a refined, furniture-grade look</li>
					<li>Melamine coating delivers outstanding scratch resistance and everyday impact protection in high-traffic locker rooms</li>
					<li>Engineered plywood core is dimensionally stable and moisture-resistant, helping the locker stay straight and true over time</li>
					<li>Ideal for sports facilities, schools, locker rooms, police and fire stations or wherever a professional environment is needed</li>
					<li>Available in black, light grey, dark grey, and maple finishes to match your room design</li>
					<li>Available in 24 inch or 30 inch widths; standard configuration is 24 inches wide, 76 inches high, and 24 inches deep, with an optional 4 inch base that can be added</li>
					<li>14" high foot locker provides comfortable seating and secure equipment storage, with optional top and bottom cushions (or both) for added comfort</li>
				</ul>

				<h3 class="product-info-subheading">Options</h3>
				<ul class="product-options-list">
					<li>Choice of finishes: black, light grey, dark grey, or maple</li>
					<li>Vented front panel for increased airflow</li>
					<li>Secure lock box integrated into the upper compartment</li>
					<li>Top cushion, bottom cushion, or both for added seating comfort</li>
					<li>Skate hooks for hockey or figure skating storage</li>
					<li>Custom logo option for teams or programs</li>
					<li>Black electronic or combination lock on the compartment door</li>
				</ul>

				<h3 class="product-info-subheading">Downloads</h3>
				<ul class="product-downloads-list">
					<li><a href="#">More Product Information</a></li>
					<li><a href="#">Installation Instructions</a></li>
					<li><a href="#">Lock Information</a></li>
					<li><a href="#">Technical Drawing</a></li>
					<li><a href="#">Specifications</a></li>
					<li><a href="#">BIM Models</a></li>
				</ul>
			</div>

			<!-- Related Items -->
			<div class="product-related-section">
				<h2 class="related-heading">Related Items</h2>
				<div class="related-grid">
					<a href="/services" class="related-card">
						<div class="related-image">
							<img src="/stick-rack.png" alt="Stick Rack accessory" loading="lazy" />
						</div>
						<h4 class="related-title">Stick Rack</h4>
					</a>
					<a href="/services" class="related-card">
						<div class="related-image">
							<img src="/corner-unit.png" alt="Corner Unit" loading="lazy" />
						</div>
						<h4 class="related-title">Corner Unit</h4>
					</a>
					<a href="/services" class="related-card">
						<div class="related-image">
							<img src="/images/rfid-lock.png" alt="Electronic lock" loading="lazy" />
						</div>
						<h4 class="related-title">Electronic Lock</h4>
					</a>
					<a href="/services" class="related-card">
						<div class="related-image">
							<img src="/images/wood-lockers-team-discount.jpg" alt="Wood locker bench" loading="lazy" />
						</div>
						<h4 class="related-title">Locker Bench</h4>
					</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	.product-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Hero */
	.product-hero-section {
		position: relative;
		background: #f7f7f7;
		padding: 80px 0 50px;
		overflow: hidden;
	}

	.product-hero-background-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(13, 13, 13, 0.04) 0%, transparent 100%);
	}

	.product-hero-container {
		position: relative;
		z-index: 2;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.product-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		margin-bottom: 20px;
	}

	.product-breadcrumbs a {
		color: #8c8c8c;
		text-decoration: none;
		transition: color 0.3s;
	}

	.product-breadcrumbs a:hover {
		color: #fe5900;
	}

	.breadcrumbs-sep {
		margin: 0 8px;
		color: #b6b6b6;
	}

	.breadcrumbs-current {
		color: #0d0d0d;
	}

	.product-background-text {
		position: absolute;
		font-family: 'Oswald', sans-serif;
		font-size: 200px;
		font-weight: 700;
		color: rgba(13, 13, 13, 0.04);
		text-transform: uppercase;
		letter-spacing: -2px;
		bottom: -30px;
		left: 50%;
		transform: translateX(-50%);
		white-space: nowrap;
		z-index: 1;
	}

	/* Main section */
	.product-main-section {
		padding: 60px 0 100px;
		background: #ffffff;
	}

	.product-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: start;
		margin-bottom: 80px;
	}

	/* Gallery */
	.product-gallery-main {
		position: relative;
		background: #f7f7f7;
		aspect-ratio: 1;
		overflow: hidden;
		margin-bottom: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.product-main-image {
		width: 96%;
		height: 96%;
		object-fit: contain;
		display: block;
	}

	.product-enlarge-hint {
		position: absolute;
		bottom: 12px;
		right: 12px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.product-gallery-thumbs {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.thumb {
		width: 80px;
		height: 80px;
		padding: 0;
		border: 2px solid transparent;
		background: #f0f0f0;
		cursor: pointer;
		overflow: hidden;
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	.thumb:hover,
	.thumb.active {
		border-color: #fe5900;
		box-shadow: 0 0 0 1px #fe5900;
	}

	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	/* Product detail column */
	.product-detail {
		position: sticky;
		top: 120px;
	}

	.product-volume-badge {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 16px;
		font-weight: 500;
	}

	.product-title {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		line-height: 1.25;
		margin: 0 0 12px;
		text-transform: none;
	}

	.product-model {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 8px;
	}

	.product-dimensions {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin: 4px 0 12px;
	}

	.product-lead-time {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin: 0 0 24px;
		text-transform: lowercase;
	}

	.product-price-block {
		margin-bottom: 28px;
		padding-bottom: 24px;
		border-bottom: 1px solid #e0e0e0;
	}

	.product-price {
		font-family: 'Oswald', sans-serif;
		font-size: 36px;
		font-weight: 600;
		color: #0d0d0d;
	}

	.product-options {
		margin-bottom: 28px;
	}

	.product-option {
		margin-bottom: 20px;
	}

	.option-label {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		font-weight: 500;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 8px;
	}

	.option-value {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 8px;
		display: block;
	}

	.accessories-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 8px;
	}

	.accessory-box {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: #f0f0f0; /* match color swatches */
		border: 2px solid transparent;
		color: #0d0d0d;
		cursor: pointer;
		transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
	}

	.accessory-box:hover {
		border-color: #fe5900;
		background: #ffffff;
		box-shadow: 0 0 0 1px rgba(254, 89, 0, 0.2);
	}

	.accessory-box.selected {
		border-color: #fe5900;
		background: #ffffff;
		box-shadow: 0 0 0 1px rgba(254, 89, 0, 0.2);
	}

	.accessory-square {
		width: 14px;
		height: 14px;
		border-radius: 2px;
		border: 2px solid #b6b6b6;
		background: #ffffff;
		box-sizing: border-box;
	}

	.accessory-box.selected .accessory-square {
		border-color: #fe5900;
		background: #fe5900;
	}

	.option-swatches {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.swatch {
		padding: 8px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: #f0f0f0;
		border: 2px solid transparent;
		color: #0d0d0d;
		cursor: pointer;
		transition: border-color 0.2s, background 0.2s;
	}

	.swatch:hover {
		background: #e8e8e8;
	}

	.swatch.active {
		border-color: #fe5900;
		background: #fff;
		color: #0d0d0d;
	}

	.swatch-small {
		padding: 6px 12px;
		font-size: 11px;
	}

	.product-specs-inline {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin-top: 16px;
	}

	.product-specs-inline p {
		margin: 0 0 6px;
	}

	/* Volume discounts table */
	.product-volume-discounts {
		margin-bottom: 28px;
	}

	.volume-title {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0 0 12px;
	}

	.volume-table {
		width: 100%;
		border-collapse: collapse;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
	}

	.volume-table thead {
		background: #0d0d0d;
		color: #fff;
	}

	.volume-table th {
		padding: 12px 14px;
		text-align: left;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.volume-table th:first-child {
		background: #fe5900;
	}

	.volume-table td {
		padding: 12px 14px;
		border-bottom: 1px solid #e0e0e0;
		color: #0d0d0d;
	}

	.volume-contact-link {
		color: #fe5900;
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.volume-contact-link:hover {
		color: #e04d00;
		text-decoration: underline;
	}

	/* Actions */
	.product-actions {
		display: flex;
		align-items: center;
		gap: 16px;
		flex-wrap: wrap;
	}

	.quantity-label {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #0d0d0d;
	}

	.product-qty-input {
		width: 80px;
		padding: 12px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		border: 1px solid #ccc;
		background: #fff;
		color: #0d0d0d;
	}

	.btn {
		display: inline-block;
		padding: 15px 40px;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 500;
		letter-spacing: 0.1em;
		font-size: 16px;
		transition: all 0.3s;
		font-family: 'Yantramanav', sans-serif;
		border: none;
		cursor: pointer;
	}

	.btn-primary {
		background: #fe5900;
		color: #ffffff;
		border: 2px solid #fe5900;
	}

	.btn-primary:hover {
		background: #e04d00;
		border-color: #e04d00;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(254, 89, 0, 0.3);
	}

	.product-add-cart {
		padding: 16px 36px;
	}

	/* More Information section */
	.product-info-section {
		padding: 60px 0 0;
		border-top: 1px solid #e0e0e0;
		margin-top: 40px;
	}

	.product-info-heading {
		font-family: 'Oswald', sans-serif;
		font-size: 32px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		margin: 0 0 32px;
	}

	.product-info-subheading {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 32px 0 16px;
	}

	.product-info-subheading:first-of-type {
		margin-top: 0;
	}

	.product-features-list,
	.product-options-list,
	.product-downloads-list {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		line-height: 1.7;
		color: #0d0d0d;
		margin: 0 0 24px;
		padding-left: 24px;
	}

	.product-features-list li,
	.product-options-list li,
	.product-downloads-list li {
		margin-bottom: 10px;
	}

	.product-downloads-list {
		list-style: none;
		padding-left: 0;
	}

	.product-downloads-list a {
		color: #fe5900;
		text-decoration: none;
		transition: color 0.2s;
	}

	.product-downloads-list a:hover {
		color: #e04d00;
		text-decoration: underline;
	}

	/* Related items */
	.product-related-section {
		margin-top: 80px;
		padding-top: 60px;
		border-top: 1px solid #e0e0e0;
	}

	.related-heading {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		margin: 0 0 32px;
	}

	.related-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px;
	}

	.related-card {
		text-decoration: none;
		color: inherit;
		transition: transform 0.2s;
	}

	.related-card:hover {
		transform: translateY(-4px);
	}

	.related-image {
		aspect-ratio: 1;
		background: #f7f7f7;
		overflow: hidden;
		margin-bottom: 12px;
	}

	.related-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: grayscale(40%);
		transition: filter 0.2s;
	}

	.related-card:hover .related-image img {
		filter: grayscale(0%);
	}

	.related-title {
		font-family: 'Oswald', sans-serif;
		font-size: 16px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0;
		line-height: 1.3;
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.product-layout {
			grid-template-columns: 1fr;
			gap: 40px;
		}

		.product-detail {
			position: static;
		}

		.related-grid {
			grid-template-columns: repeat(2, 1fr);
