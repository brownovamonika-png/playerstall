	@media (max-width: 480px) {
		.product-title {
			font-size: 18px;
		}

		.product-info-heading {
			font-size: 24px;
		}

		.product-info-subheading {
			font-size: 18px;
		}
	}
</style>

<script>
	// Thumbnail click: switch main image (optional enhancement)
	document.querySelectorAll('.product-gallery-thumbs .thumb').forEach((thumb) => {
		thumb.addEventListener('click', () => {
			document.querySelectorAll('.product-gallery-thumbs .thumb').forEach(t => t.classList.remove('active'));
			thumb.classList.add('active');
			const img = thumb.querySelector('img');
			if (img && img.src) {
				const main = document.querySelector('.product-main-image');
				if (main instanceof HTMLImageElement) {
					main.src = img.src;
				}
			}
		});
	});

	// Accessories: toggle selection and update price
	const priceEl = document.querySelector('.product-price') as HTMLSpanElement | null;
	if (priceEl) {
		let basePrice = 0;

		const formatPrice = (value: number) =>
			`$${value.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

		const computeBaseFromWidth = () => {
			const activeWidth = document.querySelector('.width-swatch.active') as HTMLElement | null;
			if (activeWidth) {
				const bpAttr = activeWidth.getAttribute('data-base-price');
				const bp = bpAttr ? parseFloat(bpAttr) : NaN;
				if (!Number.isNaN(bp)) {
					basePrice = bp;
					return;
				}
			}
			const fallbackAttr = priceEl.getAttribute('data-base-price');
			basePrice = fallbackAttr ? parseFloat(fallbackAttr) : 0;
		};

		const updatePrice = () => {
			computeBaseFromWidth();
			let extras = 0;
			document.querySelectorAll('.accessory-box.selected').forEach((box) => {
				const el = box as HTMLElement;
				const extraAttr = el.getAttribute('data-price');
				const extra = extraAttr ? parseFloat(extraAttr) : 0;
				if (!Number.isNaN(extra)) extras += extra;
			});
			const total = basePrice + extras;
			priceEl.textContent = formatPrice(total);
		};

		// Width selection: update active state, label, and price
		const widthValueEl = document.querySelector('.product-option .option-value') as HTMLSpanElement | null;
		document.querySelectorAll('.width-swatch').forEach((btn) => {
			btn.addEventListener('click', () => {
				document.querySelectorAll('.width-swatch').forEach((b) => {
					(b as HTMLElement).classList.remove('active');
					(b as HTMLElement).setAttribute('aria-pressed', 'false');
				});
				const el = btn as HTMLElement;
				el.classList.add('active');
				el.setAttribute('aria-pressed', 'true');

				if (widthValueEl) {
					const label = el.textContent?.trim() || '';
					if (label === '30"') {
						widthValueEl.textContent = '30" width (starting at $699.00)';
					} else {
						widthValueEl.textContent = '24" width (starting at $599.00)';
					}
				}

				updatePrice();
			});
		});

		// Initial base price
		computeBaseFromWidth();
		updatePrice();

		document.querySelectorAll('.accessory-box').forEach((box) => {
			box.addEventListener('click', () => {
				const el = box as HTMLElement;
				el.classList.toggle('selected');
				updatePrice();
			});
		});
	}
</script>
