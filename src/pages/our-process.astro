---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="Our Process | Custom Sports Lockers | PlayerStall"
	description="Learn about our process for creating custom wood sports lockers. Free consultation, custom design, and premium manufacturing with 5 year warranty."
>
	<!-- Hero Section (same as shop: image + overlay + title "Our Process") -->
	<section class="process-hero-section">
		<div class="process-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Our Process" class="process-hero-bg-image" />
		</div>
		<div class="process-hero-background-overlay"></div>
		<div class="process-hero-container">
			<div class="process-hero-breadcrumbs">
				<a href="/">Home</a>
				<span>Our Process</span>
			</div>
			<h1 class="process-hero-page-title">Our Process</h1>
			<div class="process-hero-background-text">our process</div>
		</div>
	</section>

	<!-- Our Process Section (how it works / title under image) -->
	<section class="equipment-section">
		<div class="equipment-container">
			<div class="section-header">
				<p class="section-subtitle">how it works</p>
				<h2 class="section-title">OUR PROCESS</h2>
			</div>
			<div class="equipment-grid">
			<div class="equipment-item">
				<div class="equipment-item-image">
					<img src="https://playerstall.b-cdn.net/images/h3-blog-img-7.jpg" alt="Premium Materials - Quality wood sports lockers" loading="lazy" />
					<span class="equipment-circle">1</span>
				</div>
				<h4>Premium Materials</h4>
				<p>Melamine- or laminate-coated 3/4" cabinetry-grade plywood. Built to last a lifetime.</p>
			</div>
				<div class="equipment-item">
					<div class="equipment-item-image">
						<img src="https://playerstall.b-cdn.net/images/h3-blog-img-2.jpg" alt="Full Customization for team lockers" loading="lazy" />
						<span class="equipment-circle">2</span>
					</div>
					<h4>Full Customization</h4>
					<p>Team colors, vinyl logos, and branding can be done.</p>
				</div>
				<div class="equipment-item">
					<div class="equipment-item-image">
						<img src="https://playerstall.b-cdn.net/images/h3-blog-img-3.jpg" alt="Quick Ship lockers" loading="lazy" />
						<span class="equipment-circle">3</span>
					</div>
				<h4>Quick Ship</h4>
				<p>Every locker style is available in quick ship — 24" widths, one signature color per style. Ships in one month.</p>
				</div>
				<div class="equipment-item">
					<div class="equipment-item-image">
						<img src="https://playerstall.b-cdn.net/images/h3-blog-img-4.jpg" alt="Custom Ship lockers" loading="lazy" />
						<span class="equipment-circle">4</span>
					</div>
					<h4>Custom-Built</h4>
					<p>Any size, any color, any wood, phenolic, or other materials. We build luxury lockers your way — custom-built in three months.</p>
				</div>
			</div>
			<div class="equipment-accordion">
				<div class="accordion-item active">
					<div class="accordion-header">
						<span>Free Custom Design Consultation</span>
						<span>+</span>
					</div>
					<div class="accordion-content">
						<p>Every project starts with a free custom design consultation. We'll discuss your needs, space, budget, and vision to understand exactly what you're looking for. No obligation, just expert advice from 30+ years of experience.</p>
					</div>
				</div>
				<div class="accordion-item">
					<div class="accordion-header">
						<span>5 Year Warranty</span>
						<span>+</span>
					</div>
					<div class="accordion-content">
						<p>We're confident in the quality of our wood sports lockers and back every locker with a 5 year warranty. Our unique modular design means damaged parts can be replaced individually—no need to replace the entire locker.</p>
					</div>
				</div>
				<div class="accordion-item">
					<div class="accordion-header">
						<span>Quality Manufacturing</span>
						<span>+</span>
					</div>
					<div class="accordion-content">
						<p>We manufacture to the highest quality standards with premium materials and craftsmanship. Our family business is personally invested in every project—your success is our reputation.</p>
					</div>
				</div>
				<div class="accordion-item">
					<div class="accordion-header">
						<span>Sport-Specific Solutions</span>
						<span>+</span>
					</div>
					<div class="accordion-content">
						<p>Every sport has unique equipment needs. We design lockers optimized for football, hockey, basketball, baseball, soccer, and lacrosse. From spacious football lockers to reinforced hockey lockers, we have solutions for every sport.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Ready to Transform CTA -->
	<section class="live-match">
		<div class="live-badge">free</div>
		<div class="match-container">
			<div class="match-content">
				<p class="match-subtitle">no obligation</p>
				<h2 class="match-title">Ready to Transform Your Locker Room?</h2>
				<p class="match-text">Get a free custom design consultation. No obligation, just expert advice from 30+ years of experience.</p>
				<div class="match-cta-wrap">
					<a href="/contact" class="btn btn-primary btn-large match-cta">Get Free Consultation</a>
					<a href="/gallery" class="btn btn-secondary btn-large">View Our Work</a>
				</div>
				<p class="match-phone">Call us at <a href="tel:+18885841444" class="match-phone-link">1 888 584 1444</a> or fill out our <a href="/contact" class="match-phone-link">contact form</a></p>
			</div>
		</div>
	</section>

	<!-- Testimonials (what our clients say) -->
	<section class="players-section">
		<div class="players-bg-text">testimonials</div>
		<div class="players-container">
			<div class="section-header">
				<p class="section-subtitle">trusted by champions</p>
				<h2 class="section-title">what our clients say</h2>
			</div>
			<div class="players-grid">
				<div class="player-card">
					<div class="player-image">
						<img src="https://playerstall.b-cdn.net/images/player-img-10.jpg" alt="Collegiate Football Program" loading="lazy" />
					</div>
					<div class="player-details">
						<div class="player-position">Head Coach</div>
						<h4 class="player-name">"These lockers aren't just furniture—they're an investment in our culture. Our recruits notice the difference immediately."</h4>
					</div>
				</div>
				<div class="player-card">
					<div class="player-image">
						<img src="https://playerstall.b-cdn.net/images/player-img-11.jpg" alt="University Athletic Department" loading="lazy" />
					</div>
					<div class="player-details">
						<div class="player-position">Athletic Director</div>
						<h4 class="player-name">"After 15 years, our PlayerStall lockers still look professional. The modular design has saved us thousands in repairs."</h4>
					</div>
				</div>
				<div class="player-card">
					<div class="player-image">
						<img src="https://playerstall.b-cdn.net/images/player-img-12.jpg" alt="Professional Sports Organization" loading="lazy" />
					</div>
					<div class="player-details">
						<div class="player-position">Facilities Manager</div>
						<h4 class="player-name">"The free custom design service made all the difference. They understood our space and created the perfect solution."</h4>
					</div>
				</div>
				<div class="player-card">
					<div class="player-image">
						<img src="https://playerstall.b-cdn.net/images/player-img-13.jpg" alt="Collegiate Hockey Program" loading="lazy" />
					</div>
					<div class="player-details">
						<div class="player-position">Hockey Coach</div>
						<h4 class="player-name">"The reinforced construction handles our heavy hockey gear perfectly. These lockers are built to last."</h4>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		margin: 0;
		padding: 0;
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
		line-height: 1.6;
	}

	.container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		position: relative;
		z-index: 10;
	}

	/* Hero Section (same as shop: image + overlay + title) */
	.process-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}

	.process-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.process-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.process-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.process-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.process-hero-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}

	.process-hero-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.process-hero-breadcrumbs a:hover {
		color: #fe5900;
	}

	.process-hero-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.process-hero-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	.process-hero-background-text {
		display: none;
	}

	/* Section Header */
	.section-header {
		text-align: center;
		margin-bottom: 64px;
		position: relative;
		z-index: 10;
	}

	.section-subtitle {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		margin-bottom: -3px;
		display: block;
	}

	.section-title {
		font-family: 'Oswald', sans-serif;
		font-size: 48px;
		font-weight: 600;
		color: #000000;
		text-transform: uppercase;
		margin: 15px 0;
		letter-spacing: 1px;
		position: relative;
		display: inline-block;
	}

	/* Equipment Section (Our Process) */
	.equipment-section {
		background: #f7f7f7;
		padding: 100px 0;
	}

	.equipment-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.equipment-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
		margin-bottom: 4rem;
	}

	.equipment-item {
		text-align: center;
	}

	.equipment-item-image {
		position: relative;
		width: 100%;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		margin-bottom: 1.25rem;
		border-radius: 4px;
	}

	.equipment-item-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.equipment-item-image .equipment-circle {
		position: absolute;
		bottom: 16px;
		left: 16px;
		width: 56px;
		height: 56px;
		margin: 0;
		font-size: 28px;
	}

	.equipment-circle {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		background: #fe5900;
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: 'Oswald', sans-serif;
		font-size: 36px;
		font-weight: 700;
		margin: 0 auto 1.5rem;
	}

	.equipment-item h4 {
		font-family: 'Oswald', sans-serif;
		font-size: 24px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin-bottom: 1rem;
	}

	.equipment-item p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #666666;
		line-height: 1.8;
	}

	.equipment-accordion {
		max-width: 900px;
		margin: 0 auto;
	}

	.accordion-item {
		background: #fff;
		border-bottom: 1px solid #e0e0e0;
		margin-bottom: 1rem;
	}

	.accordion-header {
		padding: 1.5rem;
		cursor: pointer;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		transition: color 0.3s ease;
	}

	.accordion-header:hover {
		color: #fe5900;
	}

	.accordion-item.active .accordion-header {
		color: #fe5900;
	}

	.accordion-content {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease;
	}

	.accordion-item.active .accordion-content {
		max-height: 500px;
	}

	.accordion-content p {
		padding: 0 1.5rem 1.5rem;
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #666666;
		line-height: 1.8;
	}

	/* Ready to Transform CTA (live-match) */
	.live-match {
		position: relative;
		background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 100%);
		padding: 100px 0;
		text-align: center;
		overflow: hidden;
	}

	.live-badge {
		position: absolute;
		top: 28px;
		right: 28px;
		background: #fe5900;
		color: #fff;
		padding: 12px 28px;
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.2em;
	}

	.match-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		position: relative;
		z-index: 10;
	}

	.match-content {
		max-width: 640px;
		margin: 0 auto;
	}

	.match-subtitle {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		letter-spacing: 0.25em;
		text-transform: uppercase;
		color: #fe5900;
		margin: 0 0 12px;
	}

	.match-title {
		font-family: 'Oswald', sans-serif;
		font-size: 42px;
		font-weight: 600;
		color: #ffffff;
		text-transform: none;
		letter-spacing: 0.02em;
		line-height: 1.2;
		margin: 0 0 24px;
	}

	.match-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #b6b6b6;
		line-height: 1.7;
		margin: 0 0 32px;
	}

	.match-cta-wrap {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 0;
	}

	.match-cta-wrap .btn {
		min-width: 120px;
		padding: 0.75rem 1.8rem;
		font-size: 0.85rem;
	}

	.match-cta {
		display: inline-block;
		min-width: 132px;
	}

	.match-phone {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #8c8c8c;
		margin: 28px 0 0;
	}

	.match-phone-link {
		color: #fe5900;
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s ease;
	}

	.match-phone-link:hover {
		color: #ff7426;
	}

	/* Buttons for CTA */
	.btn {
		display: inline-block;
		padding: 0.75rem 1.8rem;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 500;
		letter-spacing: 0.1em;
		font-size: 0.85rem;
		transition: all 0.3s;
		font-family: 'Roboto', sans-serif;
		border: 2px solid transparent;
	}

	.btn-primary {
		background: #fe5900;
		color: #ffffff;
		border-color: #fe5900;
	}

	.btn-primary:hover {
		background: #e04d00;
		border-color: #e04d00;
	}

	.btn-secondary {
		background: #333;
		color: #fff;
		border-color: #333;
	}

	.btn-secondary:hover {
		background: #fe5900;
		border-color: #fe5900;
		color: #fff;
	}

	.btn-large {
		padding: 0.75rem 1.8rem;
		font-size: 0.85rem;
	}

	/* Testimonials (what our clients say) */
	.players-section {
		position: relative;
		background: #ffffff;
		padding: 100px 0;
		overflow: hidden;
	}

	.players-bg-text {
		display: none;
	}

	.players-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.players-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 25px;
	}

	.player-card {
		background: #fff;
		border: 1px solid #e0e0e0;
		overflow: hidden;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.player-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
	}

	.player-image {
		width: 100%;
		height: 250px;
		overflow: hidden;
	}

	.player-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		transition: transform 0.5s ease;
	}

	.player-card:hover .player-image img {
		transform: scale(1.1);
	}

	.player-details {
		padding: 1.5rem;
	}

	.player-position {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 1rem;
	}

	.player-name {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		line-height: 1.4;
		margin: 0;
		font-style: italic;
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.process-hero-page-title {
			font-size: 52px;
		}

		.section-title {
			font-size: 36px;
		}

		.players-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.equipment-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 2rem;
		}
	}

	@media (max-width: 768px) {
		.process-hero-section {
			min-height: 300px;
		}

		.process-hero-page-title {
			font-size: 42px;
		}

		.section-title {
			font-size: 28px;
		}

		.match-title {
			font-size: 32px;
		}

		.live-match {
			padding: 80px 0;
		}

		.equipment-section,
		.players-section {
			padding: 80px 0;
		}

		.players-grid {
			grid-template-columns: 1fr;
		}

		.equipment-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}

	@media (max-width: 480px) {
		.process-hero-page-title {
			font-size: 32px;
		}

		.section-title {
			font-size: 24px;
		}

		.match-title {
			font-size: 26px;
		}
	}
</style>

<script>
	// Accordion functionality
	function initAccordion() {
		const accordionHeaders = document.querySelectorAll('.accordion-header');

		accordionHeaders.forEach(header => {
			header.addEventListener('click', () => {
				const item = header.parentElement;
				if (!item) return;
				const isActive = item.classList.contains('active');

				// Close all items
				document.querySelectorAll('.accordion-item').forEach(i => {
					i.classList.remove('active');
				});

				// Open clicked item if it wasn't active
				if (!isActive) {
					item.classList.add('active');
				}
			});
		});
	}

	// Initialize accordion when DOM is ready
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initAccordion);
	} else {
		initAccordion();
	}
</script>
