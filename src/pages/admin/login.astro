---
export const prerender = false;

import { supabase, isSupabaseConfigured } from '../../lib/supabase';
import { getSession, setSessionCookies } from '../../lib/auth';

/** Signed-in cookie lifetime when “Keep me signed in” is checked vs unchecked */
const SESSION_REMEMBER_MAX_AGE_SEC = 60 * 60 * 24 * 90;
const SESSION_BRIEF_MAX_AGE_SEC = 60 * 60 * 24 * 7;
import {
	isCrmGateEnabled,
	isPreviewModeMissingPassword,
	verifyGatePasswordSubmitted,
	setCrmGateCookie,
} from '../../lib/crm-gate';

const demoMode = !isSupabaseConfigured;
const gateOn = isCrmGateEnabled();
const previewBlocked = isPreviewModeMissingPassword();

if (!demoMode) {
	const session = await getSession(Astro.cookies);
	if (session) {
		return Astro.redirect('/admin');
	}
}

let error = '';

if (Astro.request.method === 'POST') {
	const formData = await Astro.request.formData();
	const rememberMe = formData.get('remember_me') === 'on';
	const sessionMaxAgeSec = rememberMe ? SESSION_REMEMBER_MAX_AGE_SEC : SESSION_BRIEF_MAX_AGE_SEC;
	const gatePassword = formData.get('gate_password') as string;

	if (gateOn) {
		if (!verifyGatePasswordSubmitted(gatePassword)) {
			error = 'Invalid CRM password';
		} else {
			setCrmGateCookie(Astro.cookies, sessionMaxAgeSec);
		}
	}

	if (error) {
		// gate failed — do not continue
	} else if (demoMode) {
		if (previewBlocked) {
			error = 'Set CRM_SHARED_PASSWORD in your environment to sign in.';
		} else {
			return Astro.redirect('/admin');
		}
	} else {
		const email = formData.get('email') as string;
		const password = formData.get('password') as string;

		const { data, error: authError } = await supabase!.auth.signInWithPassword({
			email,
			password,
		});

		if (authError || !data.session) {
			error = authError?.message || 'Invalid credentials';
		} else {
			setSessionCookies(Astro.cookies, data.session.access_token, data.session.refresh_token, sessionMaxAgeSec);
			return Astro.redirect('/admin');
		}
	}
}
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<!-- Google Tag Manager -->
		<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
		new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
		j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
		'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
		})(window,document,'script','dataLayer','GTM-5J3PPW7D');</script>
		<!-- End Google Tag Manager -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex, nofollow" />
		<title>Login | PlayerStall CRM</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link href="https://fonts.googleapis.com/css?family=Yantramanav:400,500,700|Oswald:600,700&display=swap" rel="stylesheet" />
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5J3PPW7D"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		<div class="login-page">
			<div class="login-card">
				<div class="login-brand">
					<span class="brand-name">PLAYERSTALL</span>
					<span class="brand-label">CRM</span>
				</div>
			<p class="login-subtitle">Sign in to manage your clients and orders</p>

			{demoMode && (
				<div class="demo-banner">
					{previewBlocked ? (
						<>
							<strong>Configuration needed</strong> — Supabase is not connected. Add <code>CRM_SHARED_PASSWORD</code> to your environment, then sign in with that password to open the CRM (sample data).
						</>
					) : (
						<>
							<strong>Preview</strong> — Supabase is not connected; you are using sample data. Sign in with your CRM password to continue.
						</>
					)}
				</div>
			)}

			{error && <div class="error-msg">{error}</div>}

			{demoMode ? (
				previewBlocked ? null : (
				<form method="POST" action="/admin/login" autocomplete="on" class="admin-login-form">
					<div class="field">
						<label for="gate_password">Password</label>
						<input type="password" id="gate_password" name="gate_password" required autocomplete="current-password" placeholder="CRM password" />
					</div>
					<label class="remember-row">
						<input type="checkbox" name="remember_me" checked />
						<span>Keep me signed in on this device (90 days)</span>
					</label>
					<button type="submit" class="login-btn">Sign In</button>
				</form>
				)
			) : (
				<form method="POST" action="/admin/login" autocomplete="on" class="admin-login-form">
					<div class="field">
						<label for="email">Email</label>
						<input
							type="email"
							id="email"
							name="email"
							required
							autocomplete="username"
							inputmode="email"
							placeholder="Your email"
						/>
					</div>
					<div class="field">
						<label for="password">Password</label>
						<input type="password" id="password" name="password" required autocomplete="current-password" />
					</div>
					{gateOn && (
						<div class="field">
							<label for="gate_password">CRM shared password</label>
							<input
								type="password"
								id="gate_password"
								name="gate_password"
								required
								autocomplete="off"
								placeholder="From CRM_SHARED_PASSWORD"
							/>
						</div>
					)}
					<label class="remember-row">
						<input type="checkbox" name="remember_me" checked />
						<span>Keep me signed in on this device (~90 days). Uncheck for a shorter session (~1 week).</span>
					</label>
					<button type="submit" class="login-btn">Sign In</button>
				</form>
			)}

				<p class="login-footer">
					<a href="/">Back to PlayerStall.com</a>
				</p>
			</div>
		</div>
	</body>
</html>

<style>
	* { margin: 0; padding: 0; box-sizing: border-box; }

	body {
		font-family: 'Yantramanav', -apple-system, sans-serif;
		background: #f5f5f5;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.login-page {
		width: 100%;
		max-width: 420px;
		padding: 20px;
	}

	.login-card {
		background: #ffffff;
		padding: 48px 40px;
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
	}

	.login-brand {
		display: flex;
		align-items: baseline;
		gap: 10px;
		margin-bottom: 10px;
	}

	.brand-name {
		font-family: 'Oswald', sans-serif;
		font-size: 30px;
		font-weight: 700;
		color: #0d0d0d;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.brand-label {
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: #fe5900;
		text-transform: uppercase;
		letter-spacing: 0.15em;
	}

	.login-subtitle {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 32px;
	}

	.error-msg {
		background: #fef2f2;
		border: 1px solid #fecaca;
		color: #dc2626;
		padding: 12px 16px;
		font-size: 13px;
		margin-bottom: 20px;
	}

	.field {
		margin-bottom: 18px;
	}

	.field label {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		font-weight: 500;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin-bottom: 8px;
	}

	.field input {
		width: 100%;
		padding: 12px 14px;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		transition: border-color 0.3s ease;
	}

	.field input:focus {
		outline: none;
		border-color: #fe5900;
	}

	.login-btn {
		width: 100%;
		padding: 14px;
		background: #fe5900;
		color: #ffffff;
		border: 2px solid #fe5900;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		cursor: pointer;
		transition: all 0.3s ease;
		margin-top: 10px;
	}

	.login-btn:hover {
		background: #e04d00;
		border-color: #e04d00;
	}

	.login-footer {
		text-align: center;
		margin-top: 28px;
		font-size: 13px;
	}

	.login-footer a {
		color: #8c8c8c;
		text-decoration: none;
		font-family: 'Yantramanav', sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 11px;
		transition: color 0.3s;
	}

	.login-footer a:hover {
		color: #fe5900;
	}

	.demo-banner {
		background: #f7f7f7;
		border: 1px solid #e0e0e0;
		color: #666666;
		padding: 14px 18px;
		font-size: 13px;
		margin-bottom: 24px;
		line-height: 1.5;
	}

	.demo-banner strong {
		font-family: 'Oswald', sans-serif;
		color: #fe5900;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.demo-banner code {
		font-size: 12px;
		background: #eeeeee;
		padding: 2px 6px;
	}

	.remember-row {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		margin: 4px 0 8px 0;
		cursor: pointer;
		font-size: 13px;
		line-height: 1.45;
		color: #4b5563;
	}

	.remember-row input {
		margin-top: 3px;
		width: 16px;
		height: 16px;
		accent-color: #fe5900;
		flex-shrink: 0;
	}
</style>
