					print-color-adjust: exact;
				}
				.order-table thead th,
				.fallback-lines thead th {
					-webkit-print-color-adjust: exact;
					print-color-adjust: exact;
				}
				.order-table tfoot th,
				.order-table tfoot td {
					-webkit-print-color-adjust: exact;
					print-color-adjust: exact;
				}
				.est-customer-note-panel {
					break-inside: avoid;
					-webkit-print-color-adjust: exact;
					print-color-adjust: exact;
				}
			}
		</style>
	</head>
	<body class="est-body">
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5J3PPW7D"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		<div class="est-actions-wrap">
			<div class="actions">
				<button type="button" class="btn btn-print" onclick="window.print()">Print / Save as PDF</button>
				<a class="btn btn-back" href={`/admin/clients/${order.client_id}`}>Back to client</a>
				<a class="btn btn-back" href={`/admin/orders/${id}`}>Edit order</a>
			</div>
		</div>
		<section class="est-materials-section">
			<div class="est-container">
				{!docNumber && (
					<div class="warn">
						No {docType} number on file yet. Add it on the client page, save, then refresh this page before sending to
						the customer.
					</div>
				)}
				<div class="est-doc-column">
					<div class="est-top-accent" aria-hidden="true"></div>
					<header class="est-section-header">
						<h1 class="est-doc-title">{titleLabel}</h1>
						<p class="est-from-label">From</p>
						<div class="est-header-body">
							<div class="est-from-block">
								<div class="est-from-name">{brandName}</div>
								<p class="est-meta-line">2934 200 Street, Langley, BC V2Z 2C1 Canada</p>
								<p class="est-meta-line">
									1 888 584 1444 · {brandEmail}
								</p>
							</div>
							<div class="est-section-header-right">
								<dl class="est-doc-dl">
									<div class="est-doc-dl-row">
										<dt>{docType === 'invoice' ? 'Invoice #' : 'Estimate #'}</dt>
										<dd>{docNumber || '—'}</dd>
									</div>
									<div class="est-doc-dl-row">
										<dt>Date</dt>
										<dd>{today}</dd>
									</div>
								</dl>
							</div>
						</div>
					</header>

					<div class="est-parties">
						<div class="est-columns">
							<div>
								<div class="col-label">Bill to</div>
								<div class="party">{String(client?.contact_name || '—')}</div>
								{client?.company_name && <div class="party-detail">{String(client.company_name)}</div>}
								{client?.email && <div class="party-detail">{String(client.email)}</div>}
								{client?.phone && <div class="party-detail">{String(client.phone)}</div>}
							</div>
							<div>
								<div class="col-label">Ship to</div>
								<div class="party-detail">
									{client?.shipping_address ? String(client.shipping_address) : 'Same as bill to / TBD'}
								</div>
							</div>
						</div>
					</div>

					<div class="est-order-outer">
			{siteListLine != null && catalogLineTotal != null ? (
				<div class="order-summary-wrap">
					<h3 class="order-panel-title">Line items</h3>
					<table class="order-table">
						<thead>
							<tr>
								<th class="ot-product">Description</th>
								<th class="ot-qty">Qty</th>
								<th class="ot-total">Subtotal</th>
							</tr>
						</thead>
						<tbody>
							<tr>
								<td>
									<span class="ot-item-name">
										{displayName}{' '}
										<span class="ot-base-price">{fmtUsd(siteListLine.basePerLocker)}</span>
									</span>
									{specLinePlanner && <span class="ot-item-spec">{specLinePlanner}</span>}
									{accessoryDisplayLines.length > 0 && (
										<ul class="ot-acc-list">
											{accessoryDisplayLines.map((a) => (
												<li>
													{a.label}{' '}
													<span class="ot-acc-price">
														+$
														{a.addPerLocker.toLocaleString('en-US', {
															minimumFractionDigits: 2,
															maximumFractionDigits: 2,
														})}
													</span>
												</li>
											))}
										</ul>
									)}
									{String(order.description || '').trim() && (
										<p class="ot-item-desc">{order.description}</p>
									)}
								</td>
								<td class="ot-item-qty">
									{Math.max(1, Math.floor(Number(order.quantity) || 1))}
								</td>
								<td class="ot-item-total">{fmtUsd(catalogLineTotal)}</td>
							</tr>
						</tbody>
						<tfoot>
							<tr class="ot-subtotal-row">
								<th colspan="2">Subtotal</th>
								<td>{fmtUsd(catalogLineTotal)}</td>
							</tr>
							<tr class="ot-total-row">
								<th colspan="2">
									{docType === 'invoice' ? 'Total (USD)' : 'Estimated Total'}
								</th>
								<td>
									<strong>
										{finalTotalUsd != null ? fmtUsd(finalTotalUsd) : 'TBD'}
									</strong>
								</td>
							</tr>
						</tfoot>
					</table>
					<div class="order-locker-count">{lockerCountCatalog}</div>
					{customerNoteTrimmed && (
						<div class="est-customer-note-section est-customer-note-section--in-panel">
							<div class="est-customer-note-panel">
								<p class="est-customer-note-label">Message to customer</p>
								<p class="est-customer-note-body">{customerNoteTrimmed}</p>
							</div>
						</div>
					)}
					{quoteDiffersFromCatalog && amt != null && (
						<p class="crm-quote-note">
							Line detail follows the public site price list (subtotal {fmtUsd(catalogLineTotal)}). The total above is
							the amount saved on this order in the CRM ({fmtUsd(amt)}).
						</p>
					)}
				</div>
			) : (
				<div class="fallback-wrap">
					<h3 class="order-panel-title">Line items</h3>
					<table class="fallback-lines">
						<thead>
							<tr>
								<th>Description</th>
								<th class="num">Qty</th>
								<th class="num">Unit</th>
								<th class="num">Amount (USD)</th>
							</tr>
						</thead>
						<tbody>
							<tr>
								<td>
									<div class="desc-sub">
										{[
											order.locker_type && `Model: ${order.locker_type}`,
											order.locker_size && `Width: ${order.locker_size}`,
											order.locker_width && `Depth: ${order.locker_width}`,
											order.locker_color && `Color: ${order.locker_color}`,
										]
											.filter(Boolean)
											.join(' · ')}
										{String(order.description || '').trim() && (
											<>
												<br />
												{order.description}
											</>
										)}
										{order.accessories && (
											<>
												<br />
												Accessories: {order.accessories}
											</>
										)}
									</div>
								</td>
								<td class="num">{qty != null ? qty : '—'}</td>
								<td class="num">
									{unitPrice != null
										? fmtUsd(unitPrice)
										: amt != null
											? '—'
											: '—'}
								</td>
								<td class="num">{amt != null ? fmtUsd(amt) : 'TBD'}</td>
							</tr>
						</tbody>
					</table>

					<div class="totals">
						<div class="totals-inner">
							<div class="total-row">
								<span>Total (USD)</span>
								<span>{amt != null ? fmtUsd(amt) : 'TBD'}</span>
							</div>
						</div>
					</div>
					{lockerCountFallback && <div class="order-locker-count">{lockerCountFallback}</div>}
					{customerNoteTrimmed && (
						<div class="est-customer-note-section est-customer-note-section--in-panel">
							<div class="est-customer-note-panel">
								<p class="est-customer-note-label">Message to customer</p>
								<p class="est-customer-note-body">{customerNoteTrimmed}</p>
							</div>
						</div>
					)}
				</div>
			)}
					</div>

					<p class="est-footnote">
						{docType === 'estimate'
							? 'This estimate is subject to final approval and may change if specifications change. Validity and terms as agreed in writing with sales.'
							: 'Payment terms as agreed. Thank you for your business.'}{' '}
						Custom-built lead times and installation are quoted separately unless noted.
					</p>
				</div>
			</div>
		</section>
	</body>
</html>
