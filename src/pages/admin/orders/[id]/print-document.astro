---
export const prerender = false;

import { getSession } from '../../../../lib/auth';
import {
	accessoryLabelWithFinishFromNotes,
	accessoryLabelWithoutEmbeddedPrice,
	LOCKER_SPEC_ACCESSORY_ROWS,
	parseAccessoriesField,
} from '../../../../lib/crm-locker-accessories';
import {
	computeSiteListForOrderFields,
	normalizeAccessoryQuantitiesToPerLocker,
	SITE_ACCESSORY_USD,
} from '../../../../lib/crm-site-pricing';
import { supabaseAdmin } from '../../../../lib/supabase';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/admin/login');

const { id } = Astro.params;
const docType = Astro.url.searchParams.get('type') === 'invoice' ? 'invoice' : 'estimate';
const titleLabel = docType === 'invoice' ? 'Invoice' : 'Estimate';

const { data: order } = await supabaseAdmin
	.from('orders')
	.select('*, clients(*)')
	.eq('id', id)
	.single();

if (!order) return Astro.redirect('/admin');

const client = order.clients as Record<string, unknown> | null;
/** Invoices/estimates always use PlayerStall letterhead regardless of lead source site. */
const brandName = 'PlayerStall';
const brandEmail = 'team@playerstall.com';
const docNumber = docType === 'invoice' ? order.invoice_number : order.estimate_number;
const today = new Date().toLocaleDateString('en-CA', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
const amt = order.quoted_amount != null ? Number(order.quoted_amount) : null;
const qty = order.quantity != null && order.quantity > 0 ? Number(order.quantity) : null;
const unitPrice = amt != null && qty != null && qty > 0 ? amt / qty : null;

const accParsed = parseAccessoriesField(order.accessories);
const accessoriesBlob = String(order.accessories ?? '');
const siteListLine = computeSiteListForOrderFields({
	locker_type: order.locker_type,
	locker_size: order.locker_size,
	quantity: order.quantity,
	accessoryQuantities: accParsed.quantities,
});

const lockerQtyForNorm = qty != null && qty > 0 ? Math.floor(qty) : 1;
const normAcc = normalizeAccessoryQuantitiesToPerLocker(accParsed.quantities, lockerQtyForNorm);
type AccDisp = { label: string; addPerLocker: number };
const accessoryDisplayLines: AccDisp[] = [];
for (const row of LOCKER_SPEC_ACCESSORY_ROWS) {
	const q = normAcc[row.id] ?? 0;
	if (q <= 0) continue;
	const unit = SITE_ACCESSORY_USD[row.id];
	if (typeof unit !== 'number') continue;
	accessoryDisplayLines.push({
		label: accessoryLabelWithFinishFromNotes(
			row.id,
			accessoryLabelWithoutEmbeddedPrice(row.label),
			accessoriesBlob
		),
		addPerLocker: Math.round(unit * q * 100) / 100,
	});
}

const displayName = String(order.locker_type || '').trim() || order.title || 'Locker';
const widthRaw = String(order.locker_size || '').trim();
const depthRaw = String(order.locker_width || '').trim();
const colorRaw = String(order.locker_color || '').trim();
const wPart = widthRaw ? `${widthRaw.replace(/"/g, '″')}W` : '';
const dPart = depthRaw ? `${depthRaw.replace(/"/g, '″')}D` : '';
const specLinePlanner =
	[wPart, dPart].filter(Boolean).join(' × ') + (colorRaw ? ` · ${colorRaw}` : '');

const catalogLineTotal = siteListLine?.total ?? null;
const finalTotalUsd = amt ?? catalogLineTotal;
const quoteDiffersFromCatalog =
	amt != null && catalogLineTotal != null && Math.abs(amt - catalogLineTotal) > 0.02;

const nLockCatalog = Math.max(1, Math.floor(Number(order.quantity) || 1));
const lockerCountCatalog = `${nLockCatalog} locker${nLockCatalog !== 1 ? 's' : ''}`;
const nLockFallback = qty != null && qty > 0 ? Math.floor(qty) : 0;
const lockerCountFallback =
	nLockFallback > 0 ? `${nLockFallback} locker${nLockFallback !== 1 ? 's' : ''}` : '';

function fmtUsd(n: number): string {
	return `$${n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
}

const customerNoteTrimmed = String(
	(order as { estimate_customer_note?: string | null }).estimate_customer_note ?? ''
).trim();
