---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSession } from '../../../lib/auth';
import {
	buildAccessoriesFromForm,
	LOCKER_SPEC_ACCESSORY_ROWS,
	parseAccessoriesField,
} from '../../../lib/crm-locker-accessories';
import { computeSiteListForOrderFields, getSitePricingClientPayload } from '../../../lib/crm-site-pricing';
import { supabaseAdmin, STAGE_LABELS, STAGE_COLORS, STAGE_ORDER, type OrderStage } from '../../../lib/supabase';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/admin/login');

const { id } = Astro.params;
let formMessage = '';

// Handle POST actions
if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	const action = form.get('action') as string;

	if (action === 'update_stage') {
		const newStage = form.get('new_stage') as OrderStage;
		const stageNotes = form.get('stage_notes') as string;

		const { data: currentOrder } = await supabaseAdmin.from('orders').select('stage').eq('id', id).single();
		if (currentOrder) {
			await supabaseAdmin.from('orders').update({ stage: newStage }).eq('id', id);
			await supabaseAdmin.from('stage_history').insert({
				order_id: id,
				from_stage: currentOrder.stage,
				to_stage: newStage,
				changed_by: session.user.email,
				notes: stageNotes || null,
			});
			formMessage = `Stage updated to ${STAGE_LABELS[newStage]}`;
		}
	}

	if (action === 'update_order') {
		const estNoteRaw = String(form.get('estimate_customer_note') ?? '').trim();
		const { error } = await supabaseAdmin.from('orders').update({
			title: form.get('title') as string,
			description: (form.get('description') as string) || null,
			estimate_customer_note: estNoteRaw || null,
			estimate_number: (form.get('estimate_number') as string) || null,
			invoice_number: (form.get('invoice_number') as string) || null,
			quoted_amount: form.get('quoted_amount') ? Number(form.get('quoted_amount')) : null,
			locker_type: (form.get('locker_type') as string) || null,
			locker_size: (form.get('locker_size') as string) || null,
			locker_width: (form.get('locker_width') as string) || null,
			locker_color: (form.get('locker_color') as string) || null,
			accessories: buildAccessoriesFromForm(form),
			quantity: form.get('quantity') ? Number(form.get('quantity')) : null,
			assigned_to: (form.get('assigned_to') as string) || null,
			estimated_completion: (form.get('estimated_completion') as string) || null,
			completed_date: (form.get('completed_date') as string) || null,
		}).eq('id', id);
		formMessage = error ? `Error: ${error.message}` : 'Order updated';
	}

	if (action === 'add_note') {
		await supabaseAdmin.from('notes').insert({
			order_id: id,
			client_id: (form.get('client_id') as string) || null,
			content: form.get('content') as string,
			client_visible: form.get('client_visible') === 'on',
			author: session.user.email || 'Admin',
		});
		formMessage = 'Note added';
	}

	if (action === 'upload_document') {
		const file = form.get('file') as File;
		const docType = (form.get('doc_type') as string) || 'invoice';
		if (file && file.size > 0) {
			const ext = file.name.split('.').pop();
			const storagePath = `orders/${id}/${Date.now()}-${file.name}`;
			const { error: uploadError } = await supabaseAdmin.storage
				.from('documents')
				.upload(storagePath, file, { contentType: file.type });
			if (uploadError) {
				formMessage = `Upload error: ${uploadError.message}`;
			} else {
				const { data: orderRow } = await supabaseAdmin.from('orders').select('client_id').eq('id', id).single();
				await supabaseAdmin.from('documents').insert({
					order_id: id,
					client_id: orderRow?.client_id ?? null,
					file_name: file.name,
					file_type: file.type,
					file_size: file.size,
					storage_path: storagePath,
					doc_type: docType,
					uploaded_by: session.user.email || 'Admin',
				});
				formMessage = `"${file.name}" uploaded successfully`;
			}
		}
	}

	if (action === 'delete_document') {
		const docId = form.get('doc_id') as string;
		const { data: doc } = await supabaseAdmin.from('documents').select('storage_path').eq('id', docId).single();
		if (doc) {
			await supabaseAdmin.storage.from('documents').remove([doc.storage_path]);
			await supabaseAdmin.from('documents').delete().eq('id', docId);
			formMessage = 'Document deleted';
		}
	}
}

// Fetch order with client data
const { data: order } = await supabaseAdmin
	.from('orders')
	.select('*, clients(*)')
	.eq('id', id)
	.single();

if (!order) return Astro.redirect('/admin');

const client = order.clients;

// Fetch related data
const [
	{ data: stageHistory },
	{ data: notes },
	{ data: attachments },
	{ data: emailLog },
	{ data: documents },
] = await Promise.all([
	supabaseAdmin.from('stage_history').select('*').eq('order_id', id).order('created_at', { ascending: false }),
	supabaseAdmin.from('notes').select('*').eq('order_id', id).order('created_at', { ascending: false }),
	supabaseAdmin.from('attachments').select('*').eq('order_id', id).order('uploaded_at', { ascending: false }),
	supabaseAdmin.from('email_log').select('*').eq('order_id', id).order('sent_at', { ascending: false }),
	supabaseAdmin.from('documents').select('*').eq('order_id', id).order('created_at', { ascending: false }),
]);

const currentStageIndex = STAGE_ORDER.indexOf(order.stage as OrderStage);

const safeStageHistory = stageHistory ?? [];
const safeDocuments = documents ?? [];

const DOC_TYPE_LABELS: Record<string, string> = {
	invoice: 'Invoice',
	quote: 'Quote',
	design: 'Design / drawing',
	room_plan: 'Room plan',
	layout: 'Locker layout',
	spec_sheet: 'Spec sheet',
	contract: 'Contract',
	photo: 'Photo',
	other: 'Other',
};

const layoutDocTypes = new Set(['layout', 'room_plan', 'design']);
const latestLayoutDoc = [...safeDocuments]
	.filter((d) => layoutDocTypes.has(d.doc_type))
	.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime())[0];

const latestLayoutPublicUrl = latestLayoutDoc
	? supabaseAdmin.storage.from('documents').getPublicUrl(latestLayoutDoc.storage_path).data.publicUrl
	: null;

type MergedT =
	| { kind: 'created'; t: number; title: string }
	| { kind: 'stage'; t: number; entry: (typeof safeStageHistory)[number] }
	| { kind: 'file'; t: number; doc: (typeof safeDocuments)[number] }
	| { kind: 'date'; t: number; label: string; dateStr: string };

const mergedTimeline: MergedT[] = [];
mergedTimeline.push({ kind: 'created', t: new Date(order.created_at).getTime(), title: order.title });
for (const e of safeStageHistory) {
	mergedTimeline.push({ kind: 'stage', t: new Date(e.created_at).getTime(), entry: e });
}
for (const d of safeDocuments) {
	mergedTimeline.push({ kind: 'file', t: new Date(d.created_at).getTime(), doc: d });
}
if (order.estimated_completion) {
	mergedTimeline.push({
		kind: 'date',
		t: new Date(order.estimated_completion + 'T12:00:00').getTime(),
		label: 'Target completion',
		dateStr: order.estimated_completion,
	});
}
if (order.completed_date) {
	mergedTimeline.push({
		kind: 'date',
		t: new Date(order.completed_date + 'T12:00:00').getTime(),
		label: 'Completed (date)',
		dateStr: order.completed_date,
	});
}
mergedTimeline.sort((a, b) => a.t - b.t);

const accParsed = parseAccessoriesField(order.accessories);

const siteListLine = computeSiteListForOrderFields({
	locker_type: order.locker_type,
	locker_size: order.locker_size,
	quantity: order.quantity,
	accessoryQuantities: accParsed.quantities,
});

const sitePricingPayloadJson = JSON.stringify(getSitePricingClientPayload());

const hasSavedQuotedAmount =
	order.quoted_amount != null && !Number.isNaN(Number(order.quoted_amount));

function lockerTypeOptionSelected(stored: string | null | undefined, value: string): boolean {
	const o = String(stored ?? '').trim();
	if (value === 'Pro Locker') return o === 'Pro Locker' || o === 'Pro';
	if (value === 'Stadium Locker') return o === 'Stadium Locker' || o === 'Stadium';
	return o === value;
}

/** Strip trailing " × 60" / " x 60" so the page title stays clean; quantity shows in the header metrics row. */
function orderPageDisplayTitle(raw: string): string {
	const t = raw.trim();
	const m = t.match(/^(.+?)\s+[×x]\s*\d+\s*$/i);
	return m ? m[1].trim() : t;
}

const orderHeaderTitle = orderPageDisplayTitle(order.title);
const qtyDisplay =
	order.quantity != null && !Number.isNaN(Number(order.quantity))
		? Number(order.quantity).toLocaleString()
		: '—';
---

<AdminLayout title={orderHeaderTitle} activeNav="pipeline">
	<Fragment slot="header-sub">
		<div class="order-header-metrics">
			<div class="order-header-metric">
				<span class="order-header-metric-label">Locker type</span>
				<span class="order-header-metric-value">{order.locker_type?.trim() || '—'}</span>
			</div>
			<div class="order-header-metric">
				<span class="order-header-metric-label">Quantity</span>
				<span class="order-header-metric-value">{qtyDisplay}</span>
			</div>
			<div class="order-header-metric">
				<span class="order-header-metric-label">Width</span>
				<span class="order-header-metric-value">{order.locker_size?.trim() || '—'}</span>
			</div>
			<div class="order-header-metric">
				<span class="order-header-metric-label">Depth</span>
				<span class="order-header-metric-value">{order.locker_width?.trim() || '—'}</span>
			</div>
			<div class="order-header-metric">
				<span class="order-header-metric-label">Color</span>
				<span class="order-header-metric-value">{order.locker_color?.trim() || '—'}</span>
			</div>
		</div>
	</Fragment>
	<Fragment slot="header-actions">
		<a href={`/admin/clients/${client.id}`} class="btn btn-secondary btn-sm">View Client</a>
	</Fragment>

	{formMessage && (
		<div class:list={['alert', { 'alert-error': formMessage.startsWith('Error') }]}>
			{formMessage}
		</div>
	)}

	<div class="order-page-content">
	<!-- Stage Progress Bar -->
	<div class="card stage-card">
		<div class="stage-progress">
			{STAGE_ORDER.map((stage, i) => {
				const isActive = stage === order.stage;
				const isPast = i < currentStageIndex;
				const color = STAGE_COLORS[stage];
				return (
					<div class:list={['stage-step', { active: isActive, past: isPast }]}>
						<div class="stage-dot" style={isActive ? `background: ${color}; box-shadow: 0 0 0 4px ${color}33` : isPast ? `background: ${color}` : ''} />
						<span class="stage-name" style={isActive ? `color: ${color}; font-weight: 700` : ''}>{STAGE_LABELS[stage]}</span>
					</div>
				);
			})}
		</div>

		<div class="stage-actions">
			<form method="POST" class="stage-change-form">
				<input type="hidden" name="action" value="update_stage" />
				<select name="new_stage" class="stage-select">
					{STAGE_ORDER.map((stage) => (
						<option value={stage} selected={stage === order.stage}>{STAGE_LABELS[stage]}</option>
					))}
				</select>
				<input type="text" name="stage_notes" placeholder="Note (optional)" class="stage-note-input" />
				<button type="submit" class="btn btn-primary btn-sm">Move Stage</button>
			</form>
		</div>
	</div>

	{latestLayoutDoc && latestLayoutPublicUrl && (
		<div class="card layout-highlight-card">
			<h3>Latest layout / drawing</h3>
			<p class="layout-highlight-hint">Newer uploads of type Layout, Room plan, or Design appear here so the team always has the current drawing.</p>
			<div class="layout-highlight-row">
				<span class="badge layout-badge">{DOC_TYPE_LABELS[latestLayoutDoc.doc_type] || latestLayoutDoc.doc_type}</span>
				<a href={latestLayoutPublicUrl} target="_blank" rel="noopener noreferrer" class="layout-highlight-link">{latestLayoutDoc.file_name}</a>
				<span class="layout-highlight-meta">{new Date(latestLayoutDoc.created_at).toLocaleString()}</span>
			</div>
		</div>
	)}

	<div class="order-layout">
		<!-- Left: Order Details -->
		<div class="order-sidebar">
			<div class="card">
				<h3>Order Details</h3>
				<form method="POST" class="order-details-form">
					<input type="hidden" name="action" value="update_order" />
					<div class="form-group">
						<label>Title</label>
						<input type="text" name="title" value={order.title} required />
					</div>
					<div class="form-group">
						<label>Description</label>
						<textarea name="description" rows="3">{order.description || ''}</textarea>
					</div>
					<div class="form-group order-estimate-customer-note">
						<label for="estimate-customer-note">Note for customer (printed estimate / invoice)</label>
						<textarea
							id="estimate-customer-note"
							name="estimate_customer_note"
							rows="10"
							class="order-estimate-customer-note-input"
							placeholder="Thank you for your inquiry. This estimate includes… Lead time… Anything you want the customer to read on the PDF goes here. Standard legal text still prints at the bottom of the document."
						>{(order as { estimate_customer_note?: string | null }).estimate_customer_note || ''}</textarea>
						<span class="field-hint">
							Prints on the PDF <strong>under</strong> the locker count line (e.g. “60 lockers”), still inside the order
							summary. Leave blank if you do not need a custom message.
						</span>
					</div>
					<div class="form-group">
						<label>Estimate #</label>
						<input type="text" name="estimate_number" value={order.estimate_number || ''} placeholder="e.g. EST-1296" />
					</div>
					<div class="form-group">
						<label>Invoice #</label>
						<input type="text" name="invoice_number" value={order.invoice_number || ''} placeholder="e.g. INV-1088" />
					</div>
					<div class="form-group">
						<label for="order-quoted-amount">Quoted amount (USD)</label>
						<input
							type="number"
							id="order-quoted-amount"
							name="quoted_amount"
							step="0.01"
							min="0"
							placeholder={siteListLine ? `Site list: ${siteListLine.total.toFixed(2)}` : 'Set locker type, width, qty, then use button below'}
							value={
								hasSavedQuotedAmount
									? String(Number(order.quoted_amount))
									: siteListLine
										? String(siteListLine.total)
										: ''
							}
						/>
						{siteListLine && (
							<span class="field-hint order-quoted-hint">
								Site list (saved fields):{' '}
								<strong>${siteListLine.basePerLocker.toFixed(2)}</strong> list per locker
								{siteListLine.accessoriesPerLocker > 0 ? (
									<>
										{' '}
										+ <strong>${siteListLine.accessoriesPerLocker.toFixed(2)}</strong> add-ons per locker
									</>
								) : null}{' '}
								= <strong>${siteListLine.perLocker.toFixed(2)}</strong> per locker ×{' '}
								<strong>{Math.max(1, Math.floor(Number(order.quantity) || 1))}</strong> ={' '}
								<strong>${siteListLine.total.toFixed(2)}</strong> USD project total. The shop price (e.g. $599 for Pro
								24″) is <em>one locker</em>; multiply by quantity for the full order. You can still edit quoted
								amount — use <strong>Use site list price</strong> under Locker specifications after changing specs.
							</span>
						)}
						{!siteListLine && (
							<span class="field-hint order-quoted-hint">
								Choose a catalog locker type and a valid width (18–32″) to auto-fill from the shop price list.
							</span>
						)}
					</div>
					<div class="order-spec-panel">
					<p class="order-spec-section-label">Locker specifications</p>
					<div class="order-spec-fields">
						<div class="form-group">
							<label>Locker type</label>
							<select name="locker_type" id="order-locker-type">
								<option value="">Select...</option>
								<option value="Model L" selected={lockerTypeOptionSelected(order.locker_type, 'Model L')}>Model L</option>
								<option value="Model S" selected={lockerTypeOptionSelected(order.locker_type, 'Model S')}>Model S</option>
								<option value="Model Z" selected={lockerTypeOptionSelected(order.locker_type, 'Model Z')}>Model Z</option>
								<option value="Model X" selected={lockerTypeOptionSelected(order.locker_type, 'Model X')}>Model X</option>
								<option value="Semi Pro" selected={lockerTypeOptionSelected(order.locker_type, 'Semi Pro')}>Semi Pro</option>
								<option value="Varsity" selected={lockerTypeOptionSelected(order.locker_type, 'Varsity')}>Varsity</option>
								<option value="Pro Locker" selected={lockerTypeOptionSelected(order.locker_type, 'Pro Locker')}>Pro Locker</option>
								<option value="Stadium Locker" selected={lockerTypeOptionSelected(order.locker_type, 'Stadium Locker')}>Stadium Locker</option>
								<option value="Custom" selected={lockerTypeOptionSelected(order.locker_type, 'Custom')}>Custom</option>
							</select>
						</div>
						<div class="form-group">
							<label>Quantity</label>
							<input type="number" name="quantity" min="1" placeholder="e.g. 60" value={order.quantity ?? ''} />
							<span class="field-hint">Number of lockers. Site total = (per-locker list + per-locker accessories) × this.</span>
						</div>
						<div class="form-group">
							<label>Width</label>
							<input type="text" name="locker_size" value={order.locker_size || ''} placeholder='e.g. 24"' />
						</div>
						<div class="form-group">
							<label>Depth</label>
							<input type="text" name="locker_width" value={order.locker_width || ''} placeholder='e.g. 19" or 24"' />
						</div>
						<div class="form-group order-spec-full">
							<label>Color</label>
							<input type="text" name="locker_color" value={order.locker_color || ''} placeholder="e.g. Natural Oak, Dark Walnut" />
						</div>
					</div>
					<div class="order-spec-price-actions">
						<button type="button" class="btn btn-secondary btn-sm" id="fill-site-list-price-btn">
							Use site list price
						</button>
						<span class="order-site-list-live-hint field-hint" id="order-site-list-live-hint" />
					</div>
					</div>
					<p class="order-spec-section-label order-spec-section-label--after-panel">Accessories</p>
					<span class="field-hint order-accessories-hint">
						Same line items as locker PDF spec sheets. Prefer <strong>per locker</strong> counts (e.g. 1 name plate each).
						If you enter a <strong>total</strong> that divides evenly by locker quantity (e.g. 60 hooks for 60 lockers), the
						site list treats it as 1 per locker automatically.
					</span>
					<div class="order-accessories-table-wrap">
						<table class="order-accessories-table">
							<thead>
								<tr>
									<th scope="col">Accessory</th>
									<th scope="col" class="order-accessories-th-qty">Qty</th>
								</tr>
							</thead>
							<tbody>
								{LOCKER_SPEC_ACCESSORY_ROWS.map((row) => (
									<tr>
										<td class="order-accessories-td-name">{row.label}</td>
										<td class="order-accessories-td-qty">
											<label class="visually-hidden" for={`acc_qty_${row.id}`}>Quantity — {row.label}</label>
											<input
												type="number"
												id={`acc_qty_${row.id}`}
												name={`acc_qty_${row.id}`}
												class="order-accessory-qty-input"
												min="0"
												step="1"
												placeholder="0"
												value={accParsed.quantities[row.id] > 0 ? accParsed.quantities[row.id] : ''}
											/>
										</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
					<div class="form-group order-spec-full">
						<label>Other accessories / notes</label>
						<textarea name="accessories_notes" rows="2" placeholder="e.g. Corner units (6), black vs silver, extra hook count per locker">{accParsed.notes}</textarea>
					</div>
					<div class="form-group">
						<label>Assigned To</label>
						<input type="text" name="assigned_to" value={order.assigned_to || ''} />
					</div>
					<div class="form-group">
						<label>Est. completion</label>
						<input type="date" name="estimated_completion" value={order.estimated_completion || ''} />
						<span class="field-hint">Shows on the project timeline and helps track production timing.</span>
					</div>
					<div class="form-group">
						<label>Completed date</label>
						<input type="date" name="completed_date" value={order.completed_date || ''} />
					</div>
					<button type="submit" class="btn btn-primary btn-sm order-form-submit">Save Changes</button>
				</form>
			</div>

			<div class="card info-card">
				<h3>Client</h3>
				<div class="info-row">
					<span class="info-label">Name</span>
					<a href={`/admin/clients/${client.id}`}>{client.contact_name}</a>
				</div>
				{client.company_name && (
					<div class="info-row">
						<span class="info-label">Company</span>
						<span>{client.company_name}</span>
					</div>
				)}
				{client.email && (
					<div class="info-row">
						<span class="info-label">Email</span>
						<a href={`mailto:${client.email}`}>{client.email}</a>
					</div>
				)}
				{client.phone && (
					<div class="info-row">
						<span class="info-label">Phone</span>
						<span>{client.phone}</span>
					</div>
				)}
			</div>
		</div>

		<!-- Right: Timeline, Notes, Files -->
		<div class="order-main">
			<!-- Unified project timeline: stages + files + schedule -->
			<div class="card">
				<h3>Project timeline</h3>
				<p class="timeline-intro">Everything in order: pipeline moves, file uploads (layouts, spec sheets, quotes), and target dates.</p>
				{mergedTimeline.length > 0 ? (
					<div class="timeline merged-timeline">
						{mergedTimeline.map((item) => {
							if (item.kind === 'created') {
								return (
									<div class="timeline-item merged-item merged-created">
										<div class="timeline-dot" style="background: #6366f1" />
										<div class="timeline-content">
											<div class="timeline-header"><strong>Order opened</strong></div>
											<p class="timeline-notes">{item.title}</p>
											<span class="timeline-meta">{new Date(item.t).toLocaleString()}</span>
										</div>
									</div>
								);
							}
							if (item.kind === 'stage') {
								const entry = item.entry;
								return (
									<div class="timeline-item merged-item">
										<div class="timeline-dot" style={`background: ${STAGE_COLORS[entry.to_stage as OrderStage]}`} />
										<div class="timeline-content">
											<div class="timeline-header">
												<span class="merged-kind">Stage</span>
												{entry.from_stage ? (
													<span>{STAGE_LABELS[entry.from_stage as OrderStage]} → <strong style={`color: ${STAGE_COLORS[entry.to_stage as OrderStage]}`}>{STAGE_LABELS[entry.to_stage as OrderStage]}</strong></span>
												) : (
													<span>Set to <strong style={`color: ${STAGE_COLORS[entry.to_stage as OrderStage]}`}>{STAGE_LABELS[entry.to_stage as OrderStage]}</strong></span>
												)}
											</div>
											{entry.notes && <p class="timeline-notes">{entry.notes}</p>}
											<span class="timeline-meta">{entry.changed_by || 'System'} · {new Date(entry.created_at).toLocaleString()}</span>
										</div>
									</div>
								);
							}
							if (item.kind === 'file') {
								const doc = item.doc;
								const { data: urlData } = supabaseAdmin.storage.from('documents').getPublicUrl(doc.storage_path);
								const href = urlData?.publicUrl || '#';
								return (
									<div class="timeline-item merged-item merged-file">
										<div class="timeline-dot" style="background: #0d9488" />
										<div class="timeline-content">
											<div class="timeline-header">
												<span class="merged-kind">File</span>
												<span class="badge" style="background: #ecfdf5; color: #0f766e; font-size: 10px">{DOC_TYPE_LABELS[doc.doc_type] || doc.doc_type}</span>
											</div>
											<p class="timeline-notes">
												<a href={href} target="_blank" rel="noopener noreferrer">{doc.file_name}</a>
												{doc.uploaded_by && <span class="file-by"> · {doc.uploaded_by}</span>}
											</p>
											<span class="timeline-meta">{new Date(doc.created_at).toLocaleString()}</span>
										</div>
									</div>
								);
							}
							return (
								<div class="timeline-item merged-item merged-milestone">
									<div class="timeline-dot" style="background: #f59e0b" />
									<div class="timeline-content">
										<div class="timeline-header"><strong>{item.label}</strong></div>
										<p class="timeline-notes">{item.dateStr}</p>
									</div>
								</div>
							);
						})}
					</div>
				) : (
					<p style="color: #9ca3af; font-size: 14px; padding: 12px 0">No activity yet</p>
				)}
			</div>

			<!-- Notes -->
			<div class="card">
				<h3>Notes</h3>
				<form method="POST" class="note-form">
					<input type="hidden" name="action" value="add_note" />
					<input type="hidden" name="client_id" value={client.id} />
					<textarea name="content" rows="2" placeholder="Add a note..." required></textarea>
					<div class="note-form-actions">
						<label class="checkbox-label">
							<input type="checkbox" name="client_visible" />
							<span>Visible to client</span>
						</label>
						<button type="submit" class="btn btn-sm btn-primary">Add Note</button>
					</div>
				</form>
				{notes && notes.length > 0 && (
					<div class="notes-list">
						{notes.map((note: any) => (
							<div class="note-item">
								<div class="note-header">
									<span class="note-author">{note.author}</span>
									{note.client_visible && <span class="badge" style="background: #dbeafe; color: #2563eb; font-size: 10px">Client visible</span>}
									<span class="note-time">{new Date(note.created_at).toLocaleString()}</span>
								</div>
								<p class="note-content">{note.content}</p>
							</div>
						))}
					</div>
				)}
			</div>

			<!-- Attachments -->
			<div class="card">
				<h3>Files & Attachments</h3>
				{attachments && attachments.length > 0 ? (
					<div class="files-list">
						{attachments.map((file: any) => (
							<div class="file-item">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
								<a href={file.file_url} target="_blank" rel="noopener noreferrer">{file.filename}</a>
								<span class="badge" style="background: #f3f4f6; color: #6b7280; font-size: 10px">{file.file_type}</span>
								{file.client_visible && <span class="badge" style="background: #dbeafe; color: #2563eb; font-size: 10px">Client visible</span>}
							</div>
						))}
					</div>
				) : (
					<p style="color: #9ca3af; font-size: 14px; padding: 12px 0">No files attached yet</p>
				)}
			</div>

			<!-- Documents: layouts, specs, quotes, invoices (stored on order — follows project) -->
			<div class="card">
				<h3>Project files</h3>
				<p class="docs-intro">Upload locker layouts, room plans, spec sheets, quotes, and invoices. They stay on this order and appear in the timeline above.</p>
				<form method="POST" enctype="multipart/form-data" class="upload-form">
					<input type="hidden" name="action" value="upload_document" />
					<div class="upload-row">
						<select name="doc_type" class="upload-select">
							<option value="layout">Locker layout (CAD / PDF)</option>
							<option value="room_plan">Room plan</option>
							<option value="design">Design / drawing</option>
							<option value="spec_sheet">Spec sheet</option>
							<option value="quote">Quote</option>
							<option value="invoice">Invoice (e.g. QBO)</option>
							<option value="contract">Contract</option>
							<option value="photo">Photo</option>
							<option value="other">Other</option>
						</select>
						<label class="upload-btn btn btn-sm btn-secondary">
							Choose File
							<input type="file" name="file" accept=".pdf,.png,.jpg,.jpeg,.doc,.docx,.xls,.xlsx,.dwg" style="display:none" onchange="this.closest('.upload-row').querySelector('.upload-filename').textContent = this.files[0]?.name || 'No file chosen'" />
						</label>
						<span class="upload-filename">No file chosen</span>
						<button type="submit" class="btn btn-sm btn-primary">Upload</button>
					</div>
				</form>
				{documents && documents.length > 0 ? (
					<div class="doc-list">
						{documents.map((doc: any) => {
							const { data: urlData } = supabaseAdmin.storage.from('documents').getPublicUrl(doc.storage_path);
							const fileUrl = urlData?.publicUrl || '#';
							const sizeKB = doc.file_size ? `${(doc.file_size / 1024).toFixed(0)} KB` : '';
							return (
								<div class="doc-item">
									<div class="doc-icon">
										{doc.file_type === 'application/pdf' ? (
											<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
										) : (
											<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
										)}
									</div>
									<div class="doc-info">
										<a href={fileUrl} target="_blank" rel="noopener noreferrer" class="doc-name">{doc.file_name}</a>
										<span class="doc-meta">
											<span class="badge" style="background: #f3f4f6; color: #6b7280; font-size: 10px">{DOC_TYPE_LABELS[doc.doc_type] || doc.doc_type}</span>
											{sizeKB && <span>{sizeKB}</span>}
											<span>{new Date(doc.created_at).toLocaleDateString()}</span>
											{doc.uploaded_by && <span>by {doc.uploaded_by}</span>}
										</span>
									</div>
									<form method="POST" style="margin:0">
										<input type="hidden" name="action" value="delete_document" />
										<input type="hidden" name="doc_id" value={doc.id} />
										<button type="submit" class="doc-delete" title="Delete" onclick="return confirm('Delete this document?')">
											<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
										</button>
									</form>
								</div>
							);
						})}
					</div>
				) : (
					<p style="color: #9ca3af; font-size: 14px; padding: 12px 0">No files yet — add layouts, spec sheets, quotes, or invoices.</p>
				)}
			</div>

			<!-- Email History -->
			<div class="card">
				<h3>Email History</h3>
				{emailLog && emailLog.length > 0 ? (
					<div class="email-list">
