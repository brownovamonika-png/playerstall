	<script type="application/json" id="ps-order-site-pricing-json" set:html={sitePricingPayloadJson} />
	<script is:inline>
		document.addEventListener('DOMContentLoaded', function () {
			var jsonEl = document.getElementById('ps-order-site-pricing-json');
			var form = document.querySelector('.order-details-form');
			var quotedInput = document.getElementById('order-quoted-amount');
			var hintEl = document.getElementById('order-site-list-live-hint');
			var fillBtn = document.getElementById('fill-site-list-price-btn');
			if (!jsonEl || !jsonEl.textContent || !form || !quotedInput) return;
			var SITE = JSON.parse(jsonEl.textContent);

			function parseWidth(raw) {
				if (raw == null || String(raw).trim() === '') return null;
				var m = String(raw).trim().match(/^(\d+)/);
				if (!m) return null;
				var w = parseInt(m[1], 10);
				return SITE.widths.indexOf(w) >= 0 ? w : null;
			}

			function computeLive() {
				var modelEl = form.querySelector('[name="locker_type"]');
				var widthEl = form.querySelector('[name="locker_size"]');
				var qtyEl = form.querySelector('[name="quantity"]');
				var model = modelEl && modelEl.value ? modelEl.value : '';
				if (!model || model === 'Custom') return null;
				var w = parseWidth(widthEl && widthEl.value);
				var qty = Math.max(1, parseInt(qtyEl && qtyEl.value ? qtyEl.value : '1', 10) || 1);
				if (w == null) return null;
				var mod = SITE.models.find(function (x) {
					return x.value === model;
				});
				if (!mod || typeof mod.prices[w] !== 'number') return null;
				var base = mod.prices[w];
				var acc = 0;
				function normAccQty(n, lockerCount) {
					var nint = Math.max(0, Math.floor(Number(n)) || 0);
					var L = Math.max(1, lockerCount);
					if (L > 1 && nint >= L && nint % L === 0) return nint / L;
					return nint;
				}
				for (var i = 0; i < SITE.accessoryIds.length; i++) {
					var id = SITE.accessoryIds[i];
					var inp = form.querySelector('[name="acc_qty_' + id + '"]');
					var raw = Math.max(0, parseInt(inp && inp.value ? inp.value : '0', 10) || 0);
					var n = normAccQty(raw, qty);
					if (n > 0) acc += (SITE.accessoryUsd[id] || 0) * n;
				}
				var per = Math.round((base + acc) * 100) / 100;
				var total = Math.round(per * qty * 100) / 100;
				return { per: per, total: total, qty: qty };
			}

			function refreshHint() {
				if (!hintEl) return;
				var out = computeLive();
				if (!out) {
					hintEl.textContent = 'Select a catalog locker type and width (18–32″) to see the site list total.';
					return;
				}
				var modelEl = form.querySelector('[name="locker_type"]');
				var widthEl = form.querySelector('[name="locker_size"]');
				var model = modelEl && modelEl.value ? modelEl.value : '';
				var w = parseWidth(widthEl && widthEl.value);
				var mod = SITE.models.find(function (x) {
					return x.value === model;
				});
				var base = mod && w != null && typeof mod.prices[w] === 'number' ? mod.prices[w] : 0;
				var acc = Math.round((out.per - base) * 100) / 100;
				var accPart = acc > 0 ? ' + $' + acc.toFixed(2) + ' add-ons each' : '';
				hintEl.textContent =
					'Site list: $' +
					base.toFixed(2) +
					' list each' +
					accPart +
					' = $' +
					out.per.toFixed(2) +
					' per locker × ' +
					out.qty +
					' = $' +
					out.total.toFixed(2) +
					' project total (shop shows one-locker list; × qty for full order). Button copies total into Quoted amount.';
			}

			if (fillBtn) {
				fillBtn.addEventListener('click', function () {
					var out = computeLive();
					if (!out) {
						alert('Choose a locker type from the price list and a valid width (e.g. 24") first.');
						return;
					}
					quotedInput.value = String(out.total.toFixed(2));
					quotedInput.dispatchEvent(new Event('input', { bubbles: true }));
				});
			}

			form.addEventListener('change', refreshHint);
			form.addEventListener('input', refreshHint);
			refreshHint();
		});
	</script>

</AdminLayout>

