							<div class="email-item">
								<span class="email-subject">{log.subject}</span>
								<span class="email-meta">{new Date(log.sent_at).toLocaleString()}</span>
								<span class="badge" style={`background: ${log.status === 'sent' ? '#dcfce7' : '#fef9c3'}; color: ${log.status === 'sent' ? '#166534' : '#854d0e'}`}>{log.status}</span>
							</div>
						))}
					</div>
