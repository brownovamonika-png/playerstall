---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import { supabaseAdmin, isSupabaseConfigured, STAGE_LABELS, STAGE_COLORS, STAGE_ORDER, type OrderStage } from '../../lib/supabase';

const demoMode = !isSupabaseConfigured;

if (!demoMode) {
	const session = await getSession(Astro.cookies);
	if (!session) return Astro.redirect('/admin/login');

	if (Astro.request.method === 'POST') {
		const form = await Astro.request.formData();
		const orderId = form.get('order_id') as string;
		const newStage = form.get('new_stage') as OrderStage;

		if (orderId && newStage) {
			const { data: currentOrder } = await supabaseAdmin.from('orders').select('stage').eq('id', orderId).single();
			if (currentOrder && currentOrder.stage !== newStage) {
				await supabaseAdmin.from('orders').update({ stage: newStage }).eq('id', orderId);
				await supabaseAdmin.from('stage_history').insert({
					order_id: orderId,
					from_stage: currentOrder.stage,
					to_stage: newStage,
					changed_by: 'admin',
				});
			}
		}
	}
}

// Group by stage
const ordersByStage: Record<OrderStage, any[]> = {} as any;
for (const stage of STAGE_ORDER) {
	ordersByStage[stage] = [];
}

if (demoMode) {
	const demoOrders = [
		{ id: 'd1', title: 'Football Lockers — 60 units', stage: 'new_lead', clients: { contact_name: 'Mike Johnson', sport: 'Football' }, quoted_amount: 35000, assigned_to: null, updated_at: new Date().toISOString() },
		{ id: 'd2', title: 'Basketball Lockers — 20 units', stage: 'new_lead', clients: { contact_name: 'David Chen', sport: 'Basketball' }, quoted_amount: null, assigned_to: null, updated_at: new Date(Date.now() - 86400000).toISOString() },
		{ id: 'd3', title: 'Lacrosse Lockers — 25 units', stage: 'new_lead', clients: { contact_name: 'James Brown', sport: 'Lacrosse' }, quoted_amount: null, assigned_to: null, updated_at: new Date(Date.now() - 172800000).toISOString() },
		{ id: 'd4', title: 'Custom Lockers — Conference Room', stage: 'consultation', clients: { contact_name: 'Lisa Park', sport: 'Other' }, quoted_amount: null, assigned_to: 'Sales', updated_at: new Date(Date.now() - 259200000).toISOString() },
		{ id: 'd5', title: 'Hockey Lockers — 30 units', stage: 'quote_sent', clients: { contact_name: 'Sarah Williams', sport: 'Hockey' }, quoted_amount: 22500, assigned_to: null, updated_at: new Date(Date.now() - 345600000).toISOString() },
		{ id: 'd6', title: 'Baseball Lockers — 35 units', stage: 'quote_sent', clients: { contact_name: 'Tom Rivera', sport: 'Baseball' }, quoted_amount: 28000, assigned_to: null, updated_at: new Date(Date.now() - 432000000).toISOString() },
		{ id: 'd7', title: 'Stadium Lockers — 80 units', stage: 'quote_approved', clients: { contact_name: 'Andrea Smith', sport: 'Football' }, quoted_amount: 65000, assigned_to: 'Production', updated_at: new Date(Date.now() - 518400000).toISOString() },
		{ id: 'd8', title: 'Soccer Lockers — 40 units', stage: 'design_phase', clients: { contact_name: 'Emily Torres', sport: 'Soccer' }, quoted_amount: 31000, assigned_to: 'Design', updated_at: new Date(Date.now() - 604800000).toISOString() },
		{ id: 'd9', title: 'Pro Lockers — 50 units', stage: 'in_production', clients: { contact_name: 'Robert Kim', sport: 'Hockey' }, quoted_amount: 42000, assigned_to: 'Production', updated_at: new Date(Date.now() - 864000000).toISOString() },
		{ id: 'd10', title: 'Varsity Lockers — 45 units', stage: 'complete', clients: { contact_name: 'Nancy White', sport: 'Basketball' }, quoted_amount: 27500, assigned_to: null, updated_at: new Date(Date.now() - 1728000000).toISOString() },
	];
	for (const order of demoOrders) {
		ordersByStage[order.stage as OrderStage].push(order);
	}
} else {
	const { data: allOrders } = await supabaseAdmin
		.from('orders')
		.select('*, clients(contact_name, company_name, sport)')
		.order('updated_at', { ascending: false });
	if (allOrders) {
		for (const order of allOrders) {
			if (ordersByStage[order.stage as OrderStage]) {
				ordersByStage[order.stage as OrderStage].push(order);
			}
		}
	}
}
---

<AdminLayout title="Pipeline" activeNav="pipeline">
	<div class="pipeline-board" id="pipelineBoard">
		{STAGE_ORDER.map(stage => {
			const orders = ordersByStage[stage];
			const color = STAGE_COLORS[stage];
			return (
				<div class="pipeline-column" data-stage={stage}>
					<div class="column-header">
						<span class="column-dot" style={`background: ${color}`} />
						<span class="column-title">{STAGE_LABELS[stage]}</span>
						<span class="column-count">{orders.length}</span>
					</div>
					<div class="column-cards" data-stage={stage}>
						{orders.map((order: any) => {
							const daysInStage = Math.floor((Date.now() - new Date(order.updated_at).getTime()) / (1000 * 60 * 60 * 24));
							return (
								<div class="pipeline-card" draggable="true" data-order-id={order.id} data-current-stage={order.stage}>
									<a href={`/admin/orders/${order.id}`} class="card-title">{order.title}</a>
									<div class="card-client">{order.clients?.contact_name || 'Unknown'}</div>
									<div class="card-meta">
										{order.clients?.sport && <span class="card-sport">{order.clients.sport}</span>}
										{order.quoted_amount && <span class="card-amount">${Number(order.quoted_amount).toLocaleString()}</span>}
									</div>
									<div class="card-footer">
										<span class="card-days" title="Days in this stage">{daysInStage}d</span>
										{order.assigned_to && <span class="card-assigned">{order.assigned_to}</span>}
									</div>
								</div>
							);
						})}
						{orders.length === 0 && (
							<div class="column-empty">No orders</div>
						)}
					</div>
				</div>
			);
		})}
	</div>
</AdminLayout>

<style>
	.pipeline-board {
		display: flex;
		gap: 16px;
		overflow-x: auto;
		padding-bottom: 16px;
		min-height: calc(100vh - 180px);
	}

	.pipeline-column {
		min-width: 260px;
		max-width: 280px;
		flex-shrink: 0;
		display: flex;
		flex-direction: column;
	}

	.column-header {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 14px 8px;
		margin-bottom: 8px;
		border-bottom: 1px solid #e0e0e0;
	}

	.column-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.column-title {
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 700;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.column-count {
		margin-left: auto;
		background: #f0f0f0;
		color: #666666;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 700;
		padding: 2px 10px;
		border-radius: 10px;
	}

	.column-cards {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 10px;
		padding: 4px;
		min-height: 100px;
		transition: background 0.3s;
	}

	.column-cards.drag-over {
		background: rgba(254, 89, 0, 0.06);
	}

	.pipeline-card {
		background: #ffffff;
		border: none;
		padding: 16px;
		cursor: grab;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
		transition: box-shadow 0.3s, transform 0.3s;
	}

	.pipeline-card:hover {
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
		transform: translateY(-2px);
	}

	.pipeline-card.dragging {
		opacity: 0.5;
		transform: rotate(2deg);
	}

	.card-title {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: #0d0d0d;
		text-decoration: none;
		margin-bottom: 4px;
		line-height: 1.3;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.card-title:hover {
		color: #fe5900;
	}

	.card-client {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		margin-bottom: 8px;
	}

	.card-meta {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		margin-bottom: 8px;
	}

	.card-sport {
		font-family: 'Oswald', sans-serif;
		font-size: 10px;
		font-weight: 600;
		background: #f7f7f7;
		color: #8c8c8c;
		padding: 2px 8px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.card-amount {
		font-family: 'Oswald', sans-serif;
		font-size: 13px;
		font-weight: 700;
		color: #0d0d0d;
	}

	.card-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.card-days {
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		color: #b6b6b6;
	}

	.card-assigned {
		font-family: 'Oswald', sans-serif;
		font-size: 10px;
		font-weight: 600;
		background: #f0f0f0;
		color: #666666;
		padding: 2px 8px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		border-radius: 4px;
	}

	.column-empty {
		text-align: center;
		padding: 30px 8px;
		color: #cccccc;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
</style>

<script define:vars={{ STAGE_ORDER }}>
	const board = document.getElementById('pipelineBoard');
	if (!board) throw new Error('Pipeline board not found');

	let draggedCard = null;

	board.addEventListener('dragstart', (e) => {
		const card = e.target.closest('.pipeline-card');
		if (!card) return;
		draggedCard = card;
		card.classList.add('dragging');
		e.dataTransfer.effectAllowed = 'move';
		e.dataTransfer.setData('text/plain', card.dataset.orderId);
	});

	board.addEventListener('dragend', (e) => {
		const card = e.target.closest('.pipeline-card');
		if (card) card.classList.remove('dragging');
		document.querySelectorAll('.column-cards').forEach(col => col.classList.remove('drag-over'));
		draggedCard = null;
	});

	board.addEventListener('dragover', (e) => {
		e.preventDefault();
		const column = e.target.closest('.column-cards');
		if (column) {
			document.querySelectorAll('.column-cards').forEach(col => col.classList.remove('drag-over'));
			column.classList.add('drag-over');
		}
	});

	board.addEventListener('drop', async (e) => {
		e.preventDefault();
		const column = e.target.closest('.column-cards');
		if (!column || !draggedCard) return;

		column.classList.remove('drag-over');

		const orderId = draggedCard.dataset.orderId;
		const newStage = column.dataset.stage;
		const currentStage = draggedCard.dataset.currentStage;

		if (newStage === currentStage) return;

		column.appendChild(draggedCard);
		draggedCard.dataset.currentStage = newStage;

		// Update column counts
		document.querySelectorAll('.pipeline-column').forEach(col => {
			const cards = col.querySelector('.column-cards');
			const count = col.querySelector('.column-count');
			if (cards && count) {
				count.textContent = cards.querySelectorAll('.pipeline-card').length;
			}
		});

		// POST the stage change to the server
		const formData = new FormData();
		formData.append('order_id', orderId);
		formData.append('new_stage', newStage);

		try {
			await fetch('/admin/pipeline', {
				method: 'POST',
				body: formData,
			});
		} catch (err) {
			console.error('Failed to update stage:', err);
		}
	});
</script>
