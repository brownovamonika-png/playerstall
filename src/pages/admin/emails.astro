---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import {
	supabaseAdmin,
	isSupabaseConfigured,
	STAGE_LABELS,
	EMAIL_SENDER_COMPANY_LABELS,
	normalizeEmailSenderCompany,
	getCrmMailerFromEmail,
	type OrderStage,
} from '../../lib/supabase';

const demoMode = !isSupabaseConfigured;

if (!demoMode) {
	const session = await getSession(Astro.cookies);
	if (!session) return Astro.redirect('/admin/login');
}

let formMessage = '';
let templates: any[] = [];

if (demoMode) {
	const fundraisingRoomPlannerBody =
		'<p>Hi {{first_name}},</p><p>Thank you for sharing that <strong>{{company_name}}</strong> is working on fundraising for your {{sport}} locker project. We saw that in your room planner notes — and we want you to know we\'re rooting for you. A great locker room is absolutely worth the effort, and many schools and programs have successfully closed the gap with a mix of the ideas below.</p><p><strong>Ideas that work well in the U.S.</strong></p><ul><li><strong>Athletic booster club</strong> — dedicated campaigns, annual drives, or a line item for facility improvements</li><li><strong>Corporate &amp; local sponsors</strong> — naming rights on locker plaques, donor walls, or end panels (check district/athletic association rules)</li><li><strong>Alumni &amp; community giving</strong> — targeted appeals, giving days, or small-donor crowdfunding</li><li><strong>Events</strong> — tournaments, silent auctions, golf outings, or spirit-wear sales with proceeds earmarked for the locker room</li><li><strong>Grants &amp; foundations</strong> — school foundations, education funds, and regional grants for athletics or facilities (requirements vary by state and district)</li></ul><p><strong>Ideas that work well in Canada</strong></p><ul><li><strong>Parent councils &amp; athletic associations</strong> — formal proposals for capital or equipment budgets</li><li><strong>Municipal &amp; provincial programs</strong> — recreation, facility, or healthy communities grants (eligibility varies by province)</li><li><strong>Community partners</strong> — local businesses, service clubs, and alumni networks</li><li><strong>Kids\' sport &amp; access programs</strong> — programs such as Jumpstart (Canadian Tire) and similar regional initiatives where your project qualifies</li><li><strong>Fundraising events</strong> — same spirit as in the U.S.: tournaments, auctions, and team-led campaigns</li></ul><p>We\'re happy to provide <strong>renderings, a simple one-pager, or a ballpark summary</strong> you can attach to grant or donor packets — reply and tell us what would help your committee.</p><p>You can always review your project and documents here:</p><p><a href="{{portal_link}}" style="display:inline-block;padding:14px 36px;background:#fe5900;color:#ffffff;text-decoration:none;font-weight:600;border-radius:6px;text-transform:uppercase;">View Your Project</a></p><p>If you\'d like to brainstorm what has worked for other {{sport}} programs, call us at <strong>1 888 584 1444</strong> or reply to this email. We\'re here to help you get across the finish line.</p><p>Best,<br>The PlayerStall Team</p>';

	templates = [
		{ id: 'd1', name: 'Inquiry Acknowledgment', subject: 'Thanks for reaching out, {{first_name}}! | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Thank you for your interest in PlayerStall!</p>', stage_trigger: 'new_lead', delay_hours: 0, enabled: true, company: 'playerstall' },
		{ id: 'd2', name: 'Consultation Follow-Up', subject: 'Great talking with you, {{first_name}} | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Thank you for taking the time to speak with us...</p>', stage_trigger: 'consultation', delay_hours: 1, enabled: true, company: 'playerstall' },
		{ id: 'd3', name: 'Quote Delivery', subject: 'Your custom locker quote is ready, {{first_name}} | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Great news — your custom quote is ready!</p>', stage_trigger: 'quote_sent', delay_hours: 0, enabled: true, company: 'playerstall' },
		{ id: 'd4', name: 'Order Confirmation', subject: 'Welcome aboard, {{first_name}}! | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Your project is officially underway!</p>', stage_trigger: 'quote_approved', delay_hours: 2, enabled: true, company: 'playerstall' },
		{ id: 'd5', name: 'Design Phase Update', subject: 'Your locker design is in progress | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Our design team has started working...</p>', stage_trigger: 'design_phase', delay_hours: 1, enabled: true, company: 'playerstall' },
		{ id: 'd6', name: 'Production Update', subject: 'Your lockers are being built! | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Exciting news — your lockers are now in production!</p>', stage_trigger: 'in_production', delay_hours: 2, enabled: true, company: 'playerstall' },
		{ id: 'd7', name: 'Shipping Notification', subject: 'Your lockers are on their way! | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Your custom lockers have shipped!</p>', stage_trigger: 'shipped', delay_hours: 0, enabled: true, company: 'playerstall' },
		{ id: 'd8', name: 'Installation Complete', subject: 'Your new lockers are installed! | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Your new lockers are installed and ready!</p>', stage_trigger: 'installed', delay_hours: 1, enabled: true, company: 'playerstall' },
		{ id: 'd9', name: 'Gentle Quote Follow-Up', subject: 'Checking in on your locker quote | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Just wanted to check in on the quote we sent...</p>', stage_trigger: null, delay_hours: 0, enabled: true, company: 'playerstall' },
		{ id: 'd10', name: '30-Day Check-In', subject: 'How are the new lockers? | PlayerStall', body: '<p>Hi {{first_name}},</p><p>It has been about a month since installation...</p>', stage_trigger: null, delay_hours: 0, enabled: true, company: 'playerstall' },
		{ id: 'd11', name: 'Annual Warranty Reminder', subject: 'Your PlayerStall warranty check-in | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Just a friendly reminder about your 5-year guarantee...</p>', stage_trigger: null, delay_hours: 0, enabled: false, company: 'playerstall' },
		{ id: 'd12', name: 'Fundraising & Funding Ideas (Room Planner)', subject: 'Ideas to help fund your locker project, {{first_name}} | PlayerStall', body: fundraisingRoomPlannerBody, stage_trigger: null, delay_hours: 0, enabled: true, company: 'playerstall' },
		{ id: 'c1', name: 'Inquiry Acknowledgment (CSL demo)', subject: 'Thanks, {{first_name}}! | Custom Sport Lockers', body: '<p>Hi {{first_name}},</p><p>Thank you for contacting Custom Sport Lockers.</p>', stage_trigger: null, delay_hours: 0, enabled: false, company: 'custom_sport_lockers' },
	];
} else {
	if (Astro.request.method === 'POST') {
		const form = await Astro.request.formData();
		const action = form.get('action') as string;

		if (action === 'update_template') {
			const templateId = form.get('template_id') as string;
			const company = normalizeEmailSenderCompany(form.get('company') as string);
			const { error } = await supabaseAdmin.from('email_templates').update({
				name: form.get('name') as string,
				subject: form.get('subject') as string,
				body: form.get('body') as string,
				stage_trigger: (form.get('stage_trigger') as string) || null,
				delay_hours: Number(form.get('delay_hours') || 0),
				enabled: form.get('enabled') === 'on',
				company,
			}).eq('id', templateId);
			formMessage = error ? `Error: ${error.message}` : 'Template updated';
		}

		if (action === 'create_template') {
			const company = normalizeEmailSenderCompany(form.get('company') as string);
			const { error } = await supabaseAdmin.from('email_templates').insert({
				name: form.get('name') as string,
				subject: form.get('subject') as string,
				body: form.get('body') as string || '<p>Email body here...</p>',
				stage_trigger: (form.get('stage_trigger') as string) || null,
				delay_hours: Number(form.get('delay_hours') || 0),
				enabled: true,
				company,
			});
			formMessage = error ? `Error: ${error.message}` : 'Template created';
		}

		if (action === 'toggle_template') {
			const templateId = form.get('template_id') as string;
			const enabled = form.get('current_enabled') === 'true';
			await supabaseAdmin.from('email_templates').update({ enabled: !enabled }).eq('id', templateId);
			formMessage = `Template ${enabled ? 'disabled' : 'enabled'}`;
		}
	}

	const { data } = await supabaseAdmin
		.from('email_templates')
		.select('*')
		.order('company', { ascending: true })
		.order('created_at', { ascending: true });
	templates = (data || []).map((row: Record<string, unknown>) => ({
		...row,
		company: normalizeEmailSenderCompany(typeof row.company === 'string' ? row.company : undefined),
	}));
}

const mergeVars = [
	{ var: '{{first_name}}', desc: 'Client first name' },
	{ var: '{{client_name}}', desc: 'Client full name' },
	{ var: '{{company_name}}', desc: 'Company/team name' },
	{ var: '{{sport}}', desc: 'Sport type' },
	{ var: '{{order_title}}', desc: 'Order title' },
	{ var: '{{quoted_amount}}', desc: 'Quote amount' },
	{ var: '{{estimated_date}}', desc: 'Estimated completion' },
	{ var: '{{portal_link}}', desc: 'Client portal URL' },
	{ var: '{{consultation_notes}}', desc: 'Consultation notes' },
];
---

<AdminLayout title="Email Templates" activeNav="emails">
	<Fragment slot="header-actions">
		<button class="btn btn-primary" onclick="document.getElementById('newTemplateModal').showModal()">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
			New Template
		</button>
	</Fragment>

	{formMessage && (
		<div class:list={['alert', { 'alert-error': formMessage.startsWith('Error') }]}>
			{formMessage}
		</div>
	)}

	<details class="writing-tips">
		<summary class="writing-tips-summary">Writing templates — sound human, warm &amp; professional</summary>
		<div class="writing-tips-body">
			<p class="writing-tips-intro">
				Paste or type directly in the <strong>Subject</strong> and <strong>Email Body (HTML)</strong> fields below. Aim for how your best rep would actually write—upbeat and kind, not “marketing AI.”
			</p>
			<ul class="writing-tips-list">
				<li><strong>Start with the person.</strong> Use <code>{'{{first_name}}'}</code> in the first line when it fits. One short thank-you or welcome beats a long preamble.</li>
				<li><strong>Short paragraphs.</strong> 2–4 sentences per <code>&lt;p&gt;</code>. Busy coaches skim; white space helps.</li>
				<li><strong>One clear next step.</strong> e.g. “Reply with a good time to call” or a single button link (<code>{'{{portal_link}}'}</code>). Avoid three competing links.</li>
				<li><strong>Specific beats vague.</strong> Mention lockers, their sport, or timeline when you can—templated mail still feels personal when details come from merge tags.</li>
				<li><strong>Professional close.</strong> Sign as a real team (“The PlayerStall Team” / your name). Include phone: <strong>1 888 584 1444</strong> where it helps.</li>
			</ul>
			<p class="writing-tips-avoid"><strong>Often reads like AI—cut or rewrite:</strong> “I hope this email finds you well,” “We’re excited to…”, “leverage / delve / robust / streamline,” triple em dashes, bullet lists of generic platitudes, “Don’t hesitate to reach out” (prefer “Just reply to this email—we’re here.”).</p>
			<p class="writing-tips-avoid"><strong>Quick check:</strong> Read it aloud. If you wouldn’t say it on a phone call, soften or shorten it.</p>
		</div>
	</details>

	<div class="templates-layout">
		<div class="templates-list">
			{templates && templates.map((template: any) => (
				<details class="template-card" id={`template-${template.id}`}>
					<summary class="template-summary">
						<div class="template-info">
							<span class:list={['template-status', { enabled: template.enabled, disabled: !template.enabled }]} />
							<div>
								<span class="template-name">{template.name}</span>
								<span class="template-subject">{template.subject}</span>
							</div>
						</div>
						<div class="template-tags">
							<span
								class:list={[
									'badge',
									'company-badge',
									{ 'company-badge--csl': normalizeEmailSenderCompany(template.company) === 'custom_sport_lockers' },
								]}
							>
								{EMAIL_SENDER_COMPANY_LABELS[normalizeEmailSenderCompany(template.company)]}
							</span>
							{template.stage_trigger && (
								<span class="badge" style="background: #f3f4f6; color: #6b7280">
									Trigger: {STAGE_LABELS[template.stage_trigger as OrderStage]}
								</span>
							)}
							{template.delay_hours > 0 && (
								<span class="badge" style="background: #fef3c7; color: #854d0e">
									{template.delay_hours}h delay
								</span>
							)}
						</div>
					</summary>
					<div class="template-editor">
						<form method="POST">
							<input type="hidden" name="action" value="update_template" />
							<input type="hidden" name="template_id" value={template.id} />
							<div class="form-row">
								<div class="form-group">
									<label>Template Name</label>
									<input type="text" name="name" value={template.name} required />
								</div>
								<div class="form-group">
									<label>Send as</label>
									<select name="company">
										{Object.entries(EMAIL_SENDER_COMPANY_LABELS).map(([value, label]) => (
											<option
												value={value}
												selected={normalizeEmailSenderCompany(template.company) === value}
											>
												{label}
											</option>
										))}
									</select>
								</div>
							</div>
							<div class="form-row">
								<div class="form-group">
									<label>Subject Line</label>
									<input type="text" name="subject" value={template.subject} required />
								</div>
								<div class="form-group">
									<label>Delay (hours)</label>
									<input type="number" name="delay_hours" min="0" value={template.delay_hours} />
								</div>
							</div>
							<div class="form-group">
								<label>Stage Trigger</label>
								<select name="stage_trigger">
									<option value="">None (manual only)</option>
									{Object.entries(STAGE_LABELS).map(([stage, label]) => (
										<option value={stage} selected={template.stage_trigger === stage}>{label}</option>
									))}
								</select>
							</div>
							<div class="form-group">
								<label>Email Body (HTML)</label>
								<textarea name="body" rows="12" class="code-textarea">{template.body}</textarea>
							</div>
							<div class="template-actions">
								<label class="checkbox-label">
									<input type="checkbox" name="enabled" checked={template.enabled} />
									<span>Enabled</span>
								</label>
								<div style="display: flex; gap: 8px;">
									<button type="submit" class="btn btn-primary btn-sm">Save Template</button>
								</div>
							</div>
						</form>
						<form method="POST" style="margin-top: 8px;">
							<input type="hidden" name="action" value="toggle_template" />
							<input type="hidden" name="template_id" value={template.id} />
							<input type="hidden" name="current_enabled" value={String(template.enabled)} />
							<button type="submit" class="btn btn-sm btn-secondary" style="width: 100%">
								{template.enabled ? 'Disable Template' : 'Enable Template'}
							</button>
						</form>
					</div>
				</details>
			))}
		</div>

		<div class="merge-vars-panel">
			<div class="card">
				<h3>Merge Variables</h3>
				<p class="merge-desc from-line">
					<strong>From address</strong> follows &ldquo;Send as&rdquo;: PlayerStall uses{' '}
					<code>{getCrmMailerFromEmail('playerstall')}</code>
					{' '}· Custom Sport Lockers uses <code>{getCrmMailerFromEmail('custom_sport_lockers')}</code>
					(configure in <code>.env</code>; domain must be verified in MailerSend).
				</p>
				<p class="merge-desc">Use these in subject lines and email body:</p>
				<div class="vars-list">
					{mergeVars.map(v => (
						<div class="var-item">
							<code class="var-code">{v.var}</code>
							<span class="var-desc">{v.desc}</span>
						</div>
					))}
				</div>
			</div>
		</div>
	</div>

	<!-- New Template Modal -->
	<dialog id="newTemplateModal" class="modal">
		<div class="modal-content">
			<div class="modal-header">
				<h2>New Email Template</h2>
				<button type="button" class="modal-close" onclick="document.getElementById('newTemplateModal').close()">&times;</button>
			</div>
			<form method="POST">
				<input type="hidden" name="action" value="create_template" />
				<div class="form-group">
					<label>Template Name *</label>
					<input type="text" name="name" required placeholder="e.g. Follow-Up Reminder" />
				</div>
				<div class="form-group">
					<label>Subject Line *</label>
					<input type="text" name="subject" required placeholder="e.g. Checking in, {{first_name}} | PlayerStall" />
				</div>
				<div class="form-group">
					<label>Send as *</label>
					<select name="company">
						{Object.entries(EMAIL_SENDER_COMPANY_LABELS).map(([value, label]) => (
							<option value={value}>{label}</option>
						))}
					</select>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label>Stage Trigger</label>
						<select name="stage_trigger">
							<option value="">None (manual only)</option>
							{Object.entries(STAGE_LABELS).map(([stage, label]) => (
								<option value={stage}>{label}</option>
							))}
						</select>
					</div>
					<div class="form-group">
						<label>Delay (hours)</label>
						<input type="number" name="delay_hours" min="0" value="0" />
					</div>
				</div>
				<div class="form-group">
					<label>Email Body (HTML)</label>
					<textarea name="body" rows="6" placeholder="<p>Hi {{first_name}},</p><p>Your email content here...</p>"></textarea>
				</div>
				<div class="modal-actions">
					<button type="button" class="btn btn-secondary" onclick="document.getElementById('newTemplateModal').close()">Cancel</button>
					<button type="submit" class="btn btn-primary">Create Template</button>
				</div>
			</form>
		</div>
	</dialog>
</AdminLayout>

<style>
	.writing-tips {
		background: #fffbeb;
		border: 1px solid #fde68a;
		border-radius: 8px;
		margin-bottom: 24px;
		overflow: hidden;
	}

	.writing-tips-summary {
		padding: 14px 18px;
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: #78350f;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		cursor: pointer;
		list-style: none;
	}

	.writing-tips-summary::-webkit-details-marker {
		display: none;
	}

	.writing-tips-summary::after {
		content: ' +';
		font-weight: 700;
		opacity: 0.6;
	}

	.writing-tips[open] .writing-tips-summary::after {
		content: ' −';
	}

	.writing-tips-body {
		padding: 0 18px 16px;
		border-top: 1px solid #fde68a;
	}

	.writing-tips-intro {
		font-size: 14px;
		color: #44403c;
		line-height: 1.55;
		margin: 14px 0 12px;
	}

	.writing-tips-list {
		margin: 0 0 14px;
		padding-left: 1.25rem;
		font-size: 13px;
		color: #44403c;
		line-height: 1.6;
	}

	.writing-tips-list li {
		margin-bottom: 8px;
	}

	.writing-tips-list code {
		font-size: 12px;
		background: rgba(255, 255, 255, 0.8);
		padding: 1px 5px;
		border-radius: 4px;
	}

	.writing-tips-avoid {
		font-size: 12px;
		color: #57534e;
		line-height: 1.55;
		margin: 0 0 10px;
	}

	.templates-layout {
		display: grid;
		grid-template-columns: 1fr 280px;
		gap: 24px;
		align-items: start;
	}

	.templates-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.template-card {
		background: #ffffff;
		border: none;
		overflow: hidden;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
		transition: box-shadow 0.3s;
	}

	.template-card[open] {
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
	}

	.template-summary {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 18px 24px;
		cursor: pointer;
		list-style: none;
	}

	.template-summary::-webkit-details-marker {
		display: none;
	}

	.template-info {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.template-status {
		width: 8px;
		height: 8px;
		flex-shrink: 0;
	}

	.template-status.enabled {
		background: #22c55e;
	}

	.template-status.disabled {
		background: #d0d0d0;
	}

	.template-name {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 15px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.template-subject {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		margin-top: 2px;
	}

	.template-tags {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.company-badge {
		background: #fff7ed;
		color: #9a3412;
	}

	.company-badge--csl {
		background: #ede9fe;
		color: #5b21b6;
	}

	.from-line code {
		font-size: 11px;
		word-break: break-all;
	}

	.template-editor {
		padding: 24px;
		border-top: 1px solid #e0e0e0;
		background: #fafafa;
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}

	.code-textarea {
		font-family: 'Courier New', monospace;
		font-size: 13px;
		line-height: 1.5;
	}

	.template-actions {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: 16px;
		padding-top: 16px;
		border-top: 1px solid #e0e0e0;
	}

	.checkbox-label {
		display: flex;
		align-items: center;
		gap: 6px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		cursor: pointer;
	}

	.merge-vars-panel h3 {
		font-family: 'Oswald', sans-serif;
		font-size: 16px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 10px;
	}

	.merge-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		margin-bottom: 12px;
	}

	.vars-list {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.var-item {
		display: flex;
		flex-direction: column;
