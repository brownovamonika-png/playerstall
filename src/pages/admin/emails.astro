---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import { supabaseAdmin, isSupabaseConfigured, STAGE_LABELS, type OrderStage } from '../../lib/supabase';

const demoMode = !isSupabaseConfigured;

if (!demoMode) {
	const session = await getSession(Astro.cookies);
	if (!session) return Astro.redirect('/admin/login');
}

let formMessage = '';
let templates: any[] = [];

if (demoMode) {
	templates = [
		{ id: 'd1', name: 'Inquiry Acknowledgment', subject: 'Thanks for reaching out, {{first_name}}! | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Thank you for your interest in PlayerStall!</p>', stage_trigger: 'new_lead', delay_hours: 0, enabled: true },
		{ id: 'd2', name: 'Consultation Follow-Up', subject: 'Great talking with you, {{first_name}} | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Thank you for taking the time to speak with us...</p>', stage_trigger: 'consultation', delay_hours: 1, enabled: true },
		{ id: 'd3', name: 'Quote Delivery', subject: 'Your custom locker quote is ready, {{first_name}} | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Great news — your custom quote is ready!</p>', stage_trigger: 'quote_sent', delay_hours: 0, enabled: true },
		{ id: 'd4', name: 'Order Confirmation', subject: 'Welcome aboard, {{first_name}}! | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Your project is officially underway!</p>', stage_trigger: 'quote_approved', delay_hours: 2, enabled: true },
		{ id: 'd5', name: 'Design Phase Update', subject: 'Your locker design is in progress | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Our design team has started working...</p>', stage_trigger: 'design_phase', delay_hours: 1, enabled: true },
		{ id: 'd6', name: 'Production Update', subject: 'Your lockers are being built! | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Exciting news — your lockers are now in production!</p>', stage_trigger: 'in_production', delay_hours: 2, enabled: true },
		{ id: 'd7', name: 'Shipping Notification', subject: 'Your lockers are on their way! | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Your custom lockers have shipped!</p>', stage_trigger: 'shipped', delay_hours: 0, enabled: true },
		{ id: 'd8', name: 'Installation Complete', subject: 'Your new lockers are installed! | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Your new lockers are installed and ready!</p>', stage_trigger: 'installed', delay_hours: 1, enabled: true },
		{ id: 'd9', name: 'Gentle Quote Follow-Up', subject: 'Checking in on your locker quote | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Just wanted to check in on the quote we sent...</p>', stage_trigger: null, delay_hours: 0, enabled: true },
		{ id: 'd10', name: '30-Day Check-In', subject: 'How are the new lockers? | PlayerStall', body: '<p>Hi {{first_name}},</p><p>It has been about a month since installation...</p>', stage_trigger: null, delay_hours: 0, enabled: true },
		{ id: 'd11', name: 'Annual Warranty Reminder', subject: 'Your PlayerStall warranty check-in | PlayerStall', body: '<p>Hi {{first_name}},</p><p>Just a friendly reminder about your 5-year guarantee...</p>', stage_trigger: null, delay_hours: 0, enabled: false },
	];
} else {
	if (Astro.request.method === 'POST') {
		const form = await Astro.request.formData();
		const action = form.get('action') as string;

		if (action === 'update_template') {
			const templateId = form.get('template_id') as string;
			const { error } = await supabaseAdmin.from('email_templates').update({
				name: form.get('name') as string,
				subject: form.get('subject') as string,
				body: form.get('body') as string,
				stage_trigger: (form.get('stage_trigger') as string) || null,
				delay_hours: Number(form.get('delay_hours') || 0),
				enabled: form.get('enabled') === 'on',
			}).eq('id', templateId);
			formMessage = error ? `Error: ${error.message}` : 'Template updated';
		}

		if (action === 'create_template') {
			const { error } = await supabaseAdmin.from('email_templates').insert({
				name: form.get('name') as string,
				subject: form.get('subject') as string,
				body: form.get('body') as string || '<p>Email body here...</p>',
				stage_trigger: (form.get('stage_trigger') as string) || null,
				delay_hours: Number(form.get('delay_hours') || 0),
				enabled: true,
			});
			formMessage = error ? `Error: ${error.message}` : 'Template created';
		}

		if (action === 'toggle_template') {
			const templateId = form.get('template_id') as string;
			const enabled = form.get('current_enabled') === 'true';
			await supabaseAdmin.from('email_templates').update({ enabled: !enabled }).eq('id', templateId);
			formMessage = `Template ${enabled ? 'disabled' : 'enabled'}`;
		}
	}

	const { data } = await supabaseAdmin
		.from('email_templates')
		.select('*')
		.order('created_at', { ascending: true });
	templates = data || [];
}

const mergeVars = [
	{ var: '{{first_name}}', desc: 'Client first name' },
	{ var: '{{client_name}}', desc: 'Client full name' },
	{ var: '{{company_name}}', desc: 'Company/team name' },
	{ var: '{{sport}}', desc: 'Sport type' },
	{ var: '{{order_title}}', desc: 'Order title' },
	{ var: '{{quoted_amount}}', desc: 'Quote amount' },
	{ var: '{{estimated_date}}', desc: 'Estimated completion' },
	{ var: '{{portal_link}}', desc: 'Client portal URL' },
	{ var: '{{consultation_notes}}', desc: 'Consultation notes' },
];
---

<AdminLayout title="Email Templates" activeNav="emails">
	<Fragment slot="header-actions">
		<button class="btn btn-primary" onclick="document.getElementById('newTemplateModal').showModal()">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
			New Template
		</button>
	</Fragment>

	{formMessage && (
		<div class:list={['alert', { 'alert-error': formMessage.startsWith('Error') }]}>
			{formMessage}
		</div>
	)}

	<div class="templates-layout">
		<div class="templates-list">
			{templates && templates.map((template: any) => (
				<details class="template-card" id={`template-${template.id}`}>
					<summary class="template-summary">
						<div class="template-info">
							<span class:list={['template-status', { enabled: template.enabled, disabled: !template.enabled }]} />
							<div>
								<span class="template-name">{template.name}</span>
								<span class="template-subject">{template.subject}</span>
							</div>
						</div>
						<div class="template-tags">
							{template.stage_trigger && (
								<span class="badge" style="background: #f3f4f6; color: #6b7280">
									Trigger: {STAGE_LABELS[template.stage_trigger as OrderStage]}
								</span>
							)}
							{template.delay_hours > 0 && (
								<span class="badge" style="background: #fef3c7; color: #854d0e">
									{template.delay_hours}h delay
								</span>
							)}
						</div>
					</summary>
					<div class="template-editor">
						<form method="POST">
							<input type="hidden" name="action" value="update_template" />
							<input type="hidden" name="template_id" value={template.id} />
							<div class="form-row">
								<div class="form-group">
									<label>Template Name</label>
									<input type="text" name="name" value={template.name} required />
								</div>
								<div class="form-group">
									<label>Stage Trigger</label>
									<select name="stage_trigger">
										<option value="">None (manual only)</option>
										{Object.entries(STAGE_LABELS).map(([stage, label]) => (
											<option value={stage} selected={template.stage_trigger === stage}>{label}</option>
										))}
									</select>
								</div>
							</div>
							<div class="form-row">
								<div class="form-group">
									<label>Subject Line</label>
									<input type="text" name="subject" value={template.subject} required />
								</div>
								<div class="form-group">
									<label>Delay (hours)</label>
									<input type="number" name="delay_hours" min="0" value={template.delay_hours} />
								</div>
							</div>
							<div class="form-group">
								<label>Email Body (HTML)</label>
								<textarea name="body" rows="12" class="code-textarea">{template.body}</textarea>
							</div>
							<div class="template-actions">
								<label class="checkbox-label">
									<input type="checkbox" name="enabled" checked={template.enabled} />
									<span>Enabled</span>
								</label>
								<div style="display: flex; gap: 8px;">
									<button type="submit" class="btn btn-primary btn-sm">Save Template</button>
								</div>
							</div>
						</form>
						<form method="POST" style="margin-top: 8px;">
							<input type="hidden" name="action" value="toggle_template" />
							<input type="hidden" name="template_id" value={template.id} />
							<input type="hidden" name="current_enabled" value={String(template.enabled)} />
							<button type="submit" class="btn btn-sm btn-secondary" style="width: 100%">
								{template.enabled ? 'Disable Template' : 'Enable Template'}
							</button>
						</form>
					</div>
				</details>
			))}
		</div>

		<div class="merge-vars-panel">
			<div class="card">
				<h3>Merge Variables</h3>
				<p class="merge-desc">Use these in subject lines and email body:</p>
				<div class="vars-list">
					{mergeVars.map(v => (
						<div class="var-item">
							<code class="var-code">{v.var}</code>
							<span class="var-desc">{v.desc}</span>
						</div>
					))}
				</div>
			</div>
		</div>
	</div>

	<!-- New Template Modal -->
	<dialog id="newTemplateModal" class="modal">
		<div class="modal-content">
			<div class="modal-header">
				<h2>New Email Template</h2>
				<button type="button" class="modal-close" onclick="document.getElementById('newTemplateModal').close()">&times;</button>
			</div>
			<form method="POST">
				<input type="hidden" name="action" value="create_template" />
				<div class="form-group">
					<label>Template Name *</label>
					<input type="text" name="name" required placeholder="e.g. Follow-Up Reminder" />
				</div>
				<div class="form-group">
					<label>Subject Line *</label>
					<input type="text" name="subject" required placeholder="e.g. Checking in, {{first_name}} | PlayerStall" />
				</div>
				<div class="form-row">
					<div class="form-group">
						<label>Stage Trigger</label>
						<select name="stage_trigger">
							<option value="">None (manual only)</option>
							{Object.entries(STAGE_LABELS).map(([stage, label]) => (
								<option value={stage}>{label}</option>
							))}
						</select>
					</div>
					<div class="form-group">
						<label>Delay (hours)</label>
						<input type="number" name="delay_hours" min="0" value="0" />
					</div>
				</div>
				<div class="form-group">
					<label>Email Body (HTML)</label>
					<textarea name="body" rows="6" placeholder="<p>Hi {{first_name}},</p><p>Your email content here...</p>"></textarea>
				</div>
				<div class="modal-actions">
					<button type="button" class="btn btn-secondary" onclick="document.getElementById('newTemplateModal').close()">Cancel</button>
					<button type="submit" class="btn btn-primary">Create Template</button>
				</div>
			</form>
		</div>
	</dialog>
</AdminLayout>

<style>
	.templates-layout {
		display: grid;
		grid-template-columns: 1fr 280px;
		gap: 24px;
		align-items: start;
	}

	.templates-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.template-card {
		background: #ffffff;
		border: none;
		overflow: hidden;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
		transition: box-shadow 0.3s;
	}

	.template-card[open] {
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
	}

	.template-summary {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 18px 24px;
		cursor: pointer;
		list-style: none;
	}

	.template-summary::-webkit-details-marker {
		display: none;
	}

	.template-info {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.template-status {
		width: 8px;
		height: 8px;
		flex-shrink: 0;
	}

	.template-status.enabled {
		background: #22c55e;
	}

	.template-status.disabled {
		background: #d0d0d0;
	}

	.template-name {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 15px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.template-subject {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		margin-top: 2px;
	}

	.template-tags {
		display: flex;
		gap: 8px;
	}

	.template-editor {
		padding: 24px;
		border-top: 1px solid #e0e0e0;
		background: #fafafa;
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}

	.code-textarea {
		font-family: 'Courier New', monospace;
		font-size: 13px;
		line-height: 1.5;
	}

	.template-actions {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: 16px;
		padding-top: 16px;
		border-top: 1px solid #e0e0e0;
	}

	.checkbox-label {
		display: flex;
		align-items: center;
		gap: 6px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		cursor: pointer;
	}

	.merge-vars-panel h3 {
		font-family: 'Oswald', sans-serif;
		font-size: 16px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 10px;
	}

	.merge-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		margin-bottom: 12px;
	}

	.vars-list {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.var-item {
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: 6px 0;
		border-bottom: 1px solid #f0f0f0;
	}

	.var-code {
		font-family: 'Courier New', monospace;
		font-size: 12px;
		color: #fe5900;
		background: rgba(254, 89, 0, 0.08);
		padding: 2px 6px;
		display: inline-block;
	}

	.var-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
	}

	.alert {
		background: #f0fdf4;
		border: 1px solid #bbf7d0;
		color: #166534;
		padding: 12px 18px;
		font-size: 14px;
		margin-bottom: 20px;
	}

	.alert-error {
		background: #fef2f2;
		border-color: #fecaca;
		color: #dc2626;
	}

	.modal {
		border: none;
		padding: 0;
		max-width: 600px;
		width: 90%;
		box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);
	}

	.modal::backdrop {
		background: rgba(0, 0, 0, 0.6);
	}

	.modal-content {
		padding: 32px;
	}

	.modal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 24px;
		padding-bottom: 14px;
		border-bottom: 1px solid #e0e0e0;
	}

	.modal-header h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 22px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.modal-close {
		background: none;
		border: none;
		font-size: 28px;
		color: #8c8c8c;
		cursor: pointer;
		transition: color 0.3s;
	}

	.modal-close:hover {
		color: #0d0d0d;
	}

	.modal-actions {
		display: flex;
		justify-content: flex-end;
		gap: 12px;
		margin-top: 24px;
		padding-top: 20px;
		border-top: 1px solid #e0e0e0;
	}

	@media (max-width: 768px) {
		.templates-layout {
			grid-template-columns: 1fr;
		}

		.form-row {
			grid-template-columns: 1fr;
		}
	}
</style>
