	<script type="application/json" id="ps-site-pricing-json" set:html={sitePricingPayloadJson} />
	<script is:inline>
		document.addEventListener('DOMContentLoaded', function () {
			const el = document.getElementById('ps-site-pricing-json');
			if (!el || !el.textContent) return;
			var SITE = JSON.parse(el.textContent);

			function tierForModel(value) {
				var m = SITE.models.find(function (x) {
					return x.value === value;
				});
				return m ? m.tier : 'premium';
			}

			function syncDepthSelect(depthSel, tier) {
				if (!depthSel) return;
				var opt24 = depthSel.querySelector('option[value="24"]');
				if (!opt24) return;
				if (tier === 'essential') {
					opt24.disabled = true;
					if (depthSel.value === '24') depthSel.value = '19';
				} else {
					opt24.disabled = false;
				}
			}

			function computeFormTotal(form) {
				var prefix = form.getAttribute('data-acc-prefix');
				if (!prefix) return null;
				var modelEl = form.querySelector('[name="catalog_model"]');
				var widthEl = form.querySelector('[name="catalog_width"]');
				var qtyEl = form.querySelector('[name="catalog_quantity"]');
				if (!modelEl || !widthEl || !qtyEl) return null;
				var model = modelEl.value;
				var width = parseInt(widthEl.value, 10);
				var qty = Math.max(1, parseInt(qtyEl.value, 10) || 1);
				var mod = SITE.models.find(function (x) {
					return x.value === model;
				});
				if (!mod || typeof mod.prices[width] !== 'number') return null;
				var base = mod.prices[width];
				var acc = 0;
				function normAccQty(n, lockerCount) {
					var nint = Math.max(0, Math.floor(Number(n)) || 0);
					var L = Math.max(1, lockerCount);
					if (L > 1 && nint >= L && nint % L === 0) return nint / L;
					return nint;
				}
				for (var i = 0; i < SITE.accessoryIds.length; i++) {
					var id = SITE.accessoryIds[i];
					var inp = form.querySelector('[name="' + prefix + 'acc_qty_' + id + '"]');
					var raw = Math.max(0, parseInt(inp && inp.value ? inp.value : '0', 10) || 0);
					var n = normAccQty(raw, qty);
					if (n > 0) acc += (SITE.accessoryUsd[id] || 0) * n;
				}
				var per = Math.round((base + acc) * 100) / 100;
				var total = Math.round(per * qty * 100) / 100;
				return { per: per, total: total, qty: qty };
			}

			function refreshForm(form) {
				var depthSel = form.querySelector('.site-catalog-depth');
				var modelEl = form.querySelector('[name="catalog_model"]');
				if (modelEl && depthSel) syncDepthSelect(depthSel, tierForModel(modelEl.value));
				var out = computeFormTotal(form);
				var strong = form.querySelector('.site-catalog-live-total');
				var sub = form.querySelector('.site-catalog-live-sub');
				if (!strong) return;
				if (!out) {
					strong.textContent = '—';
					if (sub) sub.textContent = '';
					return;
				}
				strong.textContent = '$' + out.total.toFixed(2);
				if (sub)
					sub.textContent =
						' (' +
						out.qty +
						' × $' +
						out.per.toFixed(2) +
						' per locker)';
			}

			document.querySelectorAll('[data-site-catalog-form]').forEach(function (form) {
				function onChange() {
					refreshForm(form);
				}
				form.addEventListener('change', onChange);
				form.addEventListener('input', onChange);
				var modelEl = form.querySelector('[name="catalog_model"]');
				if (modelEl) modelEl.addEventListener('change', onChange);
				refreshForm(form);
			});
		});
	</script>

