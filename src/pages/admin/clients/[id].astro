---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import CrmManufacturerFormPicker from '../../../components/admin/CrmManufacturerFormPicker.astro';
import { isManufacturerFormLockerType } from '../../../lib/crm-manufacturer-forms';
import { getSession } from '../../../lib/auth';
import {
	accessoryQuantitiesFromFormPrefixed,
	buildAccessoriesFromForm,
	buildAccessoriesFromFormPrefixed,
	LOCKER_SPEC_ACCESSORY_ROWS,
	parseAccessoriesField,
} from '../../../lib/crm-locker-accessories';
import {
	SITE_CATALOG_WIDTHS,
	SITE_LOCKER_MODELS,
	computeCatalogLineUsd,
	getSiteCatalogModel,
	getSitePricingClientPayload,
	parseDepthInches,
	parseWidthInches,
} from '../../../lib/crm-site-pricing';
import {
	fundraisingStatusOptionsForSelect,
	normalizeFundraisingStatus,
} from '../../../lib/crm-fundraising-status';
import { supabaseAdmin, STAGE_LABELS, STAGE_COLORS, STAGE_ORDER, type OrderStage } from '../../../lib/supabase';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/admin/login');

const { id } = Astro.params;
let formMessage = '';

// Handle POST actions
if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	const action = form.get('action') as string;

	if (action === 'update_client') {
		const { error } = await supabaseAdmin.from('clients').update({
			contact_name: form.get('contact_name') as string,
			company_name: (form.get('company_name') as string) || null,
			email: (form.get('email') as string) || null,
			phone: (form.get('phone') as string) || null,
			sport: (form.get('sport') as string) || null,
			team_name: (form.get('team_name') as string) || null,
			country: (form.get('country') as string) || null,
			shipping_address: (form.get('shipping_address') as string) || null,
			source_website: (form.get('source_website') as string) || null,
			notes: (form.get('notes') as string) || null,
		}).eq('id', id);
		formMessage = error ? `Error: ${error.message}` : 'Client updated';
	}

	if (action === 'set_manufacturers_form') {
		const orderId = String(form.get('order_id') || '').trim();
		const model = String(form.get('locker_model') || '').trim();
		if (!orderId || !isManufacturerFormLockerType(model)) {
			formMessage = 'Error: invalid manufacturer form request';
		} else {
			const { data: row } = await supabaseAdmin
				.from('orders')
				.select('id, locker_size')
				.eq('id', orderId)
				.eq('client_id', id)
				.single();
			if (!row) {
				formMessage = 'Error: order not found for this client';
			} else {
				const updates: Record<string, unknown> = {
					manufacturers_form: model,
					locker_type: model,
				};
				const ls = String(row.locker_size ?? '').trim();
				if (!ls) updates.locker_size = '24"';
				const { error } = await supabaseAdmin.from('orders').update(updates).eq('id', orderId);
				formMessage = error ? `Error: ${error.message}` : `Manufacturer's form: ${model} saved`;
			}
		}
	}

	if (action === 'create_order') {
		const { data: order, error } = await supabaseAdmin.from('orders').insert({
			client_id: id,
			title: form.get('title') as string,
			description: (form.get('description') as string) || null,
			locker_type: (form.get('locker_type') as string) || null,
			locker_size: (form.get('locker_size') as string) || null,
			locker_width: (form.get('locker_width') as string) || null,
			locker_color: (form.get('locker_color') as string) || null,
			accessories: buildAccessoriesFromForm(form),
			quantity: form.get('quantity') ? Number(form.get('quantity')) : null,
		}).select().single();

		if (!error && order) {
			await supabaseAdmin.from('stage_history').insert({
				order_id: order.id,
				to_stage: 'new_lead',
				changed_by: session.user.email,
				notes: 'Order created',
			});
			formMessage = 'Order created';
		} else {
			formMessage = `Error: ${error?.message}`;
		}
	}

	if (action === 'add_note') {
		const { error } = await supabaseAdmin.from('notes').insert({
			client_id: id,
			order_id: (form.get('order_id') as string) || null,
			content: form.get('content') as string,
			client_visible: form.get('client_visible') === 'on',
			author: session.user.email || 'Admin',
		});
		formMessage = error ? `Error: ${error.message}` : 'Note added';
	}

	if (action === 'regenerate_token') {
		const newToken = [...Array(48)].map(() => Math.random().toString(36)[2]).join('');
		await supabaseAdmin.from('clients').update({ portal_token: newToken }).eq('id', id);
		formMessage = 'Portal link regenerated';
	}

	if (action === 'update_order_financials') {
		const orderId = form.get('order_id') as string;
		const { data: row } = await supabaseAdmin.from('orders').select('id').eq('id', orderId).eq('client_id', id).single();
		if (!row) {
			formMessage = 'Error: order not found for this client';
		} else {
			const est = ((form.get('estimate_number') as string) || '').trim() || null;
			const inv = ((form.get('invoice_number') as string) || '').trim() || null;
			const qaRaw = form.get('quoted_amount') as string;
			const { error } = await supabaseAdmin
				.from('orders')
				.update({
					estimate_number: est,
					invoice_number: inv,
					quoted_amount: qaRaw && String(qaRaw).trim() !== '' ? Number(qaRaw) : null,
				})
				.eq('id', orderId);
			formMessage = error ? `Error: ${error.message}` : 'Estimate / invoice details saved';
		}
	}

	if (action === 'apply_site_catalog_to_order') {
		const orderId = form.get('order_id') as string;
		const { data: row } = await supabaseAdmin
			.from('orders')
			.select('id, title')
			.eq('id', orderId)
			.eq('client_id', id)
			.single();
		if (!row) {
			formMessage = 'Error: order not found for this client';
		} else {
			const model = String(form.get('catalog_model') || '').trim();
			const w = Math.floor(Number(form.get('catalog_width')));
			const qty = Math.max(1, Math.floor(Number(form.get('catalog_quantity')) || 1));
			let depthIn = String(form.get('catalog_depth') || '19') === '24' ? 24 : 19;
			const meta = getSiteCatalogModel(model);
			if (meta?.tier === 'essential') depthIn = 19;
			const prefix = `co_${orderId}_`;
			const accQty = accessoryQuantitiesFromFormPrefixed(form, prefix);
			const accStr = buildAccessoriesFromFormPrefixed(form, prefix);
			const computed = computeCatalogLineUsd({
				modelValue: model,
				widthInches: w,
				lockerQuantity: qty,
				accessoryQuantities: accQty,
			});
			if (!computed) {
				formMessage = 'Error: choose a valid model and width from the site catalog';
			} else {
				const titleOverride = String(form.get('catalog_title') || '').trim();
				const desc = String(form.get('catalog_description') || '').trim();
				const updates: Record<string, unknown> = {
					locker_type: model || null,
					locker_size: `${w}"`,
					locker_width: depthIn === 24 ? '24"' : '19"',
					quantity: qty,
					accessories: accStr,
					quoted_amount: computed.total,
					manufacturers_form: isManufacturerFormLockerType(model) ? model : null,
				};
				if (titleOverride) updates.title = titleOverride;
				if (desc) updates.description = desc;
				const color = String(form.get('catalog_color') || '').trim();
				if (color) updates.locker_color = color;
				const { error } = await supabaseAdmin.from('orders').update(updates).eq('id', orderId);
				formMessage = error
					? `Error: ${error.message}`
					: `Site catalog applied — ${qty} locker${qty === 1 ? '' : 's'} × $${computed.perLocker.toFixed(2)} = $${computed.total.toFixed(2)} USD. Estimate/invoice totals updated; add numbers below if needed.`;
			}
		}
	}
}

const sitePricingPayloadJson = JSON.stringify(getSitePricingClientPayload());

// Fetch client data
const { data: client } = await supabaseAdmin
	.from('clients')
	.select('*')
	.eq('id', id)
	.single();

if (!client) return Astro.redirect('/admin/clients');

// Fetch related data
const [
	{ data: orders },
	{ data: notes },
	{ data: messages },
	{ data: emailLog },
	{ data: clientDocs },
] = await Promise.all([
	supabaseAdmin.from('orders').select('*').eq('client_id', id).order('created_at', { ascending: false }),
	supabaseAdmin.from('notes').select('*').eq('client_id', id).order('created_at', { ascending: false }),
	supabaseAdmin.from('messages').select('*').eq('client_id', id).order('created_at', { ascending: false }).limit(20),
	supabaseAdmin.from('email_log').select('*').eq('client_id', id).order('sent_at', { ascending: false }).limit(20),
	supabaseAdmin.from('documents').select('*').eq('client_id', id).order('created_at', { ascending: false }),
]);

const portalUrl = `${Astro.url.origin}/my-project/${client.portal_token}`;
const fundraisingSelectOptions = fundraisingStatusOptionsForSelect();
---

<AdminLayout title={client.contact_name} activeNav="clients">
	<Fragment slot="header-actions">
		<a href="/admin/clients" class="btn btn-secondary btn-sm">Back to Clients</a>
	</Fragment>

	{formMessage && (
		<div class:list={['alert', { 'alert-error': formMessage.startsWith('Error') }]}>
			{formMessage}
		</div>
	)}

	<div class="client-layout">
		<!-- Left Column: Client Info -->
		<div class="client-sidebar">
			<div class="card client-details-card">
				<h3>Client Details</h3>
				<form method="POST" class="client-details-form">
					<input type="hidden" name="action" value="update_client" />
					<div class="form-group">
						<label>Contact Name</label>
						<input type="text" name="contact_name" value={client.contact_name} required />
					</div>
					<div class="form-group">
						<label>Company</label>
						<input type="text" name="company_name" value={client.company_name || ''} />
					</div>
					<div class="form-group">
						<label>Email</label>
						<input type="email" name="email" value={client.email || ''} />
					</div>
					<div class="form-group">
						<label>Phone</label>
						<input type="tel" name="phone" value={client.phone || ''} />
					</div>
					<div class="form-group">
						<label>Sport</label>
						<select name="sport">
							<option value="">Select...</option>
							{['Football', 'Hockey', 'Basketball', 'Baseball', 'Soccer', 'Lacrosse', 'Other'].map(s => (
								<option value={s} selected={client.sport === s}>{s}</option>
							))}
						</select>
					</div>
					<div class="form-group">
						<label>Team Name</label>
						<input type="text" name="team_name" value={client.team_name || ''} />
					</div>
					<div class="form-group">
						<label>Fundraising status</label>
						<select name="fundraising_status">
							{fundraisingSelectOptions.map((o) => (
								<option value={o.value} selected={o.value === (client.fundraising_status || '')}>
									{o.label}
								</option>
							))}
						</select>
					</div>
					<div class="form-group">
						<label>Country</label>
						<select name="country">
							<option value="">Select...</option>
							<option value="USA" selected={client.country === 'USA'}>USA</option>
							<option value="Canada" selected={client.country === 'Canada'}>Canada</option>
						</select>
					</div>
					<div class="form-group">
						<label>Source Website</label>
						<input type="text" name="source_website" value={client.source_website || ''} placeholder="e.g. customsportslockers.com" />
					</div>
					<div class="form-group">
						<label>Shipping Address</label>
						<textarea name="shipping_address" rows="2" placeholder="Full shipping address">{client.shipping_address || ''}</textarea>
					</div>
					<div class="form-group">
						<label>Notes</label>
						<textarea name="notes" rows="3">{client.notes || ''}</textarea>
					</div>
					<button type="submit" class="btn btn-primary btn-sm client-details-save">Save Changes</button>
				</form>
			</div>

			<div class="card portal-card">
				<h3>Client Portal</h3>
				<p class="portal-desc">Share this link so your client can track their project:</p>
				<div class="portal-link-box">
					<input type="text" value={portalUrl} readonly id="portalUrl" class="portal-input" />
					<button type="button" class="btn btn-sm btn-secondary" onclick="navigator.clipboard.writeText(document.getElementById('portalUrl').value).then(()=>this.textContent='Copied!').catch(()=>{})">Copy</button>
				</div>
				<form method="POST" style="margin-top: 8px">
					<input type="hidden" name="action" value="regenerate_token" />
					<button type="submit" class="btn btn-sm btn-secondary" style="width:100%" onclick="return confirm('Regenerate portal link? The old link will stop working.')">Regenerate Link</button>
				</form>
			</div>
		</div>

		<!-- Right Column: Orders, Notes, Activity -->
		<div class="client-main">
			<!-- Orders Section -->
			<div class="card">
				<div class="card-header">
					<h3>Orders</h3>
					<button class="btn btn-primary btn-sm" onclick="document.getElementById('newOrderModal').showModal()">New Order</button>
				</div>
				<p class="orders-lead">
					Use <strong>Site price list</strong> to pull the same models, widths, depths, and accessory prices as playerstall.com / your CAD sheet — totals are computed on the server. Then set estimate and invoice numbers and use <strong>Open estimate</strong> or <strong>Open invoice</strong> (Print → Save as PDF).
				</p>
				{orders && orders.length > 0 ? (
					<div class="order-cards">
						{orders.map((order: any) => (
							<div class="order-card">
								<div class="order-card-top">
									<div class="order-card-title">
										<a href={`/admin/orders/${order.id}`}>{order.title}</a>
									</div>
									<div class="order-card-top-actions">
										<a href={`/admin/orders/${order.id}`} class="btn btn-primary btn-sm">Edit order</a>
										<span class="badge" style={`background: ${STAGE_COLORS[order.stage as OrderStage]}20; color: ${STAGE_COLORS[order.stage as OrderStage]}`}>
											{STAGE_LABELS[order.stage as OrderStage]}
										</span>
									</div>
								</div>
								<div class="order-card-grid">
									<div class="order-field">
										<span class="order-field-label">Locker Type</span>
										<span class="order-field-value">{order.locker_type || '—'}</span>
									</div>
									<div class="order-field">
										<span class="order-field-label">Manufacturer's form</span>
										<span class="order-field-value">{order.manufacturers_form || '—'}</span>
									</div>
									<div class="order-field">
										<span class="order-field-label">Width</span>
										<span class="order-field-value">{order.locker_size || '—'}</span>
									</div>
									<div class="order-field">
										<span class="order-field-label">Depth</span>
										<span class="order-field-value">{order.locker_width || '—'}</span>
									</div>
									<div class="order-field">
										<span class="order-field-label">Quantity</span>
										<span class="order-field-value">{order.quantity || '—'}</span>
									</div>
									<div class="order-field">
										<span class="order-field-label">Color</span>
										<span class="order-field-value">{order.locker_color || '—'}</span>
									</div>
									<div class="order-field full-width">
										<span class="order-field-label">Accessories</span>
										<span class="order-field-value">{order.accessories || '—'}</span>
									</div>
									{order.description && (
										<div class="order-field full-width">
											<span class="order-field-label">Description</span>
											<span class="order-field-value">{order.description}</span>
										</div>
									)}
									<div class="order-field">
										<span class="order-field-label">Assigned To</span>
										<span class="order-field-value">{order.assigned_to || '—'}</span>
									</div>
									<div class="order-field">
										<span class="order-field-label">Est. Completion</span>
										<span class="order-field-value">{order.estimated_completion ? new Date(order.estimated_completion).toLocaleDateString() : '—'}</span>
									</div>
									<div class="order-field">
										<span class="order-field-label">Completed Date</span>
										<span class="order-field-value" style={order.completed_date ? 'color: #16a34a; font-weight: 600' : ''}>
											{order.completed_date ? new Date(order.completed_date).toLocaleDateString() : '—'}
										</span>
									</div>
									<div class="order-field">
										<span class="order-field-label">Created</span>
										<span class="order-field-value">{new Date(order.created_at).toLocaleDateString()}</span>
									</div>
								</div>

								{(() => {
									const coPrefix = `co_${order.id}_`;
									const accPrefill = parseAccessoriesField(order.accessories);
									const defWidth = parseWidthInches(order.locker_size) ?? 24;
									const modelOk = SITE_LOCKER_MODELS.some((m) => m.value === order.locker_type);
									const defModel = modelOk ? String(order.locker_type) : 'Model L';
									const tier = getSiteCatalogModel(defModel)?.tier ?? 'premium';
									let defDepth = parseDepthInches(order.locker_width);
									if (tier === 'essential') defDepth = 19;
									const defQty = order.quantity != null && order.quantity > 0 ? order.quantity : 1;
									return (
										<details class="site-catalog-panel">
											<summary class="site-catalog-summary">Site price list — fill order from shop pricing (USD)</summary>
											<form method="POST" class="site-catalog-form" data-site-catalog-form data-acc-prefix={coPrefix} data-order-id={order.id}>
												<input type="hidden" name="action" value="apply_site_catalog_to_order" />
												<input type="hidden" name="order_id" value={order.id} />
												<p class="site-catalog-hint">
													Prices match <strong>playerstall.com</strong> / <code>price-sheet-cad.html</code>. Total is saved to this order and flows into printable estimates and invoices.
												</p>
												<div class="site-catalog-grid">
													<div class="form-group site-catalog-field">
														<label for={`cm-${order.id}`}>Model</label>
														<select id={`cm-${order.id}`} name="catalog_model" class="site-catalog-model" required>
															{SITE_LOCKER_MODELS.map((m) => (
																<option value={m.value} selected={m.value === defModel}>
																	{m.label}
																</option>
															))}
														</select>
													</div>
													<div class="form-group site-catalog-field">
														<label for={`cw-${order.id}`}>Width</label>
														<select id={`cw-${order.id}`} name="catalog_width" class="site-catalog-width" required>
															{SITE_CATALOG_WIDTHS.map((w) => (
																<option value={w} selected={w === defWidth}>
																	{w}"
																</option>
															))}
														</select>
													</div>
													<div class="form-group site-catalog-field">
														<label for={`cd-${order.id}`}>Depth</label>
														<select id={`cd-${order.id}`} name="catalog_depth" class="site-catalog-depth">
															<option value="19" selected={defDepth === 19}>
																19″ (Essential / standard)
															</option>
															<option value="24" selected={defDepth === 24}>
																24″ (Premium only, same list price)
															</option>
														</select>
													</div>
													<div class="form-group site-catalog-field">
														<label for={`cq-${order.id}`}>Locker qty</label>
														<input id={`cq-${order.id}`} type="number" name="catalog_quantity" min="1" step="1" value={defQty} class="site-catalog-qty" required />
													</div>
													<div class="form-group site-catalog-field site-catalog-field-wide">
														<label for={`ccol-${order.id}`}>Color / finish</label>
														<input
															id={`ccol-${order.id}`}
															type="text"
															name="catalog_color"
															placeholder="e.g. High Reflective White, Java woodgrain"
															value={order.locker_color || ''}
														/>
													</div>
													<div class="form-group site-catalog-field site-catalog-field-wide">
														<label for={`ct-${order.id}`}>Line title (estimate / invoice)</label>
														<input id={`ct-${order.id}`} type="text" name="catalog_title" value={order.title} />
													</div>
													<div class="form-group site-catalog-field site-catalog-field-full">
														<label for={`cdesc-${order.id}`}>Description / notes</label>
														<textarea id={`cdesc-${order.id}`} name="catalog_description" rows="2" placeholder="Optional scope notes">{order.description || ''}</textarea>
													</div>
												</div>
												<p class="site-catalog-acc-label">Accessories (qty per locker — same options as spec sheets)</p>
												<div class="site-catalog-acc-table-wrap">
													<table class="site-catalog-acc-table">
														<thead>
															<tr>
																<th scope="col">Accessory</th>
																<th scope="col" class="site-catalog-acc-qty">Qty / locker</th>
															</tr>
														</thead>
														<tbody>
															{LOCKER_SPEC_ACCESSORY_ROWS.map((row) => (
																<tr>
																	<td>{row.label}</td>
																	<td>
																		<label class="visually-hidden" for={`${coPrefix}acc-${row.id}`}>
																			Quantity — {row.label}
																		</label>
																		<input
																			type="number"
																			id={`${coPrefix}acc-${row.id}`}
																			name={`${coPrefix}acc_qty_${row.id}`}
																			class="site-catalog-acc-input"
																			min="0"
																			step="1"
																			value={accPrefill.quantities[row.id] > 0 ? String(accPrefill.quantities[row.id]) : ''}
																			placeholder="0"
																		/>
																	</td>
																</tr>
															))}
														</tbody>
													</table>
												</div>
												<div class="form-group site-catalog-field-full">
													<label for={`${coPrefix}notes`}>Other accessories / notes</label>
													<textarea id={`${coPrefix}notes`} name={`${coPrefix}accessories_notes`} rows="2" placeholder="e.g. Corner units">{accPrefill.notes}</textarea>
												</div>
												<div class="site-catalog-footer">
													<p class="site-catalog-live-total-wrap">
														<span class="site-catalog-live-label">Live total (USD):</span>{' '}
														<strong class="site-catalog-live-total">—</strong>
														<span class="site-catalog-live-sub" />
													</p>
													<button type="submit" class="btn btn-primary btn-sm">
														Apply to order &amp; update total
													</button>
												</div>
											</form>
										</details>
									);
								})()}

								<details class="site-catalog-panel mfg-form-order-details">
