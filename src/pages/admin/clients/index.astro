} else {
	if (Astro.request.method === 'POST') {
		const form = await Astro.request.formData();
		const action = form.get('action') as string;

		if (action === 'create_client') {
			const orderTitle = (form.get('order_title') as string)?.trim() || null;
			const result = await createClientWithInitialOrder(supabaseAdmin!, {
				contact_name: form.get('contact_name') as string,
				company_name: (form.get('company_name') as string) || null,
				email: (form.get('email') as string) || null,
				phone: (form.get('phone') as string) || null,
				sport: (form.get('sport') as string) || null,
				team_name: (form.get('team_name') as string) || null,
				fundraising_status: normalizeFundraisingStatus(form.get('fundraising_status') as string),
				country: (form.get('country') as string) || null,
				shipping_address: (form.get('shipping_address') as string) || null,
				source: (form.get('source') as string) || 'other',
				source_website: (form.get('source_website') as string) || null,
				notes: null,
				order_title: orderTitle,
				locker_type: (form.get('locker_type') as string) || null,
				locker_size: (form.get('locker_size') as string) || null,
				locker_width: (form.get('locker_width') as string) || null,
				locker_color: (form.get('locker_color') as string) || null,
				accessories: (form.get('accessories') as string) || null,
				quantity: form.get('quantity') ? Number(form.get('quantity')) : null,
				estimated_completion: null,
			});
			if ('error' in result) {
				formError = result.error;
			} else {
				return Astro.redirect(`/admin/clients/${result.clientId}`);
			}
		}
	}

	let query = supabaseAdmin
		.from('clients')
		.select('*, orders(id, stage)')
		.order('created_at', { ascending: false });

	if (search) {
		query = query.or(`contact_name.ilike.%${search}%,company_name.ilike.%${search}%,email.ilike.%${search}%`);
	}

	const { data } = await query;
	clients = data || [];
}

const allRows: { client: any; order: any }[] = [];
let totalValue = 0;
let totalQty = 0;
(clients || []).forEach((client: any) => {
	if (client.orders && client.orders.length > 0) {
		client.orders.forEach((order: any) => {
			totalValue += Number(order.quoted_amount) || 0;
			totalQty += Number(order.quantity) || 0;
			allRows.push({ client, order });
		});
	} else {
		allRows.push({ client, order: null });
	}
});
const fmtValue = '$' + totalValue.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const fmtQty = totalQty.toLocaleString();

const processedRows = allRows.map((row, idx) => {
	const stageColor = row.order ? (STAGE_COLORS[row.order.stage as OrderStage] || '#999') : '';
	const stageLabel = row.order ? (STAGE_LABELS[row.order.stage as OrderStage] || row.order.stage) : '';
	const badgeStyle = row.order ? 'background:' + stageColor + '20; color:' + stageColor : '';
	const amountStr = row.order?.quoted_amount ? '$' + Number(row.order.quoted_amount).toLocaleString() : '—';
	const sourceStr = row.client.source ? row.client.source.replace('_', ' ') : '';
	const dateStr = new Date(row.client.created_at).toLocaleDateString();
	const fundingStr = displayFundraisingStatus(row.client.fundraising_status);
	return { ...row, idx, stageColor, stageLabel, badgeStyle, amountStr, sourceStr, dateStr, fundingStr };
});

const fundraisingSelectOptions = fundraisingStatusOptionsForSelect();
