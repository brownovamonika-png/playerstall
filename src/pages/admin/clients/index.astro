<AdminLayout title="Clients" activeNav="clients">
	<Fragment slot="header-actions">
		<a href="/admin/paste-inquiry" class="btn btn-secondary">
			Paste inquiry
		</a>
		<button class="btn btn-primary" onclick="document.getElementById('newClientModal').showModal()">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
			New Client
		</button>
	</Fragment>

	<div class="clients-toolbar">
		<form method="GET" class="search-form">
			<input type="text" name="q" value={search} placeholder="Search clients..." class="search-input" />
			<button type="submit" class="btn btn-secondary btn-sm">Search</button>
		</form>
		<span class="client-count">{clients?.length || 0} clients</span>
	</div>

	<div class="card">
		<div class="summary-bar">
			<span class="summary-item"><strong>{clients.length}</strong> Clients</span>
			<span class="summary-item"><strong>{processedRows.length}</strong> Orders</span>
			<span class="summary-item"><strong>{fmtQty}</strong> Total Lockers</span>
			<span class="summary-item"><strong>{fmtValue}</strong> Total Value</span>
		</div>
		<div class="table-wrap">
			<table class="data-table">
				<thead>
					<tr>
						<th>#</th>
						<th>Name</th>
						<th>Email</th>
						<th>Phone</th>
						<th>Company / Team</th>
						<th>Sport</th>
						<th>Fundraising</th>
						<th>Country</th>
						<th>Shipping Address</th>
						<th>Estimate #</th>
						<th>Locker Type</th>
						<th>Width</th>
						<th>Color</th>
						<th>Qty</th>
						<th>Accessories</th>
						<th>Amount</th>
						<th>Invoice #</th>
						<th>Stage</th>
						<th>Source</th>
						<th>Date</th>
					</tr>
				</thead>
				<tbody>
					{processedRows.map((r) => (
						<tr>
							<td class="row-num">{r.idx + 1}</td>
							<td class="name-cell">
								<a href={'/admin/clients/' + r.client.id}>{r.client.contact_name}</a>
							</td>
							<td>{r.client.email || '—'}</td>
							<td>{r.client.phone || '—'}</td>
							<td>{r.client.company_name || r.client.team_name || '—'}</td>
							<td>{r.client.sport || '—'}</td>
							<td>{r.client.country || '—'}</td>
							<td class="address-cell">{r.client.shipping_address || '—'}</td>
							<td class="est-cell">{r.order?.estimate_number || '—'}</td>
							<td>{r.order?.locker_type || '—'}</td>
							<td>{r.order?.locker_size || '—'}</td>
							<td>{r.order?.locker_color || '—'}</td>
							<td>{r.order?.quantity || '—'}</td>
							<td><span class="accessories-cell">{r.order?.accessories || '—'}</span></td>
							<td class="amount-cell">{r.amountStr}</td>
							<td>{r.order?.invoice_number || '—'}</td>
							<td>
								{r.order ? (
									<span class="badge" style={r.badgeStyle}>{r.stageLabel}</span>
								) : (
									<span style="color: #9ca3af">No orders</span>
								)}
							</td>
							<td>
								<span class="badge" style="background: #f3f4f6; color: #6b7280">{r.sourceStr}</span>
							</td>
							<td class="date-cell">{r.dateStr}</td>
						</tr>
					))}
				</tbody>
				<tfoot>
					<tr class="totals-row">
						<td colspan="13" class="totals-label">TOTALS</td>
						<td><strong>{fmtQty}</strong></td>
						<td></td>
						<td><strong>{fmtValue}</strong></td>
						<td colspan="4"></td>
					</tr>
				</tfoot>
			</table>
		</div>
	</div>

	<!-- New Client Modal -->
	<dialog id="newClientModal" class="modal">
		<div class="modal-content">
			<div class="modal-header">
				<h2>New Client</h2>
				<button type="button" class="modal-close" onclick="document.getElementById('newClientModal').close()">&times;</button>
			</div>
			{formError && <div class="error-msg">{formError}</div>}
			<form method="POST">
				<input type="hidden" name="action" value="create_client" />
				<div class="form-row">
					<div class="form-group">
						<label for="contact_name">Contact Name *</label>
						<input type="text" id="contact_name" name="contact_name" required />
					</div>
					<div class="form-group">
						<label for="company_name">Company / Organization</label>
						<input type="text" id="company_name" name="company_name" />
					</div>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="email">Email</label>
						<input type="email" id="email" name="email" />
					</div>
					<div class="form-group">
						<label for="phone">Phone</label>
						<input type="tel" id="phone" name="phone" />
					</div>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="sport">Sport</label>
						<select id="sport" name="sport">
							<option value="">Select...</option>
							<option value="Football">Football</option>
							<option value="Hockey">Hockey</option>
							<option value="Basketball">Basketball</option>
							<option value="Baseball">Baseball</option>
							<option value="Soccer">Soccer</option>
							<option value="Lacrosse">Lacrosse</option>
							<option value="Other">Other</option>
						</select>
					</div>
					<div class="form-group">
						<label for="team_name">Team Name</label>
						<input type="text" id="team_name" name="team_name" />
					</div>
				</div>
				<div class="form-row">
					<div class="form-group" style="grid-column: 1 / -1;">
						<label for="fundraising_status">Fundraising status</label>
						<select id="fundraising_status" name="fundraising_status">
							{fundraisingSelectOptions.map((o) => (
								<option value={o.value}>{o.label}</option>
							))}
						</select>
					</div>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="country">Country</label>
						<select id="country" name="country">
							<option value="">Select...</option>
							<option value="USA">USA</option>
							<option value="Canada">Canada</option>
						</select>
					</div>
					<div class="form-group">
						<label for="source">Source</label>
						<select id="source" name="source">
							<option value="web_form">Web Form</option>
							<option value="phone">Phone</option>
							<option value="email">Email</option>
							<option value="old_website">Old Website</option>
							<option value="referral">Referral</option>
							<option value="room_planner">Room Planner</option>
							<option value="other">Other</option>
						</select>
					</div>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="source_website">Source Website</label>
						<input type="text" id="source_website" name="source_website" placeholder="e.g. customsportslockers.com" />
					</div>
					<div class="form-group">
						<label for="shipping_address">Shipping Address</label>
						<input type="text" id="shipping_address" name="shipping_address" placeholder="Full shipping address" />
					</div>
				</div>

				<div style="border-top: 1px solid #e0e0e0; margin: 20px 0 16px; padding-top: 16px;">
					<span style="font-family: 'Oswald', sans-serif; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #8c8c8c;">Initial Order (optional)</span>
				</div>
				<div class="form-group">
					<label for="order_title">Order Title</label>
					<input type="text" id="order_title" name="order_title" placeholder="e.g. Football Lockers - 50 units" />
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="locker_type">Locker Type</label>
						<select id="locker_type" name="locker_type">
							<option value="">Select...</option>
							<option value="Model L">Model L</option>
							<option value="Model S">Model S</option>
							<option value="Model Z">Model Z</option>
							<option value="Model X">Model X</option>
							<option value="Semi Pro">Semi Pro</option>
							<option value="Varsity">Varsity</option>
							<option value="Pro">Pro</option>
							<option value="Stadium">Stadium</option>
							<option value="Custom">Custom</option>
						</select>
					</div>
					<div class="form-group">
						<label for="quantity">Quantity</label>
						<input type="number" id="quantity" name="quantity" min="1" placeholder="Number of lockers" />
					</div>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="locker_size">Width</label>
						<input type="text" id="locker_size" name="locker_size" placeholder='e.g. 24"' />
					</div>
					<div class="form-group">
						<label for="locker_width">Depth</label>
						<input type="text" id="locker_width" name="locker_width" placeholder='e.g. 18"' />
					</div>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="locker_color">Color</label>
						<input type="text" id="locker_color" name="locker_color" placeholder="e.g. Natural Oak, Dark Walnut" />
					</div>
					<div class="form-group">
						<label for="accessories">Accessories</label>
						<input type="text" id="accessories" name="accessories" placeholder="e.g. Name plates, hooks, shelves" />
					</div>
				</div>

				<div class="modal-actions">
					<button type="button" class="btn btn-secondary" onclick="document.getElementById('newClientModal').close()">Cancel</button>
					<button type="submit" class="btn btn-primary">Create Client</button>
				</div>
			</form>
		</div>
	</dialog>
</AdminLayout>

<style>
	.clients-toolbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 24px;
	}

	.search-form {
		display: flex;
		gap: 8px;
	}

	.search-input {
		padding: 10px 14px;
		border: 1px solid #e0e0e0;
		border-radius: 0;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		width: 300px;
		transition: border-color 0.3s;
	}

	.search-input:focus {
		outline: none;
		border-color: #0d0d0d;
	}

	.client-count {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
