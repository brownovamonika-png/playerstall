	}

	.modal-content {
		padding: 32px;
	}

	.modal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 24px;
		padding-bottom: 14px;
		border-bottom: 1px solid #e0e0e0;
	}

	.modal-header h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 22px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.modal-close {
		background: none;
		border: none;
		font-size: 28px;
		color: #8c8c8c;
		cursor: pointer;
		padding: 0;
		line-height: 1;
		transition: color 0.3s;
