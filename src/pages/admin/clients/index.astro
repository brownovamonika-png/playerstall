	.modal-close:hover {
		color: #0d0d0d;
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}

	.modal-actions {
		display: flex;
		justify-content: flex-end;
		gap: 12px;
		margin-top: 24px;
		padding-top: 20px;
		border-top: 1px solid #e0e0e0;
	}

	.error-msg {
		background: #fef2f2;
		border: 1px solid #fecaca;
		color: #dc2626;
		padding: 12px 16px;
		font-size: 13px;
		margin-bottom: 16px;
	}

	.summary-bar {
		display: flex;
		gap: 32px;
		padding: 16px 20px;
		border-bottom: 2px solid #e0e0e0;
		background: #fafafa;
	}

	.summary-item {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #555;
	}

	.summary-item strong {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 700;
		color: #0d0d0d;
		margin-right: 4px;
	}

	.table-wrap {
		overflow-x: auto;
	}

	.row-num {
		color: #999;
