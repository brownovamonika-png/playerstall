---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import LockerSpecReferencePanel from '../../components/admin/LockerSpecReferencePanel.astro';
import { getSession } from '../../lib/auth';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/admin/login');
---

<AdminLayout title="Locker build form" activeNav="locker-build-form">
	<div class="lbf-card card">
		<p class="lbf-lead">
			Use the <strong>spec reference panel</strong> below for side elevation, top, bottom, depth, width, and accessories. Reference only — not saved to the database yet.
		</p>

		<LockerSpecReferencePanel line="essential" idPrefix="lbf" />

		<p class="lbf-footnote">
			Next step (when you’re ready): persist these choices on an order in Supabase, or export a PDF from this workflow.
		</p>
	</div>
</AdminLayout>

<style>
	.lbf-lead {
		font-size: 15px;
		line-height: 1.6;
		color: #4b5563;
		margin: 0 0 24px 0;
		max-width: 820px;
	}

	.lbf-footnote {
		font-size: 13px;
		color: #9ca3af;
		margin: 24px 0 0 0;
		max-width: 820px;
	}
</style>
