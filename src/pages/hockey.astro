---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="By Sport - Custom Sports Lockers | PlayerStall" 
	description="Sport-specific wood lockers for football, hockey, basketball, baseball, and soccer. Custom locker room solutions for collegiate and professional teams."
>
	<!-- Hero: Match Schedule style – full-width title image + breadcrumb & title overlay -->
	<section class="by-sport-hero">
		<div class="by-sport-hero-img-holder">
			<div class="by-sport-hero-img-wrapper">
				<img src="/images/topscorer/our-team-title-photo.jpg" alt="Sport-specific lockers" class="by-sport-hero-img" />
			</div>
		</div>
		<div class="by-sport-hero-overlay"></div>
		<div class="by-sport-hero-container">
			<div class="by-sport-breadcrumbs">
				<a href="/">Home</a>
				<span>By Sport</span>
			</div>
			<h1 class="by-sport-page-title">By Sport</h1>
			<div class="by-sport-bg-text">by sport</div>
		</div>
	</section>

	<!-- Two-column layout: main content + sidebar (Match Schedule style) -->
	<section class="by-sport-content-section">
		<div class="by-sport-container">
			<div class="by-sport-layout">
				<!-- Main content (left) -->
				<main class="by-sport-main">
					<p class="by-sport-intro">Every sport has unique equipment needs. We design custom wood and melamine lockers optimized for your game—from football and hockey to basketball, baseball, and soccer. Choose your sport below or explore our full lineup.</p>
					<div class="by-sport-list">
						<a href="#football" class="by-sport-list-item">
							<span class="by-sport-list-label">Football Lockers</span>
							<span class="by-sport-list-desc">Spacious, ventilated storage for helmets, pads, and cleats.</span>
						</a>
						<a href="#hockey" class="by-sport-list-item">
							<span class="by-sport-list-label">Hockey Lockers</span>
							<span class="by-sport-list-desc">Reinforced construction for heavy gear and equipment.</span>
						</a>
						<a href="#basketball" class="by-sport-list-item">
							<span class="by-sport-list-label">Basketball Lockers</span>
							<span class="by-sport-list-desc">Sleek design for shoes, uniforms, and personal items.</span>
						</a>
						<a href="#baseball" class="by-sport-list-item">
							<span class="by-sport-list-label">Baseball Lockers</span>
							<span class="by-sport-list-desc">Organized storage for bats, gloves, helmets, and uniforms.</span>
						</a>
						<a href="#soccer" class="by-sport-list-item">
							<span class="by-sport-list-label">Soccer Lockers</span>
							<span class="by-sport-list-desc">Compartments for cleats, shin guards, and team gear.</span>
						</a>
					</div>
				</main>

				<!-- Sidebar (right) - Match Schedule style widgets -->
				<aside class="by-sport-sidebar">
					<div class="by-sport-widget">
						<h3 class="by-sport-widget-title">What's trending</h3>
						<ul class="by-sport-widget-links">
							<li><a href="/blog/complete-guide-custom-sports-lockers">Complete Guide to Custom Sports Lockers</a></li>
							<li><a href="/blog/hockey-wood-lockers-complete-guide">Hockey Wood Lockers Guide</a></li>
							<li><a href="/blog/college-athletic-locker-guide">College Athletic Locker Guide</a></li>
							<li><a href="/blog/wood-vs-metal-sports-lockers-comparison">Wood vs Metal Sports Lockers</a></li>
						</ul>
					</div>
					<div class="by-sport-widget by-sport-widget-cta">
						<h3 class="by-sport-widget-title">Get a quote</h3>
						<p class="by-sport-widget-text">Free design consultation for your locker room. 30+ years experience, 5 year warranty.</p>
						<a href="/contact" class="by-sport-cta-btn">Request a quote</a>
					</div>
				</aside>
			</div>
		</div>
	</section>

	<!-- Sport detail blocks (anchors for sidebar links) -->
	<section class="by-sport-detail-section">
		<div class="container">
			<div id="football" class="by-sport-detail">
				<div class="by-sport-detail-grid">
					<div class="by-sport-detail-content">
						<h2>Football Lockers</h2>
						<p class="by-sport-intro">Football equipment is bulky, heavy, and needs proper ventilation. Our football lockers are designed for helmets, pads, cleats, and uniforms while keeping everything organized and dry.</p>
						<ul class="feature-list">
							<li>Spacious compartments for helmets and shoulder pads</li>
							<li>Enhanced ventilation to prevent moisture buildup</li>
							<li>Dedicated storage for cleats and footwear</li>
							<li>Uniform hanging space and reinforced construction</li>
						</ul>
						<a href="/contact" class="btn btn-primary">Get Football Locker Quote</a>
					</div>
					<div class="by-sport-detail-image">
						<img src="/images/topscorer/h1-img-2.jpg" alt="Football lockers" />
					</div>
				</div>
			</div>
			<div id="hockey" class="by-sport-detail">
				<div class="by-sport-detail-grid reverse">
					<div class="by-sport-detail-content">
						<h2>Hockey Lockers</h2>
						<p class="by-sport-intro">Hockey equipment is among the most challenging to store. Our hockey lockers are built for skates, pads, sticks, and gear with specialized storage and drying features.</p>
						<ul class="feature-list">
							<li>Reinforced construction for heavy gear</li>
							<li>Compartments for skates and stick storage</li>
							<li>Ventilated compartments for pads and helmets</li>
							<li>Equipment drying features</li>
						</ul>
						<a href="/contact" class="btn btn-primary">Get Hockey Locker Quote</a>
					</div>
					<div class="by-sport-detail-image">
						<img src="/images/topscorer/h3-img-1.jpg" alt="Hockey lockers" />
					</div>
				</div>
			</div>
			<div id="basketball" class="by-sport-detail">
				<div class="by-sport-detail-grid">
					<div class="by-sport-detail-content">
						<h2>Basketball Lockers</h2>
						<p class="by-sport-intro">Our basketball lockers provide sleek, organized storage for shoes, uniforms, and personal items with a professional, modern appearance.</p>
						<ul class="feature-list">
							<li>Sleek and organized design</li>
							<li>Dedicated shoe and uniform storage</li>
							<li>Personal item compartments</li>
							<li>Space-efficient layout</li>
						</ul>
						<a href="/contact" class="btn btn-primary">Get Basketball Locker Quote</a>
					</div>
					<div class="by-sport-detail-image">
						<img src="/images/topscorer/basketball-dribble.png" alt="Basketball lockers" />
					</div>
				</div>
			</div>
			<div id="baseball" class="by-sport-detail">
				<div class="by-sport-detail-grid reverse">
					<div class="by-sport-detail-content">
						<h2>Baseball Lockers</h2>
						<p class="by-sport-intro">Customized storage for bats, gloves, helmets, and uniforms. Our baseball lockers keep everything organized and accessible.</p>
						<ul class="feature-list">
							<li>Equipment-specific compartments</li>
							<li>Uniform and gear organization</li>
							<li>Easy access and durable construction</li>
						</ul>
						<a href="/contact" class="btn btn-primary">Get Baseball Locker Quote</a>
					</div>
					<div class="by-sport-detail-image">
						<img src="/images/topscorer/h2-blog-img-2-1.jpg" alt="Baseball lockers" />
					</div>
				</div>
			</div>
			<div id="soccer" class="by-sport-detail">
				<div class="by-sport-detail-grid">
					<div class="by-sport-detail-content">
						<h2>Soccer Lockers</h2>
						<p class="by-sport-intro">Organized storage for cleats, shin guards, uniforms, and equipment. Our soccer lockers keep everything accessible and professional.</p>
						<ul class="feature-list">
							<li>Compartments for cleats and gear</li>
							<li>Uniform hanging and ventilated storage</li>
						</ul>
						<a href="/contact" class="btn btn-primary">Get Soccer Locker Quote</a>
					</div>
					<div class="by-sport-detail-image">
						<img src="/images/topscorer/soccer.jpg" alt="Soccer lockers" />
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="by-sport-cta-section">
		<div class="container">
			<div class="by-sport-cta-content">
				<h2>Need Lockers for Multiple Sports?</h2>
				<p>We design complete locker room solutions for multi-sport facilities. Get a free custom design consultation.</p>
				<a href="/contact" class="btn btn-primary btn-large">Get Free Design Consultation</a>
			</div>
		</div>
	</section>

	<!-- Bottom strip: scrolling client logos only (Match Schedule style – no background image) -->
	<section class="by-sport-logos-strip" aria-label="Trusted by teams">
		<div class="by-sport-logos-strip-inner">
			<div class="by-sport-logos-track">
				<div class="by-sport-logos-set">
					<img src="/images/topscorer/client-1.png" alt="Client" width="120" height="60" />
					<img src="/images/topscorer/client-2.png" alt="Client" width="120" height="60" />
					<img src="/images/topscorer/client-3.png" alt="Client" width="120" height="60" />
					<img src="/images/topscorer/client-4.png" alt="Client" width="120" height="60" />
					<img src="/images/topscorer/client-5.png" alt="Client" width="120" height="60" />
					<img src="/images/topscorer/client-6.png" alt="Client" width="120" height="60" />
					<img src="/images/topscorer/client-8.png" alt="Client" width="120" height="60" />
					<img src="/images/topscorer/client-9.png" alt="Client" width="120" height="60" />
					<img src="/images/topscorer/client-10.png" alt="Client" width="120" height="60" />
				</div>
				<div class="by-sport-logos-set" aria-hidden="true">
					<img src="/images/topscorer/client-1.png" alt="" width="120" height="60" />
					<img src="/images/topscorer/client-2.png" alt="" width="120" height="60" />
					<img src="/images/topscorer/client-3.png" alt="" width="120" height="60" />
					<img src="/images/topscorer/client-4.png" alt="" width="120" height="60" />
					<img src="/images/topscorer/client-5.png" alt="" width="120" height="60" />
					<img src="/images/topscorer/client-6.png" alt="" width="120" height="60" />
					<img src="/images/topscorer/client-8.png" alt="" width="120" height="60" />
					<img src="/images/topscorer/client-9.png" alt="" width="120" height="60" />
					<img src="/images/topscorer/client-10.png" alt="" width="120" height="60" />
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	.container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Hero – full-width title image (Match Schedule style) */
	.by-sport-hero {
		position: relative;
		min-height: 420px;
		overflow: hidden;
		display: flex;
		align-items: flex-end;
		padding-bottom: 0;
	}

	.by-sport-hero-img-holder {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
	}

	.by-sport-hero-img-wrapper {
		position: relative;
		width: 100%;
		height: 100%;
		overflow: hidden;
	}

	.by-sport-hero-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
	}

	.by-sport-hero-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(to bottom, rgba(0, 0, 0, 0.25) 0%, rgba(0, 0, 0, 0.5) 100%);
		z-index: 1;
	}

	.by-sport-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px 80px;
		width: 100%;
		text-align: left;
	}

	.by-sport-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #cccccc;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}

	.by-sport-breadcrumbs a {
		color: #cccccc;
		text-decoration: none;
		transition: color 0.3s;
	}

	.by-sport-breadcrumbs a:hover {
		color: #fe5900;
	}

	.by-sport-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.by-sport-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 72px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
		text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
	}

	.by-sport-bg-text {
		position: absolute;
		font-family: 'Oswald', sans-serif;
		font-size: 300px;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.06);
		text-transform: uppercase;
		letter-spacing: -3px;
		bottom: -50px;
		left: 50%;
		transform: translateX(-50%);
		white-space: nowrap;
		z-index: 1;
	}

	/* Bottom strip: scrolling client logos only (Match Schedule style) */
	.by-sport-logos-strip {
		padding: 50px 0;
		border-top: 1px solid #e8e8e8;
		overflow: hidden;
		background: #fff;
	}
	.by-sport-logos-strip-inner {
		width: 100%;
		overflow: hidden;
	}

	.by-sport-logos-track {
		display: flex;
		width: max-content;
		animation: by-sport-logos-scroll 35s linear infinite;
	}

	.by-sport-logos-track:hover {
		animation-play-state: paused;
	}

	.by-sport-logos-set {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 4rem;
		padding: 0 3rem;
		flex-shrink: 0;
	}

	.by-sport-logos-set img {
		height: 50px;
		width: auto;
		max-width: 120px;
		object-fit: contain;
		opacity: 0.7;
		filter: grayscale(0.4);
		transition: opacity 0.3s;
	}

	.by-sport-logos-set img:hover {
		opacity: 1;
		filter: grayscale(0);
	}

	@keyframes by-sport-logos-scroll {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}

	/* Two-column content - Match Schedule layout */
	.by-sport-content-section {
		position: relative;
		background: #ffffff;
		padding: 60px 0 80px;
	}

	.by-sport-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.by-sport-layout {
		display: grid;
		grid-template-columns: 1fr 340px;
		gap: 60px;
		align-items: start;
	}

	.by-sport-main {
		min-width: 0;
	}

	.by-sport-intro {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #666666;
		line-height: 1.8;
		margin: 0 0 2rem 0;
	}

	.by-sport-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.by-sport-list-item {
		display: block;
		padding: 1rem 0;
		border-bottom: 1px solid #e8e8e8;
		text-decoration: none;
		color: inherit;
		transition: background 0.2s, color 0.2s;
	}

	.by-sport-list-item:hover {
		background: #f7f7f7;
		color: #fe5900;
	}

	.by-sport-list-label {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		text-transform: uppercase;
		display: block;
		margin-bottom: 0.25rem;
	}

	.by-sport-list-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		line-height: 1.5;
	}

	/* Sidebar widgets - Match Schedule style */
	.by-sport-sidebar {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.by-sport-widget {
		background: #f7f7f7;
		padding: 1.75rem 1.5rem;
		border: 1px solid #e8e8e8;
	}

	.by-sport-widget-title {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0 0 1.25rem 0;
	}

	.by-sport-widget-links {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.by-sport-widget-links li {
		margin-bottom: 1rem;
	}

	.by-sport-widget-links li:last-child {
		margin-bottom: 0;
	}

	.by-sport-widget-links a {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		text-decoration: none;
		line-height: 1.5;
		transition: color 0.2s;
	}

	.by-sport-widget-links a:hover {
		color: #fe5900;
	}

	.by-sport-widget-cta .by-sport-widget-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #666;
		line-height: 1.6;
		margin: 0 0 1.25rem 0;
	}

	.by-sport-cta-btn {
		display: inline-block;
		padding: 12px 28px;
		background: #fe5900;
		color: #ffffff;
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		text-decoration: none;
		transition: background 0.3s;
		border: none;
		cursor: pointer;
	}

	.by-sport-cta-btn:hover {
		background: #e04d00;
	}

	/* Detail sections */
	.by-sport-detail-section {
		background: #f7f7f7;
		padding: 80px 0;
	}

	.by-sport-detail {
		margin-bottom: 4rem;
	}

	.by-sport-detail:last-child {
		margin-bottom: 0;
	}

	.by-sport-detail-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
	}

	.by-sport-detail-grid.reverse {
		direction: rtl;
	}

	.by-sport-detail-grid.reverse > * {
		direction: ltr;
	}

	.by-sport-detail-content h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 36px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 1rem 0;
	}

	.feature-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem 0;
	}

	.feature-list li {
		padding: 0.5rem 0 0.5rem 1.5rem;
		position: relative;
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #333;
		line-height: 1.6;
	}

	.feature-list li::before {
		content: "✓";
		position: absolute;
		left: 0;
		color: #fe5900;
		font-weight: bold;
	}

	.btn {
		display: inline-block;
		padding: 14px 32px;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 500;
		letter-spacing: 0.1em;
		font-size: 14px;
		transition: all 0.3s;
		font-family: 'Oswald', sans-serif;
	}

	.btn-primary {
		background: #fe5900;
		color: #ffffff;
		border: 2px solid #fe5900;
	}

	.btn-primary:hover {
		background: #e04d00;
		border-color: #e04d00;
	}

	.btn-large {
		padding: 18px 44px;
		font-size: 16px;
	}

	.by-sport-detail-image {
		overflow: hidden;
		border-radius: 4px;
		background: #e0e0e0;
	}

	.by-sport-detail-image img {
		width: 100%;
		height: 320px;
		object-fit: cover;
		display: block;
	}

	.by-sport-cta-section {
		padding: 80px 0;
		background: #0d0d0d;
		text-align: center;
	}

	.by-sport-cta-content h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 42px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0 0 1rem 0;
	}

	.by-sport-cta-content p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #b6b6b6;
		margin: 0 0 2rem 0;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
		line-height: 1.7;
	}

	.by-sport-cta-content .btn-primary {
		border-color: #fe5900;
	}

	/* Bottom scrolling image strip (Match Schedule style animation) */
	.by-sport-logos-strip {
		overflow: hidden;
		padding: 2.5rem 0;
		background: #f5f5f5;
		border-top: 1px solid #e8e8e8;
	}
	.by-sport-logos-strip-inner {
		width: 100%;
		overflow: hidden;
	}
	.by-sport-logos-track {
		display: flex;
		gap: 3.5rem;
		width: max-content;
		animation: by-sport-scroll 35s linear infinite;
	}
	.by-sport-logos-track:hover {
		animation-play-state: paused;
	}
	.by-sport-logos-set {
		display: flex;
		gap: 3.5rem;
		align-items: center;
		flex-shrink: 0;
	}
	.by-sport-logos-set img {
		height: 56px;
		width: auto;
		max-width: 140px;
		object-fit: contain;
		opacity: 0.9;
		filter: grayscale(20%);
	}
