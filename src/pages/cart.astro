---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="Cart - Custom Sports Lockers | PlayerStall"
	description="Your shopping cart. View and manage your selected custom wood sports lockers."
>
	<!-- Hero Section (same as blog page) -->
	<section class="cart-hero-section">
		<div class="cart-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Cart" class="cart-hero-bg-image" />
		</div>
		<div class="cart-hero-background-overlay"></div>
		<div class="cart-hero-container">
			<div class="cart-breadcrumbs">
				<a href="/">Home</a>
				<span>Cart</span>
			</div>
			<h1 class="cart-page-title-display">Cart</h1>
			<div class="cart-background-text">cart</div>
		</div>
	</section>

	<!-- Cart Section -->
	<section class="cart-section" aria-labelledby="cart-heading">
		<h1 id="cart-heading" class="visually-hidden">Cart</h1>
		<div class="cart-container qodef-content-grid">
			<div class="woocommerce">
				<div class="woocommerce-notices-wrapper"></div>
				
				<!-- Cart Items Container -->
				<div id="cart-items-container" style="display: none;">
					<form class="woocommerce-cart-form" action="/checkout" method="post">
						<table class="shop_table shop_table_responsive cart woocommerce-cart-form__contents">
							<thead>
								<tr>
									<th class="product-remove" scope="col"><span class="visually-hidden">Remove</span></th>
									<th class="product-thumbnail" scope="col"><span class="visually-hidden">Image</span></th>
									<th class="product-name" scope="col">Product</th>
									<th class="product-price">Price</th>
									<th class="product-quantity">Quantity</th>
									<th class="product-subtotal">Subtotal</th>
								</tr>
							</thead>
							<tbody id="cart-items-body">
								<!-- Cart items will be inserted here -->
							</tbody>
						</table>

						<div class="cart-coupon-and-actions">
							<div class="cart-coupon">
								<input type="text" name="coupon_code" class="coupon-input" id="coupon_code" placeholder="Coupon code" value="" />
								<button type="button" class="button apply-coupon" id="apply-coupon">Apply coupon</button>
							</div>
							<div class="cart-actions">
								<button type="button" class="button update-cart" id="update-cart">Update cart</button>
								<a href="/shop" class="button continue-shopping">Continue shopping</a>
							</div>
						</div>
					</form>

					<div class="cart-collaterals">
						<div class="cart_totals">
							<h2 class="cart-totals-title">CART TOTALS</h2>
							<table class="shop_table shop_table_responsive cart-totals-table">
								<tbody>
									<tr class="cart-subtotal">
										<th>SUBTOTAL</th>
										<td data-title="Subtotal">
											<span class="woocommerce-Price-amount amount"><bdi><span class="woocommerce-Price-currencySymbol">$</span><span id="cart-subtotal">0.00</span></bdi></span>
										</td>
									</tr>
									<tr class="shipping">
										<th>SHIPPING</th>
										<td data-title="Shipping">
											<form class="woocommerce-shipping-calculator" action="/cart" method="post">
												<section class="woocommerce-shipping-calculator-form" style="display:none;">
													<p class="form-row form-row-wide" id="calc_shipping_country_field">
														<select name="calc_shipping_country" id="calc_shipping_country" class="country_to_state country_select" data-state-field="calc_shipping_state">
															<option value="">Select a country / region</option>
															<option value="CA">Canada</option>
															<option value="US">United States</option>
														</select>
													</p>
													<p class="form-row form-row-wide" id="calc_shipping_state_field">
														<input type="text" class="input-text" value="" placeholder="State / County" name="calc_shipping_state" id="calc_shipping_state" />
													</p>
													<p class="form-row form-row-wide" id="calc_shipping_postcode_field">
														<input type="text" class="input-text" value="" placeholder="Postcode / ZIP" name="calc_shipping_postcode" id="calc_shipping_postcode" />
													</p>
													<p>
														<button type="submit" name="calc_shipping" value="1" class="button">Update</button>
													</p>
												</section>
												<div class="shipping-display">
													<span class="woocommerce-Price-amount amount"><bdi><span class="woocommerce-Price-currencySymbol">$</span><span id="shipping-cost">0.00</span></bdi></span>
												</div>
												<div class="woocommerce-shipping-methods" style="display: none;">
													<label>
														<input type="radio" name="shipping_method[0]" data-index="0" id="shipping_method_0_flat_rate" value="flat_rate" class="shipping_method" checked="checked" />
														<span>Flat rate:</span>
														<span class="woocommerce-Price-amount amount">
															<bdi><span class="woocommerce-Price-currencySymbol">$</span><span>0.00</span></bdi>
														</span>
													</label>
												</div>
											</form>
										</td>
									</tr>
									<tr class="order-total">
										<th>TOTAL</th>
										<td data-title="Total">
											<span class="woocommerce-Price-amount amount"><bdi><span class="woocommerce-Price-currencySymbol">$</span><span id="cart-total">0.00</span></bdi></span>
										</td>
									</tr>
								</tbody>
							</table>
							<div class="wc-proceed-to-checkout">
								<a href="/checkout" class="checkout-button button alt wc-forward">PROCEED TO CHECKOUT</a>
							</div>
						</div>
					</div>
				</div>

				<!-- Empty Cart Message -->
				<div id="cart-empty-message">
					<p class="cart-empty woocommerce-info">Your cart is currently empty.</p>
					<p class="return-to-shop">
						<a class="button wc-backward" href="/shop">
							Return to shop
						</a>
					</p>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	.qodef-content-grid {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Cart Hero Section (same as blog page: full-bleed image + overlay + title) */
	.cart-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
		width: 100%;
		max-width: none;
		margin: 0;
	}

	.cart-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.cart-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.cart-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.cart-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.cart-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}

	.cart-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.cart-breadcrumbs a:hover {
		color: #fe5900;
	}

	.cart-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.cart-page-title-display {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	.cart-background-text {
		display: none;
	}

	/* Cart Section - use :global so styles apply to JS-inserted cart rows */
	.cart-section {
		padding: 50px 0 80px;
		background: #ffffff;
	}

	:global(.cart-section .cart-container) {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	:global(.cart-section .woocommerce) {
		width: 100%;
	}

	/* All number text greyed out on cart page: prices, amounts, quantity */
	:global(.cart-section .woocommerce-Price-amount),
	:global(.cart-section .woocommerce-Price-currencySymbol) {
		color: #8c8c8c;
	}

	:global(.cart-section .woocommerce-notices-wrapper) {
		margin-bottom: 20px;
	}

	:global(.cart-section .cart-empty) {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #0d0d0d;
		margin-bottom: 30px;
		padding: 0;
		background: transparent;
		border: none;
		text-align: left;
	}

	:global(.cart-section .return-to-shop) {
		margin-top: 30px;
		text-align: left;
	}

	:global(.cart-section .button.wc-backward) {
		display: inline-block;
		padding: 15px 40px;
		background: #0d0d0d;
		color: #ffffff;
		border: none;
		font-family: 'Oswald', sans-serif;
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		text-decoration: none;
		cursor: pointer;
		transition: background 0.3s;
	}

	:global(.cart-section .button.wc-backward:hover) {
		background: #333333;
		color: #ffffff;
	}

	/* Cart Table */
	:global(.cart-section .woocommerce-cart-form) {
		margin-bottom: 40px;
	}

	:global(.cart-section .shop_table) {
		width: 100%;
		border-collapse: collapse;
		margin-bottom: 0;
	}

	:global(.cart-section .shop_table thead) {
		border-bottom: 1px solid #e0e0e0;
		margin-bottom: 0;
	}

	:global(.cart-section .shop_table th) {
		padding: 20px 15px;
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 700;
		color: #1c1c1c;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		text-align: left;
		vertical-align: middle;
	}

	:global(.cart-section .shop_table th.product-price),
	:global(.cart-section .shop_table th.product-quantity),
	:global(.cart-section .shop_table th.product-subtotal) {
		text-align: right;
	}

	:global(.cart-section .shop_table td) {
		padding: 20px 15px;
		border-bottom: 1px solid #e0e0e0;
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #0d0d0d;
		vertical-align: middle;
	}

	:global(.cart-section .shop_table td.product-price),
	:global(.cart-section .shop_table td.product-quantity),
	:global(.cart-section .shop_table td.product-subtotal) {
		text-align: right;
		padding-right: 15px;
	}

	:global(.cart-section .shop_table th.product-price),
	:global(.cart-section .shop_table th.product-quantity),
	:global(.cart-section .shop_table th.product-subtotal) {
		padding-right: 15px;
	}

	:global(.cart-section .shop_table td.product-subtotal) {
		min-width: 100px;
	}

	:global(.cart-section .shop_table td.product-price .woocommerce-Price-amount),
	:global(.cart-section .shop_table td.product-subtotal .woocommerce-Price-amount) {
		display: block;
		text-align: right;
	}

	/* Model: remove and thumbnail columns have no visible header text */
	.visually-hidden,
	:global(.cart-section .visually-hidden) {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	:global(.cart-section .product-remove) {
		width: 40px;
		padding-right: 0;
	}

	:global(.cart-section .product-remove a) {
		color: #1c1c1c;
		text-decoration: none;
		font-size: 14px;
		font-weight: 400;
		font-family: 'Yantramanav', sans-serif;
		line-height: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		text-align: center;
		transition: opacity 0.3s;
	}

	:global(.cart-section .product-remove a:hover) {
		opacity: 0.6;
		color: #1c1c1c;
	}

	/* Product thumbnail images - match model site exactly (32px square) */
	:global(.cart-section .product-thumbnail) {
		width: 50px;
		padding-right: 15px;
		vertical-align: middle;
	}
	
	:global(.cart-section .product-thumbnail img),
	:global(.cart-section .shop_table .product-thumbnail img),
	:global(.cart-section .shop_table td.product-thumbnail img),
	:global(.cart-section .woocommerce-cart-form .product-thumbnail img),
	:global(.cart-section table.shop_table .product-thumbnail img),
	:global(.cart-section .cart_item .product-thumbnail img),
	:global(.cart-section td.product-thumbnail img),
	:global(.cart-section img[width="36"]) {
		width: 45px !important;
		height: 45px !important;
		min-width: 45px !important;
		min-height: 45px !important;
		max-width: 45px !important;
		max-height: 45px !important;
		object-fit: cover;
		border-radius: 0;
		display: block !important;
		flex-shrink: 0;
		box-sizing: border-box;
		margin: 0;
		padding: 0;
		vertical-align: middle;
		background: #ffffff;
	}
	
	:global(.cart-section .shop_table .product-thumbnail),
	:global(.cart-section .shop_table td.product-thumbnail) {
		width: 55px;
		max-width: 55px;
		overflow: hidden;
		padding-right: 15px;
	}

	/* Product name: same font and size as table header "PRODUCT" above (Oswald, model site) */
	:global(.cart-section .product-name),
	:global(.cart-section .product-name a),
	:global(.cart-section td.product-name) {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: #1c1c1c;
		text-decoration: none;
	}

	:global(.cart-section .product-name a:hover) {
		color: #1c1c1c;
		text-decoration: none;
	}

	:global(.cart-section .product-price),
	:global(.cart-section .product-subtotal) {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		font-weight: 400;
		color: #8c8c8c;
		letter-spacing: 0;
		text-align: right;
	}

	:global(.cart-section .product-quantity) {
		width: 120px;
		text-align: right;
	}

	/* Quantity control: model site – number left, spinner (up/down) right, thin grey borders */
	:global(.cart-section .quantity-control) {
		display: inline-flex;
		align-items: stretch;
		width: 96px;
		min-width: 96px;
		height: 40px;
		border: 1px solid #e0e0e0;
		background: #ffffff;
		border-radius: 0;
		overflow: hidden;
		vertical-align: middle;
	}

	:global(.cart-section .quantity-control .quantity-input),
	:global(.cart-section .quantity-control input.quantity-input[type="number"]) {
		width: 60px;
		min-width: 0;
		height: 100%;
		margin: 0;
		padding: 0 6px;
		border: none;
		border-right: 1px solid #e0e0e0;
		background: #ffffff;
		box-sizing: border-box;
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 700;
		color: #000000;
		text-align: center;
		-moz-appearance: textfield;
		appearance: textfield;
		outline: none;
	}

	:global(.cart-section .quantity-control input.quantity-input[type="number"]::-webkit-outer-spin-button),
	:global(.cart-section .quantity-control input.quantity-input[type="number"]::-webkit-inner-spin-button) {
		-webkit-appearance: none;
		margin: 0;
	}

	:global(.cart-section .quantity-spinner) {
		display: flex;
		flex-direction: column;
		flex: 0 0 34px;
		width: 34px;
		background: #ffffff;
	}

	:global(.cart-section .qty-btn) {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 0;
		padding: 0;
		border: none;
		border-bottom: 1px solid #e0e0e0;
		background: #ffffff;
		color: #1c1c1c;
		font-size: 10px;
		line-height: 1;
		cursor: pointer;
		transition: background 0.2s;
	}

	:global(.cart-section .qty-btn:last-child) {
		border-bottom: none;
	}

	:global(.cart-section .qty-btn:hover) {
		background: #f5f5f5;
	}

	:global(.cart-section .qty-btn:active) {
		background: #ebebeb;
	}

	:global(.cart-section .cart-coupon-and-actions) {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		margin-top: 20px;
		margin-left: 0;
		width: 100%;
		max-width: 100%;
	}

	:global(.cart-section .cart-coupon) {
		display: flex;
		gap: 10px;
		align-items: center;
		flex-wrap: wrap;
	}

	:global(.cart-section .coupon-input) {
		padding: 10px 13px;
		border: 1px solid #e0e0e0;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		font-weight: 400;
		color: #1c1c1c;
		background: #ffffff;
		min-width: 176px;
		box-sizing: border-box;
	}

	:global(.cart-section .coupon-input::placeholder) {
		color: #969696;
		font-size: 13px;
		font-weight: 400;
	}

	:global(.cart-section .coupon-input:focus) {
		outline: none;
		border-color: #1c1c1c;
	}

	:global(.cart-section .apply-coupon:hover) {
		background: #1c1c1c;
		color: #ffffff;
	}

	:global(.cart-section .cart-actions) {
		display: flex;
		gap: 10px;
		justify-content: flex-end;
	}

	/* Same size for Apply coupon and Update cart / Continue shopping */
	:global(.cart-section .cart-actions .button),
	:global(.cart-section .cart-coupon .button.apply-coupon) {
		padding: 10px 19px;
		font-size: 13px;
		letter-spacing: 0.1em;
	}

	:global(.cart-section .apply-coupon) {
		background: #000000;
		border: none;
		color: #ffffff;
		font-family: 'Oswald', sans-serif;
		font-weight: 700;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 0.3s;
		border-radius: 0;
	}

	:global(.cart-section .button) {
		padding: 12px 24px;
		background: #000000;
		color: #ffffff;
		border: none;
		font-family: 'Oswald', sans-serif;
		font-size: 16px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		text-decoration: none;
		cursor: pointer;
		transition: background 0.3s;
		display: inline-block;
		border-radius: 0;
	}

	:global(.cart-section .button:hover) {
		background: #1c1c1c;
		color: #ffffff;
	}

	:global(.cart-section .update-cart) {
		background: #000000;
		border: none;
		color: #ffffff;
	}

	:global(.cart-section .continue-shopping) {
		background: #ffffff;
		border: 1px solid #e0e0e0;
		color: #1c1c1c;
	}

	:global(.cart-section .continue-shopping:hover) {
		background: #1c1c1c;
		color: #ffffff;
		border-color: #1c1c1c;
	}

	:global(.cart-section .cart-collaterals) {
		display: grid;
		grid-template-columns: 720px 1fr;
		gap: 50px;
		align-items: start;
		margin-bottom: 52px;
	}

	/* ========== CART TOTALS – match reference exactly ========== */
	:global(.cart-section .cart_totals) {
		background: #ffffff;
		padding: 40px 36px 44px;
		border: none;
		box-sizing: border-box;
		max-width: 600px;
		margin-left: 0;
	}

	:global(.cart-section .cart_totals h2.cart-totals-title) {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 700;
		color: #000000;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin: 0 0 20px;
		padding: 0;
		border: none;
		line-height: 1.2;
	}

	:global(.cart-section .cart_totals .shop_table.cart-totals-table) {
		width: 100%;
		margin: 0;
		border: none;
		border-collapse: collapse;
	}

	:global(.cart-section .cart_totals .shop_table.cart-totals-table tbody tr) {
		border-top: 1px solid #e0e0e0;
	}

	:global(.cart-section .cart_totals .shop_table.cart-totals-table th) {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 700;
		color: #000000;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		text-align: left;
		padding: 14px 0;
		border: none;
		width: 45%;
		vertical-align: top;
	}

	:global(.cart-section .cart_totals .shop_table.cart-totals-table td) {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		font-weight: 400;
		color: #8c8c8c;
		text-align: right;
		padding: 14px 0;
		border: none;
		vertical-align: top;
	}

	:global(.cart-section .cart_totals .shop_table.cart-totals-table .woocommerce-Price-amount) {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		font-weight: 400;
		color: #8c8c8c;
	}

	/* Shipping: one line like subtotal – label left, value right */
	:global(.cart-section .cart_totals .shipping td) {
		text-align: right;
		vertical-align: middle;
	}

	:global(.cart-section .cart_totals .woocommerce-shipping-calculator) {
		text-align: right;
	}

	:global(.cart-section .cart_totals .shipping-display) {
		text-align: right;
		display: block;
		white-space: nowrap;
	}

	:global(.cart-section .cart_totals .shipping-display .woocommerce-Price-amount) {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		font-weight: 400;
		color: #8c8c8c;
	}

	:global(.cart-section .cart_totals .shipping-calculator-button) {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		font-weight: 400;
		color: #8c8c8c;
		text-decoration: underline;
		cursor: pointer;
		transition: color 0.2s;
		margin-left: 0.35em;
	}

	:global(.cart-section .cart_totals .shipping-calculator-button:hover) {
		color: #fe5900;
	}

	:global(.cart-section .cart_totals .woocommerce-shipping-calculator-form) {
		margin-top: 10px;
		padding-top: 10px;
		border-top: 1px solid #e0e0e0;
		text-align: left;
	}

	:global(.cart-section .cart_totals .woocommerce-shipping-calculator-form .form-row) {
		margin-bottom: 10px;
	}

	:global(.cart-section .cart_totals .woocommerce-shipping-calculator-form select),
	:global(.cart-section .cart_totals .woocommerce-shipping-calculator-form input[type="text"]) {
		width: 100%;
		padding: 10px 12px;
		border: 1px solid #e0e0e0;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		background: #fff;
		box-sizing: border-box;
	}

	:global(.cart-section .cart_totals .woocommerce-shipping-calculator-form .button) {
		padding: 10px 20px;
		font-size: 12px;
	}

	:global(.cart-section .cart_totals .woocommerce-shipping-methods) {
		margin: 0;
		padding: 0;
	}

	:global(.cart-section .cart_totals .woocommerce-shipping-methods label) {
		display: flex;
		align-items: center;
		gap: 8px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		cursor: pointer;
		margin: 0;
	}

	/* Proceed to Checkout: compact, full width, black, white text */
	:global(.cart-section .cart_totals .wc-proceed-to-checkout) {
		margin-top: 20px;
		padding: 0;
	}

	:global(.cart-section .cart_totals .checkout-button) {
		display: inline-block;
		width: auto;
		box-sizing: border-box;
		padding: 12px 22px;
		background: #000000;
		color: #ffffff;
		border: none;
		text-align: center;
		margin: 0;
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		text-decoration: none;
		cursor: pointer;
		transition: background 0.2s, color 0.2s;
		border-radius: 4px;
	}

	:global(.cart-section .checkout-button:hover),
	:global(.cart-section .checkout-button:active),
	:global(.cart-section .checkout-button:focus) {
		background: #fe5900;
		color: #ffffff;
		outline: none;
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.cart-collaterals {
			grid-template-columns: 1fr;
		}

		.cart-page-title-display {
			font-size: 52px;
		}
	}

	@media (max-width: 768px) {
		.cart-hero-section {
			min-height: 300px;
		}

		.cart-page-title-display {
			font-size: 42px;
		}

		.cart-section {
			padding: 36px 0 60px;
		}

		:global(.cart-section .shop_table) {
			display: block;
		}

		:global(.cart-section .shop_table thead) {
			display: none;
		}

		:global(.cart-section .shop_table tbody),
		:global(.cart-section .shop_table tr),
		:global(.cart-section .shop_table td) {
			display: block;
		}

		:global(.cart-section .shop_table tr) {
			border: 1px solid #e0e0e0;
			margin-bottom: 20px;
			padding: 15px;
		}

		:global(.cart-section .shop_table td) {
			border: none;
			padding: 10px 0;
			text-align: left !important;
		}

		:global(.cart-section .shop_table td:before) {
			content: attr(data-title) ": ";
			font-weight: 600;
			display: inline-block;
			width: 100px;
		}

		:global(.cart-section .shop_table td.product-remove:before),
		:global(.cart-section .shop_table td.product-thumbnail:before) {
			content: none;
			display: none;
		}
	}

	@media (max-width: 480px) {
		.cart-page-title-display {
			font-size: 32px;
		}
	}
	
	/* Final override to ensure product images are exactly 32px - match model site */
	:global(.cart-section .woocommerce-cart-form table.shop_table tbody td.product-thumbnail img),
	:global(.cart-section .woocommerce-cart-form .shop_table .product-thumbnail img),
	:global(#cart-items-container .product-thumbnail img),
	:global(.cart-section .shop_table tbody .product-thumbnail img) {
		width: 32px !important;
		height: 32px !important;
		max-width: 32px !important;
		max-height: 32px !important;
		min-width: 32px !important;
		min-height: 32px !important;
		display: block !important;
		object-fit: cover !important;
		background: #ffffff !important;
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		// Cart utility functions
		function getCart() {
			const cart = localStorage.getItem('playerstall_cart');
			return cart ? JSON.parse(cart) : [];
		}

		function saveCart(cart: { quantity: number; price?: number; name?: string; image?: string }[]) {
			localStorage.setItem('playerstall_cart', JSON.stringify(cart));
			updateCartCount();
			renderCart();
		}

		function updateCartCount() {
			const cart = getCart();
			const totalItems = cart.reduce((sum: number, item: { quantity: number }) => sum + item.quantity, 0);
			const cartCount = document.querySelector('.cart-count');
			if (cartCount) {
				cartCount.textContent = totalItems;
			}
			window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: totalItems } }));
		}

		function renderCart() {
			const cart = getCart();
			const container = document.getElementById('cart-items-container');
			const emptyMessage = document.getElementById('cart-empty-message');
			const cartBody = document.getElementById('cart-items-body');
			const subtotalEl = document.getElementById('cart-subtotal');
			const totalEl = document.getElementById('cart-total');

			if (cart.length === 0) {
				if (container) (container as HTMLElement).style.display = 'none';
				if (emptyMessage) (emptyMessage as HTMLElement).style.display = 'block';
				return;
			}

			if (container) (container as HTMLElement).style.display = 'block';
			if (emptyMessage) (emptyMessage as HTMLElement).style.display = 'none';

			let subtotal = 0;
			let html = '';

			cart.forEach((item: { name: string; image: string; price: number; quantity: number }, index: number) => {
				const itemTotal = item.price * item.quantity;
				subtotal += itemTotal;

				html += `
					<tr class="cart_item">
						<td class="product-remove">
							<a href="#" class="remove" data-index="${index}" aria-label="Remove this item">×</a>
						</td>
						<td class="product-thumbnail">
							<img src="${item.image}" alt="${item.name}" width="32" height="32" style="width: 32px !important; height: 32px !important; max-width: 32px !important; max-height: 32px !important; min-width: 32px !important; min-height: 32px !important; object-fit: cover; display: block; margin: 0; padding: 0; background: #ffffff;" />
						</td>
						<td class="product-name" data-title="Product">
							${item.name}
						</td>
						<td class="product-price" data-title="Price">
							<span class="woocommerce-Price-amount amount">
								<bdi><span class="woocommerce-Price-currencySymbol">$</span>${item.price.toFixed(2)}</bdi>
							</span>
						</td>
						<td class="product-quantity" data-title="Quantity">
							<div class="quantity-control">
								<input type="number" class="quantity-input qty-input" value="${item.quantity}" min="1" max="999" data-index="${index}" />
								<div class="quantity-spinner">
									<button type="button" class="qty-btn qty-up" data-index="${index}" aria-label="Increase quantity">&#9650;</button>
									<button type="button" class="qty-btn qty-down" data-index="${index}" aria-label="Decrease quantity">&#9660;</button>
								</div>
							</div>
						</td>
						<td class="product-subtotal" data-title="Subtotal">
							<span class="woocommerce-Price-amount amount">
								<bdi><span class="woocommerce-Price-currencySymbol">$</span>${itemTotal.toFixed(2)}</bdi>
							</span>
						</td>
					</tr>
				`;
			});

			if (cartBody) cartBody.innerHTML = html;
			if (subtotalEl) subtotalEl.textContent = subtotal.toFixed(2);
			
			// Calculate total with shipping (default $0.00)
			const shippingCostEl = document.getElementById('shipping-cost');
			const shippingCost = shippingCostEl ? parseFloat(shippingCostEl.textContent) : 0.00;
			const total = subtotal + shippingCost;
			if (totalEl) totalEl.textContent = total.toFixed(2);

			// Attach event listeners
			document.querySelectorAll('.remove').forEach(btn => {
				btn.addEventListener('click', (e) => {
					e.preventDefault();
					const el = e.currentTarget as HTMLElement;
					const index = parseInt(el.getAttribute('data-index') ?? '0', 10);
					const cart = getCart();
					cart.splice(index, 1);
					saveCart(cart);
				});
			});

			document.querySelectorAll('.qty-input').forEach(input => {
				input.addEventListener('change', () => {
					const el = input as HTMLInputElement;
					const index = parseInt(el.getAttribute('data-index') ?? '0', 10);
					const quantity = Math.min(999, Math.max(1, parseInt(el.value, 10) || 1));
					el.value = String(quantity);
					const cart = getCart();
					cart[index].quantity = quantity;
					saveCart(cart);
					renderCart();
				});
			});

			document.querySelectorAll('.qty-up').forEach(btn => {
				btn.addEventListener('click', () => {
					const control = (btn as HTMLElement).closest('.quantity-control');
					const input = control ? control.querySelector('.qty-input') as HTMLInputElement | null : null;
					if (!input) return;
					const index = parseInt(input.getAttribute('data-index') ?? '0', 10);
					const quantity = Math.min(999, (parseInt(input.value, 10) || 1) + 1);
					input.value = String(quantity);
					const cart = getCart();
					cart[index].quantity = quantity;
					saveCart(cart);
					renderCart();
				});
			});

			document.querySelectorAll('.qty-down').forEach(btn => {
				btn.addEventListener('click', () => {
					const control = (btn as HTMLElement).closest('.quantity-control');
					const input = control ? control.querySelector('.qty-input') as HTMLInputElement | null : null;
					if (!input) return;
					const index = parseInt(input.getAttribute('data-index') ?? '0', 10);
					const quantity = Math.max(1, (parseInt(input.value, 10) || 1) - 1);
					input.value = String(quantity);
					const cart = getCart();
					cart[index].quantity = quantity;
					saveCart(cart);
					renderCart();
				});
			});
		}

		// Initialize cart display
		renderCart();
		updateCartCount();

		// Listen for cart updates from other pages
		window.addEventListener('cartUpdated', function() {
			renderCart();
		});
		
		// Shipping calculator toggle - wait for cart to render first
		setTimeout(function() {
			const shippingCalculatorButton = document.querySelector('.shipping-calculator-button');
			const shippingCalculatorForm = document.querySelector('.woocommerce-shipping-calculator-form');
			const shippingDisplay = document.querySelector('.shipping-display');
			
			if (shippingCalculatorButton && shippingCalculatorForm) {
				shippingCalculatorButton.addEventListener('click', (e) => {
					e.preventDefault();
					const formEl = shippingCalculatorForm as HTMLElement;
					const btnEl = shippingCalculatorButton as HTMLElement;
					const isHidden = formEl.style.display === 'none' || !formEl.style.display;
					formEl.style.display = isHidden ? 'block' : 'none';
					if (shippingDisplay) (shippingDisplay as HTMLElement).style.display = isHidden ? 'none' : 'block';
					btnEl.textContent = isHidden ? 'Cancel' : 'Calculate shipping';
				});
			}
		}, 100);
		
		// Update total when shipping method changes
		const shippingMethods = document.querySelectorAll('.woocommerce-shipping-methods input[type="radio"]');
		const shippingCostEl = document.getElementById('shipping-cost');
		const totalEl = document.getElementById('cart-total');
		
		if (shippingMethods.length && shippingCostEl && totalEl) {
			shippingMethods.forEach(method => {
				method.addEventListener('change', () => {
					const cart = getCart();
					const subtotal = cart.reduce((sum: number, item: { price: number; quantity: number }) => sum + (item.price * item.quantity), 0);
					const inputEl = method as HTMLInputElement;
					if (inputEl.value === 'flat_rate') {
						shippingCostEl.textContent = '0.00';
					} else if (inputEl.value === 'local_pickup') {
						shippingCostEl.textContent = '0.00';
					}
					const total = subtotal + 0.00;
					totalEl.textContent = total.toFixed(2);
				});
			});
		}
	});
</script>
