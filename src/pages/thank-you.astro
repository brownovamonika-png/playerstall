---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Thank You — We Received Your Message | PlayerStall"
	description="Thanks for reaching out to PlayerStall. Our team will review your request and follow up within 2–3 business days. Custom wood sports lockers, 30+ years experience."
>
	<section class="ty-hero">
		<div class="ty-hero-bg">
			<img
				src="https://playerstall.b-cdn.net/images/stadium-goalpost-playerstall-lockers.jpg"
				alt=""
				class="ty-hero-image"
				role="presentation"
			/>
		</div>
		<div class="ty-hero-overlay"></div>
		<div class="ty-hero-inner">
			<div class="ty-breadcrumbs">
				<a href="/">Home</a>
				<span>Consultation received</span>
			</div>
			<div class="ty-hero-focus">
				<h1 class="ty-headline">Thank you</h1>
				<p class="ty-hero-tagline">We’d love to help your team get a locker room they’re proud of.</p>
			</div>
		</div>
	</section>

	<section class="ty-body-section">
		<div class="ty-container">
			<div class="ty-panel">
				<p class="ty-panel-eyebrow">Next steps</p>
				<h2 class="ty-section-label">What happens next</h2>
				<p class="ty-copy ty-copy-tight">
					We’re grateful you took the time to reach out. A member of our team will read your details and get back to you within <strong>two to three business days</strong>, often sooner.
				</p>
			</div>
		</div>
	</section>

	<section class="ty-journey-section" aria-labelledby="ty-journey-title">
		<div class="ty-container">
			<header class="ty-journey-header">
				<span class="ty-journey-section-label">YOUR JOURNEY WITH US</span>
				<h2 class="ty-journey-section-title" id="ty-journey-title">You are here</h2>
			</header>
			<ol class="ty-journey-grid">
				<li class="ty-journey-box ty-journey-done">
					<span class="ty-journey-num">1</span>
					<span class="ty-journey-label">Explore</span>
				</li>
				<li class="ty-journey-box ty-journey-active" aria-current="step">
					<span class="ty-journey-num">2</span>
					<span class="ty-journey-label">Consultation</span>
				</li>
				<li class="ty-journey-box">
					<span class="ty-journey-num">3</span>
					<span class="ty-journey-label">Design &amp; quote</span>
				</li>
				<li class="ty-journey-box">
					<span class="ty-journey-num">4</span>
					<span class="ty-journey-label">Approval</span>
				</li>
				<li class="ty-journey-box">
					<span class="ty-journey-num">5</span>
					<span class="ty-journey-label">Production</span>
				</li>
				<li class="ty-journey-box">
					<span class="ty-journey-num">6</span>
					<span class="ty-journey-label">Shipping</span>
				</li>
				<li class="ty-journey-box">
					<span class="ty-journey-num">7</span>
					<span class="ty-journey-label">Installation</span>
				</li>
			</ol>
			<p class="ty-journey-note">
				Want the full picture? <a href="/how-it-works">See how it works</a>
			</p>
		</div>
	</section>

	<section class="ty-foot-section" aria-label="Email follow-up">
		<div class="ty-container">
			<p class="ty-foot">
				Need to add something? Email us at{' '}
				<a href="mailto:team@playerstall.com">team@playerstall.com</a>
			</p>
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	.ty-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Hero — aligned with homepage slider feel */
	.ty-hero {
		position: relative;
		min-height: 42vh;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 72px;
		overflow: hidden;
	}

	.ty-hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		overflow: hidden;
	}

	.ty-hero-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
	}

	.ty-hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.35) 45%, rgba(0, 0, 0, 0.2) 100%);
		z-index: 1;
	}

	.ty-hero-inner {
		position: relative;
		z-index: 2;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		width: 100%;
	}

	/* Breadcrumb row + hero tagline: same face; tagline +10% size vs crumbs; extra gap below headline (+15%) */
	.ty-breadcrumbs,
	.ty-hero-tagline {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		line-height: 1.35;
		color: rgba(255, 255, 255, 0.85);
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.ty-breadcrumbs {
		font-size: 12px;
		margin-bottom: 28px;
	}

	.ty-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.ty-breadcrumbs a:hover {
		color: #fe5900;
	}

	.ty-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.ty-hero-focus {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		text-align: left;
		width: 100%;
	}

	.ty-headline {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(27px, 4.05vw, 49px);
		font-weight: 700;
		color: #ffffff;
		text-transform: uppercase;
		line-height: 1.05;
		margin: 0 0 calc(14px * 1.15);
		max-width: 18ch;
	}

	.ty-hero-tagline {
		margin: 0;
		max-width: 42rem;
		font-size: calc(12px * 1.1);
		/* Match .ty-breadcrumbs span (second segment), not the link tone */
		color: #ffffff;
	}

	@media (max-width: 480px) {
		.ty-breadcrumbs {
			font-size: 11px;
			letter-spacing: 0.09em;
		}

		.ty-hero-tagline {
			font-size: calc(11px * 1.1);
			letter-spacing: 0.09em;
		}
	}

	/* Content — open layout, no card frame */
	.ty-body-section {
		padding: 3rem 0 4rem;
		background: #ffffff;
	}

	.ty-panel {
		max-width: 520px;
		margin: 0 auto;
		text-align: center;
		padding: 0;
	}

	.ty-panel-eyebrow {
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: #9a9a9a;
		margin: 0 0 10px;
	}

	.ty-section-label {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(24px, 3.2vw, 34px);
		font-weight: 600;
		text-transform: uppercase;
		color: #1a1a1a;
		line-height: 1.15;
		margin: 0 0 1.35rem;
		letter-spacing: 0.02em;
	}

	.ty-copy {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #5c5c5c;
		line-height: 1.72;
		margin: 0 0 1.25rem;
		max-width: 46ch;
		margin-left: auto;
		margin-right: auto;
	}

	.ty-copy strong {
		color: #2a2a2a;
		font-weight: 600;
	}

	.ty-copy-tight {
		margin-bottom: 0;
	}

	.ty-foot-section {
		padding: 2rem 0 3.25rem;
		background: #ffffff;
	}

	.ty-foot {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		line-height: 1.65;
		margin: 0 auto;
		max-width: 520px;
		text-align: center;
	}

	.ty-foot a {
		color: #1a1a1a;
		font-weight: 500;
		text-decoration: none;
		border-bottom: 1px solid #c5c5c5;
		padding-bottom: 1px;
		transition: color 0.2s ease, border-color 0.2s ease;
	}

	.ty-foot a:hover {
		color: #fe5900;
		border-bottom-color: #fe5900;
	}

	/* Journey — neutral palette; orange only on current step */
	.ty-journey-section {
		padding: 48px 0 56px;
		background: linear-gradient(180deg, #fafafa 0%, #f3f3f3 100%);
	}

	.ty-journey-header {
		text-align: center;
		margin-bottom: 28px;
	}

	.ty-journey-section-label {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: #9a9a9a;
		margin-bottom: 8px;
	}

	.ty-journey-section-title {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(22px, 3vw, 32px);
		font-weight: 600;
		text-transform: uppercase;
		color: #1a1a1a;
		line-height: 1.12;
		margin: 0;
		letter-spacing: 0.02em;
	}

	.ty-journey-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
		list-style: none;
		margin: 0 auto 26px;
		padding: 0;
		max-width: 520px;
	}

	.ty-journey-box {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: 16px 10px 14px;
		background: #ffffff;
		border: 1px solid #e6e6e6;
		border-top: 2px solid #dcdcdc;
		border-radius: 3px;
		box-sizing: border-box;
		min-height: 0;
		justify-content: flex-start;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.ty-journey-box.ty-journey-done {
		border-top-color: #4a4a4a;
	}

	.ty-journey-box.ty-journey-active {
		border-top-color: #4a4a4a;
		border-color: #d8d8d8;
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.07);
	}

	.ty-journey-num {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		margin: 0 0 10px;
		font-family: 'Oswald', sans-serif;
		font-size: 15px;
		font-weight: 600;
		line-height: 1;
		color: #7a7a7a;
		background: #f0f0f0;
		border: 1px solid #e2e2e2;
		border-radius: 2px;
		flex-shrink: 0;
	}

	.ty-journey-done .ty-journey-num {
		background: #2d2d2d;
		border-color: #2d2d2d;
		color: #ffffff;
	}

	.ty-journey-active .ty-journey-num {
		background: #ffffff;
		border: 1px solid #c8c8c8;
		color: #1a1a1a;
		box-shadow: inset 0 -2px 0 #fe5900;
	}

	.ty-journey-label {
		font-family: 'Oswald', sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		color: #9a9a9a;
		line-height: 1.35;
		letter-spacing: 0.07em;
		max-width: 11em;
	}

	.ty-journey-done .ty-journey-label,
	.ty-journey-active .ty-journey-label {
		color: #1a1a1a;
	}

	.ty-journey-note {
		text-align: center;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		line-height: 1.6;
		color: #6b6b6b;
		margin: 0;
	}

	.ty-journey-note a {
		color: #1a1a1a;
		text-decoration: none;
		font-weight: 500;
		border-bottom: 1px solid #c5c5c5;
		padding-bottom: 1px;
		transition: color 0.2s ease, border-color 0.2s ease;
	}

	.ty-journey-note a:hover {
		color: #fe5900;
		border-bottom-color: #fe5900;
	}

	@media (min-width: 640px) {
		.ty-journey-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			max-width: 680px;
			gap: 12px;
		}
	}

	@media (min-width: 1024px) {
		.ty-journey-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
			max-width: 760px;
		}
	}

	@media (min-width: 1200px) {
		.ty-journey-grid {
			grid-template-columns: repeat(7, minmax(0, 1fr));
			max-width: 900px;
			gap: 11px;
		}

		.ty-journey-box {
			padding: 14px 8px 12px;
		}

		.ty-journey-label {
			font-size: 10px;
			max-width: none;
		}
	}

	@media (max-width: 768px) {
		.ty-hero {
			min-height: 38vh;
			padding-bottom: 48px;
		}

		.ty-body-section {
			padding: 2.25rem 0 2.75rem;
		}
	}
</style>
