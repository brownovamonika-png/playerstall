---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="Installation Guide | Wood Sports Locker Setup | PlayerStall"
	description="Step-by-step installation guide for PlayerStall wood sports lockers. Pre-installation checklist, tools needed, assembly instructions, and troubleshooting. Phone support available."
>
	<Fragment slot="head">
		<script type="application/ld+json">
		{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://playerstall.com"},
				{"@type": "ListItem", "position": 2, "name": "Installation Guide", "item": "https://playerstall.com/installation-guide"}
			]
		})}
		</script>
		<script type="application/ld+json">
		{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "HowTo",
			"name": "How to Install PlayerStall Wood Sports Lockers",
			"description": "Complete installation guide for PlayerStall custom wood sports lockers, from room preparation to final adjustments.",
			"totalTime": "PT4H",
			"tool": [
				{"@type": "HowToTool", "name": "Power drill/driver"},
				{"@type": "HowToTool", "name": "Level (48-inch recommended)"},
				{"@type": "HowToTool", "name": "Tape measure"},
				{"@type": "HowToTool", "name": "Stud finder"},
				{"@type": "HowToTool", "name": "Rubber mallet"}
			],
			"step": [
				{"@type": "HowToStep", "name": "Prepare the Room", "text": "Clear the installation area, verify dimensions, locate wall studs, and ensure the floor is level."},
				{"@type": "HowToStep", "name": "Unpack and Inspect", "text": "Carefully unpack all components, check against the packing list, and inspect for shipping damage."},
				{"@type": "HowToStep", "name": "Mark Wall Positions", "text": "Using your layout plan, mark locker positions on the wall with a pencil, ensuring proper spacing."},
				{"@type": "HowToStep", "name": "Install Wall Cleats", "text": "Secure wall cleats to studs using provided hardware, ensuring they are level."},
				{"@type": "HowToStep", "name": "Set Locker Units", "text": "Hang locker units on wall cleats, connect adjacent units, and secure to wall."},
				{"@type": "HowToStep", "name": "Install Accessories", "text": "Attach hooks, shelves, name plates, and other accessories per your design layout."},
				{"@type": "HowToStep", "name": "Final Adjustments", "text": "Level all units, tighten connections, and verify all doors and components operate properly."}
			]
		})}
		</script>
	</Fragment>

	<!-- Hero -->
	<section class="ig-hero">
		<div class="ig-hero-bg">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Installation guide for PlayerStall sports lockers" class="ig-hero-image" />
		</div>
		<div class="ig-hero-overlay"></div>
		<div class="ig-hero-container">
			<div class="ig-breadcrumbs">
				<a href="/">Home</a>
				<span>Installation Guide</span>
			</div>
			<h1 class="ig-hero-title">Installation Guide</h1>
		</div>
	</section>

	<!-- Intro -->
	<section class="ig-intro">
		<div class="container">
			<div class="ig-intro-content">
				<p class="ig-label">step 6 of your journey</p>
				<h2 class="ig-heading">Everything You Need for a Smooth Installation</h2>
				<p class="ig-intro-text">Our lockers are built to be easy to install. This guide covers everything from prepping your space to getting the lockers up on the wall. And if you get stuck, our team is always just a phone call away.</p>
				<div class="ig-support-banner">
					<strong>Need help?</strong> Call us at <a href="tel:+18885841444">1 888 584 1444</a> anytime during installation. We're here for you.
				</div>
			</div>
		</div>
	</section>

	<!-- Pre Installation Checklist -->
	<section class="ig-checklist">
		<div class="container">
			<div class="ig-section-header">
				<p class="ig-label">before you begin</p>
				<h2 class="ig-heading">Pre Installation Checklist</h2>
			</div>
			<div class="ig-checklist-grid">
				<div class="ig-check-group">
					<h4>Room Preparation</h4>
					<ul>
						<li>Clear the installation area of all furniture, equipment, and debris</li>
						<li>Make sure the floor is clean, dry, and level (use shims if needed)</li>
						<li>Verify room dimensions match the approved layout plan</li>
						<li>Confirm adequate lighting in the work area</li>
						<li>Protect flooring with drop cloths or cardboard</li>
						<li>Make sure HVAC is running (wood needs stable temperature and humidity)</li>
					</ul>
				</div>
				<div class="ig-check-group">
					<h4>Wall &amp; Electrical</h4>
					<ul>
						<li>Locate and mark all wall studs using a stud finder</li>
						<li>Identify any electrical outlets, switches, or conduit behind the wall</li>
						<li>Make sure walls can handle the weight of fully loaded lockers</li>
						<li>Patch and paint walls before installation (if needed)</li>
						<li>Mark the finished floor line if flooring is being installed afterward</li>
					</ul>
				</div>
				<div class="ig-check-group">
					<h4>Measurements</h4>
					<ul>
						<li>Measure wall lengths and confirm against the layout plan</li>
						<li>Measure ceiling height to verify locker clearance</li>
						<li>Check door swing clearances</li>
						<li>Account for baseboards, trim, or sprinkler heads</li>
						<li>Mark center lines for symmetrical installations</li>
					</ul>
				</div>
				<div class="ig-check-group">
					<h4>Tools Needed</h4>
					<ul>
						<li>Power drill/driver with Phillips and Robertson bits</li>
						<li>48 inch level (laser level recommended for long runs)</li>
						<li>Tape measure (25 foot minimum)</li>
						<li>Stud finder</li>
						<li>Rubber mallet</li>
						<li>Pencil and painter's tape for marking</li>
						<li>Step ladder</li>
						<li>Safety glasses and work gloves</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Installation Steps -->
	<section class="ig-steps">
		<div class="container">
			<div class="ig-section-header">
				<p class="ig-label">step by step</p>
				<h2 class="ig-heading">Installation Instructions</h2>
			</div>

			<div class="ig-step-list">
				<div class="ig-step">
					<div class="ig-step-num">1</div>
					<div class="ig-step-body">
						<h4>Unpack &amp; Inspect</h4>
						<p>Carefully unpack all components in the installation area. Check every piece against the packing list included in your shipment. Inspect for any shipping damage and photograph anything that looks off. Report damage within 48 hours by calling <a href="tel:+18885841444">1 888 584 1444</a> or emailing <a href="mailto:team@playerstall.com">team@playerstall.com</a>.</p>
						<div class="ig-tip">
							<strong>Tip:</strong> Keep all hardware packets organized by locker unit. Label each group with the corresponding unit number from your layout plan.
						</div>
					</div>
				</div>

				<div class="ig-step">
					<div class="ig-step-num">2</div>
					<div class="ig-step-body">
						<h4>Mark Wall Positions</h4>
						<p>Using your approved layout plan (included with your shipment), measure and mark the position of each locker unit on the wall with a pencil. Use a level to draw a horizontal reference line at the cleat height. Mark wall stud locations along this line.</p>
						<div class="ig-tip">
							<strong>Tip:</strong> Start from a corner or center reference point and work outward. This ensures even spacing and prevents cumulative measurement errors.
						</div>
					</div>
				</div>

				<div class="ig-step">
					<div class="ig-step-num">3</div>
					<div class="ig-step-body">
						<h4>Install Wall Cleats</h4>
						<p>Secure the wall cleats (included) to wall studs using the provided lag screws. The cleats need to be perfectly level because this is the foundation for the whole installation. Use a 48 inch level or laser level to verify. Each cleat must hit at least two studs.</p>
						<div class="ig-tip">
							<strong>Tip:</strong> Predrill pilot holes into the studs to prevent splitting and ensure a tight, secure fit.
						</div>
					</div>
				</div>

				<div class="ig-step">
					<div class="ig-step-num">4</div>
					<div class="ig-step-body">
						<h4>Set Locker Units in Place</h4>
						<p>With a partner, lift each locker unit and hang it on the wall cleats. Start from one end and work your way across. Once each unit is on the cleat, use the provided connecting bolts to join adjacent units together. Check level after every 2 or 3 units.</p>
						<div class="ig-tip">
							<strong>Tip:</strong> Have one person hold the unit against the wall while the other checks the level and secures the connection. A rubber mallet helps seat units firmly on the cleats.
						</div>
					</div>
				</div>

				<div class="ig-step">
					<div class="ig-step-num">5</div>
					<div class="ig-step-body">
						<h4>Install Accessories &amp; Hardware</h4>
						<p>Attach hooks, shelves, name plates, lock boxes, and any other accessories per your design layout. Predrilled holes are provided for standard accessories. For custom accessories, refer to the included spec sheet for recommended screw sizes and positions.</p>
					</div>
				</div>

				<div class="ig-step">
					<div class="ig-step-num">6</div>
					<div class="ig-step-body">
						<h4>Final Adjustments &amp; Inspection</h4>
						<p>Walk the entire run of lockers and verify every unit is level, all connections are tight, and all accessories are secure. Open and close any doors or drawers to confirm smooth operation. Tighten any loose hardware. Remove protective film from surfaces.</p>
						<div class="ig-tip">
							<strong>Tip:</strong> Take photos of the completed installation from multiple angles. These are great for your records, and we'd love to see them too. Email them to <a href="mailto:team@playerstall.com">team@playerstall.com</a> and we may feature your locker room in our gallery.
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Troubleshooting -->
	<section class="ig-troubleshoot">
		<div class="container">
			<div class="ig-section-header">
				<p class="ig-label">common questions</p>
				<h2 class="ig-heading">Troubleshooting</h2>
			</div>
			<div class="ig-faq-list">
				<div class="ig-faq-item active">
					<div class="ig-faq-q">
						<span>Lockers are not sitting level</span>
						<span class="ig-faq-toggle">+</span>
					</div>
					<div class="ig-faq-a">
						<p>First, verify your wall cleats are level. If the cleats are level but the lockers aren't sitting evenly, use shims between the cleat and the locker. For uneven floors, use leveling feet (available as an accessory) or shim the base. Always check with a level after each adjustment.</p>
					</div>
				</div>
				<div class="ig-faq-item">
					<div class="ig-faq-q">
						<span>Hardware doesn't seem to fit</span>
						<span class="ig-faq-toggle">+</span>
					</div>
					<div class="ig-faq-a">
						<p>Verify you're using the correct hardware packet for that specific component (packets are labeled). If a pre drilled hole doesn't line up, don't force the screw. Give us a call and we'll sort it out. It may be a simple misalignment that can be corrected.</p>
					</div>
				</div>
				<div class="ig-faq-item">
					<div class="ig-faq-q">
						<span>Shipping damage found after unpacking</span>
						<span class="ig-faq-toggle">+</span>
					</div>
					<div class="ig-faq-a">
						<p>Photograph the damage and the packaging. Contact us within 48 hours at <a href="tel:+18885841444">1 888 584 1444</a> or <a href="mailto:team@playerstall.com">team@playerstall.com</a>. Because of our modular design, individual panels and components can be replaced without swapping out the whole locker. We'll get replacement parts out to you right away.</p>
					</div>
				</div>
				<div class="ig-faq-item">
					<div class="ig-faq-q">
						<span>Wall studs don't align with cleat holes</span>
						<span class="ig-faq-toggle">+</span>
					</div>
					<div class="ig-faq-a">
						<p>Our cleats have multiple mounting points, but if your stud spacing is nonstandard, you can drill additional holes in the steel cleat. Use a metal rated drill bit and ensure each cleat hits at least two studs. For drywall only areas, use heavy duty toggle bolts rated for the load.</p>
					</div>
				</div>
				<div class="ig-faq-item">
					<div class="ig-faq-q">
						<span>Doors or drawers are sticking</span>
						<span class="ig-faq-toggle">+</span>
					</div>
					<div class="ig-faq-a">
						<p>This is usually caused by the locker not being perfectly level. Recheck level and adjust shims or cleats as needed. If the unit is level and doors still stick, check that connecting bolts between adjacent units are not pulling the frame out of square. Loosen slightly and retighten.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA / Support -->
	<section class="ig-cta">
		<div class="container">
			<div class="ig-cta-content">
				<h2>Still Need Help?</h2>
				<p>Our team is here to help anytime during installation. We've helped thousands of facilities get set up and we're happy to walk you through any step.</p>
				<div class="ig-cta-buttons">
					<a href="mailto:team@playerstall.com" class="btn btn-primary btn-large">Email Us</a>
				</div>
				<p class="ig-cta-links">
					<a href="/warranty">Warranty &amp; Care</a> &middot;
					<a href="/how-it-works">How It Works</a> &middot;
					<a href="/contact">Contact Us</a>
				</p>
			</div>
		</div>
	</section>

</BaseLayout>

<style>
	.container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Hero */
	.ig-hero {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}

	.ig-hero-bg {
		position: absolute;
		top: 0; left: 0; width: 100%; height: 100%;
		z-index: 0; overflow: hidden;
	}

	.ig-hero-image {
		width: 100%; height: 100%;
		object-fit: cover;
		filter: grayscale(100%);
	}

	.ig-hero-overlay {
		position: absolute;
		top: 0; left: 0; right: 0; bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.ig-hero-container {
		position: relative; z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		width: 100%;
	}

	.ig-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}

	.ig-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.ig-breadcrumbs a:hover { color: #fe5900; }

	.ig-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.ig-hero-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0; line-height: 1.1;
	}

	/* Common */
	.ig-label {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		margin-bottom: -3px;
		display: block;
	}

	.ig-heading {
		font-family: 'Oswald', sans-serif;
		font-size: 48px;
		font-weight: 600;
		color: #000000;
		text-transform: uppercase;
		margin: 15px 0;
		letter-spacing: 1px;
	}

	.ig-section-header {
		text-align: center;
		margin-bottom: 50px;
	}

	/* Intro */
	.ig-intro {
		padding: 80px 0 60px;
		background: #ffffff;
	}

	.ig-intro-content {
		text-align: center;
		max-width: 720px;
		margin: 0 auto;
	}

	.ig-intro-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #666666;
		line-height: 1.8;
		margin: 0 0 32px;
	}

	.ig-support-banner {
		display: inline-block;
		background: #f7f7f7;
		border: 1px solid #e0e0e0;
		border-left: 3px solid #fe5900;
		padding: 16px 24px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #0d0d0d;
	}

	.ig-support-banner a {
		color: #fe5900;
		text-decoration: none;
		font-weight: 500;
	}

	.ig-support-banner a:hover {
		text-decoration: underline;
	}

	/* Checklist */
	.ig-checklist {
		padding: 80px 0;
		background: #f7f7f7;
	}

	.ig-checklist-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 40px;
		max-width: 960px;
		margin: 0 auto;
	}

	.ig-check-group {
		background: #ffffff;
		padding: 32px;
		border: 1px solid #e8e8e8;
	}

	.ig-check-group h4 {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 20px;
	}

	.ig-check-group ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.ig-check-group li {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #444444;
		line-height: 1.6;
		padding: 8px 0 8px 28px;
		position: relative;
		border-bottom: 1px solid #f0f0f0;
	}

	.ig-check-group li:last-child {
		border-bottom: none;
	}

	.ig-check-group li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 14px;
		width: 16px;
		height: 16px;
		border: 2px solid #e0e0e0;
		border-radius: 3px;
	}

	/* Installation Steps */
	.ig-steps {
		padding: 80px 0;
		background: #ffffff;
	}

	.ig-step-list {
		max-width: 800px;
		margin: 0 auto;
	}

	.ig-step {
		display: flex;
		gap: 24px;
		margin-bottom: 48px;
	}

	.ig-step:last-child {
		margin-bottom: 0;
	}

	.ig-step-num {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		background: #fe5900;
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: 'Oswald', sans-serif;
		font-size: 24px;
		font-weight: 700;
		flex-shrink: 0;
	}

	.ig-step-body {
		flex: 1;
		padding-top: 8px;
	}

	.ig-step-body h4 {
		font-family: 'Oswald', sans-serif;
		font-size: 24px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 12px;
	}

	.ig-step-body p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #666666;
		line-height: 1.8;
		margin: 0 0 16px;
	}

	.ig-step-body a {
		color: #fe5900;
		text-decoration: none;
	}

	.ig-step-body a:hover {
		text-decoration: underline;
	}

	.ig-tip {
		background: #f7f7f7;
		border-left: 3px solid #fe5900;
		padding: 16px 20px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #444444;
		line-height: 1.6;
	}

	/* Troubleshooting FAQ */
	.ig-troubleshoot {
		padding: 80px 0;
		background: #f7f7f7;
	}

	.ig-faq-list {
		max-width: 800px;
		margin: 0 auto;
	}

	.ig-faq-item {
		border-bottom: 1px solid #e0e0e0;
		background: #ffffff;
		margin-bottom: 8px;
	}

	.ig-faq-q {
		padding: 20px 24px;
		cursor: pointer;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		transition: color 0.3s;
	}

	.ig-faq-q:hover { color: #fe5900; }
	.ig-faq-item.active .ig-faq-q { color: #fe5900; }

	.ig-faq-toggle {
		font-size: 24px;
		font-weight: 400;
		transition: transform 0.3s;
		flex-shrink: 0;
		margin-left: 16px;
	}

	.ig-faq-item.active .ig-faq-toggle {
		transform: rotate(45deg);
	}

	.ig-faq-a {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease;
	}

	.ig-faq-item.active .ig-faq-a {
		max-height: 400px;
	}

	.ig-faq-a p {
		padding: 0 24px 20px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #666666;
		line-height: 1.8;
		margin: 0;
	}

	.ig-faq-a a {
		color: #fe5900;
		text-decoration: none;
	}

	.ig-faq-a a:hover { text-decoration: underline; }

	/* CTA */
	.ig-cta {
		padding: 80px 0;
		background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 100%);
		text-align: center;
	}

	.ig-cta-content {
		max-width: 640px;
		margin: 0 auto;
	}

	.ig-cta-content h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 42px;
		font-weight: 600;
		color: #ffffff;
		margin: 0 0 16px;
	}

	.ig-cta-content > p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #b6b6b6;
		line-height: 1.7;
		margin: 0 0 32px;
	}

	.ig-cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 24px;
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 1.8rem;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 500;
		letter-spacing: 0.1em;
		font-size: 0.85rem;
		transition: all 0.3s;
