---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';

const post = {
	title: 'How to Choose Sports Lockers: Complete 2025 Buying Guide',
	description:
		'Everything you need to know to make the right choice for your athletic facility. From sizing to materials to customization, this comprehensive guide covers it all.',
	category: 'Planning',
	datePublished: '2025-01-20',
	readTime: '9 min read',
	author: 'PlayerStall Editorial Team',
	slug: 'how-to-choose-sports-lockers-2025',
	wordCount: 2000
};

const faqItems = [
	{
		question: 'What locker width should I choose for my sport?',
		answer:
			'Standard widths: 12" for minimal storage, 15" for most sports, 18" for football and hockey with heavy equipment, 24" for premium maximum storage. Consider your sport\'s equipment—football and hockey typically need 18" minimum; basketball can use 15".'
	},
	{
		question: 'Wood vs metal lockers—which is better long-term?',
		answer:
			'Wood lockers offer 15-20 year lifespan, unlimited customization, modular repair, no rust, and premium aesthetic. Metal lockers have lower initial cost but are prone to dents and rust, limited customization, and 10-15 year lifespan. For long-term installations and custom branding, wood delivers better value.'
	},
	{
		question: 'How do I choose the right product tier?',
		answer:
			'Semi Pro ($349) suits high schools and budget-conscious facilities. Varsity ($449) is most popular for collegiate programs. Pro ($549) for professional and elite programs. Stadium ($599) for championship-caliber facilities. All tiers include full 3/4" Birch construction and 5 year warranty.'
	}
];

const content = `<p>This is a draft blog post. Content coming soon.</p>`;
const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Article',
			headline: post.title,
			description: post.description,
			datePublished: post.datePublished,
			dateModified: post.datePublished,
			wordCount: post.wordCount,
			author: { '@type': 'Organization', name: post.author },
			publisher: { '@type': 'Organization', name: 'PlayerStall', logo: { '@type': 'ImageObject', url: 'https://playerstall.com/images/logoblack2.png' } },
			mainEntityOfPage: { '@type': 'WebPage', '@id': `https://playerstall.com/blog/${post.slug}` }
		},
		{ '@type': 'FAQPage', mainEntity: faqItems.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })) }
	]
};
---

<BlogPostLayout
  title={post.title}
  description={post.description}
  category={post.category}
  datePublished={post.datePublished}
  readTime={post.readTime}
  author={post.author}
  tags={['Planning', 'Sports Lockers']}
>
  <Fragment set:html={content} />
</BlogPostLayout>

