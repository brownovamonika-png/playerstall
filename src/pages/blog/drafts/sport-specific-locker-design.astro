---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';

const post = {
	title: 'Sport-Specific Locker Design: Meeting Each Sport\'s Unique Needs',
	description:
		'Every sport has unique equipment needs. Learn how to design lockers for football, basketball, hockey, baseball, and soccer with sport-specific configurations that maximize organization and functionality.',
	category: 'Design',
	datePublished: '2024-11-15',
	readTime: '10 min read',
	author: 'PlayerStall Editorial Team',
	slug: 'sport-specific-locker-design',
	wordCount: 2100
};

const faqItems = [
	{
		question: 'What locker configuration is best for football?',
		answer:
			'Football needs Varsity or Pro tier, 18" width minimum, lift-up seat with ventilation for wet cleats, multiple hanging rods for uniforms, and extra hooks for pads and equipment. Custom team colors and branding complete the setup.'
	},
	{
		question: 'Why do hockey lockers need special ventilation?',
		answer:
			'Hockey equipment gets wet and must dry to prevent odors and damage. Use Varsity or Pro tier with maximum ventilation: lift-up seat with ventilation grill, adequate room air circulation, and hockey stick racks. See our hockey locker room guide for full details.'
	},
	{
		question: 'Can one facility serve multiple sports?',
		answer:
			'Yes. Use flexible design with lockers that adapt to different sports, modular components for reconfiguration, universal features that work for all sports, and sport-specific zones when possible. Our free design consultation helps plan multi-sport layouts.'
	}
];

const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Article',
			headline: post.title,
			description: post.description,
			datePublished: post.datePublished,
			dateModified: post.datePublished,
			wordCount: post.wordCount,
			author: { '@type': 'Organization', name: post.author },
			publisher: { '@type': 'Organization', name: 'PlayerStall', logo: { '@type': 'ImageObject', url: 'https://playerstall.com/images/logoblack2.png' } },
			mainEntityOfPage: { '@type': 'WebPage', '@id': `https://playerstall.com/blog/${post.slug}` }
		},
		{ '@type': 'FAQPage', mainEntity: faqItems.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })) }
	]
};
---

<BlogPostLayout
  title={post.title}
  description={post.description}
  category={post.category}
  datePublished={post.datePublished}
  readTime={post.readTime}
  author={post.author}
  tags={['Design', 'Sports Lockers']}
>
  <Fragment set:html={content} />
</BlogPostLayout>

