---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';

const post = {
	title: 'Wood vs Metal Sports Lockers: The Complete 2025 Comparison Guide',
	description:
		'After 30+ years in the business, we\'ve seen it all. Here\'s the truth about wood vs metal lockers—what works, what doesn\'t, and why wood is making a comeback in modern athletic facilities.',
	category: 'Design',
	datePublished: '2025-01-15',
	readTime: '11 min read',
	author: 'PlayerStall Editorial Team',
	slug: 'wood-vs-metal-sports-lockers-comparison',
	wordCount: 2500
};

const faqItems = [
	{
		question: 'Are wood lockers really more durable than metal?',
		answer:
			'Yes, when properly maintained. Our 3/4" Birch wood lockers resist dents and scratches, don\'t rust, and with modular design allow individual part replacement. They typically last 15+ years. Metal lockers dent easily, rust in humid environments, and often need full replacement every 8-10 years.'
	},
	{
		question: 'What is the 15-year total cost of wood vs metal lockers?',
		answer:
			'For a typical 50-locker installation, metal can total $59,200 over 15 years (including replacement at year 8 and higher maintenance). Wood lockers total about $32,950 with no replacement—saving roughly $1,750 per year. See our ROI article for the full breakdown.'
	},
	{
		question: 'When might metal lockers make sense?',
		answer:
			'Metal can make sense for extremely tight budgets, temporary or short-term facilities, or high-security environments requiring specific metal features. For most athletic programs planning a long-term facility, wood delivers better value, culture, and recruiting impact.'
	}
];

const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Article',
			headline: post.title,
			description: post.description,
			datePublished: post.datePublished,
			dateModified: post.datePublished,
			wordCount: post.wordCount,
			author: { '@type': 'Organization', name: post.author },
			publisher: { '@type': 'Organization', name: 'PlayerStall', logo: { '@type': 'ImageObject', url: 'https://playerstall.com/images/logoblack2.png' } },
			mainEntityOfPage: { '@type': 'WebPage', '@id': `https://playerstall.com/blog/${post.slug}` }
		},
		{ '@type': 'FAQPage', mainEntity: faqItems.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })) }
	]
};
---

<BlogPostLayout
  title={post.title}
  description={post.description}
  category={post.category}
  datePublished={post.datePublished}
  readTime={post.readTime}
  author={post.author}
  tags={['Design', 'Sports Lockers']}
>
  <Fragment set:html={content} />
</BlogPostLayout>

