---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';

const post = {
	title: 'College Athletic Facilities: Choosing the Right Locker Solution',
	description:
		'Complete guide for college athletic facilities choosing locker solutions. Learn about budget planning, multi-sport needs, and creating facilities that support recruiting and team success.',
	category: 'College Athletics',
	datePublished: '2024-11-20',
	readTime: '8 min read',
	author: 'PlayerStall Editorial Team',
	slug: 'college-facilities-locker-solution',
	wordCount: 1850
};

const faqItems = [
	{
		question: 'How much should a college program budget for new custom lockers?',
		answer:
			'Most Division I and II programs earmark $400-$700 per locker depending on finishes, integrated power, and branding. We recommend planning across multiple tiers so non-revenue sports can leverage Semi Pro or Varsity lines while football or basketball invests in Pro or Stadium.'
	},
	{
		question: 'What timeline should athletic directors expect for locker room renovations?',
		answer:
			'Custom orders are built in three months from deposit, with 2-4 weeks for shipping, install, and punch-list. Quick ship options (24" or 30" widths, one signature color) ship in one month. 50% deposit required to begin custom production. Start conversations early if you need completion before fall camp or postseason play.'
	},
	{
		question: 'How do we keep multi-sport locker rooms compliant with NCAA and ADA standards?',
		answer:
			'Build at least 5% of lockers with ADA-compliant dimensions, integrate anti-microbial ventilation, and coordinate with campus facilities to confirm egress, lighting, and security specs. Partnering with a custom shop ensures drawings are stamped against NCAA guidance before fabrication.'
	}
];

const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Article',
			headline: post.title,
			description: post.description,
			datePublished: post.datePublished,
			dateModified: post.datePublished,
			wordCount: post.wordCount,
			author: {
				'@type': 'Organization',
				name: post.author
			},
			publisher: {
				'@type': 'Organization',
				name: 'PlayerStall',
				logo: {
					'@type': 'ImageObject',
					url: 'https://playerstall.com/images/logoblack2.png'
				}
			},
			mainEntityOfPage: {
				'@type': 'WebPage',
				'@id': `https://playerstall.com/blog/${post.slug}`
			}
		},
		{
			'@type': 'FAQPage',
			mainEntity: faqItems.map((item) => ({
				'@type': 'Question',
				name: item.question,
				acceptedAnswer: {
					'@type': 'Answer',
					text: item.answer
				}
			}))
		}
	]
};
---

<BlogPostLayout
  title={post.title}
  description={post.description}
  category={post.category}
  datePublished={post.datePublished}
  readTime={post.readTime}
  author={post.author}
  tags={['College Athletics', 'Sports Lockers']}
>
  <Fragment set:html={content} />
</BlogPostLayout>

