---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getBlogHeroUrl } from '../../../lib/blog-hero';
import { slugify } from '../../../lib/slug';

export async function getStaticPaths() {
  const allEntries = await getCollection('blog');
  const periodSet = new Set<string>();
  for (const entry of allEntries) {
    const d = new Date(entry.data.datePublished + 'T12:00:00');
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth() + 1).padStart(2, '0');
    periodSet.add(`${yyyy}-${mm}`);
  }
  return Array.from(periodSet).sort((a, b) => b.localeCompare(a)).map((period) => ({
    params: { period },
  }));
}

const { period } = Astro.params;
if (!period || !/^\d{4}-\d{2}$/.test(period)) {
  return Astro.redirect('/blog');
}

const [yearStr, monthStr] = period.split('-');
const year = parseInt(yearStr!, 10);
const month = parseInt(monthStr!, 10);

const allEntries = await getCollection('blog');
const posts = allEntries
  .filter((entry) => {
    const d = new Date(entry.data.datePublished + 'T12:00:00');
    return d.getFullYear() === year && d.getMonth() + 1 === month;
  })
  .map((entry) => {
    const dateObj = new Date(entry.data.datePublished + 'T12:00:00');
    return {
      title: entry.data.title,
      date: dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
      category: entry.data.category || 'Blog',
      summary: (entry.data.description || entry.data.title).slice(0, 200) + '…',
      heroImage: getBlogHeroUrl({ slug: entry.slug, heroImage: entry.data.heroImage, category: entry.data.category, tags: entry.data.tags }),
      url: `/blog/${entry.slug}`,
      dateSort: dateObj.getTime(),
    };
  })
  .sort((a, b) => b.dateSort - a.dateSort);

const monthLabel = new Date(year, month - 1, 1).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const pageTitle = `Blog archives: ${monthLabel} | PlayerStall`;
const pageDescription = `Blog posts from PlayerStall published in ${monthLabel}.`;

const archivesByMonth = allEntries
  .map((entry) => {
    const dateObj = new Date(entry.data.datePublished + 'T12:00:00');
    const yyyy = dateObj.getFullYear();
    const mm = String(dateObj.getMonth() + 1).padStart(2, '0');
    return {
      archiveSlug: `${yyyy}-${mm}`,
      monthLabel: dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'short' }),
    };
  })
  .reduce<{ archiveSlug: string; monthLabel: string }[]>((acc, item) => {
    if (!acc.some((g) => g.archiveSlug === item.archiveSlug)) acc.push(item);
    return acc;
  }, [])
  .sort((a, b) => b.archiveSlug.localeCompare(a.archiveSlug));
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="blog-hero-section">
    <div class="blog-hero-background">
      <img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Blog archives" class="blog-hero-bg-image" />
    </div>
    <div class="blog-hero-background-overlay"></div>
    <div class="blog-hero-container">
      <div class="blog-breadcrumbs">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <span>Archives · {monthLabel}</span>
      </div>
      <h1 class="blog-page-title">Archives: {monthLabel}</h1>
      <div class="blog-background-text">archives</div>
    </div>
  </section>

  <section class="blog-content-section" id="blog-posts">
    <div class="blog-container">
      <main class="blog-main">
        {posts.length === 0 ? (
          <p class="archive-empty">No posts found for this month.</p>
        ) : (
          <div class="blog-mosaic">
            {posts.map((post, index) => (
              <article class={index === 0 ? 'blog-card featured' : 'blog-card'}>
                <div class="blog-card-meta">
                  <a href={`/categories/${slugify(post.category)}`} class="blog-card-category">{post.category}</a>
                  <span class="blog-card-date">{post.date}</span>
                </div>
                <a href={post.url} class="blog-card-link">
                  <div class="blog-card-image">
                    <img src={post.heroImage} alt={post.title} loading="lazy" />
                  </div>
                  <div class="blog-card-body">
                    <h2 class="blog-card-title">{post.title}</h2>
                    <p class="blog-card-excerpt">{post.summary}</p>
                    <span class="blog-card-cta">Read More</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        )}
      </main>

      <aside class="blog-sidebar">
        <nav class="sidebar-block sidebar-archives" aria-label="Archives by date">
          <h3 class="sidebar-title">Archives</h3>
          <ul class="archives-list">
            {archivesByMonth.map((group) => (
              <li>
                <a href={`/blog/archives/${group.archiveSlug}`} class={`archive-link${group.archiveSlug === period ? ' active' : ''}`}>
                  {group.monthLabel}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <p class="sidebar-back">
          <a href="/blog">← Back to Blog</a>
        </p>
      </aside>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Have Questions About Your Locker Room Project?</h2>
        <p>Get expert advice from 30+ years of experience. Free custom design consultation.</p>
        <a href="/contact" class="btn btn-primary btn-large">Get Free Consultation</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(body) {
    font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
    background: #ffffff;
    color: #0d0d0d;
    margin: 0;
    padding: 0;
    line-height: 1.6;
  }

  .blog-container,
  .cta-section .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .blog-hero-section {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 0 80px;
    overflow: hidden;
    min-height: 320px;
    width: 100%;
    max-width: none;
    margin: 0;
  }

  .blog-hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
  }

  .blog-hero-bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    filter: grayscale(100%);
  }

  .blog-hero-background-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.2);
    z-index: 1;
  }

  .blog-hero-container {
    position: relative;
    z-index: 10;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: left;
    width: 100%;
  }

  .blog-breadcrumbs {
    font-family: 'Yantramanav', sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.85);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 30px;
  }

  .blog-breadcrumbs a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 0.3s;
  }

  .blog-breadcrumbs a:hover {
    color: #fe5900;
  }

  .blog-breadcrumbs span {
    margin-left: 10px;
    color: #ffffff;
  }

  .blog-page-title {
    font-family: 'Oswald', sans-serif;
    font-size: 72px;
    font-weight: 600;
    color: #ffffff;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.1;
    position: relative;
    z-index: 10;
  }

  .blog-background-text {
    display: none;
  }

  .blog-content-section {
    background: #ffffff;
    padding: 48px 0 64px;
  }

  .blog-container {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
    gap: 48px;
    align-items: start;
  }

  .blog-main {
    min-width: 0;
  }

  .archive-empty {
    font-family: 'Yantramanav', sans-serif;
    font-size: 18px;
    color: #666;
    margin: 0;
  }

  .blog-mosaic {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    grid-auto-rows: minmax(220px, auto);
  }

  .blog-card.featured {
    grid-column: span 2;
    grid-row: span 2;
  }

  .blog-card.featured .blog-card-image {
    aspect-ratio: 16 / 9;
  }

  .blog-card.featured .blog-card-body {
    padding: 24px;
  }

  .blog-card.featured .blog-card-title {
    font-size: 24px;
  }

  .blog-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 6px;
    overflow: hidden;
    transition: box-shadow 0.25s, border-color 0.25s;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .blog-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .blog-card-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #f0f0f0;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s;
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.04);
  }

  .blog-card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-card > .blog-card-meta {
    padding: 12px 20px 0;
  }

  .blog-card.featured > .blog-card-meta {
    padding: 12px 24px 0;
  }

  .blog-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 10px;
    font-family: 'Yantramanav', sans-serif;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8c8c8c;
  }

  .blog-card-category {
    color: #fe5900;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
  }

  .blog-card-category:hover {
    color: #e04d00;
    text-decoration: underline;
  }

  .blog-card-date {
    color: #8c8c8c;
  }

  .blog-card-title {
    font-family: 'Oswald', sans-serif;
    font-size: 20px;
    font-weight: 600;
    line-height: 1.35;
    color: #0d0d0d;
    margin: 0 0 10px;
    transition: color 0.25s;
  }

  .blog-card:hover .blog-card-title {
    color: #fe5900;
  }

  .blog-card-excerpt {
    font-family: 'Yantramanav', sans-serif;
    font-size: 14px;
    color: #666;
    line-height: 1.55;
    margin: 0 0 12px;
    flex: 1;
  }

  .blog-card-cta {
    font-family: 'Yantramanav', sans-serif;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    color: #0d0d0d;
    transition: color 0.25s;
  }

  .blog-card:hover .blog-card-cta {
    color: #fe5900;
  }

  .blog-sidebar {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .sidebar-block {
    background: #f8f8f8;
    border: 1px solid #e8e8e8;
    border-radius: 6px;
    padding: 20px;
  }

  .sidebar-title {
    font-family: 'Oswald', sans-serif;
    font-size: 18px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #0d0d0d;
    margin: 0 0 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid #fe5900;
  }

  .archives-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .archives-list li {
    margin-bottom: 10px;
    font-size: 14px;
    line-height: 1.4;
  }

  .archives-list li:last-child {
    margin-bottom: 0;
  }

  .archive-link {
    color: #0d0d0d;
    text-decoration: none;
    display: block;
    padding: 6px 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    font-family: 'Yantramanav', sans-serif;
  }

  .archive-link:hover,
  .archive-link.active {
    color: #fe5900;
    border-bottom-color: #fe5900;
  }

  .sidebar-back {
    margin: 0;
    font-size: 14px;
  }

  .sidebar-back a {
    color: #fe5900;
    text-decoration: none;
    font-weight: 500;
  }

  .sidebar-back a:hover {
    text-decoration: underline;
  }

  .btn {
    display: inline-block;
    padding: 15px 40px;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 0.1em;
    font-size: 20px;
    transition: all 0.3s;
    font-family: 'Roboto', sans-serif;
  }

  .btn-primary {
    background: #fe5900;
    color: #ffffff;
    border: 2px solid #fe5900;
  }

  .btn-primary:hover {
    background: #e04d00;
    border-color: #e04d00;
  }

  .cta-section {
    padding: 5rem 0;
    background: #0d0d0d;
    color: #fff;
    text-align: center;
  }

  .cta-content h2 {
    font-family: 'Oswald', sans-serif;
    font-size: 48px;
    font-weight: 600;
    color: #fff;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .cta-content p {
    font-family: 'Yantramanav', sans-serif;
    font-size: 20px;
    color: #ccc;
    margin-bottom: 2rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.8;
  }

  .btn-large {
    padding: 18px 50px;
    font-size: 18px;
  }

  @media (max-width: 1024px) {
    .blog-container {
      grid-template-columns: 1fr;
    }

    .blog-mosaic {
      grid-template-columns: 1fr;
    }

    .blog-card.featured {
      grid-column: span 1;
      grid-row: span 1;
    }

    .blog-sidebar {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .blog-hero-section {
      min-height: 300px;
    }

    .blog-page-title {
      font-size: 42px;
    }

    .blog-mosaic {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .cta-content h2 {
      font-size: 36px;
    }
  }

  @media (max-width: 480px) {
    .blog-page-title {
      font-size: 32px;
    }
  }
</style>
