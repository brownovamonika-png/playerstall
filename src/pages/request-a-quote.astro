---
import BaseLayout from '../layouts/BaseLayout.astro';

const thankYouUrl = `${Astro.url.origin}/thank-you`;
---

<BaseLayout
	title="Request a Quote | Custom Sports Lockers | PlayerStall"
	description="Request a quote for custom sports lockers. Tell us your project details, locker requirements, and attach drawings. Free design consultation. 30+ years experience, serving USA and Canada."
>
	<!-- Hero Section (same as original contact/quote page) -->
	<section class="contact-hero-section" id="hero">
		<div class="contact-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Request a Quote from PlayerStall" class="contact-hero-bg-image" />
		</div>
		<div class="contact-hero-background-overlay"></div>
		<div class="contact-hero-container">
			<div class="contact-hero-breadcrumbs">
				<a href="/">Home</a>
				<span>Request a Quote</span>
			</div>
			<h1 class="contact-hero-page-title">Request a Quote</h1>
			<div class="contact-hero-background-text">quote</div>
		</div>
	</section>

	<!-- Journey Progress Bar -->
	<section class="raq-journey">
		<div class="container">
			<div class="raq-journey-track">
				<div class="raq-journey-step raq-done">
					<div class="raq-journey-dot"></div>
					<span>Explore</span>
				</div>
				<div class="raq-journey-connector raq-connector-done"></div>
				<div class="raq-journey-step raq-active">
					<div class="raq-journey-dot"></div>
					<span>Consultation</span>
				</div>
				<div class="raq-journey-connector"></div>
				<div class="raq-journey-step">
					<div class="raq-journey-dot"></div>
					<span>Design &amp; Quote</span>
				</div>
				<div class="raq-journey-connector"></div>
				<div class="raq-journey-step">
					<div class="raq-journey-dot"></div>
					<span>Approval</span>
				</div>
				<div class="raq-journey-connector"></div>
				<div class="raq-journey-step">
					<div class="raq-journey-dot"></div>
					<span>Production</span>
				</div>
				<div class="raq-journey-connector"></div>
				<div class="raq-journey-step">
					<div class="raq-journey-dot"></div>
					<span>Shipping</span>
				</div>
				<div class="raq-journey-connector"></div>
				<div class="raq-journey-step">
					<div class="raq-journey-dot"></div>
					<span>Installation</span>
				</div>
			</div>
			<p class="raq-journey-note">Step 2 of 7 &middot; <a href="/how-it-works">See the full journey</a></p>
		</div>
	</section>

	<section class="contact-section">
		<div class="container container-center">
			<div class="contact-header">
				<h2>Request a Quote</h2>
				<p>Have questions? Need a quote? Tell us about your locker room project and we'll get back to you within 24 hours.</p>
			</div>

			<!-- Form + Sidebar Layout -->
			<div class="raq-layout">

			<!-- What to Expect Sidebar -->
			<aside class="raq-sidebar">
				<div class="raq-sidebar-card">
					<h3>What to Expect</h3>
					<div class="raq-expect-steps">
						<div class="raq-expect-step">
							<div class="raq-expect-num">1</div>
							<div>
								<strong>You submit this form</strong>
								<p>Tell us about your project: sport, quantities, timeline, and budget.</p>
							</div>
						</div>
						<div class="raq-expect-step">
							<div class="raq-expect-num">2</div>
							<div>
								<strong>We review within 24 hours</strong>
								<p>One of our team gets assigned to your project and reaches out.</p>
							</div>
						</div>
						<div class="raq-expect-step">
							<div class="raq-expect-num">3</div>
							<div>
								<strong>Custom quote in 2 to 3 days</strong>
								<p>You get a detailed layout and itemized pricing built around your space.</p>
							</div>
						</div>
						<div class="raq-expect-step">
							<div class="raq-expect-num">4</div>
							<div>
								<strong>Refine until you love it</strong>
								<p>Unlimited revisions at no cost. 50% deposit starts production.</p>
							</div>
						</div>
					</div>
				</div>
				<div class="raq-sidebar-support">
					<strong>Need help now?</strong>
					<p>Call <a href="tel:+18885841444">1 888 584 1444</a> or email <a href="mailto:team@playerstall.com">team@playerstall.com</a></p>
				</div>
				<div class="raq-sidebar-promise">
					<div class="raq-promise-item">Free consultation, no obligation</div>
					<div class="raq-promise-item">30+ years of experience</div>
					<div class="raq-promise-item">5 year warranty on every locker</div>
					<div class="raq-promise-item">Custom-built in 8 to 12 weeks</div>
				</div>
			</aside>

			<div class="quote-form-wrapper" id="quote-form">
				<h2>Tell us about your project</h2>
				<p class="form-intro">Fields marked with <span class="required">*</span> are required.</p>

				<form class="quote-form" action="https://formspree.io/f/xqedgojb" method="POST" enctype="multipart/form-data">
					<input type="hidden" name="_next" value={thankYouUrl} />
					<input type="hidden" name="_subject" value="New Quote Request from PlayerStall" />
					<div class="form-section">
						<h3>Project &amp; Locker Details</h3>
						<div class="form-group">
							<label for="requirements">Locker requirements, dimensions &amp; quantities <span class="required">*</span></label>
							<textarea id="requirements" name="requirements" rows="6" maxlength="1000" required placeholder="Examples: 60 football lockers for home team"></textarea>
							<div class="helper-row">
								<small id="requirements-count">1000 characters left</small>
							</div>
						</div>
						<div class="form-row">
							<div class="form-group">
								<label for="sport">Primary sport</label>
								<select id="sport" name="sport">
									<option value="">Select sport</option>
									<option value="football">Football</option>
									<option value="hockey">Hockey</option>
									<option value="basketball">Basketball</option>
									<option value="baseball">Baseball</option>
									<option value="soccer">Soccer</option>
									<option value="lacrosse">Lacrosse</option>
									<option value="multi-sport">Multi-sport facility</option>
									<option value="other">Other / Not listed</option>
								</select>
							</div>
							<div class="form-group">
								<label for="project-reference">Project reference (optional)</label>
								<input type="text" id="project-reference" name="projectReference" placeholder="E.g. 2026 Varsity Locker Room Renovation" />
							</div>
						</div>
						<div class="form-row">
							<div class="form-group">
								<label for="timeline">When do you need your lockers? <span class="required">*</span></label>
								<select id="timeline" name="timeline" required>
									<option value="">Select timeline</option>
									<option value="immediately">Immediately</option>
									<option value="2-3-weeks">In 2 to 3 weeks</option>
									<option value="1-2-months">In 1 to 2 months</option>
									<option value="3-plus-months">In 3+ months</option>
									<option value="undetermined">Not sure yet</option>
								</select>
							</div>
							<div class="form-group">
								<label for="budget">Estimated budget (optional)</label>
								<input type="text" id="budget" name="budget" placeholder="Approximate budget range" />
							</div>
						</div>
					</div>

					<div class="form-section">
						<h3>Contact &amp; Organization Details</h3>
						<div class="form-row">
							<div class="form-group">
								<label for="first-name">First name <span class="required">*</span></label>
								<input type="text" id="first-name" name="firstName" required />
							</div>
							<div class="form-group">
								<label for="last-name">Last name <span class="required">*</span></label>
								<input type="text" id="last-name" name="lastName" required />
							</div>
						</div>
						<div class="form-row">
							<div class="form-group">
								<label for="title">Role / Title</label>
								<input type="text" id="title" name="title" placeholder="Athletic Director, Head Coach, etc." />
							</div>
							<div class="form-group">
								<label for="organization">School / Organization / Team <span class="required">*</span></label>
								<input type="text" id="organization" name="organization" required />
							</div>
						</div>
						<div class="form-row">
							<div class="form-group">
								<label for="quote-email">Email <span class="required">*</span></label>
								<input type="email" id="quote-email" name="email" required />
							</div>
							<div class="form-group">
								<label for="confirm-email">Confirm email <span class="required">*</span></label>
								<input type="email" id="confirm-email" name="confirmEmail" required />
							</div>
						</div>
						<div class="form-group">
							<label for="phone">Phone <span class="required">*</span></label>
							<input type="tel" id="phone" name="phone" required />
						</div>
						<div class="form-row">
							<div class="form-group">
								<label for="country">Country <span class="required">*</span></label>
								<select id="country" name="country" required>
									<option value="">Select country</option>
									<option value="united-states">United States</option>
									<option value="canada">Canada</option>
									<option value="other">Other</option>
								</select>
							</div>
							<div class="form-group">
								<label for="state">State / Province</label>
								<input type="text" id="state" name="state" />
							</div>
						</div>
						<div class="form-row">
							<div class="form-group">
								<label for="city">City <span class="required">*</span></label>
								<input type="text" id="city" name="city" required />
							</div>
							<div class="form-group">
								<label for="postal-code">ZIP / Postal code <span class="required">*</span></label>
								<input type="text" id="postal-code" name="postalCode" required />
							</div>
						</div>
						<div class="form-group">
							<label for="street">Street address <span class="required">*</span></label>
							<input type="text" id="street" name="street" required />
						</div>
						<div class="form-group">
							<label for="street-2">Apt., suite, or floor (optional)</label>
							<input type="text" id="street-2" name="street2" />
						</div>
						<div class="form-group">
							<label for="ship-postal-code">Ship-to ZIP / Postal code (optional)</label>
							<input type="text" id="ship-postal-code" name="shipPostalCode" />
						</div>
					</div>

					<div class="form-section">
						<h3>Drawings &amp; Attachments (optional)</h3>
						<p class="section-helper">
							Attach floor plans, locker room layouts, or inspiration photos to help our team prepare the most accurate quote. For files larger than 10 MB, please email
							<a href="mailto:team@playerstall.com">team@playerstall.com</a>.
						</p>
						<div class="form-group">
							<label for="file-1">Attach document (max 10 MB)</label>
							<input type="file" id="file-1" name="attachment1" />
						</div>
						<div class="form-group">
							<label for="file-2">Attach another document (optional)</label>
							<input type="file" id="file-2" name="attachment2" />
						</div>
						<div class="form-group">
							<label for="file-3">Attach another document (optional)</label>
							<input type="file" id="file-3" name="attachment3" />
						</div>
						<div class="form-group">
							<label for="notes">Anything else we should know?</label>
							<textarea id="notes" name="notes" rows="4" placeholder="Share timing constraints, construction partners, or other project details."></textarea>
						</div>
					</div>

					<div class="form-footer">
						<p class="disclaimer">
							By submitting this form, you agree that a PlayerStall representative may contact you about your project. We will never share your information with third parties.
						</p>
						<button type="submit" class="btn btn-primary">Request your quote</button>
					</div>
				</form>
			</div>

			</div><!-- .raq-layout -->
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #f7f7f7;
		color: #0d0d0d;
	}

	.container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.contact-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}

	.contact-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.contact-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.contact-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.contact-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.contact-hero-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}

	.contact-hero-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.contact-hero-breadcrumbs a:hover {
		color: #fe5900;
	}

	.contact-hero-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.contact-hero-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	.contact-hero-background-text {
		display: none;
	}

	/* Journey Progress Bar */
	.raq-journey {
		padding: 24px 0;
		background: #f7f7f7;
		border-bottom: 1px solid #e8e8e8;
	}

	.raq-journey-track {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0;
		max-width: 800px;
		margin: 0 auto 12px;
		flex-wrap: wrap;
	}

	.raq-journey-step {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
		flex-shrink: 0;
	}

	.raq-journey-dot {
		width: 16px; height: 16px;
		border-radius: 50%;
		background: #e0e0e0;
		border: 2px solid #e0e0e0;
	}

	.raq-done .raq-journey-dot {
		background: #fe5900;
		border-color: #fe5900;
	}

	.raq-active .raq-journey-dot {
		background: #ffffff;
		border-color: #fe5900;
		box-shadow: 0 0 0 3px rgba(254, 89, 0, 0.2);
	}

	.raq-journey-step span {
		font-family: 'Yantramanav', sans-serif;
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #8c8c8c;
		white-space: nowrap;
	}

	.raq-done span,
	.raq-active span {
		color: #0d0d0d;
		font-weight: 600;
	}

	.raq-journey-connector {
		width: 32px;
		height: 2px;
		background: #e0e0e0;
		margin: 0 3px;
		margin-bottom: 20px;
	}

	.raq-connector-done {
		background: #fe5900;
	}

	.raq-journey-note {
		text-align: center;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		margin: 0;
	}

	.raq-journey-note a {
		color: #fe5900;
		text-decoration: none;
		font-weight: 500;
	}

	.raq-journey-note a:hover {
		text-decoration: underline;
	}

	/* Layout with sidebar */
	.raq-layout {
		display: grid;
		grid-template-columns: 280px 1fr;
		gap: 40px;
		max-width: 1060px;
		width: 100%;
		align-items: start;
	}

	.raq-sidebar {
		position: sticky;
		top: 100px;
	}

	.raq-sidebar-card {
		background: #f7f7f7;
		border: 1px solid #e8e8e8;
		padding: 28px;
		margin-bottom: 20px;
	}

	.raq-sidebar-card h3 {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 20px;
	}

	.raq-expect-steps {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.raq-expect-step {
		display: flex;
		gap: 12px;
		align-items: flex-start;
	}

	.raq-expect-num {
		width: 28px; height: 28px;
		border-radius: 50%;
		background: #fe5900;
		color: #fff;
		display: flex; align-items: center; justify-content: center;
		font-family: 'Oswald', sans-serif;
		font-size: 13px; font-weight: 700;
		flex-shrink: 0;
	}

	.raq-expect-step strong {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		display: block;
		margin-bottom: 2px;
	}

	.raq-expect-step p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #666666;
		line-height: 1.5;
		margin: 0;
	}

	.raq-sidebar-support {
		background: #ffffff;
		border: 1px solid #e8e8e8;
		border-left: 3px solid #fe5900;
		padding: 20px;
		margin-bottom: 20px;
	}

	.raq-sidebar-support strong {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		display: block;
		margin-bottom: 4px;
	}

	.raq-sidebar-support p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #666666;
		margin: 0;
	}

	.raq-sidebar-support a {
		color: #fe5900;
		text-decoration: none;
	}

	.raq-sidebar-support a:hover {
		text-decoration: underline;
	}

	.raq-sidebar-promise {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.raq-promise-item {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #444444;
		padding: 10px 0 10px 24px;
		position: relative;
		border-bottom: 1px solid #f0f0f0;
	}

	.raq-promise-item:last-child {
		border-bottom: none;
	}

	.raq-promise-item::before {
		content: '\2713';
		position: absolute;
		left: 0;
		color: #fe5900;
		font-weight: 700;
		font-size: 13px;
	}

	.contact-section {
		padding: 5rem 0;
		background: #ffffff;
	}

	.contact-header {
		text-align: center;
		max-width: 800px;
		margin: 0 auto 4rem;
	}

	.contact-header h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 48px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin-bottom: 1.5rem;
	}

	.contact-header p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #666666;
		line-height: 1.8;
	}

	.quote-process-section {
		width: 100%;
		max-width: 700px;
		margin: 0 auto 3rem;
		padding: 0;
		text-align: center;
	}
	.quote-process-center {
		max-width: 700px;
		margin: 0 auto;
	}
	.quote-process-title {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 1.25rem;
		letter-spacing: 0.02em;
	}
	.quote-process-intro {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #666666;
		line-height: 1.7;
		margin: 0 0 1.5rem;
	}
	.quote-process-steps {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: 0 auto 1.5rem;
		max-width: 520px;
		text-align: center;
	}
	.quote-process-step {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #0d0d0d;
		line-height: 1.5;
		text-align: center;
	}
	.quote-process-support {
		background: #f8f8f8;
		border: 1px solid #e0e0e0;
		padding: 1.25rem 1.5rem;
		font-size: 14px;
		color: #666666;
		display: inline-block;
		text-align: center;
	}
	.quote-process-support a {
		color: #fe5900;
		text-decoration: none;
	}
	.quote-process-support a:hover {
		text-decoration: underline;
	}

	.container-center {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.raq-layout .quote-form-wrapper {
		width: 100%;
		max-width: none;
	}

	.form-group {
		display: flex;
		flex-direction: column;
	}

	.form-group label {
		margin-top: 0.5rem;
		margin-bottom: 0.2rem;
		color: #0d0d0d;
