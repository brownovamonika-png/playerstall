---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getBlogHeroUrl } from '../../lib/blog-hero';
import { slugify } from '../../lib/slug';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  const categorySlugs = new Set<string>();
  for (const entry of entries) {
    const cat = entry.data.category?.trim();
    if (cat) categorySlugs.add(slugify(cat));
  }
  return Array.from(categorySlugs).map((category) => ({ params: { category } }));
}

const { category: categorySlug } = Astro.params;
if (!categorySlug) return Astro.redirect('/blog');

const entries = await getCollection('blog');
const matching = entries.filter((entry) => slugify(entry.data.category ?? '') === categorySlug);

const displayName =
  matching.length > 0 ? (matching[0].data.category ?? categorySlug) : categorySlug.replace(/-/g, ' ');

const posts = matching
  .map((entry) => {
    const dateObj = new Date(entry.data.datePublished + 'T12:00:00');
    return {
      title: entry.data.title,
      date: dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
      category: entry.data.category || 'Blog',
      summary: (entry.data.description || entry.data.title).slice(0, 200) + '…',
      heroImage: getBlogHeroUrl({
        slug: entry.slug,
        heroImage: entry.data.heroImage,
        category: entry.data.category,
        tags: entry.data.tags,
      }),
      url: `/blog/${entry.slug}`,
      dateSort: dateObj.getTime(),
    };
  })
  .sort((a, b) => b.dateSort - a.dateSort);

const title = `Category: ${displayName} | PlayerStall Blog`;
const description = `Browse all blog posts in the ${displayName} category. Sports lockers, locker room design, and athletic facility insights from PlayerStall.`;
---

<BaseLayout title={title} description={description}>
  <section class="blog-hero-section">
    <div class="blog-hero-background">
      <img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="" class="blog-hero-bg-image" />
    </div>
    <div class="blog-hero-background-overlay"></div>
    <div class="blog-hero-container">
      <div class="blog-breadcrumbs">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <span>Category: {displayName}</span>
      </div>
      <h1 class="blog-page-title">Category: {displayName}</h1>
    </div>
  </section>

  <section class="blog-content-section">
    <div class="blog-container">
      <main class="blog-main">
        {posts.length > 0 ? (
          <div class="blog-mosaic">
            {posts.map((post, index) => (
              <article class={index === 0 ? 'blog-card featured' : 'blog-card'}>
                <a href={post.url} class="blog-card-link">
                  <div class="blog-card-image">
                    <img src={post.heroImage} alt={post.title} loading="lazy" />
                  </div>
                  <div class="blog-card-body">
                    <div class="blog-card-meta">
                      <span class="blog-card-category">{post.category}</span>
                      <span class="blog-card-date">{post.date}</span>
                    </div>
                    <h2 class="blog-card-title">{post.title}</h2>
                    <p class="blog-card-excerpt">{post.summary}</p>
                    <span class="blog-card-cta">Read More</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <p class="blog-empty">No posts found in this category.</p>
        )}
      </main>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Have Questions About Your Locker Room Project?</h2>
        <p>Get expert advice from 30+ years of experience. Free custom design consultation.</p>
        <a href="/contact" class="btn btn-primary btn-large">Get Free Consultation</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(body) {
    font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
    background: #ffffff;
    color: #0d0d0d;
    margin: 0;
    padding: 0;
    line-height: 1.6;
  }

  .blog-container,
  .cta-section .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .blog-hero-section {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 0 80px;
    overflow: hidden;
    min-height: 320px;
    width: 100%;
    max-width: none;
    margin: 0;
  }

  .blog-hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
  }

  .blog-hero-bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    filter: grayscale(100%);
  }

  .blog-hero-background-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.2);
    z-index: 1;
  }

  .blog-hero-container {
    position: relative;
    z-index: 10;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: left;
    width: 100%;
  }

  .blog-breadcrumbs {
    font-family: 'Yantramanav', sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.85);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 30px;
  }

  .blog-breadcrumbs a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 0.3s;
  }

  .blog-breadcrumbs a:hover {
    color: #fe5900;
  }

  .blog-breadcrumbs span {
    margin-left: 10px;
    color: #ffffff;
  }

  .blog-page-title {
    font-family: 'Oswald', sans-serif;
    font-size: 72px;
    font-weight: 600;
    color: #ffffff;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.1;
    position: relative;
    z-index: 10;
  }

  .blog-content-section {
    background: #ffffff;
    padding: 48px 0 64px;
  }

  .blog-container {
    display: block;
  }

  .blog-mosaic {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    grid-auto-rows: minmax(220px, auto);
  }

  .blog-card.featured {
    grid-column: span 2;
    grid-row: span 1;
  }

  .blog-card.featured .blog-card-image {
    aspect-ratio: 21 / 9;
  }

  .blog-card.featured .blog-card-body {
    padding: 24px;
  }

  .blog-card.featured .blog-card-title {
    font-size: 24px;
  }

  .blog-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 6px;
    overflow: hidden;
    transition: box-shadow 0.25s, border-color 0.25s;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .blog-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .blog-card-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #f0f0f0;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s;
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.04);
  }

  .blog-card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 10px;
    font-family: 'Yantramanav', sans-serif;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8c8c8c;
  }

  .blog-card-category {
    color: #fe5900;
    font-weight: 500;
  }

  .blog-card-date {
    color: #8c8c8c;
  }

  .blog-card-title {
    font-family: 'Oswald', sans-serif;
    font-size: 20px;
    font-weight: 600;
    line-height: 1.35;
    color: #0d0d0d;
    margin: 0 0 10px;
    transition: color 0.25s;
  }

  .blog-card:hover .blog-card-title {
    color: #fe5900;
  }

  .blog-card-excerpt {
    font-family: 'Yantramanav', sans-serif;
    font-size: 14px;
    color: #666;
    line-height: 1.55;
    margin: 0 0 12px;
    flex: 1;
  }

  .blog-card-cta {
    font-family: 'Yantramanav', sans-serif;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    color: #0d0d0d;
    transition: color 0.25s;
  }

  .blog-card:hover .blog-card-cta {
    color: #fe5900;
  }

  .blog-empty {
    font-family: 'Yantramanav', sans-serif;
    font-size: 18px;
    color: #666;
    text-align: center;
    padding: 3rem;
  }

  .btn {
    display: inline-block;
    padding: 15px 40px;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 0.1em;
    font-size: 20px;
    transition: all 0.3s;
    font-family: 'Roboto', sans-serif;
  }

  .btn-primary {
    background: #fe5900;
    color: #ffffff;
    border: 2px solid #fe5900;
  }

  .btn-primary:hover {
    background: #e04d00;
    border-color: #e04d00;
  }

  .cta-section {
    padding: 5rem 0;
    background: #0d0d0d;
    color: #fff;
    text-align: center;
  }

  .cta-content h2 {
    font-family: 'Oswald', sans-serif;
    font-size: 48px;
    font-weight: 600;
    color: #fff;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .cta-content p {
    font-family: 'Yantramanav', sans-serif;
    font-size: 20px;
    color: #ccc;
    margin-bottom: 2rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.8;
  }

  .btn-large {
    padding: 18px 50px;
    font-size: 18px;
  }

  @media (max-width: 768px) {
    .blog-hero-section {
      min-height: 300px;
    }

    .blog-page-title {
      font-size: 42px;
    }

    .blog-mosaic {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .blog-card.featured {
      grid-column: span 1;
      grid-row: span 1;
    }

    .cta-content h2 {
      font-size: 36px;
    }
  }

  @media (max-width: 480px) {
    .blog-page-title {
      font-size: 32px;
    }
  }
</style>
