---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="Warranty & Care | 5-Year Guarantee | PlayerStall"
	description="PlayerStall 5-year warranty details, wood locker care guide, and maintenance tips. Modular design means easy part replacement. 30+ years of craftsmanship behind every locker."
>
	<Fragment slot="head">
		<script type="application/ld+json">
		{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://playerstall.com"},
				{"@type": "ListItem", "position": 2, "name": "Warranty & Care", "item": "https://playerstall.com/warranty"}
			]
		})}
		</script>
		<script type="application/ld+json">
		{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "What does the PlayerStall 5-year warranty cover?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Our warranty covers defects in materials and workmanship for 5 years from the date of delivery. This includes structural failures, delamination, hardware defects, and manufacturing defects under normal use conditions."
					}
				},
				{
					"@type": "Question",
					"name": "Can individual locker parts be replaced?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Yes. Thanks to our modular design, individual panels, shelves, hooks, doors, and other components can be replaced without replacing the entire locker. This saves significant cost and reduces downtime."
					}
				},
				{
					"@type": "Question",
					"name": "How do I file a warranty claim with PlayerStall?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Contact us at 1 888 584 1444 or email team@playerstall.com with photos of the issue, your order number, and a description of the problem. We'll assess the claim and ship replacement parts or arrange a solution promptly."
					}
				}
			]
		})}
		</script>
	</Fragment>

	<!-- Hero -->
	<section class="wr-hero">
		<div class="wr-hero-bg">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="PlayerStall warranty and care" class="wr-hero-image" />
		</div>
		<div class="wr-hero-overlay"></div>
		<div class="wr-hero-container">
			<div class="wr-breadcrumbs">
				<a href="/">Home</a>
				<span>Warranty &amp; Care</span>
			</div>
			<h1 class="wr-hero-title">Warranty &amp; Care</h1>
		</div>
	</section>

	<!-- Intro -->
	<section class="wr-intro">
		<div class="container">
			<div class="wr-intro-content">
				<p class="wr-label">step 7 of your journey</p>
				<h2 class="wr-heading">We Stand Behind Every Locker We Build</h2>
				<p class="wr-intro-text">We've been building lockers for over 30 years, and we stand behind every one. That's why every PlayerStall locker comes with a full 5 year warranty. And because of our modular design, if something does go wrong, you can replace just that one part quickly and at low cost.</p>
			</div>
		</div>
	</section>

	<!-- Warranty Details -->
	<section class="wr-warranty">
		<div class="container">
			<div class="wr-section-header">
				<p class="wr-label">our guarantee</p>
				<h2 class="wr-heading">5 Year Warranty</h2>
			</div>
			<div class="wr-warranty-grid">
				<div class="wr-warranty-card wr-covered">
					<h4>What's Covered</h4>
					<ul>
						<li>Structural integrity of all locker components</li>
						<li>Delamination or separation of surface materials</li>
						<li>Defects in hardware (hinges, hooks, brackets)</li>
						<li>Manufacturing defects in finish and assembly</li>
						<li>Warping under normal indoor conditions</li>
						<li>Color fading under normal indoor lighting</li>
					</ul>
				</div>
				<div class="wr-warranty-card wr-not-covered">
					<h4>What's Not Covered</h4>
					<ul>
						<li>Damage from misuse, abuse, or negligence</li>
						<li>Modifications made after delivery</li>
						<li>Normal wear and tear (surface scratches, minor dents)</li>
						<li>Damage from water, flooding, or excessive humidity</li>
						<li>Damage from improper installation not following our guide</li>
						<li>Cosmetic variations natural to wood products</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Modular Advantage -->
	<section class="wr-modular">
		<div class="container">
			<div class="wr-modular-content">
				<div class="wr-modular-text">
					<p class="wr-label">modular design advantage</p>
					<h3>Replace Parts, Not Whole Lockers</h3>
					<p>Most locker systems are one solid piece, so if something breaks, you're stuck replacing the whole unit. Not ours. If a panel gets damaged, a shelf cracks, or a hook bends, we just ship you that one part. It saves you thousands of dollars and your team barely notices.</p>
					<div class="wr-modular-features">
						<div class="wr-feature">
							<strong>Individual panels</strong> can be swapped out in minutes
						</div>
						<div class="wr-feature">
							<strong>Hardware</strong> (hooks, hinges, brackets) is standard and replaceable
						</div>
						<div class="wr-feature">
							<strong>Shelves and accessories</strong> snap in without special tools
						</div>
						<div class="wr-feature">
							<strong>Name plates and branding</strong> can be updated for new players each season
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- How to File a Claim -->
	<section class="wr-claim">
		<div class="container">
			<div class="wr-section-header">
				<p class="wr-label">need a replacement?</p>
				<h2 class="wr-heading">How to File a Warranty Claim</h2>
			</div>
			<div class="wr-claim-steps">
				<div class="wr-claim-step">
					<div class="wr-claim-num">1</div>
					<h4>Document the Issue</h4>
					<p>Take clear photos of the damage or defect. Note when you first noticed it and any relevant details about the conditions.</p>
				</div>
				<div class="wr-claim-step">
					<div class="wr-claim-num">2</div>
					<h4>Contact Us</h4>
					<p>Call <a href="tel:+18885841444">1 888 584 1444</a> or email <a href="mailto:team@playerstall.com">team@playerstall.com</a> with your photos, order number, and a description of the issue.</p>
				</div>
				<div class="wr-claim-step">
					<div class="wr-claim-num">3</div>
					<h4>We Resolve It</h4>
					<p>We look into it, and if it's covered, we ship replacement parts or work out a solution. Most claims are wrapped up within 5 to 10 business days.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Care & Maintenance -->
	<section class="wr-care">
		<div class="container">
			<div class="wr-section-header">
				<p class="wr-label">keep them looking great</p>
				<h2 class="wr-heading">Care &amp; Maintenance Guide</h2>
			</div>
			<div class="wr-care-grid">
				<div class="wr-care-card">
					<h4>Daily Care</h4>
					<ul>
						<li>Wipe down surfaces with a damp cloth as needed</li>
						<li>Clean up spills immediately to prevent staining</li>
						<li>Keep locker doors and drawers closed when not in use</li>
						<li>Avoid placing wet gear directly on wood surfaces. Use hooks or hangers instead</li>
					</ul>
				</div>
				<div class="wr-care-card">
					<h4>Weekly Maintenance</h4>
					<ul>
						<li>Wipe all surfaces with a mild soap and water solution</li>
						<li>Check hooks and hardware for looseness and tighten as needed</li>
						<li>Inspect for scratches or damage and address early</li>
						<li>Clean ventilation openings to maintain airflow</li>
					</ul>
				</div>
				<div class="wr-care-card">
					<h4>Seasonal Maintenance</h4>
					<ul>
						<li>Deep clean all lockers between seasons</li>
						<li>Inspect all hardware and tighten any loose connections</li>
						<li>Check wall cleat connections remain secure</li>
						<li>Update name plates and branding as rosters change</li>
						<li>Order replacement parts for any wear items before next season</li>
					</ul>
				</div>
				<div class="wr-care-card">
					<h4>Environment Tips</h4>
					<ul>
						<li>Maintain indoor temperature between 60–80°F (15–27°C)</li>
						<li>Keep relative humidity between 30–60% to prevent warping</li>
						<li>Make sure there's good ventilation in the locker room</li>
						<li>Avoid direct contact with harsh chemicals or solvents</li>
						<li>Use felt pads on anything that slides across locker surfaces</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Cleaning Do's and Don'ts -->
	<section class="wr-cleaning">
		<div class="container">
			<div class="wr-cleaning-content">
				<h3>Cleaning Do's &amp; Don'ts</h3>
				<div class="wr-cleaning-grid">
					<div class="wr-cleaning-do">
						<h4>Do</h4>
						<ul>
							<li>Use mild soap and warm water</li>
							<li>Wipe in the direction of the wood grain</li>
							<li>Dry surfaces after cleaning</li>
							<li>Use a soft microfiber cloth</li>
							<li>Test any new cleaner in a hidden area first</li>
						</ul>
					</div>
					<div class="wr-cleaning-dont">
						<h4>Don't</h4>
						<ul>
							<li>Use abrasive cleaners, steel wool, or scouring pads</li>
							<li>Apply bleach or ammonia based products</li>
							<li>Use power washers or excessive water</li>
							<li>Leave standing water on surfaces</li>
							<li>Use furniture polish with silicone (causes buildup)</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="wr-cta">
		<div class="container">
			<div class="wr-cta-content">
				<h2>Questions About Your Warranty?</h2>
				<p>Email us about warranty questions, replacement parts, or maintenance. We're always happy to help.</p>
				<div class="wr-cta-buttons">
					<a href="mailto:team@playerstall.com" class="btn btn-primary btn-large">Email Us</a>
				</div>
				<p class="wr-cta-links">
					<a href="/installation-guide">Installation Guide</a> &middot;
					<a href="/how-it-works">How It Works</a> &middot;
					<a href="/contact">Contact Us</a>
				</p>
			</div>
		</div>
	</section>

</BaseLayout>

<style>
	.container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Hero */
	.wr-hero {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}

	.wr-hero-bg {
		position: absolute;
		top: 0; left: 0; width: 100%; height: 100%;
		z-index: 0; overflow: hidden;
	}

	.wr-hero-image {
		width: 100%; height: 100%;
		object-fit: cover;
		filter: grayscale(100%);
	}

	.wr-hero-overlay {
		position: absolute;
		top: 0; left: 0; right: 0; bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.wr-hero-container {
		position: relative; z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px; width: 100%;
	}

	.wr-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}

	.wr-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.wr-breadcrumbs a:hover { color: #fe5900; }

	.wr-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.wr-hero-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0; line-height: 1.1;
	}

	/* Common */
	.wr-label {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		margin-bottom: -3px;
		display: block;
	}

	.wr-heading {
		font-family: 'Oswald', sans-serif;
		font-size: 48px;
		font-weight: 600;
		color: #000000;
		text-transform: uppercase;
		margin: 15px 0;
		letter-spacing: 1px;
	}

	.wr-section-header {
		text-align: center;
		margin-bottom: 50px;
	}

	/* Intro */
	.wr-intro {
		padding: 80px 0 60px;
		background: #ffffff;
	}

	.wr-intro-content {
		text-align: center;
		max-width: 720px;
		margin: 0 auto;
	}

	.wr-intro-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #666666;
		line-height: 1.8;
		margin: 0;
	}

	/* Warranty Grid */
	.wr-warranty {
		padding: 80px 0;
		background: #f7f7f7;
	}

	.wr-warranty-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 40px;
		max-width: 900px;
		margin: 0 auto;
	}

	.wr-warranty-card {
		background: #ffffff;
		padding: 36px;
		border: 1px solid #e8e8e8;
	}

	.wr-covered {
		border-top: 4px solid #fe5900;
	}

	.wr-not-covered {
		border-top: 4px solid #e0e0e0;
	}

	.wr-warranty-card h4 {
		font-family: 'Oswald', sans-serif;
		font-size: 22px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 20px;
	}

	.wr-warranty-card ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.wr-warranty-card li {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #444444;
		line-height: 1.6;
		padding: 10px 0 10px 24px;
		position: relative;
		border-bottom: 1px solid #f0f0f0;
	}

	.wr-warranty-card li:last-child {
		border-bottom: none;
	}

	.wr-covered li::before {
		content: '\2713';
		position: absolute;
		left: 0;
		color: #fe5900;
		font-weight: 700;
		font-size: 14px;
	}

	.wr-not-covered li::before {
		content: '\2717';
		position: absolute;
		left: 0;
		color: #cc0000;
		font-weight: 700;
		font-size: 14px;
	}

	/* Modular Section */
	.wr-modular {
		padding: 80px 0;
		background: #ffffff;
	}

	.wr-modular-content {
		max-width: 800px;
		margin: 0 auto;
	}

	.wr-modular-text h3 {
		font-family: 'Oswald', sans-serif;
		font-size: 36px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 15px 0 16px;
	}

	.wr-modular-text > p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #666666;
		line-height: 1.8;
		margin: 0 0 32px;
	}

	.wr-modular-features {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 16px;
	}

	.wr-feature {
		background: #f7f7f7;
		padding: 20px;
		border-left: 3px solid #fe5900;
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #444444;
		line-height: 1.6;
	}

	.wr-feature strong {
		color: #0d0d0d;
	}

	/* Claim Steps */
	.wr-claim {
		padding: 80px 0;
		background: #f7f7f7;
	}

	.wr-claim-steps {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 40px;
		max-width: 960px;
		margin: 0 auto;
	}

	.wr-claim-step {
		text-align: center;
		padding: 32px 24px;
		background: #ffffff;
		border-top: 3px solid #fe5900;
	}

	.wr-claim-num {
		width: 48px; height: 48px;
		border-radius: 50%;
		background: #fe5900;
		color: #fff;
		display: flex; align-items: center; justify-content: center;
		font-family: 'Oswald', sans-serif;
		font-size: 20px; font-weight: 700;
		margin: 0 auto 16px;
	}

	.wr-claim-step h4 {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 12px;
	}

	.wr-claim-step p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #666666;
		line-height: 1.7;
		margin: 0;
	}

	.wr-claim-step a {
		color: #fe5900;
		text-decoration: none;
	}

	.wr-claim-step a:hover { text-decoration: underline; }

	/* Care Grid */
	.wr-care {
		padding: 80px 0;
		background: #ffffff;
	}

	.wr-care-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 32px;
		max-width: 960px;
		margin: 0 auto;
	}

	.wr-care-card {
		background: #f7f7f7;
		padding: 32px;
		border: 1px solid #e8e8e8;
	}

	.wr-care-card h4 {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 16px;
	}

	.wr-care-card ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.wr-care-card li {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #444444;
		line-height: 1.6;
		padding: 8px 0 8px 20px;
		position: relative;
	}

	.wr-care-card li::before {
		content: '\2022';
		position: absolute;
		left: 0;
		color: #fe5900;
		font-weight: 700;
	}

	/* Cleaning */
	.wr-cleaning {
		padding: 60px 0 80px;
		background: #ffffff;
	}

	.wr-cleaning-content {
		max-width: 800px;
		margin: 0 auto;
	}

	.wr-cleaning-content h3 {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		text-align: center;
		margin: 0 0 32px;
	}

	.wr-cleaning-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 32px;
	}

	.wr-cleaning-do,
	.wr-cleaning-dont {
		padding: 28px;
	}

	.wr-cleaning-do {
		background: #f0fdf4;
		border: 1px solid #bbf7d0;
		border-top: 3px solid #22c55e;
	}

	.wr-cleaning-dont {
		background: #fef2f2;
		border: 1px solid #fecaca;
		border-top: 3px solid #ef4444;
	}

	.wr-cleaning-do h4,
	.wr-cleaning-dont h4 {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		text-transform: uppercase;
		margin: 0 0 16px;
	}

	.wr-cleaning-do h4 { color: #166534; }
	.wr-cleaning-dont h4 { color: #991b1b; }

	.wr-cleaning-do ul,
	.wr-cleaning-dont ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.wr-cleaning-do li,
	.wr-cleaning-dont li {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #444444;
		line-height: 1.6;
		padding: 6px 0 6px 24px;
		position: relative;
	}

	.wr-cleaning-do li::before {
		content: '\2713';
		position: absolute;
		left: 0;
		color: #22c55e;
		font-weight: 700;
	}

	.wr-cleaning-dont li::before {
		content: '\2717';
		position: absolute;
		left: 0;
		color: #ef4444;
		font-weight: 700;
	}

	/* CTA */
	.wr-cta {
		padding: 80px 0;
		background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 100%);
		text-align: center;
	}

	.wr-cta-content {
		max-width: 640px;
		margin: 0 auto;
	}

	.wr-cta-content h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 42px;
		font-weight: 600;
		color: #ffffff;
		margin: 0 0 16px;
	}

	.wr-cta-content > p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #b6b6b6;
		line-height: 1.7;
		margin: 0 0 32px;
	}

	.wr-cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 24px;
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 1.8rem;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 500;
		letter-spacing: 0.1em;
		font-size: 0.85rem;
		transition: all 0.3s;
		font-family: 'Roboto', sans-serif;
		border: 2px solid transparent;
	}

	.btn-primary { background: #fe5900; color: #fff; border-color: #fe5900; }
	.btn-primary:hover { background: #e04d00; border-color: #e04d00; }
