---
// PREMIUM — Model S only. 19" or 24" depth, melamine. Spec PDF: /pdf/model-s-locker-spec/ (do not use stadium-locker-spec).
import BaseLayout from '../layouts/BaseLayout.astro';
import LockerAccessories from '../components/LockerAccessories.astro';
import AccessoryModal from '../components/AccessoryModal.astro';
import ProductSpecSheet from '../components/ProductSpecSheet.astro';
import ProductGalleryControls from '../components/ProductGalleryControls.astro';
import { SHOP_ACCESSORIES_MODAL } from '../data/shop-accessories';
import {
	ADORNUS_DESIGNER_PAINT_FINISHES,
	DEFAULT_ADORNUS_PAINT_CODE,
	DEFAULT_ADORNUS_PAINT_LABEL,
} from '../data/adornus-designer-paint-colors';
import { TEXTURED_WOODGRAIN_OPTIONS, texturedWoodgrainSwatchUrl } from '../data/textured-woodgrain-colors';
import { MODEL_S_HERO_IMAGE } from '../data/model-s-assets';
const modelSDimensions19Src = 'https://playerstall.b-cdn.net/images/Model%20S%2019%20inches.png';
const modelSDimensions24Src = 'https://playerstall.b-cdn.net/images/Model%20S%2024%20inches.png';
import lockBoxSpecSheet from '../assets/lock-box-spec-sheet.png';

const modelSSpecs = [
	{ label: 'Standard dimensions', value: '24" W × 76" H × 19" D' },
	{ label: 'Base', value: 'Optional 4" high base' },
	{ label: 'Frame', value: '3/4"' },
	{ label: 'Backing', value: '3/4"' },
	{ label: 'Weight', value: 'Approx. 175 lbs' },
	{ label: 'Construction', value: 'MPW-6C plywood core, premium melamine surface' },
	{ label: 'Edgebanding', value: 'PVC edgebanding' },
	{ label: 'Width range', value: '18" – 32"' },
	{ label: 'Depth options', value: '19" or 24"' },
	{ label: 'Custom build', value: '8–12 weeks — any size, wood, or materials' },
	{ label: 'Warranty', value: '5 year warranty' },
];
---

<BaseLayout
	title="Model S Wood Locker | PlayerStall"
	description="Model S wood locker: premium melamine, 76&quot; H x 19&quot; or 24&quot; D, widths 18&quot;–32&quot;. From $649. Full color options. Custom-built in 8–12 weeks. 5 year warranty."
>
	<!-- Hero Section (no banner photo — title on white) -->
	<section class="product-hero-section product-hero-section--plain">
		<div class="product-hero-container">
			<div class="product-breadcrumbs">
				<a href="/">Home</a>
				<span class="breadcrumbs-sep">/</span>
				<a href="/shop">Shop</a>
				<span class="breadcrumbs-sep">/</span>
				<span class="breadcrumbs-current">Model S Locker</span>
			</div>
			<h1 class="product-page-title">Model S</h1>
		</div>
	</section>

	<!-- Product Main -->
	<section class="product-main-section">
		<div class="product-container">
			<div class="product-layout">
				<!-- Left: Gallery -->
				<div class="product-gallery">
					<div class="product-gallery-main">
						<img
							src={MODEL_S_HERO_IMAGE}
							alt="Model S wood athletic locker in black, three-quarter view"
							class="product-main-image"
						/>
						<ProductGalleryControls />
						</div>
					<p class="product-gallery-caption">Displayed in black</p>
					<div class="product-gallery-thumbs">
						<button type="button" class="thumb active" aria-label="Model S in black, left-side view">
							<img src={MODEL_S_HERO_IMAGE} alt="Model S wood athletic locker in black, left-side view" />
						</button>
						<button type="button" class="thumb" aria-label="Model S in black, front view with base">
							<img src="/images/model-s-black-front-base.png" alt="Model S wood athletic locker in black, front view with solid base" />
						</button>
						<button type="button" class="thumb" aria-label="Model S in black, side profile view">
							<img src="/images/model-s-black-side-view.png" alt="Model S wood athletic locker in black, side profile silhouette" />
						</button>
						<button type="button" class="thumb" aria-label="Model S in black, right-side view">
							<img src="/images/model-s-black-right-side.png" alt="Model S wood athletic locker in black, right-side view" />
						</button>
						<button type="button" class="thumb" aria-label="Model S digital lock box in black">
							<img src="/images/lock-box-black.jpg" alt="Model S digital lock box in black finish with keypad" />
						</button>
						<button type="button" class="thumb" aria-label="Model S dimensions sheet – 19 inch depth">
							<img src={modelSDimensions19Src} alt="Model S locker dimensions sheet – 19 inch depth, front and side views with measurements in inches" />
						</button>
						<button type="button" class="thumb" aria-label="Model S dimensions sheet – 24 inch depth">
							<img src={modelSDimensions24Src} alt="Model S locker dimensions sheet – 24 inch depth, front and side views with measurements in inches" />
						</button>
						<button type="button" class="thumb thumb--lock-box" aria-label="Digital lock box dimensions and spec">
							<img src={lockBoxSpecSheet.src} alt="Lock box with digital key lock – keypad, latch and lock body with dimensions" />
						</button>
					</div>
				</div>

				<!-- Right: Details -->
				<div class="product-detail">
					<h1 class="product-title">Model S Locker</h1>

					<p class="product-model" data-model-letter="S">Model # S-{DEFAULT_ADORNUS_PAINT_LABEL}-18</p>

					<p class="product-lead-time">Lead time: Custom-built in three months</p>

					<div class="product-price-block">
						<span class="product-price" data-base-price="649">$649.00</span>
					</div>

					<div class="product-options">
						<div class="product-option">
							<label class="option-label">Deep:</label>
							<span class="option-value">19&quot; (standard)</span>
							<div class="option-swatches">
								<button type="button" class="swatch deep-swatch active" title="19 inch deep" aria-pressed="true">19&quot;</button>
								<button type="button" class="swatch deep-swatch" title="24 inch deep">24&quot;</button>
							</div>
						</div>
						<div class="product-option">
							<label class="option-label">Width:</label>
							<span class="option-value">18&quot;</span>
							<div class="option-swatches">
								<button type="button" class="swatch width-swatch active" data-base-price="649" title="18 inch width">18&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="649" title="20 inch width">20&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="649" title="22 inch width">22&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="649" title="24 inch width">24&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="699" title="26 inch width">26&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="699" title="28 inch width">28&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="749" title="30 inch width">30&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="749" title="32 inch width">32&quot;</button>
							</div>
						</div>
						<div class="product-option">
							<label class="option-label" for="color-select">Color:</label>
							<div class="color-select-wrapper">
								<span class="color-preview" id="color-preview" style="background-color: #f4f4f0;"></span>
								<select id="color-select" class="color-dropdown">
									<optgroup label="Solid colors (Sherwin-Williams)">
										{ADORNUS_DESIGNER_PAINT_FINISHES.map((o) => (
											<option value={o.code} data-color={o.approxHex} selected={o.code === DEFAULT_ADORNUS_PAINT_CODE}>
												{o.label}
											</option>
										))}
									</optgroup>
									<optgroup label="Textured woodgrain">
										{TEXTURED_WOODGRAIN_OPTIONS.map((o) => (
											<option
												value={o.code}
												data-color={o.fallbackHex}
												data-swatch-image={texturedWoodgrainSwatchUrl(o.fileSlug)}
											>
												{o.label}
											</option>
										))}
									</optgroup>
								</select>
							</div>
							<p class="option-note"><a href="/colors/all-color-options-pdf.html" target="_blank" rel="noopener noreferrer" class="color-pdf-link">View Color Option PDF</a></p>
						</div>
						<div class="product-option">
							<label class="option-label">Accessories:</label>
							<span class="option-value">Select add-ons to update price</span>
							<div class="accessories-grid">
								<button type="button" class="accessory-box" data-price="40" title="Vented front">
									<span class="accessory-square"></span>
									<span class="accessory-label">Vented front (+$40)</span>
								</button>
								<button type="button" class="accessory-box" data-price="80" title="Lock box">
									<span class="accessory-square"></span>
									<span class="accessory-label">Lock box (+$80)</span>
								</button>
								<button type="button" class="accessory-box" data-price="75" title="Bottom cushion">
									<span class="accessory-square"></span>
									<span class="accessory-label">Bottom cushion (+$75)</span>
								</button>
								<button type="button" class="accessory-box" data-price="150" title="Top &amp; bottom cushions">
									<span class="accessory-square"></span>
									<span class="accessory-label">Top &amp; bottom cushions (+$150)</span>
								</button>
								<button type="button" class="accessory-box" data-price="10" title="Name plate">
									<span class="accessory-square"></span>
									<span class="accessory-label">Name plate (+$10)</span>
								</button>
								<button type="button" class="accessory-box" data-price="12" title="4 hooks">
									<span class="accessory-square"></span>
									<span class="accessory-label">4 hooks (+$12)</span>
								</button>
								<button type="button" class="accessory-box" data-price="25" title="Skate hooks">
									<span class="accessory-square"></span>
									<span class="accessory-label">Skate hooks (+$25)</span>
								</button>
								<button type="button" class="accessory-box" data-price="75" title="Custom logo">
									<span class="accessory-square"></span>
									<span class="accessory-label">Custom logo (+$75)</span>
								</button>
							</div>
						</div>
					</div>

					<div class="product-volume-discounts">
						<h3 class="volume-title">Volume Discounts</h3>
						<table class="volume-table">
							<thead>
								<tr>
									<th>Quantity</th>
									<th>Price</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td>50 + lockers</td>
									<td>3–5% discount – <a href="/contact" class="volume-contact-link">Contact us</a> for pricing</td>
								</tr>
							</tbody>
						</table>
					</div>

					<div class="product-actions">
						<label class="quantity-label" for="product-qty">Quantity:</label>
						<input type="number" id="product-qty" class="product-qty-input" value="1" min="1" max="999" />
						<button type="button" class="btn btn-primary product-add-cart">Add to Cart</button>
					</div>
				</div>
			</div>

			<!-- More Information -->
			<div class="product-info-section" id="moreinfo">
				<h2 class="product-info-heading">Model S Wood Locker – Features &amp; Options</h2>

				<div class="product-info-grid">
					<div class="product-info-col product-info-col-specs">
						<ProductSpecSheet productName="Model S Locker" specs={modelSSpecs} />
						<h3 class="product-info-subheading">Downloads</h3>
						<ul class="product-downloads-list">
							<li><a href="/pdf/installation-instructions/" target="_blank" rel="noopener noreferrer">Shipping and Assembly Instruction PDF</a></li>
							<li><a href="/pdf/model-s-locker-spec/" target="_blank" rel="noopener noreferrer">Spec sheet (PDF)</a></li>
							<li><a href="/colors/all-color-options-pdf.html" target="_blank" rel="noopener noreferrer">Color Option PDF</a></li>
							<li><a href="/colors/laminate-colors-pdf.html" target="_blank" rel="noopener noreferrer">Laminate Colors PDF</a></li>
							<li><a href="/colors/woodgrain-colors-pdf.html" target="_blank" rel="noopener noreferrer">Woodgrain Colors PDF</a></li>
							<li><a href="/colors/phenolic-colors-pdf.html" target="_blank" rel="noopener noreferrer">Phenolic Colors PDF</a></li>
							<li><a href="/colors/cushion-colors-pdf.html" target="_blank" rel="noopener noreferrer">Cushion Colors PDF</a></li>
						</ul>
					</div>
					<div class="product-info-col product-info-col-features">
						<h3 class="product-info-subheading">Features</h3>
						<ul class="product-features-list">
							<li>MPW-6C plywood core with premium melamine surface for a furniture-grade look</li>
							<li>High scratch resistance and impact durability; moisture-resistant, dimensionally stable</li>
							<li>Engineered for high-traffic athletic locker rooms</li>
							<li>14&quot; high foot locker provides comfortable seating and secure equipment storage</li>
							<li>Available in 18&quot; to 32&quot; widths; standard configuration 24&quot; W x 76&quot; H x 19&quot; D with optional 4&quot; base</li>
							<li>5 year warranty</li>
						</ul>

						<h3 class="product-info-subheading">Options</h3>
						<ul class="product-options-list">
							<li>Vented front panel for increased airflow</li>
							<li>Secure lock box integrated into the upper compartment</li>
							<li>Bottom cushion or both cushions for added seating comfort</li>
							<li>Name plate and additional gear hooks</li>
						</ul>
					</div>
				</div>
			</div>

			<LockerAccessories title="LOCKER ACCESSORIES" items={SHOP_ACCESSORIES_MODAL} useModal={true} />
		</div>
	</section>
	<AccessoryModal />
</BaseLayout>

<style is:global>
	body {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	.product-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.product-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}

	.product-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.product-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.product-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.product-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.product-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 20px;
	}

	.product-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.product-breadcrumbs a:hover {
		color: #fe5900;
	}

	.breadcrumbs-sep {
		margin: 0 8px;
		color: rgba(255, 255, 255, 0.6);
	}

	.breadcrumbs-current {
		color: #ffffff;
	}

	.product-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0 0 0 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	/* Model S: no hero banner photo — breadcrumbs & title on white */
	.product-hero-section.product-hero-section--plain {
		background: #ffffff;
		min-height: 0;
		padding: 32px 0 40px;
		justify-content: flex-start;
		overflow: visible;
	}
	.product-hero-section.product-hero-section--plain .product-breadcrumbs {
		color: #8c8c8c;
	}
	.product-hero-section.product-hero-section--plain .product-breadcrumbs a {
		color: #8c8c8c;
	}
	.product-hero-section.product-hero-section--plain .product-breadcrumbs a:hover {
		color: #fe5900;
	}
	.product-hero-section.product-hero-section--plain .breadcrumbs-sep {
		color: #cccccc;
	}
	.product-hero-section.product-hero-section--plain .breadcrumbs-current {
		color: #0d0d0d;
	}
	.product-hero-section.product-hero-section--plain .product-page-title {
		color: #0d0d0d;
	}

	.product-background-text {
		position: absolute;
		font-family: 'Oswald', sans-serif;
		font-size: 200px;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.06);
		text-transform: uppercase;
		letter-spacing: -2px;
		bottom: -30px;
		left: 50%;
		transform: translateX(-50%);
		white-space: nowrap;
		z-index: 1;
	}

	.product-main-section {
		padding: 60px 0 100px;
		background: #ffffff;
	}

	.product-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: start;
		margin-bottom: 80px;
	}

	/* Same gallery frame as Model X PDP — consistent hero size */
	.product-gallery-main {
		position: relative;
		background: transparent;
		width: 100%;
		min-height: 420px;
		margin-bottom: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: visible;
	}

	.product-main-image {
		width: auto;
		max-width: min(100%, 720px);
		max-height: 640px;
		height: auto;
		object-fit: contain;
		display: block;
		margin: 0 auto;
	}

	.product-gallery-thumbs {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.thumb {
		width: 80px;
		height: 80px;
		padding: 0;
		border: 2px solid transparent;
		background: transparent;
		cursor: pointer;
		overflow: hidden;
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	.thumb:hover,
	.thumb.active {
		border-color: #fe5900;
		box-shadow: 0 0 0 1px #fe5900;
	}

	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center center;
		display: block;
	}

	.thumb--lock-box img {
		max-width: 36px;
		max-height: 36px;
		margin: auto;
	}

	.product-gallery-main--lock-box .product-main-image {
		max-width: 115px;
		max-height: 115px;
		width: auto;
		height: auto;
	}

	.product-detail {
		position: sticky;
		top: 120px;
	}

	.product-title {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		line-height: 1.25;
		margin: 0 0 12px;
		text-transform: none;
	}

	.product-model {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 8px;
	}

	.product-lead-time {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin: 0 0 24px;
		text-transform: lowercase;
	}

	.product-price-block {
		margin-bottom: 28px;
		padding-bottom: 24px;
		border-bottom: 1px solid #e0e0e0;
	}

	.product-price {
		font-family: 'Oswald', sans-serif;
		font-size: 36px;
		font-weight: 600;
		color: #0d0d0d;
	}

	.product-options {
		margin-bottom: 28px;
	}

	.product-option {
		margin-bottom: 20px;
	}

	.option-label {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 8px;
	}

	.option-value {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 8px;
		display: block;
	}

	.accessories-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 8px;
	}

	.accessory-box {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: #f0f0f0;
		border: 2px solid transparent;
		color: #0d0d0d;
		cursor: pointer;
		transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
	}

	.accessory-box:hover {
		border-color: #fe5900;
		background: #ffffff;
		box-shadow: 0 0 0 1px rgba(254, 89, 0, 0.2);
	}

	.accessory-box.selected {
		border-color: #fe5900;
		background: #ffffff;
		box-shadow: 0 0 0 1px rgba(254, 89, 0, 0.2);
	}

	.accessory-square {
		width: 14px;
		height: 14px;
		border-radius: 2px;
		border: 2px solid #b6b6b6;
		background: #ffffff;
		box-sizing: border-box;
	}

	.accessory-box.selected .accessory-square {
		border-color: #fe5900;
		background: #fe5900;
	}

	.option-swatches {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.swatch {
		padding: 8px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: #f0f0f0;
		border: 2px solid transparent;
		color: #0d0d0d;
		cursor: pointer;
		transition: border-color 0.2s, background 0.2s;
	}

	.swatch:hover {
		background: #e8e8e8;
	}

	.swatch.active {
		border-color: #fe5900;
		box-shadow: 0 0 0 1px #fe5900;
	}
	/* Color swatches: show as text only; show color only on hover */
	.swatch[data-color-code] {
		background: transparent;
		color: #0d0d0d;
		border-color: #ccc;
	}
	.swatch[data-color-code]:hover,
	.swatch[data-color-code].active {
		border-color: transparent;
