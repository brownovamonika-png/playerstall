<script define:vars={{ MODEL_S_HERO_IMAGE }}>
	document.querySelectorAll('.product-gallery-thumbs .thumb').forEach((thumb) => {
		thumb.addEventListener('click', () => {
			document.querySelectorAll('.product-gallery-thumbs .thumb').forEach((t) => t.classList.remove('active'));
			thumb.classList.add('active');
			const img = thumb.querySelector('img');
			if (img && img.src) {
				const main = document.querySelector('.product-main-image');
				if (main instanceof HTMLImageElement) {
					main.src = img.src;
				}
				const galleryMain = document.querySelector('.product-gallery-main');
				if (galleryMain) {
					galleryMain.classList.toggle('product-gallery-main--lock-box', thumb.classList.contains('thumb--lock-box'));
				}
			}
		});
	});

	const priceEl = document.querySelector('.product-price');
	if (priceEl) {
		let basePrice = 0;

		const formatPrice = (value) =>
			'$' + value.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

		const computeBaseFromWidth = () => {
			const activeWidth = document.querySelector('.width-swatch.active');
			if (activeWidth) {
				const bpAttr = activeWidth.getAttribute('data-base-price');
				const bp = bpAttr ? parseFloat(bpAttr) : NaN;
				if (!Number.isNaN(bp)) {
					basePrice = bp;
					return;
				}
			}
			basePrice = parseFloat(priceEl.getAttribute('data-base-price') || '0') || 0;
		};

		const updatePrice = () => {
			computeBaseFromWidth();
			let extras = 0;
			document.querySelectorAll('.accessory-box.selected').forEach((box) => {
				const extra = parseFloat(box.getAttribute('data-price') || '0') || 0;
				extras += extra;
			});
			priceEl.textContent = formatPrice(basePrice + extras);
		};

		const widthOption = document.querySelector('.product-option');
		const widthValueEl = widthOption ? widthOption.querySelector('.option-value') : null;
		const modelEl = document.querySelector('.product-model[data-model-letter]');
		const colorSelect = document.getElementById('color-select');
		const colorPreview = document.getElementById('color-preview');
		const modelLetter = 'S';

		function updateModelNumber() {
			const activeWidth = document.querySelector('.width-swatch.active');
			const widthLabel = (activeWidth?.textContent ?? '18"').trim().replace(/"/g, '');
			const colorName = colorSelect?.options[colorSelect.selectedIndex]?.textContent?.trim() ?? 'High Reflective White';
			if (modelEl) modelEl.textContent = 'Model # ' + modelLetter + '-' + colorName + '-' + widthLabel;
		}

		function applyColorPreviewFromOption(selectedOption) {
			if (!colorPreview || !selectedOption) return;
			const img = selectedOption.getAttribute('data-swatch-image');
			const color = selectedOption.getAttribute('data-color');
			if (img) {
				colorPreview.style.backgroundColor = 'transparent';
				colorPreview.style.backgroundImage = `url("${img}")`;
				colorPreview.style.backgroundSize = 'cover';
				colorPreview.style.backgroundPosition = 'center';
			} else {
				colorPreview.style.backgroundImage = '';
				if (color) colorPreview.style.backgroundColor = color;
			}
		}

		if (colorSelect && colorPreview) {
			colorSelect.addEventListener('change', () => {
				const selectedOption = colorSelect.options[colorSelect.selectedIndex];
				applyColorPreviewFromOption(selectedOption);
				updateModelNumber();
			});
			applyColorPreviewFromOption(colorSelect.options[colorSelect.selectedIndex]);
		}

		document.querySelectorAll('.width-swatch').forEach((btn) => {
			btn.addEventListener('click', () => {
				document.querySelectorAll('.width-swatch').forEach((b) => {
					b.classList.remove('active');
					b.setAttribute('aria-pressed', 'false');
				});
				btn.classList.add('active');
				btn.setAttribute('aria-pressed', 'true');
				if (widthValueEl) {
					const label = (btn.textContent || '').trim();
					widthValueEl.textContent = label === '24"' ? '24" (standard)' : label;
				}
				updateModelNumber();
				updatePrice();
			});
		});

		// Deep option handling
		const deepOption = document.querySelectorAll('.product-option')[0];
		const deepValueEl = deepOption ? deepOption.querySelector('.option-value') : null;

		document.querySelectorAll('.deep-swatch').forEach((btn) => {
			btn.addEventListener('click', () => {
				document.querySelectorAll('.deep-swatch').forEach((b) => {
					b.classList.remove('active');
					b.setAttribute('aria-pressed', 'false');
				});
				btn.classList.add('active');
				btn.setAttribute('aria-pressed', 'true');
				if (deepValueEl) {
					const label = (btn.textContent || '').trim();
					deepValueEl.textContent = label === '19"' ? '19" (standard)' : label;
				}
			});
		});

		computeBaseFromWidth();
		updatePrice();

		document.querySelectorAll('.accessory-box').forEach((box) => {
			box.addEventListener('click', () => {
				box.classList.toggle('selected');
				updatePrice();
			});
		});
	}

	// Add to cart
	const addCartBtn = document.querySelector('.product-add-cart');
	if (addCartBtn) {
		function getCart() {
			const cart = localStorage.getItem('playerstall_cart');
			return cart ? JSON.parse(cart) : [];
		}
		function saveCart(cart) {
			localStorage.setItem('playerstall_cart', JSON.stringify(cart));
			const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
			window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: totalItems } }));
		}
		addCartBtn.addEventListener('click', () => {
			const priceEl = document.querySelector('.product-price');
			const priceText = priceEl?.textContent?.replace(/[$,]/g, '') ?? '649';
			const price = parseFloat(priceText) || 649;
			const qtyEl = document.getElementById('product-qty');
			const qty = Math.max(1, parseInt(qtyEl?.value ?? '1', 10) || 1);
			const titleEl = document.querySelector('.product-title');
			const name = titleEl?.textContent?.trim() ?? 'Model S Locker';
			const widthSwatch = document.querySelector('.width-swatch.active');
			const width = (widthSwatch?.getAttribute('title') ?? '18"').replace(/\s*inch width/, '').trim();
			const deepSwatch = document.querySelector('.deep-swatch.active');
			const deep = (deepSwatch?.getAttribute('title') ?? '19 inch deep').replace(/\s*inch deep/, '').trim();
			const colorCode = document.getElementById('color-select')?.value ?? 'AD-HRW';
			const id = 'model-s-locker-' + width + '-' + deep + '-' + colorCode;
			const modelEl = document.querySelector('.product-model[data-model-letter]');
			const model = (modelEl?.textContent ?? '').trim().replace(/^Model #\s*/i, '') || null;
			const image = MODEL_S_HERO_IMAGE;
			const cart = getCart();
			const existing = cart.find((item) => item.id === id);
			if (existing) {
				existing.quantity += qty;
				if (model) existing.model = model;
			} else cart.push({ id, name, price, image, quantity: qty, model: model || undefined });
			saveCart(cart);
			const originalText = addCartBtn.textContent;
			addCartBtn.textContent = 'Added to cart';
			setTimeout(() => { addCartBtn.textContent = originalText; }, 1500);
		});
	}
</script>
