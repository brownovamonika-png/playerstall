---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="Custom Sports Lockers | Wood Athletic Lockers | PlayerStall"
	description="High-quality sports lockers at unbeatable prices. Quick ship in 2–4 weeks (Stadium & Elite) or custom wood, phenolic & more in 8–12 weeks. Price match guarantee. 30+ years experience."
>
	<!-- Hero Slider Section -->
	<section class="hero-slider" id="hero">
		<div class="hero-slider-container">
			<div class="hero-slide active first-slide" style="background-image: url('https://playerstall.b-cdn.net/images/p4-img.jpg');">
				<div class="hero-slide-content">
					<h1 class="hero-slide-title">Premium Wood Lockers. Unbeatable Prices.</h1>
					<p class="hero-slide-text">Quick ship in 2–4 weeks or custom in 8–12 weeks. We'll match any USA competitor's price.</p>
					<div class="hero-slide-buttons">
						<a href="/shop" class="btn btn-slide-primary">Shop Quick Ship</a>
						<a href="/contact#quote-form" class="btn btn-slide-secondary">Request a Quote</a>
					</div>
				</div>
			</div>
			<div class="hero-slide" style="background-image: url('https://playerstall.b-cdn.net/images/p4-title-img.jpg');">
				<div class="hero-slide-overlay"></div>
				<div class="hero-slide-content">
					<h1 class="hero-slide-title">Premium Wood Lockers. Unbeatable Prices.</h1>
					<p class="hero-slide-text">Your timeline. Your way. Stadium & Elite quick ship (2–4 weeks) — or custom size, wood & materials.</p>
					<div class="hero-slide-buttons">
						<a href="/shop" class="btn btn-slide-primary">View Shop</a>
						<a href="/contact" class="btn btn-slide-secondary">Contact Us</a>
					</div>
				</div>
			</div>
		<div class="hero-slide" style="background-image: url('https://playerstall.b-cdn.net/images/topscorer/h2-rev-slide-4.jpg');">
			<div class="hero-slide-overlay"></div>
			<div class="hero-slide-content">
				<h1 class="hero-slide-title">Premium Wood Lockers. Unbeatable Prices.</h1>
				<p class="hero-slide-text">We focus on core models so production never stops. That's how we keep prices low.</p>
				<div class="hero-slide-buttons">
					<a href="/contact" class="btn btn-slide-primary">Learn Why</a>
					<a href="/contact" class="btn btn-slide-secondary">Contact Us</a>
				</div>
			</div>
		</div>
		<div class="hero-slide slide-bottom" style="background-image: url('https://playerstall.b-cdn.net/images/topscorer/h3-img-1.jpg');">
			<div class="hero-slide-overlay"></div>
				<div class="hero-slide-content">
					<h1 class="hero-slide-title">Premium Wood Lockers. Unbeatable Prices.</h1>
					<p class="hero-slide-text">Wood, phenolic, and more — custom in 8–12 weeks. High style. Lower cost.</p>
					<div class="hero-slide-buttons">
						<a href="/hockey" class="btn btn-slide-primary">By Sport</a>
						<a href="/contact#quote-form" class="btn btn-slide-secondary">Get a Quote</a>
					</div>
				</div>
			</div>
		</div>
		<div class="hero-slider-nav">
			<button class="slider-nav-btn slider-nav-prev" aria-label="Previous slide">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M15 18l-6-6 6-6"/>
				</svg>
			</button>
			<button class="slider-nav-btn slider-nav-next" aria-label="Next slide">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M9 18l6-6-6-6"/>
				</svg>
			</button>
		</div>
		<div class="hero-slider-dots">
			<button class="slider-dot active" aria-label="Slide 1"></button>
			<button class="slider-dot" aria-label="Slide 2"></button>
			<button class="slider-dot" aria-label="Slide 3"></button>
			<button class="slider-dot" aria-label="Slide 4"></button>
		</div>
	</section>

	<!-- Our Lockers: Premium first, then Essential -->
	<section class="home-shop-section">
		<div class="home-shop-container">
			<!-- Premium Lockers: Pro, Stadium, Elite, Legendary -->
			<div class="home-shop-section-header">
				<p class="home-shop-section-subtitle">THE LOCKER ROOM</p>
				<h2 class="home-shop-section-title">PREMIUM LOCKERS</h2>
			</div>
			<div class="home-shop-main">
				<div class="home-shop-products-grid">
					<!-- Pro -->
					<div class="home-shop-product-item">
						<div class="home-shop-product-image">
							<img src="https://playerstall.b-cdn.net/images/pro-locker.jpg" alt="Pro Locker" loading="lazy" />
						</div>
						<div class="home-shop-product-content">
							<div class="home-shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="home-shop-product-title"><a href="/product-pro-locker">Pro</a></h5>
							<span class="home-shop-product-price">$549.00</span>
						</div>
					</div>
					<!-- Stadium -->
					<div class="home-shop-product-item">
						<div class="home-shop-product-image">
							<img src="https://playerstall.b-cdn.net/images/stadium-locker.jpg" alt="Stadium Locker" loading="lazy" />
						</div>
						<div class="home-shop-product-content">
							<div class="home-shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="home-shop-product-title"><a href="/product-stadium-locker">Stadium</a></h5>
							<span class="home-shop-product-price">$599.00</span>
						</div>
					</div>
					<!-- Elite -->
					<div class="home-shop-product-item">
						<div class="home-shop-product-image">
							<span class="home-shop-badge new">New</span>
							<img src="https://playerstall.b-cdn.net/images/grid_locker_gray_curved-75a91a17-f394-49fb-8c61-0029ab3bc6b7.png" alt="Elite Locker" loading="lazy" />
						</div>
						<div class="home-shop-product-content">
							<div class="home-shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="home-shop-product-title"><a href="/product-elite-locker">Elite</a></h5>
							<span class="home-shop-product-price">$599.00</span>
						</div>
					</div>
					<!-- Legendary -->
					<div class="home-shop-product-item">
						<div class="home-shop-product-image">
							<span class="home-shop-badge new">New</span>
							<img src="https://playerstall.b-cdn.net/images/legendary-locker.png" alt="Legendary Locker" loading="lazy" />
						</div>
						<div class="home-shop-product-content">
							<div class="home-shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="home-shop-product-title"><a href="/product-legendary-locker">Legendary</a></h5>
							<span class="home-shop-product-price">$599.00</span>
						</div>
					</div>
				</div>
			</div>

			<!-- Essential Lockers: Semi Pro, Varsity -->
			<div class="home-shop-section-header home-shop-section-header-spaced">
				<p class="home-shop-section-subtitle">THE LOCKER ROOM</p>
				<h2 class="home-shop-section-title">ESSENTIAL LOCKERS</h2>
			</div>
			<div class="home-shop-main">
				<div class="home-shop-products-grid home-shop-products-grid-centered">
					<!-- Semi Pro -->
					<div class="home-shop-product-item">
						<div class="home-shop-product-image">
							<img src="https://playerstall.b-cdn.net/images/semi-pro-locker-new.png" alt="Semi Pro Locker" loading="lazy" />
						</div>
						<div class="home-shop-product-content">
							<div class="home-shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="home-shop-product-title"><a href="/product-semi-pro-locker">Semi Pro</a></h5>
							<span class="home-shop-product-price">$349.00</span>
						</div>
					</div>
					<!-- Varsity -->
					<div class="home-shop-product-item">
						<div class="home-shop-product-image">
							<img src="https://playerstall.b-cdn.net/images/varsity-locker.jpg" alt="Varsity Locker" loading="lazy" />
						</div>
						<div class="home-shop-product-content">
							<div class="home-shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="home-shop-product-title"><a href="/product-varsity-locker">Varsity</a></h5>
							<span class="home-shop-product-price">$449.00</span>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="games-container">

		</div>
	</section>

	<!-- Free Custom Design CTA (under Essential Lockers) -->
	<section class="live-match">
		<div class="live-badge">free</div>
		<div class="match-container">
			<div class="match-content">
				<p class="match-subtitle">no obligation</p>
				<h2 class="match-title">Free Custom Design Consultation</h2>
				<p class="match-text">Get expert advice from 30+ years of experience. No obligation, just professional guidance to create the perfect locker room solution for your team.</p>
				<a href="/contact" class="btn btn-primary btn-large match-cta">Get Started Today</a>
				<p class="match-phone">Call us at <a href="tel:+18885841444" class="match-phone-link">1 888 584 1444</a></p>
			</div>
		</div>
	</section>

	<!-- Our Process Section (how it works / OUR PROCESS) -->
	<section class="equipment-section">
		<div class="equipment-container">
			<div class="section-header">
				<p class="section-subtitle">how it works</p>
				<h2 class="section-title">OUR PROCESS</h2>
			</div>
			<div class="equipment-grid">
				<div class="equipment-item">
					<div class="equipment-item-image">
						<img src="https://playerstall.b-cdn.net/images/topscorer/h3-blog-img-1.jpg" alt="Free consultation for custom sports lockers" loading="lazy" />
						<span class="equipment-circle">1</span>
					</div>
					<h4>Free Consultation</h4>
					<p>Fill out the custom form and we'll get in touch with you. We start with a free custom design consultation to understand your needs, space, and vision.</p>
				</div>
				<div class="equipment-item">
					<div class="equipment-item-image">
						<img src="https://playerstall.b-cdn.net/images/topscorer/h3-blog-img-2.jpg" alt="Custom design for locker room solutions" loading="lazy" />
						<span class="equipment-circle">2</span>
					</div>
					<h4>Custom Design</h4>
					<p>We create a design to fit your budget and space.</p>
				</div>
				<div class="equipment-item">
					<div class="equipment-item-image">
						<img src="https://playerstall.b-cdn.net/images/topscorer/h3-blog-img-3.jpg" alt="Premium wood locker manufacturing" loading="lazy" />
						<span class="equipment-circle">3</span>
					</div>
					<h4>Manufacturing</h4>
					<p>We manufacture lockers for you using premium 3/4" solid wood and the highest quality materials.</p>
				</div>
				<div class="equipment-item">
					<div class="equipment-item-image">
						<img src="https://playerstall.b-cdn.net/images/topscorer/h3-blog-img-4.jpg" alt="Locker delivery to your facility" loading="lazy" />
						<span class="equipment-circle">4</span>
					</div>
					<h4>Delivery</h4>
					<p>We deliver your lockers to your facility so your locker room is ready for your team.</p>
				</div>
			</div>
			<div class="equipment-accordion">
				<div class="accordion-item active">
					<div class="accordion-header">
						<span>Free Custom Design Consultation</span>
						<span>+</span>
					</div>
					<div class="accordion-content">
						<p>Every project starts with a free custom design consultation. We'll discuss your needs, space, budget, and vision to understand exactly what you're looking for. No obligation, just expert advice from 30+ years of experience.</p>
					</div>
				</div>
				<div class="accordion-item">
					<div class="accordion-header">
						<span>5 Year Warranty</span>
						<span>+</span>
					</div>
					<div class="accordion-content">
						<p>We're confident in the quality of our wood sports lockers and back every locker with a 5 year warranty. Our modular design means damaged parts can be replaced individually—no need to replace the entire locker.</p>
					</div>
				</div>
				<div class="accordion-item">
					<div class="accordion-header">
						<span>Made to Your Liking</span>
						<span>+</span>
					</div>
					<div class="accordion-content">
						<p>We build lockers to your specs, your style, and your space. Choose from our Essential or Premium lines, quick ship or full custom—colors, sizes, and options are up to you. Tell us what you want and we'll make it happen.</p>
					</div>
				</div>
				<div class="accordion-item">
					<div class="accordion-header">
						<span>Sport-Specific Solutions</span>
						<span>+</span>
					</div>
					<div class="accordion-content">
						<p>We have all the shapes and sizes that are required for most locker rooms. It is up to you and your style to choose from.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- What's Trending Stats Section (TopScorer hockey style) -->
	<section class="trending-stats-section">
		<div class="trending-stats-container">
			<div class="trending-stats-header">
				<p class="trending-stats-subtitle">what's trending</p>
				<h2 class="trending-stats-title">PLAYERSTALL EQUIPMENT</h2>
			</div>
			<div class="trending-stats-grid">
				<div class="trending-stat-item">
					<div class="trending-stat-circle">
						<svg class="progress-ring" viewBox="0 0 140 140">
							<circle class="progress-ring-bg" cx="70" cy="70" r="62" />
							<circle class="progress-ring-fill" cx="70" cy="70" r="62" data-percent="35" />
						</svg>
						<div class="trending-stat-counter">
							<span class="trending-stat-number" data-target="35">0</span>
							<span class="trending-stat-percent">%</span>
						</div>
					</div>
					<div class="trending-stat-info">
						<h4 class="trending-stat-label">weight ratio</h4>
						<p class="trending-stat-text">Premium wood construction at 35% less weight than metal — easier handling, faster setup, same lasting durability.</p>
					</div>
				</div>
				<div class="trending-stat-item">
					<div class="trending-stat-circle">
						<svg class="progress-ring" viewBox="0 0 140 140">
							<circle class="progress-ring-bg" cx="70" cy="70" r="62" />
							<circle class="progress-ring-fill" cx="70" cy="70" r="62" data-percent="68" />
						</svg>
						<div class="trending-stat-counter">
							<span class="trending-stat-number" data-target="68">0</span>
							<span class="trending-stat-percent">%</span>
						</div>
					</div>
					<div class="trending-stat-info">
						<h4 class="trending-stat-label">cost savings</h4>
						<p class="trending-stat-text">Save up to 68% compared to custom metal lockers while getting premium quality backed by our lifetime guarantee.</p>
					</div>
				</div>
				<div class="trending-stat-item">
					<div class="trending-stat-circle">
						<svg class="progress-ring" viewBox="0 0 140 140">
							<circle class="progress-ring-bg" cx="70" cy="70" r="62" />
							<circle class="progress-ring-fill" cx="70" cy="70" r="62" data-percent="75" />
						</svg>
						<div class="trending-stat-counter">
							<span class="trending-stat-number" data-target="75">0</span>
							<span class="trending-stat-percent">%</span>
						</div>
					</div>
					<div class="trending-stat-info">
						<h4 class="trending-stat-label">faster install</h4>
						<p class="trending-stat-text">Modular flat-pack design means 75% faster assembly — each locker goes together in just 20 to 30 minutes.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Top Scorer-style banner – matches model: same background (player in scene), black strip behind title, model typography -->
	<section class="topscorer-banner" style="background-image: url('https://playerstall.b-cdn.net/images/h1-img-8.jpg');">
		<div class="topscorer-banner-overlay"></div>
		<div class="topscorer-banner-bg-text" aria-hidden="true">
			<span class="topscorer-banner-bg-line">PLAY</span>
			<span class="topscorer-banner-bg-line">OF THE WEEK</span>
		</div>
		<div class="topscorer-banner-content">
			<p class="topscorer-banner-subtitle">Powerful Sports Theme</p>
			<h2 class="topscorer-banner-title"><span class="topscorer-banner-title-strip">Taste the Victory</span></h2>
			<p class="topscorer-banner-text">Etiam scelerisque tortor at lectus dapibus, nec fermentum feugiat diam. Morbi rutrum magna et dui feugiat, non tristique mi aliquam.</p>
			<div class="topscorer-banner-buttons">
				<a href="/shop" class="btn topscorer-btn-solid">Read more</a>
				<a href="/contact" class="btn topscorer-btn-outline">Contact Us</a>
			</div>
		</div>
		<div class="topscorer-banner-players" aria-hidden="true">
			<div class="topscorer-banner-player-slide active"><img src="https://playerstall.b-cdn.net/images/topscorer/player-img-10.jpg" alt="" width="480" height="640" loading="eager" /></div>
			<div class="topscorer-banner-player-slide"><img src="https://playerstall.b-cdn.net/images/topscorer/soccer-player.png" alt="" width="480" height="640" loading="lazy" /></div>
			<div class="topscorer-banner-player-slide"><img src="https://playerstall.b-cdn.net/images/topscorer/hockey-player.png" alt="" width="480" height="640" loading="lazy" /></div>
			<div class="topscorer-banner-player-slide"><img src="https://playerstall.b-cdn.net/images/topscorer/basketball-player.png" alt="" width="480" height="640" loading="lazy" /></div>
			<div class="topscorer-banner-player-slide"><img src="https://playerstall.b-cdn.net/images/topscorer/baseball-player.png" alt="" width="480" height="640" loading="lazy" /></div>
			<div class="topscorer-banner-player-slide"><img src="https://playerstall.b-cdn.net/images/topscorer/player-football-blue-orange.png" alt="" width="480" height="640" loading="lazy" /></div>
		</div>
	</section>

	<!-- Testimonials Section -->
	<section class="players-section">
		<div class="players-bg-text">testimonials</div>
		<div class="players-container">
			<div class="section-header">
				<p class="section-subtitle">trusted by champions</p>
				<h2 class="section-title">what our clients say</h2>
			</div>
			<div class="players-grid">
				<div class="player-card">
					<div class="player-image">
						<img src="https://playerstall.b-cdn.net/images/player-img-10.jpg" alt="Collegiate Football Program" />
					</div>
					<div class="player-details">
						<div class="player-position">Head Coach</div>
						<h4 class="player-name">"These lockers aren't just furniture—they're an investment in our culture. Our recruits notice the difference immediately."</h4>
					</div>
				</div>
				<div class="player-card">
					<div class="player-image">
						<img src="https://playerstall.b-cdn.net/images/player-img-11.jpg" alt="University Athletic Department" />
					</div>
					<div class="player-details">
						<div class="player-position">Athletic Director</div>
						<h4 class="player-name">"After 15 years, our PlayerStall lockers still look professional. The modular design has saved us thousands in repairs."</h4>
					</div>
				</div>
				<div class="player-card">
					<div class="player-image">
						<img src="https://playerstall.b-cdn.net/images/player-img-12.jpg" alt="Professional Sports Organization" />
					</div>
					<div class="player-details">
						<div class="player-position">Facilities Manager</div>
						<h4 class="player-name">"The free custom design service made all the difference. They understood our space and created the perfect solution."</h4>
					</div>
				</div>
				<div class="player-card">
					<div class="player-image">
						<img src="https://playerstall.b-cdn.net/images/player-img-13.jpg" alt="Collegiate Hockey Program" />
					</div>
					<div class="player-details">
						<div class="player-position">Hockey Coach</div>
						<h4 class="player-name">"The reinforced construction handles our heavy hockey gear perfectly. These lockers are built to last."</h4>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Why choose us / Wood vs Metal Section (bottom of page) -->
	<section class="ranking-section">
		<div class="ranking-container">
			<div class="ranking-image">
				<img src="https://playerstall.b-cdn.net/images/h3-img-1.jpg" alt="Custom Wood Sports Lockers" loading="lazy" />
			</div>
			<div class="ranking-content">
				<p class="section-subtitle">why choose us</p>
				<h2 class="section-title">WHY WOOD OUTPERFORMS<br>METAL</h2>
				<p class="ranking-text">After 30+ years in the business, we've seen it all. Wood lockers aren't just a trend—they're a superior choice. Wood creates a professional, prestigious atmosphere that metal simply can't match. When properly cared for, wood outlasts metal. Our lockers have been in use for 15+ years and still look professional.</p>
				<a href="/contact" class="btn btn-outline">Learn More</a>
			</div>
		</div>
	</section>

	<!-- Why Our Prices Section (bottom of page) -->
	<section class="ranking-section" style="background: #f8f8f8;">
		<div class="ranking-container">
			<div class="ranking-image">
				<img src="https://playerstall.b-cdn.net/images/h3-img-1.jpg" alt="Custom Wood Sports Lockers" loading="lazy" />
			</div>
			<div class="ranking-content">
				<p class="section-subtitle">why our prices</p>
				<h2 class="section-title">EFFICIENT PRODUCTION.<br>UNBEATABLE VALUE.</h2>
				<p class="ranking-text">We run an efficient operation. We focus on a core few models and don't stop production—no constant changeovers, no idle time. That lets us keep costs down and pass the savings to you. High-quality lockers at unbeatable prices: it's not magic, it's smart manufacturing.</p>
				<a href="/contact" class="btn btn-outline">Learn More</a>
			</div>
		</div>
	</section>

	<!-- LOCKERS (bold typography + polaroid track) – bottom of page -->
	<section class="bold-typography-section">
		<div class="bold-typography-container">
			<div class="bold-typography-left">
				<h2 class="bold-typography-hero">LOCKERS</h2>
				<p class="bold-typography-date">Premium wood. Unbeatable price.</p>
				<p class="bold-typography-tagline">Custom sports lockers for collegiate and professional teams. Quick ship in 2–4 weeks or full custom in 8–12 weeks. 30+ years experience. 5 year warranty.</p>
				<a href="/shop" class="btn bold-typography-cta">Shop Now</a>
			</div>
			<div class="bold-typography-right">
				<div class="bold-typography-panel bold-typography-panel--polaroid">
					<div class="bold-typography-polaroid-slot">
