/* ===========================================
   BOTTOM QUOTE STRIP (Top Scorer ref: white bg, image left, "PLAYERS" light gray behind quote right)
   =========================================== */
.home-quote-strip {
	background: #f5f5f5;
	overflow: visible;
	transform: translateZ(0);
}

.home-quote-strip-inner {
	position: relative;
	display: flex;
	align-items: stretch;
	min-height: 540px;
	max-width: 100%;
	overflow: hidden;
}

/* Dropping images: between quote text and numbers; background removed via blend */
.home-quote-strip-drop-imgs {
	position: absolute;
	inset: 0;
	pointer-events: none;
	z-index: 0;
	background: #f5f5f5;
	isolation: isolate;
}

.home-quote-strip-drop-img {
	position: absolute;
	left: 72%;
	top: 38%;
	width: 230px;
	height: auto;
	max-height: 330px;
	object-fit: contain;
	object-position: bottom;
	mix-blend-mode: darken;
	transform: scaleX(-1) translateZ(0) translateY(-150%);
	opacity: 0;
	backface-visibility: hidden;
	transition: opacity 0.4s ease-out;
}

/* Active image: run drop animation (set by JS when quote changes) */
.home-quote-strip-drop-img.active-drop {
	animation: dropInOnce 0.7s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
	opacity: 1;
}

.home-quote-strip-drop-img.active-drop.home-quote-strip-drop-img-hockey {
	animation: dropInOnceHockey 0.7s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
}

.home-quote-strip-drop-img-png {
	mix-blend-mode: normal;
}

@keyframes dropInOnce {
	0%   { transform: scaleX(-1) translateZ(0) translateY(-150%); opacity: 0; }
	100% { transform: scaleX(-1) translateZ(0) translateY(-15%); opacity: 0.92; }
}

@keyframes dropInOnceHockey {
	0%   { transform: scaleX(-1) translateZ(0) translateY(-150%); opacity: 0; }
	100% { transform: scaleX(-1) translateZ(0) translateY(-25%); opacity: 0.92; }
}

/* Full-width: "PLAYERS" background + quote slider; content bottom aligned with bottom of P */
.home-quote-strip-right {
	position: relative;
	z-index: 1;
	flex: 1;
	width: 100%;
	max-width: 1600px;
	margin: 0 auto;
	display: flex;
	flex-direction: column;
	align-items: flex-start;
	justify-content: flex-end;
	padding: 60px 72px 185px 4%;
	box-sizing: border-box;
}

/* Slider: 4 quote slides, left-aligned; bottom aligns with bottom of P */
.home-quote-strip-slides {
	position: relative;
	width: 100%;
	flex: 0 0 auto;
	display: flex;
	align-items: flex-end;
	justify-content: flex-start;
	min-height: 260px;
}

.home-quote-strip-slide {
	position: absolute;
	inset: 0;
	display: flex;
	align-items: center;
	justify-content: flex-start;
	opacity: 0;
	visibility: hidden;
	transform: translateY(16px) translateZ(0);
	transition: transform 0.5s cubic-bezier(0.33, 0, 0.2, 1), opacity 0.5s cubic-bezier(0.33, 0, 0.2, 1), visibility 0.5s ease;
	backface-visibility: hidden;
}

.home-quote-strip-slide.active {
	position: relative;
	opacity: 1;
	visibility: visible;
	transform: translateY(0) translateZ(0);
}

/* Number indicator: 01 02 03 04 – vertical list, pushed further right */
.home-quote-strip-numbers {
	position: absolute;
	right: -28px;
	top: 50%;
	transform: translateY(-50%);
	display: flex;
	flex-direction: column;
	align-items: flex-end;
	gap: 12px;
	z-index: 2;
	padding-bottom: 12px;
	border-bottom: 1px solid #d0d0d0;
}

.home-quote-strip-num {
	font-family: 'Oswald', sans-serif;
	font-size: 13px;
	font-weight: 600;
	letter-spacing: 0.06em;
	color: #b6b6b6;
	background: none;
	border: none;
	padding: 4px 8px;
	cursor: pointer;
	transition: color 0.25s ease;
	text-align: center;
}

.home-quote-strip-num:hover {
	color: #0d0d0d;
}

.home-quote-strip-num.active {
	color: #0d0d0d;
	font-weight: 700;
	font-size: 14px;
}

/* Large "PLAYERS" in background – lightly shadowed, subtle (model site style) */
.home-quote-strip-bg-text {
	position: absolute;
	inset: 0;
	display: flex;
	align-items: center;
	justify-content: center;
	pointer-events: none;
	padding: 0 5%;
}

/* PLAYERS: tighter letter-spacing, slightly more visible (model style), 10% wider */
.home-quote-strip-bg-word {
	font-family: 'Oswald', sans-serif;
	font-size: clamp(140px, 18vw, 320px);
	font-weight: 600;
	text-transform: uppercase;
	letter-spacing: 0.08em;
	color: rgba(0, 0, 0, 0.035);
	line-height: 0.85;
	white-space: nowrap;
	user-select: none;
	transform: scaleX(1.1);
	transform-origin: center center;
}

/* Quote block: large quote mark left, quote + attribution left-aligned (model style) */
.home-quote-strip-quote {
	position: relative;
	z-index: 1;
	display: flex;
	flex-direction: row;
	align-items: flex-start;
	text-align: left;
	margin: 0;
	padding: 0;
	border: none;
	gap: 0.4em;
}

.home-quote-strip-quote-mark {
	font-family: 'Oswald', sans-serif;
	font-size: clamp(100px, 13vw, 200px);
	font-weight: 700;
	line-height: 0.75;
	color: #0d0d0d;
	flex-shrink: 0;
}

.home-quote-strip-quote-body {
	display: flex;
	flex-direction: column;
	align-items: flex-start;
	text-align: left;
}

.home-quote-strip-quote-line {
	font-family: 'Oswald', sans-serif;
	font-size: clamp(30px, 3.8vw, 46px);
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.02em;
	color: #0d0d0d;
	line-height: 1.2;
	margin: 0 0 28px;
	max-width: 22em;
	text-align: left;
}

.home-quote-strip-meta {
	display: flex;
	flex-direction: column;
	gap: 6px;
	align-items: flex-start;
}

.home-quote-strip-role {
	font-family: 'Yantramanav', sans-serif;
	font-size: 14px;
	font-weight: 500;
	letter-spacing: 0.22em;
	text-transform: uppercase;
	color: #9a9a9a;
}

.home-quote-strip-name {
	font-family: 'Oswald', sans-serif;
	font-size: 20px;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.05em;
	color: #0d0d0d;
}

@media (max-width: 1024px) {
	.home-quote-strip-inner {
		min-height: 460px;
	}
	.home-quote-strip-right {
		padding: 48px 4% 158px 4%;
	}
	.home-quote-strip-bg-word {
		font-size: clamp(100px, 20vw, 200px);
	}
