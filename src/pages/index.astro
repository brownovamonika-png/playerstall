						<div class="home-shop-product-content">
							<div class="home-shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="home-shop-product-title"><a href="/product-pro-locker">Pro</a></h5>
							<span class="home-shop-product-price">$549.00</span>
						</div>
					</div>
					<!-- Stadium -->
					<div class="home-shop-product-item">
						<div class="home-shop-product-image">
							<img src="/stadium-locker.jpg" alt="Stadium Locker" loading="lazy" />
						</div>
						<div class="home-shop-product-content">
							<div class="home-shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="home-shop-product-title"><a href="/product-stadium-locker">Stadium</a></h5>
							<span class="home-shop-product-price">$599.00</span>
						</div>
					</div>
					<!-- Elite -->
					<div class="home-shop-product-item">
						<div class="home-shop-product-image">
							<span class="home-shop-badge new">New</span>
							<img src="/images/grid_locker_gray_curved-75a91a17-f394-49fb-8c61-0029ab3bc6b7.png" alt="Elite Locker" loading="lazy" />
						</div>
						<div class="home-shop-product-content">
							<div class="home-shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="home-shop-product-title"><a href="/product-elite-locker">Elite</a></h5>
							<span class="home-shop-product-price">$599.00</span>
						</div>
					</div>
					<!-- Legendary -->
					<div class="home-shop-product-item">
						<div class="home-shop-product-image">
							<span class="home-shop-badge new">New</span>
							<img src="/images/legendary-locker.png" alt="Legendary Locker" loading="lazy" />
						</div>
						<div class="home-shop-product-content">
							<div class="home-shop-product-categories">Lockers - Sports Equipment</div>
							<h5 class="home-shop-product-title"><a href="/product-legendary-locker">Legendary</a></h5>
							<span class="home-shop-product-price">$599.00</span>
						</div>
					</div>
				</div>
			</div>

			<!-- Essential Lockers: Semi Pro, Varsity -->
			<div class="home-shop-section-header home-shop-section-header-spaced">
				<p class="home-shop-section-subtitle">the locker room</p>
				<h2 class="home-shop-section-title">ESSENTIAL LOCKERS</h2>
			</div>
			<div class="home-shop-main">
				<div class="home-shop-products-grid home-shop-products-grid-centered">
					<!-- Semi Pro -->
					<div class="home-shop-product-item">
						<div class="home-shop-product-image">
							<img src="/semi-pro-locker.jpg" alt="Semi Pro Locker" loading="lazy" />
