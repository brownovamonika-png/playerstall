	background: #ffffff;
	overflow: hidden;
}

.home-shop-container {
	max-width: 1300px;
	margin: 0 auto;
	padding: 0 20px;
	position: relative;
	z-index: 10;
}

.home-shop-section-header {
	text-align: center;
	margin-bottom: 60px;
}

.home-shop-section-header-spaced {
	margin-top: 140px;
}

.home-shop-section-subtitle {
	display: block;
	font-family: 'Yantramanav', sans-serif;
	font-size: 13px;
	letter-spacing: 6px;
	text-transform: uppercase;
	color: #8c8c8c;
	margin-bottom: 10px;
}

.home-shop-section-title {
	font-family: 'Oswald', sans-serif;
	font-size: clamp(32px, 4vw, 52px);
	font-weight: 700;
	text-transform: uppercase;
	color: #0d0d0d;
	line-height: 1.1;
	margin: 0;
}

.home-shop-main {
	width: 100%;
}

.home-shop-products-grid {
	display: grid;
