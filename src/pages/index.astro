}

/* ===========================================
   STORE / CAROUSEL SECTION
   =========================================== */
.ts-store-section {
	position: relative;
	padding: 100px 60px;
	background: #ffffff;
	overflow: hidden;
}
.ts-store-label {
	text-align: center;
	font-family: 'Yantramanav', sans-serif;
	font-size: 13px;
	letter-spacing: 6px;
	text-transform: uppercase;
	color: #cccccc;
	margin-bottom: 10px;
}
.ts-store-carousel-wrapper {
	position: relative;
	max-width: 1200px;
	margin: 0 auto;
	overflow: hidden;
}
.ts-store-carousel {
	display: flex;
	gap: 20px;
	transition: transform 0.5s ease;
}
.ts-store-item {
	min-width: calc(25% - 15px);
	flex-shrink: 0;
}
.ts-store-item-image {
	position: relative;
	overflow: hidden;
	background: #f5f5f5;
	aspect-ratio: 3/4;
}
.ts-store-item-image img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: transform 0.5s ease;
}
.ts-store-item:hover .ts-store-item-image img {
	transform: scale(1.05);
}
.ts-badge {
	position: absolute;
	top: 15px;
	left: 15px;
	padding: 5px 12px;
	font-family: 'Yantramanav', sans-serif;
	font-size: 12px;
	font-weight: 500;
	text-transform: uppercase;
	letter-spacing: 1px;
	z-index: 2;
}
.ts-badge-new {
	background: #fe5900;
	color: #ffffff;
}
.ts-badge-sale {
	background: #000000;
	color: #ffffff;
}
.ts-add-to-cart {
	position: absolute;
	bottom: 0;
	left: 0;
	width: 100%;
	padding: 14px;
	background: #000000;
	color: #ffffff;
	font-family: 'Oswald', sans-serif;
	font-size: 13px;
	letter-spacing: 2px;
	text-transform: uppercase;
	text-align: center;
	text-decoration: none;
	transform: translateY(100%);
	transition: transform 0.3s ease, background 0.3s ease;
}
.ts-store-item:hover .ts-add-to-cart {
	transform: translateY(0);
}
.ts-add-to-cart:hover {
	background: #fe5900;
}
.ts-store-item-info {
	padding: 15px 5px;
	text-align: center;
}
.ts-store-item-brand {
	font-family: 'Yantramanav', sans-serif;
	font-size: 12px;
	letter-spacing: 2px;
	text-transform: uppercase;
	color: #b6b6b6;
}
.ts-store-item-info h5 {
	font-family: 'Oswald', sans-serif;
	font-size: 18px;
	font-weight: 600;
	margin: 5px 0;
}
.ts-store-item-info h5 a {
	color: #0d0d0d;
	text-decoration: none;
	transition: color 0.3s;
}
.ts-store-item-info h5 a:hover {
	color: #fe5900;
}
.ts-store-item-price {
	font-family: 'Yantramanav', sans-serif;
	font-size: 15px;
	color: #0d0d0d;
}
.ts-store-item-price del {
	color: #b6b6b6;
	margin-right: 8px;
}
.ts-carousel-btn {
	position: absolute;
	top: 50%;
	transform: translateY(-50%);
	width: 50px;
	height: 50px;
	background: #000000;
	color: #ffffff;
	border: none;
	font-size: 18px;
	cursor: pointer;
	z-index: 5;
	transition: background 0.3s;
	display: flex;
	align-items: center;
	justify-content: center;
}
.ts-carousel-btn:hover {
	background: #fe5900;
}
.ts-carousel-prev {
	left: -25px;
}
.ts-carousel-next {
	right: -25px;
}

/* ===========================================
   FEATURES SECTION
   =========================================== */
.ts-features-section {
	position: relative;
	min-height: 600px;
	display: flex;
	align-items: center;
	justify-content: center;
	text-align: center;
	overflow: hidden;
}
.ts-features-bg {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	background-size: cover;
	background-position: center;
	background-attachment: fixed;
}
.ts-features-overlay {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	background: rgba(0,0,0,0.15);
}
.ts-features-content {
	position: relative;
	z-index: 2;
	max-width: 800px;
	padding: 80px 20px;
}
.ts-features-label {
	display: block;
	font-family: 'Yantramanav', sans-serif;
	font-size: 13px;
	letter-spacing: 6px;
	text-transform: uppercase;
	color: rgba(255,255,255,0.6);
	margin-bottom: 20px;
}
.ts-features-title {
	font-family: 'Oswald', sans-serif;
	font-size: clamp(36px, 5vw, 60px);
	font-weight: 700;
	color: #ffffff;
	line-height: 1.15;
	margin: 0 0 30px;
	text-transform: uppercase;
}
.ts-features-tags {
	display: flex;
	justify-content: center;
	gap: 30px;
	margin-bottom: 40px;
	flex-wrap: wrap;
}
.ts-features-tags span {
	font-family: 'Oswald', sans-serif;
	font-size: 14px;
	font-weight: 600;
	letter-spacing: 3px;
	text-transform: uppercase;
	color: rgba(255,255,255,0.95);
	border-bottom: 2px solid rgba(255,255,255,0.5);
	padding-bottom: 5px;
	text-shadow: 0 2px 4px rgba(0,0,0,0.8);
}

/* Homepage: remove gap between Premium Craftsmanship section and footer */
:global(main + footer) {
	margin-top: 0;
}

/* ===========================================
   RANKING SECTION
   =========================================== */
.ts-ranking-section {
	padding: 100px 60px;
	background: #ffffff;
}
.ts-ranking-inner {
	max-width: 800px;
	margin: 0 auto;
	text-align: center;
}
.ts-ranking-text {
	font-family: 'Yantramanav', sans-serif;
	font-size: 16px;
	line-height: 1.8;
	color: #8c8c8c;
	margin-top: 30px;
}

/* ===========================================
   NEWS ROW SECTION
   =========================================== */
.ts-news-row-section {
	padding: 0;
}
.ts-news-row-grid {
	display: grid;
	grid-template-columns: repeat(4, 1fr);
}
.ts-news-row-item {
	position: relative;
	overflow: hidden;
}
.ts-news-row-image {
	height: 350px;
	overflow: hidden;
}
.ts-news-row-image img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: transform 0.6s ease;
}
.ts-news-row-item:hover .ts-news-row-image img {
	transform: scale(1.08);
}
.ts-news-row-content {
	position: absolute;
	bottom: 0;
	left: 0;
	width: 100%;
	padding: 30px 25px;
	background: linear-gradient(transparent, rgba(0,0,0,0.8));
	color: #ffffff;
}
.ts-news-category {
	font-family: 'Yantramanav', sans-serif;
	font-size: 12px;
	letter-spacing: 3px;
	text-transform: uppercase;
	color: #fe5900;
	text-decoration: none;
}
.ts-news-row-content h4 {
	font-family: 'Oswald', sans-serif;
	font-size: 20px;
	font-weight: 600;
	margin: 8px 0 12px;
}
.ts-news-row-content h4 a {
	color: #ffffff;
	text-decoration: none;
}
.ts-news-row-content h4 a:hover {
	color: #fe5900;
}
.ts-news-row-content .ts-read-more {
	color: #ffffff;
	border-color: #ffffff;
}
.ts-news-row-content .ts-read-more:hover {
	color: #fe5900;
	border-color: #fe5900;
}

/* ===========================================
   SERVICES / TABS SECTION
   =========================================== */
.ts-services-section {
	padding: 100px 60px;
	background: #ffffff;
}
.ts-services-inner {
	max-width: 900px;
	margin: 0 auto;
}
.ts-services-tabs {
	display: flex;
	flex-direction: column;
	gap: 0;
}
.ts-tab {
	border-bottom: 1px solid #e0e0e0;
	overflow: hidden;
	cursor: pointer;
}
.ts-tab-title {
	font-family: 'Oswald', sans-serif;
	font-size: 20px;
	font-weight: 600;
	padding: 25px 0;
	margin: 0;
	position: relative;
	padding-right: 40px;
	transition: color 0.3s;
}
.ts-tab-title::after {
	content: '+';
	position: absolute;
	right: 0;
	top: 50%;
	transform: translateY(-50%);
	font-size: 24px;
	font-weight: 300;
	transition: transform 0.3s;
}
.ts-tab.active .ts-tab-title::after {
	content: '-';
}
.ts-tab.active .ts-tab-title {
	color: #fe5900;
}
.ts-tab-content {
	max-height: 0;
	overflow: hidden;
	transition: max-height 0.4s ease, padding 0.4s ease;
	padding: 0;
}
.ts-tab.active .ts-tab-content {
	max-height: 200px;
	padding-bottom: 25px;
}
.ts-tab-content p {
	font-family: 'Yantramanav', sans-serif;
	font-size: 15px;
	line-height: 1.8;
	color: #8c8c8c;
	margin: 0;
}

/* ===========================================
   SCROLL ANIMATIONS
   =========================================== */
.ts-animate {
	opacity: 0;
	transform: translateY(40px);
	transition: opacity 0.8s ease, transform 0.8s ease;
}
.ts-animate.ts-visible {
	opacity: 1;
	transform: translateY(0);
}
.ts-animate-left {
	opacity: 0;
	transform: translateX(-60px);
	transition: opacity 0.8s ease, transform 0.8s ease;
}
.ts-animate-left.ts-visible {
	opacity: 1;
	transform: translateX(0);
}
.ts-animate-right {
	opacity: 0;
	transform: translateX(60px);
	transition: opacity 0.8s ease, transform 0.8s ease;
}
.ts-animate-right.ts-visible {
	opacity: 1;
	transform: translateX(0);
}

/* ===========================================
   PLAYERSTALL EQUIPMENT STATS SECTION
   =========================================== */
.trending-stats-section {
	background: #f7f7f7;
	padding: 100px 0;
}
.trending-stats-container {
	max-width: 1300px;
	margin: 0 auto;
	padding: 0 20px;
}
.trending-stats-header {
	text-align: center;
	margin-bottom: 60px;
}
.trending-stats-subtitle {
	font-family: 'Yantramanav', sans-serif;
	font-size: 13px;
	color: #b6b6b6;
	letter-spacing: 0.3em;
	text-transform: uppercase;
	margin-bottom: 10px;
}
.trending-stats-title {
	font-family: 'Oswald', sans-serif;
	font-size: 48px;
	font-weight: 700;
	color: #1a1a1a;
	text-transform: uppercase;
	margin: 0;
}
.trending-stats-grid {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 30px;
}
.trending-stat-item {
	display: flex;
	align-items: center;
	gap: 24px;
}
/* Circle + SVG ring */
.trending-stat-circle {
	position: relative;
	width: 140px;
	height: 140px;
	flex-shrink: 0;
}
.progress-ring {
	width: 100%;
	height: 100%;
	transform: rotate(-90deg);
}
.progress-ring-bg {
	fill: none;
	stroke: #e8e8e8;
	stroke-width: 3;
}
.progress-ring-fill {
	fill: none;
	stroke: #1a1a1a;
	stroke-width: 3;
	stroke-linecap: round;
	stroke-dasharray: 389.56;  /* 2 * π * 62 */
	stroke-dashoffset: 389.56; /* starts fully hidden */
	transition: stroke-dashoffset 0.05s linear;
}
.trending-stat-counter {
	position: absolute;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	display: flex;
	align-items: baseline;
}
.trending-stat-number {
	font-family: 'Oswald', sans-serif;
	font-size: 40px;
	font-weight: 700;
	color: #1a1a1a;
	line-height: 1;
}
.trending-stat-percent {
	font-family: 'Oswald', sans-serif;
	font-size: 18px;
	font-weight: 600;
	color: #1a1a1a;
	margin-left: 2px;
}
/* Text info to the right */
.trending-stat-info {
	flex: 1;
}
.trending-stat-label {
	font-family: 'Oswald', sans-serif;
	font-size: 15px;
	font-weight: 600;
	color: #1a1a1a;
	text-transform: uppercase;
	letter-spacing: 0.12em;
	margin: 0 0 8px 0;
}
.trending-stat-text {
	font-family: 'Yantramanav', sans-serif;
	font-size: 14px;
	color: #8c8c8c;
	line-height: 1.6;
	margin: 0;
}

/* ===========================================
   RESPONSIVE
   =========================================== */
@media (max-width: 1024px) {
	.trending-stats-grid {
		grid-template-columns: repeat(2, 1fr);
	}
	.ts-scores-grid {
		grid-template-columns: 1fr;
		gap: 30px;
	}
	.ts-shipping-card {
		padding: 25px 20px;
	}
	.ts-shipping-title {
		font-size: 26px;
	}
	.ts-blog-cards-grid {
		grid-template-columns: repeat(2, 1fr);
	}
	.ts-store-item {
		min-width: calc(33.333% - 14px);
	}
	.ts-news-row-grid {
		grid-template-columns: repeat(2, 1fr);
	}
	.ts-vertical-text {
		display: none;
	}
	.ts-corner-img {
		display: none;
	}
}
@media (max-width: 768px) {
	.ts-slide-content {
		padding-left: 5%;
		padding-right: 5%;
	}
	.ts-slide-title {
		font-size: 32px;
		letter-spacing: 1px;
		margin-bottom: 12px;
	}
	.ts-scores-section {
		padding: 50px 20px;
	}
	.ts-scores-grid {
		grid-template-columns: 1fr;
		gap: 25px;
		margin-top: 40px;
	}
	.ts-shipping-card {
		padding: 20px 15px;
	}
	.ts-shipping-title {
		font-size: 22px;
	}
	.ts-shipping-description {
		font-size: 14px;
	}
	.ts-section-description {
		font-size: 14px;
	}
	.ts-shipping-card .ts-score-buttons {
		flex-direction: row;
		gap: 8px;
	}
	.ts-shipping-card .ts-score-buttons .ts-btn {
		padding: 10px 18px;
		font-size: 12px;
	}
	.ts-spotlight-inner {
		grid-template-columns: 1fr;
	}
	.ts-spotlight-section {
		padding: 60px 20px;
	}
	.ts-blog-cards-grid {
		grid-template-columns: 1fr;
	}
	.ts-store-section {
		padding: 60px 20px;
	}
	.ts-store-item {
		min-width: calc(50% - 10px);
	}
	.ts-ranking-section {
		padding: 60px 20px;
	}
	.ts-news-row-grid {
		grid-template-columns: 1fr;
	}
	.ts-news-row-image {
		height: 250px;
	}
	.ts-services-section {
		padding: 60px 20px;
	}
	.ts-countdown-timer {
		gap: 20px;
	}
	.ts-carousel-prev {
		left: 0;
	}
	.ts-carousel-next {
		right: 0;
	}
}
@media (max-width: 640px) {
	.trending-stats-grid {
		grid-template-columns: 1fr;
	}
	.trending-stats-title {
		font-size: 32px;
	}
	.trending-stat-circle {
		width: 120px;
		height: 120px;
	}
}

@media (max-width: 480px) {
	.ts-slide-buttons {
		flex-direction: row;
		justify-content: center;
		flex-wrap: wrap;
		gap: 12px;
	}
	.ts-hero-btn {
		padding: 10px 22px;
		font-size: 11px;
	}
	.ts-shipping-card {
		padding: 20px 15px;
	}
	.ts-shipping-title {
		font-size: 20px;
	}
	.ts-shipping-features li {
		font-size: 12px;
		padding: 5px 0;
	}
	.ts-shipping-card .ts-score-buttons {
		flex-wrap: wrap;
		gap: 6px;
	}
	.ts-shipping-card .ts-score-buttons .ts-btn {
		font-size: 10px;
		padding: 9px 14px;
		flex: 1 1 auto;
		min-width: 98px;
	}
	.ts-store-item {
		min-width: 100%;
	}
}

/* ============================================
   OUR LOCKERS SECTION STYLES
   ============================================ */
.home-shop-section {
