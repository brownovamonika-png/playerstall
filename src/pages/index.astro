<script>
document.addEventListener('DOMContentLoaded', () => {
	// =====================
	// HERO SLIDER (TS-SLIDE)
	// =====================
	const tsSlides = document.querySelectorAll('.ts-slide');
	let currentTsSlide = 0;
	let tsSlideInterval: ReturnType<typeof setInterval>;

	function goToTsSlide(index: number) {
		tsSlides.forEach((slide, i) => {
			slide.classList.toggle('active', i === index);
		});
		currentTsSlide = index;
	}

	function nextTsSlide() {
		goToTsSlide((currentTsSlide + 1) % tsSlides.length);
	}

	function startTsSlider() {
		if (tsSlides.length > 0) {
			tsSlideInterval = setInterval(nextTsSlide, 6000);
		}
	}

	startTsSlider();

	// =====================
	// HERO SLIDER (from index.astro)
	// =====================
	function initHeroSlider() {
		const heroSlides = document.querySelectorAll('.hero-slide');
		const dots = document.querySelectorAll('.slider-dot');
		const prevBtn = document.querySelector('.slider-nav-prev');
		const nextBtn = document.querySelector('.slider-nav-next');
		
		if (heroSlides.length === 0) return;

		let currentSlide = 0;
		let autoPlayInterval: ReturnType<typeof setInterval>;

		function showSlide(index: number) {
			// Remove active class from all slides and dots
			heroSlides.forEach(slide => {
				slide.classList.remove('active');
				// Reset animation
				(slide as HTMLElement).style.animation = 'none';
				setTimeout(() => {
					if (slide.classList.contains('active')) {
						(slide as HTMLElement).style.animation = '';
					}
				}, 10);
			});
			dots.forEach(dot => dot.classList.remove('active'));

			// Add active class to current slide and dot
			const activeSlide = heroSlides[index] as HTMLElement;
			activeSlide.classList.add('active');
			dots[index].classList.add('active');
			
			// Restart animation
			activeSlide.style.animation = 'none';
			setTimeout(() => {
				if (activeSlide.classList.contains('first-slide')) {
					activeSlide.style.animation = 'zoomInFirst 20s ease-in-out infinite';
				} else if (activeSlide.classList.contains('slide-bottom')) {
					activeSlide.style.animation = 'zoomInBottom 20s ease-in-out infinite';
				} else {
					activeSlide.style.animation = 'zoomIn 20s ease-in-out infinite';
				}
			}, 10);
			
			currentSlide = index;
		}

		function nextSlide() {
			const next = (currentSlide + 1) % heroSlides.length;
			showSlide(next);
		}

		function prevSlide() {
			const prev = (currentSlide - 1 + heroSlides.length) % heroSlides.length;
			showSlide(prev);
		}

		function startAutoPlay() {
			autoPlayInterval = setInterval(nextSlide, 5000);
		}

		function stopAutoPlay() {
			if (autoPlayInterval) {
				clearInterval(autoPlayInterval);
			}
		}

		// Navigation button events
		if (nextBtn) {
			nextBtn.addEventListener('click', () => {
				stopAutoPlay();
				nextSlide();
				startAutoPlay();
			});
		}

		if (prevBtn) {
			prevBtn.addEventListener('click', () => {
				stopAutoPlay();
				prevSlide();
				startAutoPlay();
			});
		}

		// Dot navigation
		dots.forEach((dot, index) => {
			dot.addEventListener('click', () => {
				stopAutoPlay();
				showSlide(index);
				startAutoPlay();
			});
		});

		// Pause autoplay on hover
		const slider = document.querySelector('.hero-slider');
		if (slider) {
			slider.addEventListener('mouseenter', stopAutoPlay);
			slider.addEventListener('mouseleave', startAutoPlay);
		}

		// Ensure first slide is visible on load
		showSlide(0);
		// Start autoplay
		startAutoPlay();
	}

	// Initialize hero slider
	initHeroSlider();

	// =====================
	// QUOTE STRIP SLIDER (4 quotes + number indicator 01–04); drop images synced to same index
	// =====================
	function initQuoteStripSlider() {
		const strip = document.querySelector('.home-quote-strip');
		const slides = document.querySelectorAll('.home-quote-strip-slide');
		const nums = document.querySelectorAll('.home-quote-strip-num');
		const dropContainer = document.querySelector('.home-quote-strip-drop-imgs');
		const dropImgs = document.querySelectorAll('.home-quote-strip-drop-img');
		if (slides.length === 0 || nums.length === 0) return;

		let current = 0;
		let autoInterval: ReturnType<typeof setInterval>;

		function setActiveDropImage(index: number) {
			if (!dropContainer || dropImgs.length === 0) return;
			const i = (index + dropImgs.length) % dropImgs.length;
			(dropContainer as HTMLElement).dataset.activeDrop = String(i);
			dropImgs.forEach((img, j) => {
				const el = img as HTMLElement;
				if (j === i) {
					el.classList.remove('active-drop');
					void el.offsetHeight; // force reflow so animation runs again when cycling back
					el.classList.add('active-drop');
				} else {
					el.classList.remove('active-drop');
				}
			});
		}

		function goTo(index: number) {
			current = (index + slides.length) % slides.length;
			slides.forEach((el, i) => el.classList.toggle('active', i === current));
			nums.forEach((el, i) => {
				el.classList.toggle('active', i === current);
				el.setAttribute('aria-current', i === current ? 'true' : 'false');
			});
			setActiveDropImage(current);
		}

		function next() {
			goTo(current + 1);
		}

		nums.forEach((btn, i) => {
			btn.addEventListener('click', () => {
				clearInterval(autoInterval);
				goTo(i);
				startAuto();
			});
		});

		function startAuto() {
			autoInterval = setInterval(next, 8000);
		}
		if (strip) {
			strip.addEventListener('mouseenter', () => clearInterval(autoInterval));
			strip.addEventListener('mouseleave', startAuto);
		}
		goTo(0);
		startAuto();
	}
	initQuoteStripSlider();

	// =====================
	// COUNTDOWN TIMER
	// =====================
	const targetDate = new Date();
	targetDate.setDate(targetDate.getDate() + 84); // 12 weeks from now

	function updateCountdown() {
		const now = new Date().getTime();
		const diff = targetDate.getTime() - now;

		if (diff <= 0) return;

		const days = Math.floor(diff / (1000 * 60 * 60 * 24));
		const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
		const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
		const secs = Math.floor((diff % (1000 * 60)) / 1000);

		const daysEl = document.getElementById('countdown-days');
		const hoursEl = document.getElementById('countdown-hours');
		const minsEl = document.getElementById('countdown-mins');
		const secsEl = document.getElementById('countdown-secs');
		
		if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
		if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
		if (minsEl) minsEl.textContent = String(mins).padStart(2, '0');
		if (secsEl) secsEl.textContent = String(secs).padStart(2, '0');
	}

	updateCountdown();
	setInterval(updateCountdown, 1000);

	// =====================
	// STORE CAROUSEL
	// =====================
	const carousel = document.getElementById('storeCarousel') as HTMLElement;
	const prevBtn = document.getElementById('storePrev');
	const nextBtn = document.getElementById('storeNext');
	let carouselPos = 0;

	function getItemWidth() {
		const item = carousel?.querySelector('.ts-store-item') as HTMLElement;
		if (!item) return 300;
		return item.offsetWidth + 20; // width + gap
	}

	function getVisibleItems() {
		const w = window.innerWidth;
		if (w <= 480) return 1;
		if (w <= 768) return 2;
		if (w <= 1024) return 3;
		return 4;
	}

	function moveCarousel(direction: number) {
		if (!carousel) return;
		const items = carousel.querySelectorAll('.ts-store-item');
		const maxPos = items.length - getVisibleItems();
		carouselPos = Math.max(0, Math.min(carouselPos + direction, maxPos));
		carousel.style.transform = `translateX(-${carouselPos * getItemWidth()}px)`;
	}

	prevBtn?.addEventListener('click', () => moveCarousel(-1));
	nextBtn?.addEventListener('click', () => moveCarousel(1));

	// =====================
	// ACCORDION TABS
	// =====================
	const tabs = document.querySelectorAll('.ts-tab');
	tabs.forEach(tab => {
		const title = tab.querySelector('.ts-tab-title');
		title?.addEventListener('click', () => {
			const isActive = tab.classList.contains('active');
			tabs.forEach(t => t.classList.remove('active'));
			if (!isActive) {
				tab.classList.add('active');
			}
		});
	});

	// =====================
	// SCROLL ANIMATIONS
	// =====================
	const animElements = document.querySelectorAll(
		'.ts-section-header, .ts-score-card, .ts-spotlight-image, .ts-spotlight-content, .ts-blog-card, .ts-store-item, .ts-features-content, .ts-ranking-inner, .ts-news-row-item, .ts-tab'
	);

	const observerOptions = {
		threshold: 0.15,
		rootMargin: '0px 0px -50px 0px'
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach((entry, i) => {
			if (entry.isIntersecting) {
				setTimeout(() => {
					(entry.target as HTMLElement).style.opacity = '1';
					(entry.target as HTMLElement).style.transform = 'translateY(0)';
				}, i * 100);
				observer.unobserve(entry.target);
			}
		});
	}, observerOptions);

	animElements.forEach(el => {
		(el as HTMLElement).style.opacity = '0';
		(el as HTMLElement).style.transform = 'translateY(30px)';
		(el as HTMLElement).style.transition = 'opacity 0.6s ease, transform 0.6s ease';
		observer.observe(el);
	});

	// =====================
	// PLAYERSTALL EQUIPMENT COUNTER ANIMATION
	// =====================
	function initCounterAnimation() {
		const counters = document.querySelectorAll('.trending-stat-number[data-target]');
		const rings = document.querySelectorAll('.progress-ring-fill[data-percent]');
		if (counters.length === 0) return;

		const radius = 62;
		const circumference = 2 * Math.PI * radius; // ≈ 389.56

		let animated = false;

		function animateCounters() {
			if (animated) return;
			animated = true;

			const duration = 2000; // 2 seconds
			const startTime = performance.now();

			function easeOutCubic(t: number) {
				return 1 - Math.pow(1 - t, 3);
			}

			function update(currentTime: number) {
				const elapsed = currentTime - startTime;
				const progress = Math.min(elapsed / duration, 1);
				const easedProgress = easeOutCubic(progress);

				// Animate numbers
				counters.forEach(counter => {
					const target = parseInt(counter.getAttribute('data-target') || '0', 10);
					const currentValue = Math.round(easedProgress * target);
					counter.textContent = progress < 1 ? String(currentValue) : String(target);
				});

				// Animate circle rings
				rings.forEach(ring => {
					const percent = parseInt(ring.getAttribute('data-percent') || '0', 10);
					const currentPercent = easedProgress * percent;
					const offset = circumference - (currentPercent / 100) * circumference;
					(ring as SVGCircleElement).style.strokeDashoffset = String(offset);
				});

				if (progress < 1) {
					requestAnimationFrame(update);
				}
			}

			requestAnimationFrame(update);
		}

		const section = document.querySelector('.trending-stats-section');
		if (!section) return;

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					animateCounters();
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.2 });

		observer.observe(section);
	}

	// Initialize counter animation
	initCounterAnimation();

	// =====================
	// COLOR MODAL
	// =====================
	const colorModal = document.getElementById('colorModal');
	const colorIframe = document.getElementById('colorIframe') as HTMLIFrameElement;
	const viewAllColorsBtn = document.getElementById('viewAllColorsBtn');
	const melamineLinkBtn = document.getElementById('melamineLinkBtn');
	const woodGrainLinkBtn = document.getElementById('woodGrainLinkBtn');
	const phenolicLinkBtn = document.getElementById('phenolicLinkBtn');
	const closeModalBtn = document.querySelector('.color-modal-close');
	const modalOverlay = document.querySelector('.color-modal-overlay');

	viewAllColorsBtn?.addEventListener('click', () => {
		if (colorModal && colorIframe) {
			colorIframe.src = '/colors/all-color-options-pdf.html';
			colorModal.classList.add('active');
			document.body.style.overflow = 'hidden';
		}
	});

	melamineLinkBtn?.addEventListener('click', (e) => {
		e.preventDefault();
		if (colorModal && colorIframe) {
			colorIframe.src = '/colors/laminate-colors-pdf.html';
			colorModal.classList.add('active');
			document.body.style.overflow = 'hidden';
		}
	});

	woodGrainLinkBtn?.addEventListener('click', (e) => {
		e.preventDefault();
		if (colorModal && colorIframe) {
			colorIframe.src = '/colors/woodgrain-colors-pdf.html';
			colorModal.classList.add('active');
			document.body.style.overflow = 'hidden';
		}
	});

	phenolicLinkBtn?.addEventListener('click', (e) => {
		e.preventDefault();
		if (colorModal && colorIframe) {
			colorIframe.src = '/colors/phenolic-colors-pdf.html';
			colorModal.classList.add('active');
			document.body.style.overflow = 'hidden';
		}
	});

	closeModalBtn?.addEventListener('click', () => {
		if (colorModal) {
			colorModal.classList.remove('active');
			document.body.style.overflow = '';
		}
	});

	modalOverlay?.addEventListener('click', () => {
		if (colorModal) {
			colorModal.classList.remove('active');
			document.body.style.overflow = '';
		}
	});
});
</script>

