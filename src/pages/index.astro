/* ===========================================
   HERO SLIDER (from index.astro)
   =========================================== */
.hero-slider {
	position: relative;
	height: 70vh;
	min-height: 490px;
	max-height: 70vh;
	overflow: hidden;
	margin-top: 0;
	width: 100%;
	background: #000000;
}

.hero-slider-container {
	position: relative;
	width: 100%;
	height: 100%;
}

.hero-slide {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	background-size: cover;
	background-position: center center;
	background-repeat: no-repeat;
	opacity: 0;
	transition: opacity 1.5s ease-in-out;
	display: flex;
	align-items: center;
	justify-content: center;
	overflow: hidden;
}

.hero-slide.active {
	opacity: 1;
	z-index: 1;
	animation: zoomIn 20s ease-in-out infinite;
}

.hero-slide.first-slide {
	background-size: cover;
	background-position: center center;
}

.hero-slide.first-slide.active {
	animation: zoomInFirst 20s ease-in-out infinite;
}

@keyframes zoomIn {
	0% {
		background-size: cover;
		background-position: center center;
		transform: scale(1);
	}
	50% {
		background-size: cover;
		background-position: center center;
		transform: scale(1.1);
	}
	100% {
		background-size: cover;
		background-position: center center;
		transform: scale(1);
	}
}

.hero-slide.slide-bottom {
	background-position: center bottom !important;
	filter: contrast(1.15) brightness(1.05) saturate(1.1);
}
.hero-slide.slide-bottom.active {
	animation: zoomInBottom 20s ease-in-out infinite;
}
@keyframes zoomInBottom {
	0% {
		background-size: cover;
		background-position: center bottom;
		transform: scale(1);
	}
	50% {
		background-size: cover;
		background-position: center bottom;
		transform: scale(1.1);
	}
	100% {
		background-size: cover;
		background-position: center bottom;
		transform: scale(1);
	}
}

@keyframes zoomInFirst {
	0% {
		background-size: cover;
		background-position: center center;
		transform: scale(1);
	}
	50% {
		background-size: cover;
		background-position: center center;
		transform: scale(1.1);
	}
	100% {
		background-size: cover;
		background-position: center center;
		transform: scale(1);
	}
}

.hero-slide-overlay {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	background: rgba(0, 0, 0, 0.3);
	z-index: 2;
}

.hero-slider-container > .hero-slide:first-child:not(.hero-slide-topscorer) .hero-slide-overlay {
	display: none;
}

.hero-slide-content {
	position: relative;
	z-index: 10;
	text-align: center;
	color: #ffffff;
	max-width: 1000px;
	padding: 10.5vh 40px 0;
	width: 100%;
}

.hero-slide:not(.active) .hero-slide-content {
	opacity: 0;
	transform: translateY(50px);
}

.hero-slide.active .hero-slide-content {
	opacity: 1;
	transform: translateY(0);
	transition: opacity 1s ease-out 0.3s, transform 1s ease-out 0.3s;
}

.hero-slide-title {
	font-family: 'Oswald', sans-serif;
	font-size: 46px;
	font-weight: 700;
	color: #ffffff;
	text-transform: uppercase;
	line-height: 1;
	margin: 0 0 16px 0;
	text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
	letter-spacing: 2px;
}

.hero-slide:not(.active) .hero-slide-title {
	opacity: 0;
	transform: translateY(30px);
}

.hero-slide.active .hero-slide-title {
	opacity: 1;
	transform: translateY(0);
	animation: slideInUpTitle 1s ease-out 0.5s both;
}

.hero-slide-text {
	font-family: 'Yantramanav', sans-serif;
	font-size: 18px;
	color: #ffffff;
	line-height: 1.3;
	margin: 0 0 39px 0;
	font-weight: 300;
	text-shadow: 0 1px 5px rgba(0, 0, 0, 0.5);
	letter-spacing: 0.3px;
}

.hero-slide:not(.active) .hero-slide-text {
	opacity: 0;
	transform: translateY(30px);
}

.hero-slide.active .hero-slide-text {
	opacity: 1;
	transform: translateY(0);
	animation: slideInUpText 1s ease-out 0.7s both;
}

@keyframes slideInUpTitle {
	from {
		opacity: 0;
		transform: translateY(30px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

@keyframes slideInUpText {
	from {
		opacity: 0;
		transform: translateY(30px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

.hero-slide-buttons {
	display: flex;
	gap: 40px;
	justify-content: center;
	flex-wrap: wrap;
	align-items: center;
}

.hero-slide:not(.active) .hero-slide-buttons {
	opacity: 0;
	transform: translateY(30px);
}

.hero-slide.active .hero-slide-buttons {
	opacity: 1;
	transform: translateY(0);
	animation: slideInUpButtons 1s ease-out 0.9s both;
}

@keyframes slideInUpButtons {
	from {
		opacity: 0;
		transform: translateY(30px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

.btn-slide-primary {
