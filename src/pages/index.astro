<!-- ============================================
     ALL STYLES
     ============================================ -->
<style>
/* ===========================================
   GLOBAL RESETS FOR THIS PAGE
   =========================================== */
:global(body) {
	overflow-x: hidden;
}

/* ===========================================
   HERO SLIDER
   =========================================== */
.ts-hero-slider {
	position: relative;
	width: 100%;
	height: 70vh;
	min-height: 490px;
	max-height: 70vh;
	overflow: hidden;
	background: #000000;
}
.ts-hero-container {
	position: relative;
	width: 100%;
	height: 100%;
}
.ts-slide {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	opacity: 0;
	transition: opacity 1s ease-in-out;
	display: flex;
	align-items: center;
	justify-content: center;
	overflow: hidden;
}
.ts-slide.active {
	opacity: 1;
	z-index: 2;
}
.ts-slide-bg {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	background-size: cover;
	background-position: center center;
	background-repeat: no-repeat;
	transition: transform 8s ease-out;
	transform: scale(1);
}
.ts-slide.active .ts-slide-bg {
	animation: tsKenBurns 20s ease-in-out infinite;
}
@keyframes tsKenBurns {
	0% { transform: scale(1); }
	50% { transform: scale(1.1); }
	100% { transform: scale(1); }
}
.ts-slide-overlay {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	background: rgba(0, 0, 0, 0.3);
	z-index: 2;
}
.ts-slide-content {
	position: relative;
	z-index: 3;
	max-width: 1000px;
	width: 100%;
	text-align: center;
	opacity: 0;
	transform: translateY(60px);
	transition: opacity 0.8s ease 0.3s, transform 0.8s ease 0.3s;
	padding: 10.5vh 40px 0;
}
.ts-slide.active .ts-slide-content {
	opacity: 1;
	transform: translateY(0);
}
.ts-slide-subtitle {
	display: block;
	color: #ffffff;
	font-family: 'Yantramanav', sans-serif;
	font-size: 14px;
	letter-spacing: 8px;
