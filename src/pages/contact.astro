---
import BaseLayout from '../layouts/BaseLayout.astro';

const thankYouUrl = `${Astro.url.origin}/thank-you`;
---

<BaseLayout
	title="Get a Free Locker Room Consultation | PlayerStall"
	description="Start your custom wood locker room project with a free consultation. 30 years serving collegiate and pro teams. Ships nationwide. Match any US competitor's price."
>
	<Fragment slot="head">
		<script type="application/ld+json">
		{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "PlayerStall",
			"image": "https://playerstall.b-cdn.net/images/logoblack2.png",
			"url": "https://playerstall.com",
			"telephone": "+18885841444",
			"email": "team@playerstall.com",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "2934 200 Street",
				"addressLocality": "Langley",
				"addressRegion": "BC",
				"postalCode": "V2Z 2C1",
				"addressCountry": "CA"
			},
			"serviceArea": {
				"@type": "Country",
				"name": "United States"
			},
			"areaServed": "US",
			"priceRange": "$$",
			"description": "Custom wood sports lockers for collegiate and professional teams. 30+ years experience. Ships nationwide."
		})}
		</script>
		<script type="application/ld+json">
		{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://playerstall.com"},
				{"@type": "ListItem", "position": 2, "name": "Contact", "item": "https://playerstall.com/contact"}
			]
		})}
		</script>
	</Fragment>

	<!-- Hero Section (same image and style as blog) -->
	<section class="contact-hero-section" id="hero">
		<div class="contact-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Contact PlayerStall" class="contact-hero-bg-image" />
		</div>
		<div class="contact-hero-background-overlay"></div>
		<div class="contact-hero-container">
			<div class="contact-hero-breadcrumbs">
				<a href="/">Home</a>
				<span>Contact</span>
			</div>
			<h1 class="contact-hero-page-title">Start Your Free Consultation</h1>
			<div class="contact-hero-background-text">contact</div>
		</div>
	</section>

	<!-- Get in touch section – quote bar, section title, then two cols (left: intro + office, right: form) -->
	<section class="contact-section" aria-labelledby="contact-section-title">
		<div class="contact-quote-bar">PLAYERSTALL – 30+ YEARS CRAFTING LOCKER ROOMS</div>
		<div class="contact-container">
			<h2 id="contact-section-title" class="contact-section-title">GET IN TOUCH WITH US</h2>
			<div class="contact-two-col">
				<!-- Left column: intro, office -->
				<div class="contact-info-block">
					<p class="contact-intro">Tell us about your space. We'll handle the rest. Every locker room we build starts with a conversation — your sport, your dimensions, your timeline. Thirty years of doing this means we ask the right questions.</p>
					<p class="contact-best-way">Email is the quickest way to reach us. We typically respond within one business day.</p>
					<h4 class="contact-office-title">OFFICE IN LANGLEY</h4>
					<div class="contact-info-list">
						<div class="contact-info-item">
							<span class="contact-info-icon" aria-hidden="true">z</span>
							<div class="contact-info-text">
								<a href="https://www.google.com/maps/search/2934+200+Street+Langley+BC+V2Z+2C1+Canada" target="_blank" rel="noopener noreferrer">2934 200 Street, Langley,<br />BC V2Z 2C1 Canada</a>
							</div>
						</div>
						<div class="contact-info-item">
							<span class="contact-info-icon" aria-hidden="true">m</span>
							<div class="contact-info-text">
								<a href="tel:+18885841444">1 888 584 1444</a>
							</div>
						</div>
						<div class="contact-info-item">
							<span class="contact-info-icon" aria-hidden="true">d</span>
							<div class="contact-info-text">
								<a href="mailto:team@playerstall.com">team@playerstall.com</a>
							</div>
						</div>
					</div>
				</div>

				<!-- Right column: form (Top Scorer: Your Name, Your Email, Your Message, Send message) -->
				<div class="contact-form-wrapper">
					<form class="contact-form" action="https://formspree.io/f/xqedgojb" method="POST">
						<input type="hidden" name="_next" value={thankYouUrl} />
						<div class="contact-form-group">
							<input type="text" id="contact-name" name="name" required placeholder="Your Name" />
						</div>
						<div class="contact-form-group">
							<input type="email" id="contact-email" name="email" required placeholder="Your Email" />
						</div>
						<div class="contact-form-group">
							<textarea id="contact-message" name="message" rows="5" required placeholder="Your Message"></textarea>
						</div>
						<button type="submit" class="contact-form-btn">Send message</button>
					</form>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	.container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Contact Hero (same as our-process: full-bleed image + overlay + white title) */
	.contact-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}

	.contact-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.contact-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.contact-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.contact-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.contact-hero-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}

	.contact-hero-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.contact-hero-breadcrumbs a:hover {
		color: #fe5900;
	}

	.contact-hero-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.contact-hero-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	.contact-hero-background-text {
		display: none;
	}

	/* Top Scorer contact section: 120px padding, 1300px content grid */
	.contact-section {
		padding: 120px 0;
		background: #fff;
	}

	/* Quote bar – Top Scorer: small uppercase grey (e.g. FINAL FOUR - 26 AVG 2019) */
	.contact-quote-bar {
		text-align: center;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: #8a8a8a;
		background: transparent;
		padding: 0 20px;
		margin-bottom: 32px;
	}

	.contact-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Two columns: left = heading + text + office, right = form (Top Scorer layout, 1300px grid) */
	.contact-two-col {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: end;
	}

	/* Left column: GET IN TOUCH + paragraphs + OFFICE IN LANGLEY + contact list */
	.contact-info-block {
		background: transparent;
		border: none;
		padding: 0;
		text-align: left;
	}

	/* Section title – GET IN TOUCH WITH US (above the two columns) */
	.contact-section-title {
		font-family: 'Oswald', sans-serif;
		font-size: 54px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: -0.01em;
		line-height: 1.2em;
		margin: 0 0 32px;
		text-align: center;
	}

	.contact-intro {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #8a8a8a;
		line-height: 1.44em;
		margin: 0 0 21px;
	}

	.contact-best-way {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #8a8a8a;
		line-height: 1.44em;
		margin: 0 0 32px;
	}

	.contact-office-title {
		font-family: 'Oswald', sans-serif;
		font-size: 24px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0;
		line-height: 1.1em;
		margin: 0 0 25px;
	}

	.contact-info-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.contact-info-item {
		display: flex;
		gap: 0.875rem;
		align-items: flex-start;
	}

	.contact-info-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		min-width: 28px;
		background: #0d0d0d;
		color: #ffffff;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		text-transform: lowercase;
	}

	.contact-info-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #8a8a8a;
		line-height: 1.44em;
		margin: 0;
	}

	.contact-info-text a {
		color: #8a8a8a;
		text-decoration: none;
		transition: color 0.2s ease-out;
	}

	.contact-info-text a:hover {
		color: #fe5900;
	}

	/* Shared form styles */
	.form-group {
		display: flex;
		flex-direction: column;
	}

	.form-group label {
		margin-bottom: 0.5rem;
		color: #0d0d0d;
		font-weight: 500;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.form-group input,
	.form-group select,
	.form-group textarea {
		padding: 0.75rem;
		border: 1px solid #bfbfbf;
		border-radius: 0;
		font-size: 15px;
		font-family: 'Yantramanav', sans-serif;
		transition: border-color 0.25s ease, box-shadow 0.25s ease;
		background: #fff;
		color: #0d0d0d;
		width: 100%;
	}

	.form-group textarea {
		resize: vertical;
	}

	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: #fe5900;
		box-shadow: 0 0 0 2px rgba(254, 89, 0, 0.1);
	}

	.helper-text {
		display: block;
		margin-top: 0.35rem;
		font-size: 12px;
		color: #8c8c8c;
	}

	.helper-row {
		display: flex;
		justify-content: space-between;
		margin-top: 0.4rem;
	}

	.helper-row small {
		font-size: 12px;
		color: #8c8c8c;
		font-family: 'Yantramanav', sans-serif;
	}

	.section-helper {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #666666;
		margin: 0 0 1.25rem;
		line-height: 1.6;
	}

	.section-helper a {
		color: #fe5900;
		text-decoration: none;
	}

	.section-helper a:hover {
		text-decoration: underline;
	}

	.btn {
		padding: 0.875rem 2rem;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.3s ease;
		display: inline-block;
		border: none;
		cursor: pointer;
		font-size: 1rem;
		font-family: 'Yantramanav', sans-serif;
	}

	.btn-primary {
		background: #fe5900;
		color: #fff;
		border: 2px solid #fe5900;
	}

	.btn-primary:hover {
		background: #e04d00;
		border-color: #e04d00;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(254, 89, 0, 0.3);
	}

	/* Right side: form – bordered inputs, Yantramanav, compact button (third variant) */
	.contact-form-wrapper {
		width: 100%;
		background: transparent;
		border: none;
		padding: 0;
		box-shadow: none;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.contact-form-group {
		width: 100%;
		margin-bottom: 1.25rem;
	}

	.contact-form-group:last-of-type {
		margin-bottom: 0;
	}

	.contact-form-group input,
	.contact-form-group textarea {
		width: 100%;
		padding: 12px 24px;
		border: 1px solid #e8e8e9;
		border-radius: 0;
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #0d0d0d;
		background: #fff;
		transition: border-color 0.2s, box-shadow 0.2s;
		outline: none;
	}

	.contact-form-group input::placeholder,
	.contact-form-group textarea::placeholder {
		color: #999;
	}

	.contact-form-group input:focus,
	.contact-form-group textarea:focus {
		border-color: #fe5900;
		box-shadow: 0 0 0 2px rgba(254, 89, 0, 0.1);
	}

	.contact-form-group textarea {
		resize: vertical;
		min-height: 100px;
	}

	.contact-form-btn {
		margin-top: 1.5rem;
		align-self: flex-start;
		padding: 0.75rem 1.75rem;
		background: #0d0d0d;
		color: #fff;
		border: 2px solid #0d0d0d;
		font-family: 'Oswald', sans-serif;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 0.2s, border-color 0.2s, color 0.2s;
	}

	.contact-form-btn:hover {
		background: #fe5900;
		border-color: #fe5900;
		color: #fff;
	}

	@media (max-width: 1024px) {
		.contact-hero-section {
			min-height: 280px;
		}
		.contact-hero-page-title {
			font-size: 52px;
		}
		.contact-hero-background-text {
			font-size: 220px;
		}
		.contact-two-col {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}
	}

	@media (max-width: 968px) {
		.contact-section-title {
			font-size: 36px;
		}
		.contact-section {
			padding: 60px 0;
		}
	}

	@media (max-width: 768px) {
		.contact-hero-section {
			min-height: 240px;
			padding-bottom: 50px;
		}
		.contact-hero-page-title {
			font-size: 42px;
		}
		.contact-hero-background-text {
			font-size: 140px;
		}

		.contact-form-wrapper {
			padding: 0;
		}

		.contact-form-btn {
			width: 100%;
			text-align: center;
		}
	}
</style>