---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Contact Us & Request a Quote | PlayerStall"
	description="Get in touch or request a quote for custom sports lockers. Free design consultation. 30+ years experience, 5 year warranty. Quick response."
>
	<!-- Hero Section (same as our-process: image + overlay + white "Contact" title) -->
	<section class="contact-hero-section" id="hero">
		<div class="contact-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Contact PlayerStall" class="contact-hero-bg-image" />
		</div>
		<div class="contact-hero-background-overlay"></div>
		<div class="contact-hero-container">
			<div class="contact-hero-breadcrumbs">
				<a href="/">Home</a>
				<span>Contact</span>
			</div>
			<h1 class="contact-hero-page-title">Contact</h1>
			<div class="contact-hero-background-text">contact</div>
		</div>
	</section>

	<section class="contact-section">
		<div class="container container-center">
			<div class="contact-header">
				<h2>Contact Us & Request a Quote</h2>
				<p>Have questions? Need a quote? We're here to help. Get in touch or tell us about your locker room project—we'll respond within 2–3 business days.</p>
			</div>

			<!-- How our quote process works – under Contact Us, centered -->
			<div class="quote-process-section">
				<div class="quote-process-center">
					<h2 class="quote-process-title">How our quote process works</h2>
					<p class="quote-process-intro">Share your project details in the form below. We'll prepare an accurate quote and walk you through options. Quick ship in one month or custom-built in three months.</p>
					<div class="quote-process-steps">
						<div class="quote-process-step"><strong>1.</strong> You tell us your sport, quantities, and requirements.</div>
						<div class="quote-process-step"><strong>2.</strong> We send a detailed quote within 2–3 business days.</div>
						<div class="quote-process-step"><strong>3.</strong> We review with you and refine until it's right.</div>
					</div>
					<div class="quote-process-support">
						<strong>Need help now?</strong> Call <a href="tel:+18885841444">1 888 584 1444</a> or email <a href="mailto:sales@playerstall.com">sales@playerstall.com</a>.
					</div>
				</div>
			</div>

			<div class="quote-form-wrapper" id="quote-form">
					<h2>Tell us about your project</h2>
					<p class="form-intro">Fields marked with <span class="required">*</span> are required.</p>

					<form class="quote-form" action="https://formspree.io/f/xqedgojb" method="POST" enctype="multipart/form-data">
						<div class="form-section">
							<h3>Project &amp; Locker Details</h3>
							<div class="form-group">
								<label for="requirements">Locker requirements, dimensions &amp; quantities <span class="required">*</span></label>
								<textarea id="requirements" name="requirements" rows="6" maxlength="1000" required placeholder="Examples: 60 football lockers for home team"></textarea>
								<div class="helper-row">
									<small id="requirements-count">1000 characters left</small>
								</div>
							</div>
							<div class="form-row">
								<div class="form-group">
									<label for="sport">Primary sport</label>
									<select id="sport" name="sport">
										<option value="">Select sport</option>
										<option value="football">Football</option>
										<option value="hockey">Hockey</option>
										<option value="basketball">Basketball</option>
										<option value="baseball">Baseball</option>
										<option value="soccer">Soccer</option>
										<option value="lacrosse">Lacrosse</option>
										<option value="multi-sport">Multi-sport facility</option>
										<option value="other">Other / Not listed</option>
									</select>
								</div>
								<div class="form-group">
									<label for="project-reference">Project reference (optional)</label>
									<input type="text" id="project-reference" name="projectReference" placeholder="E.g. 2026 Varsity Locker Room Renovation" />
								</div>
							</div>
							<div class="form-row">
								<div class="form-group">
									<label for="timeline">When do you need your lockers? <span class="required">*</span></label>
									<select id="timeline" name="timeline" required>
										<option value="">Select timeline</option>
										<option value="immediately">Immediately</option>
										<option value="2-3-weeks">In 2–3 weeks</option>
										<option value="1-2-months">In 1–2 months</option>
										<option value="3-plus-months">In 3+ months</option>
										<option value="undetermined">Not sure yet</option>
									</select>
								</div>
								<div class="form-group">
									<label for="budget">Estimated budget (optional)</label>
									<input type="text" id="budget" name="budget" placeholder="Approximate budget range" />
								</div>
							</div>
						</div>

						<div class="form-section">
							<h3>Contact &amp; Organization Details</h3>
							<div class="form-row">
								<div class="form-group">
									<label for="first-name">First name <span class="required">*</span></label>
									<input type="text" id="first-name" name="firstName" required />
								</div>
								<div class="form-group">
									<label for="last-name">Last name <span class="required">*</span></label>
									<input type="text" id="last-name" name="lastName" required />
								</div>
							</div>
							<div class="form-row">
								<div class="form-group">
									<label for="title">Role / Title</label>
									<input type="text" id="title" name="title" placeholder="Athletic Director, Head Coach, etc." />
								</div>
								<div class="form-group">
									<label for="organization">School / Organization / Team <span class="required">*</span></label>
									<input type="text" id="organization" name="organization" required />
								</div>
							</div>
							<div class="form-row">
								<div class="form-group">
									<label for="quote-email">Email <span class="required">*</span></label>
									<input type="email" id="quote-email" name="email" required />
								</div>
								<div class="form-group">
									<label for="confirm-email">Confirm email <span class="required">*</span></label>
									<input type="email" id="confirm-email" name="confirmEmail" required />
								</div>
							</div>
							<div class="form-group">
								<label for="phone">Phone <span class="required">*</span></label>
								<input type="tel" id="phone" name="phone" required />
							</div>
							<div class="form-row">
								<div class="form-group">
									<label for="country">Country <span class="required">*</span></label>
									<select id="country" name="country" required>
										<option value="">Select country</option>
										<option value="united-states">United States</option>
										<option value="canada">Canada</option>
										<option value="other">Other</option>
									</select>
								</div>
								<div class="form-group">
									<label for="state">State / Province</label>
									<input type="text" id="state" name="state" />
								</div>
							</div>
							<div class="form-row">
								<div class="form-group">
									<label for="city">City <span class="required">*</span></label>
									<input type="text" id="city" name="city" required />
								</div>
								<div class="form-group">
									<label for="postal-code">ZIP / Postal code <span class="required">*</span></label>
									<input type="text" id="postal-code" name="postalCode" required />
								</div>
							</div>
							<div class="form-group">
								<label for="street">Street address <span class="required">*</span></label>
								<input type="text" id="street" name="street" required />
							</div>
							<div class="form-group">
								<label for="street-2">Apt., suite, or floor (optional)</label>
								<input type="text" id="street-2" name="street2" />
							</div>
							<div class="form-group">
								<label for="ship-postal-code">Ship-to ZIP / Postal code (optional)</label>
								<input type="text" id="ship-postal-code" name="shipPostalCode" />
							</div>
						</div>

						<div class="form-section">
							<h3>Drawings &amp; Attachments (optional)</h3>
						<p class="section-helper">
							Attach floor plans, locker room layouts, or inspiration photos to help our team prepare the most accurate quote. For files larger than 10 MB, please email
							<a href="mailto:sales@playerstall.com">sales@playerstall.com</a>.
						</p>
							<div class="form-group">
								<label for="file-1">Attach document (max 10 MB)</label>
								<input type="file" id="file-1" name="attachment1" />
							</div>
							<div class="form-group">
								<label for="file-2">Attach another document (optional)</label>
								<input type="file" id="file-2" name="attachment2" />
							</div>
							<div class="form-group">
								<label for="file-3">Attach another document (optional)</label>
								<input type="file" id="file-3" name="attachment3" />
							</div>
							<div class="form-group">
								<label for="notes">Anything else we should know?</label>
								<textarea id="notes" name="notes" rows="4" placeholder="Share timing constraints, construction partners, or other project details."></textarea>
							</div>
						</div>

						<div class="form-footer">
							<p class="disclaimer">
								By submitting this form, you agree that a PlayerStall representative may contact you about your project. We will never share your information with third parties.
							</p>
							<button type="submit" class="btn btn-primary">Request your quote</button>
						</div>
					</form>
				</div>
		</div>
	</section>
</BaseLayout>

<style>
	:global(body) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #f7f7f7;
		color: #0d0d0d;
	}

	.container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Contact Hero (same as our-process: full-bleed image + overlay + white title) */
	.contact-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}

	.contact-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.contact-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.contact-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.contact-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.contact-hero-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}

	.contact-hero-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.contact-hero-breadcrumbs a:hover {
		color: #fe5900;
	}

	.contact-hero-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.contact-hero-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 72px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	.contact-hero-background-text {
		display: none;
	}

	.contact-section {
		padding: 5rem 0;
		background: #ffffff;
	}

	.contact-header {
		text-align: center;
		max-width: 800px;
		margin: 0 auto 4rem;
	}

	.contact-header h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 48px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin-bottom: 1.5rem;
	}

	.contact-header p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		color: #666666;
		line-height: 1.8;
	}

	/* Quote process – under Contact Us, centered */
	.quote-process-section {
		width: 100%;
		max-width: 700px;
		margin: 0 auto 3rem;
		padding: 0;
		text-align: center;
	}
	.quote-process-center {
		max-width: 700px;
		margin: 0 auto;
	}
	.quote-process-title {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 1.25rem;
		letter-spacing: 0.02em;
	}
	.quote-process-intro {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		color: #666666;
		line-height: 1.7;
		margin: 0 0 1.5rem;
	}
	.quote-process-steps {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: 0 auto 1.5rem;
		max-width: 520px;
		text-align: center;
	}
	.quote-process-step {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #0d0d0d;
		line-height: 1.5;
		text-align: center;
	}
	.quote-process-support {
		background: #f8f8f8;
		border: 1px solid #e0e0e0;
		padding: 1.25rem 1.5rem;
		font-size: 14px;
		color: #666666;
		display: inline-block;
		text-align: center;
	}
	.quote-process-support a {
		color: #fe5900;
		text-decoration: none;
	}
	.quote-process-support a:hover {
		text-decoration: underline;
	}

	/* Center main contact content (header + form) */
	.container-center {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.container-center .quote-form-wrapper {
		width: 100%;
		max-width: 720px;
	}

	/* Shared form styles */
	.form-group {
		display: flex;
		flex-direction: column;
	}

	.form-group label {
		margin-bottom: 0.5rem;
		color: #0d0d0d;
		font-weight: 500;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.form-group input,
	.form-group select,
	.form-group textarea {
		padding: 0.75rem;
		border: 1px solid #bfbfbf;
		border-radius: 0;
		font-size: 15px;
		font-family: 'Yantramanav', sans-serif;
		transition: border-color 0.25s ease, box-shadow 0.25s ease;
		background: #fff;
		color: #0d0d0d;
		width: 100%;
	}

	.form-group textarea {
		resize: vertical;
	}

	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: #fe5900;
		box-shadow: 0 0 0 2px rgba(254, 89, 0, 0.1);
	}

	.helper-text {
		display: block;
		margin-top: 0.35rem;
		font-size: 12px;
		color: #8c8c8c;
	}

	.helper-row {
		display: flex;
		justify-content: space-between;
		margin-top: 0.4rem;
	}

	.helper-row small {
		font-size: 12px;
		color: #8c8c8c;
		font-family: 'Yantramanav', sans-serif;
	}

	.section-helper {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #666666;
		margin: 0 0 1.25rem;
		line-height: 1.6;
	}

	.section-helper a {
		color: #fe5900;
		text-decoration: none;
	}

	.section-helper a:hover {
		text-decoration: underline;
	}

	.quote-form-wrapper input[type="file"] {
		padding: 0.5rem 0;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
	}

	.btn {
		padding: 0.875rem 2rem;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.3s ease;
		display: inline-block;
		border: none;
		cursor: pointer;
		font-size: 1rem;
		font-family: 'Yantramanav', sans-serif;
	}

	.btn-primary {
		background: #fe5900;
		color: #fff;
		border: 2px solid #fe5900;
	}

	.btn-primary:hover {
		background: #e04d00;
		border-color: #e04d00;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(254, 89, 0, 0.3);
	}

	/* Quote form wrapper (right column) */
	.quote-form-wrapper {
		background: #fff;
		border: 1px solid #e8e8e8;
		padding: 2.5rem;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
	}

	.quote-form-wrapper h2 {
		font-family: 'Oswald', sans-serif;
		font-size: 26px;
		font-weight: 600;
		text-transform: uppercase;
		margin-top: 0;
		margin-bottom: 0.5rem;
	}

	.form-intro {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #666666;
		margin-bottom: 1.75rem;
	}

	.required {
		color: #fe5900;
		font-weight: 600;
	}

	.quote-form {
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
	}

	.form-section h3 {
		font-family: 'Oswald', sans-serif;
		font-size: 16px;
		font-weight: 600;
		text-transform: uppercase;
		margin: 0 0 0.75rem;
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
	}

	.form-footer {
		border-top: 1px solid #e0e0e0;
		padding-top: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.disclaimer {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		max-width: 380px;
		margin: 0;
	}

	@media (max-width: 1024px) {
		.contact-hero-section {
			min-height: 280px;
		}
		.contact-hero-page-title {
			font-size: 56px;
		}
		.contact-hero-background-text {
			font-size: 220px;
		}
	}

	@media (max-width: 968px) {
		.contact-header h2 {
			font-size: 36px;
		}

		.form-row {
			grid-template-columns: 1fr;
		}

		.form-footer {
			flex-direction: column;
			align-items: stretch;
		}

		.btn {
			width: 100%;
			text-align: center;
		}
	}

	@media (max-width: 768px) {
		.contact-hero-section {
			min-height: 240px;
			padding-bottom: 50px;
		}
		.contact-hero-page-title {
			font-size: 42px;
		}
		.contact-hero-background-text {
			font-size: 140px;
		}

		.quote-form-wrapper {
			padding: 1.5rem;
		}
	}
</style>

<script>
	// Character counter for quote requirements field
	if (typeof window !== 'undefined') {
		document.addEventListener('DOMContentLoaded', () => {
			const textarea = document.getElementById('requirements');
			const counter = document.getElementById('requirements-count');
			if (!textarea || !counter) return;
			function updateCount() {
				const max = textarea.getAttribute('maxlength') || 1000;
				const remaining = Number(max) - textarea.value.length;
				counter.textContent = remaining + ' characters left';
			}
			textarea.addEventListener('input', updateCount);
			updateCount();
		});
	}
</script>