---
import BaseLayout from '../../layouts/BaseLayout.astro';

/* ───── Sport Data ───── */
interface HighlightItem {
	type: 'image' | 'text';
	image?: string;
	category?: string;
	title?: string;
	text?: string;
	link?: string;
}

interface SportInfo {
	title: string;
	tagline: string;
	description: string;
	features: string[];
	heroImage: string;
	gallery: string[];
	highlights?: HighlightItem[];
	cta: string;
}

const SPORT_DATA: Record<string, SportInfo> = {
	football: {
		title: 'Football Lockers',
		tagline: 'Built for the biggest gear in sports',
		description: 'Football equipment is bulky, heavy, and needs proper ventilation. Our football lockers are designed for helmets, pads, cleats, and uniforms — keeping everything organized and dry.',
		features: [
			'Spacious compartments for helmets and shoulder pads',
			'Enhanced ventilation to prevent moisture buildup',
			'Dedicated storage for cleats and footwear',
			'Uniform hanging space and reinforced construction',
		],
		heroImage: '/images/topscorer/title-img.jpg',
		gallery: [
			'/images/topscorer/h1-img-1.jpg',
			'/images/topscorer/player-title-img-1.jpg',
			'/images/topscorer/event-title-img.jpg',
			'/images/topscorer/team-title-img.jpg',
		],
		cta: 'Get Football Locker Quote',
	},
	hockey: {
		title: 'Hockey Lockers',
		tagline: 'Engineered for the toughest equipment',
		description: 'Hockey equipment is among the most challenging to store. Our hockey lockers are built for skates, pads, sticks, and gear with specialized storage and drying features.',
		features: [
			'Reinforced construction for heavy gear',
			'Compartments for skates and stick storage',
			'Ventilated compartments for pads and helmets',
			'Equipment drying features',
		],
		heroImage: '/images/topscorer/h3-banner-img-1.jpg',
		gallery: [
			'/images/topscorer/h3-blog-img-1.jpg',
			'/images/topscorer/h3-blog-img-3.jpg',
			'/images/topscorer/h3-img-4.jpg',
			'/images/topscorer/h3-blog-img-5.jpg',
		],
		highlights: [
			{ type: 'text', category: 'Hockey Lockers', title: 'Built for the Toughest Equipment', text: 'Hockey equipment is among the most challenging to store. Our hockey lockers are built for skates, pads, sticks, and gear with specialized storage and drying features.', link: '/contact' },
			{ type: 'image', image: '/images/topscorer/h3-blog-img-3.jpg' },
			{ type: 'text', category: 'Hockey Lockers', title: 'Reinforced Construction', text: 'Heavy-duty build designed for the weight and bulk of hockey gear. Dedicated compartments for skates and stick storage keep everything organized and accessible.', link: '/contact' },
			{ type: 'image', image: '/images/topscorer/h3-img-6.jpg' },
			{ type: 'image', image: '/images/topscorer/h3-blog-img-5.jpg' },
			{ type: 'text', category: 'Hockey Lockers', title: 'Ventilated Compartments', text: 'Purpose-built ventilation for pads, helmets, and gloves prevents moisture buildup, eliminates odor, and extends the life of expensive equipment.', link: '/contact' },
			{ type: 'image', image: '/images/topscorer/h3-img-4.jpg' },
			{ type: 'text', category: 'Hockey Lockers', title: 'Equipment Drying', text: 'Integrated drying features keep gear fresh, dry, and game-ready. Custom wood construction with premium finishes built to last a lifetime.', link: '/contact' },
		],
		cta: 'Get Hockey Locker Quote',
	},
	basketball: {
		title: 'Basketball Lockers',
		tagline: 'Sleek storage for a fast-paced game',
		description: 'Our basketball lockers provide sleek, organized storage for shoes, uniforms, and personal items with a professional, modern appearance.',
		features: [
			'Sleek and organized design',
			'Dedicated shoe and uniform storage',
			'Personal item compartments',
			'Space-efficient layout',
		],
		heroImage: '/images/topscorer/basketball-arena-game.jpg',
		gallery: [
			'/images/topscorer/basketball-dribble.png',
			'/images/topscorer/basketball-gallery-3.jpg',
			'/images/topscorer/basketball-dunk-aerial.jpg',
			'/images/topscorer/basketball-gallery-2.jpg',
		],
		cta: 'Get Basketball Locker Quote',
	},
	baseball: {
		title: 'Baseball Lockers',
		tagline: 'Organized storage from bats to cleats',
		description: 'Customized storage for bats, gloves, helmets, and uniforms. Our baseball lockers keep everything organized and accessible for game day.',
		features: [
			'Equipment-specific compartments for bats and gloves',
			'Uniform and gear organization',
			'Helmet storage with ventilation',
			'Easy access and durable construction',
		],
		heroImage: '/images/topscorer/lacrosse-field-hero.jpg',
		gallery: [
			'/images/topscorer/h2-blog-img-1-1.jpg',
			'/images/topscorer/h2-blog-img-2-1.jpg',
			'/images/topscorer/h2-blog-img-3-1.jpg',
			'/images/topscorer/h2-blog-img-6.jpg',
		],
		cta: 'Get Baseball Locker Quote',
	},
	soccer: {
		title: 'Soccer Lockers',
		tagline: 'Clean, organized, match-ready',
		description: 'Organized storage for cleats, shin guards, uniforms, and equipment. Our soccer lockers keep everything accessible and professional.',
		features: [
			'Compartments for cleats and shin guards',
			'Uniform hanging and ventilated storage',
			'Compact and space-efficient design',
			'Professional team-room appearance',
		],
		heroImage: '/images/topscorer/soccer-stadium-hero.jpg',
		gallery: [
			'/images/topscorer/soccer-gallery-1.jpg',
			'/images/topscorer/soccer-gallery-2.jpg',
			'/images/topscorer/soccer-gallery-3.jpg',
			'/images/topscorer/soccer-gallery-4.jpg',
		],
		cta: 'Get Soccer Locker Quote',
	},
	lacrosse: {
		title: 'Lacrosse Lockers',
		tagline: 'Purpose-built for every piece of gear',
		description: 'Custom storage for sticks, helmets, pads, gloves, and uniforms. Our lacrosse lockers are built to handle the full range of equipment.',
		features: [
			'Stick storage and equipment compartments',
			'Ventilated storage for pads and helmets',
			'Durable construction for heavy use',
			'Modular design for easy replacement',
		],
		heroImage: '/images/topscorer/lacrosse-field-hero.jpg',
		gallery: [
			'/images/topscorer/lacrosse-gallery-1.jpg',
			'/images/topscorer/lacrosse-gallery-2.jpg',
			'/images/topscorer/lacrosse-gallery-3.jpg',
			'/images/topscorer/lacrosse-gallery-4.jpg',
		],
		cta: 'Get Lacrosse Locker Quote',
	},
};

/* ───── Locker color options (Wilsonart) ───── */
const SOLID_COLORS = [
	{ code: 'DW', name: 'Designer White', hex: '#F5F5F5' },
	{ code: 'WS', name: 'White Sand',     hex: '#EDE8DA' },
	{ code: 'FG', name: 'Fashion Grey',   hex: '#A8A8A8' },
	{ code: 'NS', name: 'North Sea',      hex: '#6E8090' },
	{ code: 'GR', name: 'Graphite',       hex: '#4D4D4D' },
	{ code: 'BL', name: 'Black',          hex: '#1A1A1A' },
	{ code: 'HB', name: 'Hollyberry',     hex: '#C41E3A' },
	{ code: 'LB', name: 'Lapis Blue',     hex: '#1F4E8C' },
];
const WOOD_COLORS = [
	{ code: 'FM', name: 'Fusion Maple',   hex: '#DEC7A0' },
	{ code: 'PO', name: 'Pasadena Oak',   hex: '#A67C52' },
	{ code: 'WH', name: 'Walnut Heights', hex: '#6B4226' },
	{ code: 'HW', name: 'Hampton Walnut', hex: '#4A2F1B' },
];

const LOCKERS = [
	{ name: 'Semi Pro', image: '/images/semi-pro-locker-new.png', price: '$349.00', info: 'Entry-level wood locker. 3/4" solid wood construction, durable and ideal for schools and rec teams.', dimensions: '24" W × 76" H × 19" D', dimensionsNote: 'Widths 18"–30"', href: '/product-semi-pro-locker' },
	{ name: 'Varsity', image: '/varsity-locker.jpg', price: '$449.00', info: 'Step-up design with 3/4" solid wood premium finish. Great for varsity and competitive programs.', dimensions: '24" W × 76" H × 19" D', dimensionsNote: 'Widths 18"–30"; optional 4" base', href: '/product-varsity-locker' },
	{ name: 'Pro', image: '/pro-locker.jpg', price: '$549.00', info: 'MPW-6C plywood melamine construction. Reliable workhorse for team locker rooms. Quick ship in one month or custom-built in three months.', dimensions: '24" W × 76" H × 19" D', dimensionsNote: 'Widths 18"–30"; optional 4" base', href: '/product-pro-locker' },
	{ name: 'Stadium', image: '/stadium-locker.jpg', price: '$599.00', info: 'Premium plywood melamine, stadium-grade. Heavy-duty build for high-traffic facilities. Quick ship in one month or custom-built in three months.', dimensions: '24" W × 76" H × 19" D', dimensionsNote: 'Widths 18"–30"; optional 4" base', href: '/product-stadium-locker' },
	{ name: 'Elite', image: '/images/grid_locker_gray_curved-75a91a17-f394-49fb-8c61-0029ab3bc6b7.png', price: '$599.00', info: 'Top-tier locker. Curved design, premium materials. Quick ship in one month (24" or 30", one signature color).', dimensions: '24" W × 76" H × 24" D', dimensionsNote: 'Widths 18"–30"; optional 4" base', href: '/product-elite-locker' },
	{ name: 'Legendary', image: '/images/legendary-locker.png', price: '$599.00', info: 'Top-tier locker. Curved design, maximum durability and customization. Custom-built in three months with full color options.', dimensions: '24" W × 76" H × 24" D', dimensionsNote: 'Widths 18"–30"; optional 4" base', href: '/product-legendary-locker' },
];

/* ───── Route ───── */
export function getStaticPaths() {
	return [
		{ params: { sport: 'football' } },
		{ params: { sport: 'hockey' } },
		{ params: { sport: 'basketball' } },
		{ params: { sport: 'baseball' } },
		{ params: { sport: 'soccer' } },
		{ params: { sport: 'lacrosse' } },
	];
}

const { sport } = Astro.params;
if (!sport || !SPORT_DATA[sport]) {
	throw new Error(`Unknown sport: ${sport}`);
}

const data = SPORT_DATA[sport];
const titleLabel = data.title.replace(' Lockers', '');
const isDark = !!data.highlights && data.highlights.length > 0;
---

<BaseLayout
	title={`${data.title} | Custom Wood Lockers | PlayerStall`}
	description={data.description}
>
<div class={isDark ? 'sp-page sp-page-dark' : 'sp-page'}>
	<!-- ═══════ HERO BANNER ═══════ -->
	<section class="sp-hero">
		<div class="sp-hero-bg">
			<img src={data.heroImage} alt={data.title} class="sp-hero-bg-image" />
		</div>
		<div class="sp-hero-content">
			<div class="sp-hero-breadcrumb">
				<a href="/">Home</a>
				<span class="sp-bc-text">{titleLabel}</span>
			</div>
			<h1 class="sp-hero-title">{data.title}</h1>
		</div>
	</section>

	<!-- ═══════ LOCKERS LIST ═══════ -->
	<section class="sp-lockers">
		<div class="sp-lockers-inner">
			<div class="sp-lockers-header">
				<span class="sp-lockers-sub">the locker room</span>
				<h2 class="sp-lockers-title">Our Lockers</h2>
			</div>

			{/* ── Featured: Semi Pro ── */}
			{LOCKERS.filter((l) => l.name === 'Semi Pro').map((locker) => (
				<article class="sp-locker-featured">
					<div class="sp-locker-featured-nameblock">
						<h3 class="sp-locker-name">{locker.name}</h3>
						<p class="sp-locker-price">{locker.price}</p>
					</div>
					<div class="sp-locker-angles">
						<div class="sp-locker-angle">
							<img src={locker.image} alt={`${locker.name} Locker - Right Angle`} loading="lazy" />
						</div>
						<div class="sp-locker-angle">
							<img src={locker.image} alt={`${locker.name} Locker - Straight On`} loading="lazy" />
						</div>
						<div class="sp-locker-angle">
							<img src={locker.image} alt={`${locker.name} Locker - Left Angle`} loading="lazy" />
						</div>
						<div class="sp-locker-angle">
							<img src={locker.image} alt={`${locker.name} Locker - Back View`} loading="lazy" />
						</div>
					</div>
					<div class="sp-locker-featured-action">
						<a href={locker.href} class="sp-btn sp-btn-featured">View Details</a>
					</div>
				</article>
			))}

			{/* ── Varsity ── */}
			{LOCKERS.filter((l) => l.name === 'Varsity').map((locker) => (
				<article class="sp-locker-featured">
					<div class="sp-locker-featured-nameblock">
						<h3 class="sp-locker-name">{locker.name}</h3>
						<p class="sp-locker-price">{locker.price}</p>
					</div>
					<div class="sp-locker-angles">
						<div class="sp-locker-angle">
							<img src="/images/varsity-locker-front.png" alt={`${locker.name} Locker - Front View`} loading="lazy" />
						</div>
						<div class="sp-locker-angle">
							<img src="/images/varsity-locker-open.png" alt={`${locker.name} Locker - Open View`} loading="lazy" />
						</div>
					</div>
					<div class="sp-locker-featured-action">
						<a href={locker.href} class="sp-btn sp-btn-featured">View Details</a>
					</div>
				</article>
			))}

			{/* ── Remaining lockers ── */}
			{LOCKERS.filter((l) => l.name !== 'Semi Pro' && l.name !== 'Varsity').map((locker) => (
				<article class="sp-locker-row">
					<div class="sp-locker-img">
						<img src={locker.image} alt={`${locker.name} Locker`} loading="lazy" />
					</div>
					<div class="sp-locker-nameblock">
						<h3 class="sp-locker-name">{locker.name}</h3>
						<p class="sp-locker-price">{locker.price}</p>
					</div>
					<div class="sp-locker-colors">
						<span class="sp-swatch-group-label">Solid Colors</span>
						<div class="sp-locker-swatches">
							{SOLID_COLORS.map((c) => (
								<span
									class="sp-swatch"
									style={`background:${c.hex}; ${c.code === 'DW' || c.code === 'WS' ? 'border:1px solid #ddd;' : ''}`}
									title={c.name}
								></span>
							))}
						</div>
						<span class="sp-swatch-group-label sp-swatch-group-label-wood">Woodgrains</span>
						<div class="sp-locker-swatches">
							{WOOD_COLORS.map((c) => (
								<span
									class="sp-swatch"
									style={`background:${c.hex};`}
									title={c.name}
								></span>
							))}
						</div>
					</div>
					<div class="sp-locker-action">
						<a href={locker.href} class="sp-btn sp-btn-view">View Details</a>
					</div>
				</article>
			))}
		</div>
	</section>

	<!-- ═══════ HIGHLIGHTS GRID (checkerboard layout) ═══════ -->
	{data.highlights && data.highlights.length > 0 && (
		<section class="sp-highlights" aria-label={`${titleLabel} highlights`}>
			<div class="sp-highlights-grid">
				{data.highlights.map((item, i) => (
					item.type === 'image' ? (
						<div class="sp-hl-cell sp-hl-image">
							<img src={item.image} alt={`${titleLabel} highlight ${i + 1}`} loading="lazy" />
						</div>
					) : (
						<div class="sp-hl-cell sp-hl-text">
							<div class="sp-hl-text-inner">
								<span class="sp-hl-category">{item.category}</span>
								<h3 class="sp-hl-title">{item.title}</h3>
								<p class="sp-hl-desc">{item.text}</p>
								<a href={item.link || '#'} class="sp-hl-link">Read More</a>
							</div>
						</div>
					)
				))}
			</div>
		</section>
	)}

	<!-- ═══════ BOTTOM GALLERY (4 images) ═══════ -->
	<section class="sp-gallery" aria-label={`${titleLabel} imagery`}>
		<div class="sp-gallery-grid">
			{data.gallery.map((img, i) => (
				<div class="sp-gallery-item">
					<img src={img} alt={`${titleLabel} ${i + 1}`} loading="lazy" />
				</div>
			))}
		</div>
	</section>

	<!-- ═══════ CTA + SIDEBAR ═══════ -->
	<section class="sp-cta-section">
		<div class="sp-cta-inner">
			<div class="sp-cta-main">
				<h2 class="sp-cta-heading">Ready to Upgrade Your {titleLabel} Locker Room?</h2>
				<p class="sp-cta-text">With 30+ years of experience serving collegiate and professional teams across North America, we understand what makes a great locker room. Free design consultation, 5 year warranty.</p>
				<a href="/contact#quote-form" class="sp-btn sp-btn-primary">{data.cta}</a>
			</div>
			<aside class="sp-sidebar">
				<div class="sp-widget">
					<h3>Other Sports</h3>
					<ul class="sp-widget-links">
						<li><a href="/sport/football">Football Lockers</a></li>
						<li><a href="/sport/hockey">Hockey Lockers</a></li>
						<li><a href="/sport/basketball">Basketball Lockers</a></li>
						<li><a href="/sport/baseball">Baseball Lockers</a></li>
						<li><a href="/sport/soccer">Soccer Lockers</a></li>
						<li><a href="/sport/lacrosse">Lacrosse Lockers</a></li>
					</ul>
				</div>
				<div class="sp-widget sp-widget-quote">
					<h3>Get a Quote</h3>
					<p>Free consultation. 30+ years of craftsmanship. 5 year warranty.</p>
					<a href="/contact#quote-form" class="sp-btn sp-btn-primary sp-btn-block">Request a Quote</a>
				</div>
			</aside>
		</div>
	</section>
</div>
</BaseLayout>

<style>
	/* ═══════════════════════════════════════════
	   TopScorer-style sport page
	   Fonts: Oswald 600/700 (headings), Yantramanav 400/500 (body)
	   ═══════════════════════════════════════════ */

	/* ── HERO (matches blog / shop / gallery hero) ── */
	.sp-hero {
		position: relative;
		display: flex;
		align-items: flex-end;
		justify-content: flex-start;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 500px;
		width: 100%;
	}
	.sp-hero-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
		background: #0d0d0d;
	}
	.sp-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
	}
	.sp-hero-content {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}
	.sp-hero-breadcrumb {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}
	.sp-hero-breadcrumb a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}
	.sp-hero-breadcrumb a:hover { color: #fe5900; }
	.sp-bc-text {
		margin-left: 10px;
		color: #ffffff;
	}
	.sp-hero-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	/* ── INTRO ── */
	.sp-intro {
		background: #ffffff;
		padding: 60px 0;
	}
	.sp-intro-inner {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: center;
	}
	.sp-intro-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 18px;
		line-height: 1.8;
		color: #555;
		margin: 0 0 30px;
	}
	.sp-intro-features {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 10px 30px;
	}
	.sp-intro-features li {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #333;
		position: relative;
		padding-left: 18px;
	}
	.sp-intro-features li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		width: 8px;
		height: 8px;
		background: #fe5900;
		border-radius: 50%;
	}

	/* ── LOCKERS LIST ── */
	.sp-lockers {
		background: #f5f5f5;
		padding: 70px 0 80px;
	}
	.sp-lockers-inner {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}
	.sp-lockers-header {
		text-align: center;
		margin-bottom: 50px;
	}
	.sp-lockers-sub {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: #fe5900;
		display: block;
		margin-bottom: 8px;
	}
	.sp-lockers-title {
		font-family: 'Oswald', sans-serif;
		font-size: 42px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #0d0d0d;
		margin: 0;
	}

	/* Featured locker (Semi Pro) — horizontal one-line layout */
	.sp-locker-featured {
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: 20px;
		align-items: center;
		background: transparent;
		padding: 40px 20px;
		margin-bottom: 40px;
		border: none;
	}
	.sp-locker-featured-nameblock {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		text-align: left;
		gap: 2px;
		min-width: 180px;
	}
	.sp-locker-featured-nameblock .sp-locker-name {
		font-family: 'Oswald', sans-serif;
		font-size: 32px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: #0d0d0d;
		margin: 0;
	}
	.sp-locker-featured-nameblock .sp-locker-price {
		font-family: 'Oswald', sans-serif;
		font-size: 22px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #0d0d0d;
		margin: 0;
	}
	.sp-locker-angles {
