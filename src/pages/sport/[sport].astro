<script>
	// Taste the Victory banner: 6 sport players slide in one by one with pause
	function initBannerPlayers() {
		const slides = document.querySelectorAll('.topscorer-banner-player-slide');
		if (slides.length === 0) return;
		let currentIndex = 0;
		const pauseMs = 3500; // pause between slides (ms)

		function goToNext() {
			const current = slides[currentIndex];
			const nextIndex = (currentIndex + 1) % slides.length;
			const next = slides[nextIndex];
			current.classList.add('exiting');
			current.classList.remove('active');
			next.classList.add('active');
			next.classList.remove('exiting');
			setTimeout(() => {
				current.classList.remove('exiting');
			}, 800);
			currentIndex = nextIndex;
		}

		setInterval(goToNext, pauseMs);
	}

	// Rotate quotes in sync with player slides
	function initBannerQuotes() {
		const quotes = document.querySelectorAll('.topscorer-banner-quote');
		if (quotes.length <= 1) return;
		let currentIndex = 0;
		const pauseMs = 3500; // pause between quotes (ms) - same as player slides

		function goToNext() {
			const current = quotes[currentIndex];
			const nextIndex = (currentIndex + 1) % quotes.length;
			const next = quotes[nextIndex];
			current.classList.remove('active');
			next.classList.add('active');
			currentIndex = nextIndex;
		}

		setInterval(goToNext, pauseMs);
	}

	// Animate initial slide on page load
	function initInitialSlide() {
		const initialSlide = document.querySelector('[data-initial-slide="true"]');
		if (!initialSlide) return;

		const banner = document.querySelector('.topscorer-banner');
		if (!banner) return;

		// Use Intersection Observer to trigger animation when banner section is visible
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					// Load image if it has data-src (lazy load)
					const img = initialSlide.querySelector<HTMLImageElement>('img[data-src]');
					if (img && img.dataset.src && !img.src) {
						img.src = img.dataset.src;
						// Add active class after a small delay to ensure image starts loading
						setTimeout(() => {
							initialSlide.classList.add('active');
						}, 50);
					} else {
						initialSlide.classList.add('active');
					}
				} else {
					// Remove active class when scrolling away to reset animation
					initialSlide.classList.remove('active');
				}
			});
		}, {
			threshold: 0.3, // Trigger when 30% of section is visible
			rootMargin: '0px' // No extra margin - trigger only when actually in viewport
		});

		observer.observe(banner);
	}

	// Initialize when DOM is ready
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', () => {
			initBannerPlayers();
			initBannerQuotes();
			initInitialSlide();
		});
	} else {
		initBannerPlayers();
		initBannerQuotes();
		initInitialSlide();
	}
</script>
