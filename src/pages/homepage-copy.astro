</section>

<!-- ============================================
     GAMES / SCORES SECTION
     ============================================ -->
<section class="ts-scores-section">
	<div class="ts-vertical-text ts-vertical-left">G&nbsp;&nbsp;a&nbsp;&nbsp;m&nbsp;&nbsp;e&nbsp;&nbsp;s</div>
	<div class="ts-scores-inner">
		<div class="ts-section-header">
			<span class="ts-section-label">WHAT'S TRENDING</span>
			<h2 class="ts-section-title">CHECK OUT OUR LINEUP</h2>
		</div>
		<div class="ts-scores-grid">
			<!-- Match 1 -->
			<div class="ts-score-card">
				<div class="ts-score-teams">
					<div class="ts-team">
						<img src="/images/topscorer/h1-rev-img-1.png" alt="Stadium Locker" class="ts-team-logo" />
						<h5 class="ts-team-name">Stadium</h5>
					</div>
					<span class="ts-vs">vs</span>
					<div class="ts-team">
						<img src="/images/topscorer/h1-rev-img-2.png" alt="Elite Locker" class="ts-team-logo" />
						<h5 class="ts-team-name">Elite</h5>
					</div>
				</div>
				<p class="ts-match-info">Stadium vs Elite</p>
				<h3 class="ts-venue">QUICK SHIP LOCKERS</h3>
				<div class="ts-score-timer">:</div>
				<div class="ts-score-buttons">
					<a href="/shop" class="ts-btn ts-btn-outline-dark">View Details</a>
					<a href="/contact" class="ts-btn ts-btn-filled-dark">Get a Quote</a>
				</div>
			</div>
			<!-- Match 2 -->
			<div class="ts-score-card">
				<div class="ts-score-teams">
					<div class="ts-team">
						<img src="/images/topscorer/h1-rev-img-3.png" alt="Pro Locker" class="ts-team-logo" />
