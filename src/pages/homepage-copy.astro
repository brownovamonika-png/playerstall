					</div>
					<span class="ts-vs">vs</span>
					<div class="ts-team">
						<img src="/images/topscorer/h1-rev-img-4.png" alt="Legendary Locker" class="ts-team-logo" />
						<h5 class="ts-team-name">Legendary</h5>
					</div>
				</div>
				<p class="ts-match-info">Pro vs Legendary</p>
				<h3 class="ts-venue">CUSTOM WOOD LOCKERS</h3>
				<div class="ts-score-timer">:</div>
				<div class="ts-score-buttons">
					<a href="/services" class="ts-btn ts-btn-outline-dark">View Details</a>
					<a href="/contact" class="ts-btn ts-btn-filled-dark">Get a Quote</a>
