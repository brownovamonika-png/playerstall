					<span class="ts-vs">vs</span>
					<div class="ts-team">
						<img src="/images/topscorer/h1-rev-img-6.png" alt="Essential Locker" class="ts-team-logo" />
						<h5 class="ts-team-name">Essential</h5>
					</div>
				</div>
				<p class="ts-match-info">Semi-Pro vs Essential</p>
				<h3 class="ts-venue">VALUE LOCKERS</h3>
				<div class="ts-score-timer">:</div>
				<div class="ts-score-buttons">
