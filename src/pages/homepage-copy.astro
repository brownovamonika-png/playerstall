</section>

<!-- ============================================
     NEXT MATCH / COUNTDOWN SECTION
     ============================================ -->
<section class="ts-countdown-section">
	<div class="ts-countdown-bg" style="background-image: url('/images/topscorer/h1-img-1.jpg');"></div>
	<div class="ts-countdown-overlay"></div>
	<div class="ts-section-header light">
		<span class="ts-section-label">WHAT'S TRENDING</span>
		<h2 class="ts-section-title">NEXT PROJECT</h2>
	</div>
	<div class="ts-countdown-timer" id="countdown">
		<div class="ts-timer-block">
			<span class="ts-timer-number" id="countdown-days">00</span>
			<span class="ts-timer-label">DAY</span>
		</div>
		<div class="ts-timer-block">
			<span class="ts-timer-number" id="countdown-hours">00</span>
			<span class="ts-timer-label">HOUR</span>
		</div>
		<div class="ts-timer-block">
			<span class="ts-timer-number" id="countdown-mins">00</span>
			<span class="ts-timer-label">MINUTE</span>
		</div>
		<div class="ts-timer-block">
			<span class="ts-timer-number" id="countdown-secs">00</span>
			<span class="ts-timer-label">SECOND</span>
		</div>
	</div>
	<a href="/contact" class="ts-match-cta">Get Started Today</a>
	<p class="ts-match-phone">Call us at <a href="tel:+18885878255" class="ts-match-phone-link">1 (888) 58-STALL</a></p>
</section>

<!-- ============================================
     PLAYER / PRODUCT SPOTLIGHT SECTION
     ============================================ -->
<section class="ts-spotlight-section">
	<div class="ts-spotlight-inner">
		<div class="ts-spotlight-image">
			<img src="/images/topscorer/h3-img-2.jpg" alt="Custom wood sports locker installation" loading="lazy" />
		</div>
		<div class="ts-spotlight-content">
			<a href="/services" class="ts-spotlight-position">Premium Collection</a>
			<h3 class="ts-spotlight-name">The Pro Locker</h3>
			<div class="ts-spotlight-meta">
				<span>USA</span> | <a href="/services">Wood Lockers</a> | <a href="/services">Custom, Standard</a> | <span>Since 1990</span> | <span>36"W x 24"D x 84"H</span>
			</div>
			<h5 class="ts-spotlight-bio-title">Product Overview</h5>
			<p class="ts-spotlight-bio">The Pro Locker represents the pinnacle of our craftsmanship. Built from premium North American hardwoods, each locker is custom-sized to your exact specifications. Features include adjustable shelving, integrated ventilation, and our signature dovetail joinery. Backed by our lifetime guarantee and 30+ years of manufacturing excellence.</p>
			<a href="/product-pro-locker" class="ts-btn ts-btn-filled">View Product</a>
