---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="Premium Wood Lockers | Custom Sports Lockers | PlayerStall"
	description="Custom wood sports lockers at unbeatable prices. Quick ship in 2–4 weeks or custom in 8–12 weeks. 30+ years experience. Lifetime guarantee. Free consultation."
>

<!-- ============================================
     HERO SLIDER SECTION 
     ============================================ -->
<section class="ts-hero-slider" id="hero">
	<div class="ts-hero-container">
		<!-- Slide 1 -->
		<div class="ts-slide active" data-slide="0">
			<div class="ts-slide-bg" style="background-image: url('https://topscorer.qodeinteractive.com/wp-content/uploads/2020/01/p4-img.jpg');"></div>
			<div class="ts-slide-content">
				<h1 class="ts-slide-title">Premium Wood Lockers. Unbeatable Prices.</h1>
				<p class="ts-slide-text">Quick ship in 2–4 weeks or custom in 8–12 weeks. We'll match any USA competitor's price.</p>
			<div class="ts-slide-buttons">
				<a href="/shop" class="ts-hero-btn ts-hero-btn-primary">Shop Quick Ship</a>
				<a href="/contact#quote-form" class="ts-hero-btn ts-hero-btn-secondary">Request a Quote</a>
			</div>
		</div>
	</div>
	<!-- Slide 2 -->
	<div class="ts-slide" data-slide="1">
		<div class="ts-slide-bg" style="background-image: url('https://topscorer.qodeinteractive.com/wp-content/uploads/2020/01/p4-title-img.jpg');"></div>
		<div class="ts-slide-overlay"></div>
		<div class="ts-slide-content">
			<h1 class="ts-slide-title">Premium Wood Lockers. Unbeatable Prices.</h1>
			<p class="ts-slide-text">Your timeline. Your way. Stadium & Elite quick ship (2–4 weeks) — or custom size, wood & materials.</p>
			<div class="ts-slide-buttons">
				<a href="/shop" class="ts-hero-btn ts-hero-btn-primary">View Shop</a>
				<a href="/contact" class="ts-hero-btn ts-hero-btn-secondary">Contact Us</a>
			</div>
		</div>
	</div>
	<!-- Slide 3 -->
	<div class="ts-slide" data-slide="2">
		<div class="ts-slide-bg" style="background-image: url('/images/topscorer/h2-rev-slide-4.jpg');"></div>
		<div class="ts-slide-overlay"></div>
		<div class="ts-slide-content">
			<h1 class="ts-slide-title">Premium Wood Lockers. Unbeatable Prices.</h1>
			<p class="ts-slide-text">We focus on core models so production never stops. That's how we keep prices low.</p>
			<div class="ts-slide-buttons">
				<a href="/contact" class="ts-hero-btn ts-hero-btn-primary">Learn Why</a>
				<a href="/contact" class="ts-hero-btn ts-hero-btn-secondary">Contact Us</a>
			</div>
		</div>
	</div>
	<!-- Slide 4 -->
	<div class="ts-slide" data-slide="3">
		<div class="ts-slide-bg" style="background-image: url('/images/topscorer/h3-img-1.jpg');"></div>
		<div class="ts-slide-overlay"></div>
		<div class="ts-slide-content">
			<h1 class="ts-slide-title">Premium Wood Lockers. Unbeatable Prices.</h1>
			<p class="ts-slide-text">Wood, phenolic, and more — custom in 8–12 weeks. High style. Lower cost.</p>
			<div class="ts-slide-buttons">
				<a href="/hockey" class="ts-hero-btn ts-hero-btn-primary">By Sport</a>
				<a href="/contact#quote-form" class="ts-hero-btn ts-hero-btn-secondary">Get a Quote</a>
			</div>
			</div>
		</div>
	</div>
	<!-- Decorative corner images (like TopScorer) -->
	<div class="ts-hero-corner-images">
		<img src="/images/topscorer/h1-rev-img-1.png" alt="" class="ts-corner-img ts-corner-1" />
		<img src="/images/topscorer/h1-rev-img-2.png" alt="" class="ts-corner-img ts-corner-2" />
		<img src="/images/topscorer/h1-rev-img-3.png" alt="" class="ts-corner-img ts-corner-3" />
		<img src="/images/topscorer/h1-rev-img-4.png" alt="" class="ts-corner-img ts-corner-4" />
		<img src="/images/topscorer/h1-rev-img-5.png" alt="" class="ts-corner-img ts-corner-5" />
	</div>
</section>

<!-- ============================================
     OUR LOCKERS SECTION (Same as Home Page)
     ============================================ -->
