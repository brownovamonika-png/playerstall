---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="How It Works | Your Custom Locker Room Journey | PlayerStall"
	description="See exactly how PlayerStall takes care of you from first call to final installation. 7 clear steps, no surprises. Free consultation, custom design, 5-year warranty. 30+ years experience."
>
	<Fragment slot="head">
		<script type="application/ld+json">
		{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://playerstall.com"},
				{"@type": "ListItem", "position": 2, "name": "How It Works", "item": "https://playerstall.com/how-it-works"}
			]
		})}
		</script>
		<script type="application/ld+json">
		{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "How long does the entire process take from consultation to installation?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Quick Ship orders ship within 2–4 weeks. Custom orders are built in 8–12 weeks. Including consultation and design approval, most projects are complete within 3–4 months from first contact."
					}
				},
				{
					"@type": "Question",
					"name": "Is the design consultation really free?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Yes, 100% free with no obligation. We discuss your space, needs, sport requirements, and budget to create a custom layout and quote. There is no cost until you approve a design and place a deposit."
					}
				},
				{
					"@type": "Question",
					"name": "What happens after I submit a quote request?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "A dedicated PlayerStall team member reviews your project within 24 hours and reaches out to schedule a consultation. We then create a custom design with 3D visualization and itemized pricing within 2–3 business days."
					}
				},
				{
					"@type": "Question",
					"name": "Do I need to install the lockers myself?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Our lockers are designed for straightforward installation. We provide detailed installation guides, and our team is available by phone throughout the process. Many facilities managers handle installation themselves, but we can also recommend professional installers in your area."
					}
				}
			]
		})}
		</script>
	</Fragment>

	<!-- Hero Section -->
	<section class="hiw-hero">
		<div class="hiw-hero-bg">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Custom wood sports lockers by PlayerStall" class="hiw-hero-image" />
		</div>
		<div class="hiw-hero-overlay"></div>
		<div class="hiw-hero-container">
			<div class="hiw-breadcrumbs">
				<a href="/">Home</a>
				<span>How It Works</span>
			</div>
			<h1 class="hiw-hero-title">How It Works</h1>
		</div>
	</section>

	<!-- Intro Section -->
	<section class="hiw-section">
		<div class="hiw-container">
			<div class="hiw-section-header">
				<p class="hiw-subtitle">YOUR JOURNEY WITH US</p>
				<h2 class="hiw-title">HOW IT WORKS</h2>
			</div>
			<div class="hiw-centered">
				<p class="hiw-bio">From your very first question to the day your team walks into their new locker room, we take care of everything. No surprises, no guesswork. Here's what to expect.</p>
			</div>
		</div>
	</section>

	<!-- Step 1 -->
	<section class="hiw-section">
		<div class="hiw-container">
			<div class="hiw-section-header">
				<p class="hiw-subtitle">STEP 1</p>
				<h2 class="hiw-title">EXPLORE &amp; DISCOVER</h2>
			</div>
			<div class="hiw-centered">
				<p class="hiw-meta"><span>Browse Products</span> | <span>View Gallery</span> | <span>Explore by Sport</span></p>
				<p class="hiw-bio">Take your time exploring our products, gallery, and sport specific solutions. See what other programs have built with PlayerStall and start imagining what's possible for your team.</p>
				<div class="hiw-step-image">
					<img src="https://playerstall.b-cdn.net/images/h3-blog-img-7.jpg" alt="Browse PlayerStall custom wood locker products" loading="lazy" />
				</div>
				<div class="hiw-buttons">
					<a href="/shop" class="hiw-btn">View Products</a>
					<a href="/gallery" class="hiw-btn">See Our Gallery</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Step 2 -->
	<section class="hiw-section hiw-section-alt">
		<div class="hiw-container">
			<div class="hiw-section-header">
				<p class="hiw-subtitle">STEP 2</p>
				<h2 class="hiw-title">FREE CONSULTATION</h2>
			</div>
			<div class="hiw-centered">
				<p class="hiw-meta"><span>No Obligation</span> | <span>Response within 24 hours</span> | <span>30+ Years Experience</span></p>
				<p class="hiw-bio">Request a quote, use our Locker Room Planner, or simply give us a call. Share your space, your sport, your budget, and your timeline. There's no commitment and no pressure. Just a conversation with people who've been doing this for over 30 years.</p>
				<div class="hiw-step-image">
					<img src="https://playerstall.b-cdn.net/images/h3-blog-img-2.jpg" alt="Free consultation for custom sports lockers" loading="lazy" />
				</div>
				<div class="hiw-buttons">
					<a href="/request-a-quote" class="hiw-btn hiw-btn-filled">Request a Quote</a>
					<a href="/room-planner" class="hiw-btn">Try the Room Planner</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Step 3 -->
	<section class="hiw-section">
		<div class="hiw-container">
			<div class="hiw-section-header">
				<p class="hiw-subtitle">STEP 3</p>
				<h2 class="hiw-title">CUSTOM DESIGN &amp; QUOTE</h2>
			</div>
			<div class="hiw-centered">
				<p class="hiw-meta"><span>Custom Layout</span> | <span>Itemized Pricing</span> | <span>2 to 3 Business Days</span></p>
				<p class="hiw-bio">Our team creates a detailed layout and itemized quote tailored to your space and requirements. You'll see exactly what you're getting: dimensions, materials, colors, branding options, and pricing. All before making any decisions.</p>
				<div class="hiw-step-image">
					<img src="https://playerstall.b-cdn.net/images/h3-blog-img-3.jpg" alt="Custom locker room design and quote" loading="lazy" />
				</div>
			</div>
		</div>
	</section>

	<!-- Step 4 -->
	<section class="hiw-section hiw-section-alt">
		<div class="hiw-container">
			<div class="hiw-section-header">
				<p class="hiw-subtitle">STEP 4</p>
				<h2 class="hiw-title">DESIGN APPROVAL &amp; DEPOSIT</h2>
			</div>
			<div class="hiw-centered">
				<p class="hiw-meta"><span>Unlimited Revisions</span> | <span>Clear Invoice</span> | <span>50% Deposit to Start</span></p>
				<p class="hiw-bio">We'll work with you to adjust anything. Sizes, colors, configurations, accessories. Whatever it takes until the design is exactly right. Once you approve, a 50% deposit locks in your project and we begin production.</p>
				<div class="hiw-step-image">
					<img src="https://playerstall.b-cdn.net/images/h3-blog-img-4.jpg" alt="Design approval and deposit for custom lockers" loading="lazy" />
				</div>
			</div>
		</div>
	</section>

	<!-- Step 5 -->
	<section class="hiw-section">
		<div class="hiw-container">
			<div class="hiw-section-header">
				<p class="hiw-subtitle">STEP 5</p>
				<h2 class="hiw-title">PRODUCTION</h2>
			</div>
			<div class="hiw-centered">
				<p class="hiw-meta"><span>Quick Ship: 2 to 4 Weeks</span> | <span>Custom: 8 to 12 Weeks</span> | <span>Progress Updates</span></p>
				<p class="hiw-bio">Your lockers are built by people who have been doing this for decades. Every piece is made from premium cabinetry grade plywood and finished exactly the way you want it. We'll keep you posted as we go.</p>
				<div class="hiw-step-image">
					<img src="https://playerstall.b-cdn.net/images/player-img-10.jpg" alt="PlayerStall manufacturing crafting custom wood lockers" loading="lazy" />
				</div>
			</div>
		</div>
	</section>

	<!-- Step 6 -->
	<section class="hiw-section hiw-section-alt">
		<div class="hiw-container">
			<div class="hiw-section-header">
				<p class="hiw-subtitle">STEP 6</p>
				<h2 class="hiw-title">SHIPPING &amp; DELIVERY</h2>
			</div>
			<div class="hiw-centered">
				<p class="hiw-meta"><span>USA &amp; Canada</span> | <span>Carefully Packaged</span> | <span>Prep Checklist Included</span></p>
				<p class="hiw-bio">We ship across the United States and Canada. Your lockers are carefully packaged and we coordinate delivery so everything arrives safe and on time. We also send you a checklist to get your space ready before delivery.</p>
				<div class="hiw-step-image">
					<img src="https://playerstall.b-cdn.net/images/player-img-11.jpg" alt="Shipping and delivery of custom sports lockers" loading="lazy" />
				</div>
				<div class="hiw-buttons">
					<a href="/installation-guide" class="hiw-btn">View Installation Guide</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Step 7 -->
	<section class="hiw-section">
		<div class="hiw-container">
			<div class="hiw-section-header">
				<p class="hiw-subtitle">STEP 7</p>
				<h2 class="hiw-title">INSTALLATION &amp; ONGOING SUPPORT</h2>
			</div>
			<div class="hiw-centered">
				<p class="hiw-meta"><span>Easy Install</span> | <span>Phone Support</span> | <span>5 Year Warranty</span> | <span>Replacement Parts</span></p>
				<p class="hiw-bio">Our lockers are built to be easy to install, and we're just a phone call away if you need a hand. Once your locker room is set up, you're backed by our 5 year warranty. If anything gets damaged, our modular design lets you replace just that one part instead of the whole locker.</p>
				<div class="hiw-step-image">
					<img src="https://playerstall.b-cdn.net/images/player-img-12.jpg" alt="Installed custom wood sports lockers with warranty" loading="lazy" />
				</div>
				<div class="hiw-buttons">
					<a href="/installation-guide" class="hiw-btn">Installation Guide</a>
					<a href="/warranty" class="hiw-btn">Warranty &amp; Care</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Promise Banner -->
	<section class="hiw-section hiw-section-alt">
		<div class="hiw-container">
			<div class="hiw-section-header">
				<p class="hiw-subtitle">THE PLAYERSTALL DIFFERENCE</p>
				<h2 class="hiw-title">OUR PROMISE TO YOU</h2>
			</div>
			<div class="hiw-promise-grid">
				<div class="hiw-promise-item">
					<div class="hiw-promise-icon">30+</div>
					<h4>Years of Experience</h4>
					<p>Family owned since 1996. We've built thousands of locker rooms for teams all over the US and Canada.</p>
				</div>
				<div class="hiw-promise-item">
					<div class="hiw-promise-icon">5yr</div>
					<h4>Warranty on Every Locker</h4>
					<p>We stand behind our work. Modular design means you can replace individual parts, not the whole locker.</p>
				</div>
				<div class="hiw-promise-item">
					<div class="hiw-promise-icon">1</div>
					<h4>Dedicated Contact</h4>
					<p>One person handles your project from start to finish. You always know who to call.</p>
				</div>
				<div class="hiw-promise-item">
					<div class="hiw-promise-icon">$0</div>
					<h4>Free Consultation</h4>
					<p>No cost, no obligation. We'll design your space and put together a quote before you commit to anything.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="hiw-faq">
		<div class="hiw-container">
			<div class="hiw-section-header">
				<p class="hiw-subtitle">COMMON QUESTIONS</p>
				<h2 class="hiw-title">FREQUENTLY ASKED QUESTIONS</h2>
			</div>
			<div class="hiw-faq-list">
				<div class="hiw-faq-item active">
					<div class="hiw-faq-question">
						<span>How long does the entire process take?</span>
						<span class="hiw-faq-toggle">+</span>
					</div>
					<div class="hiw-faq-answer">
						<p>Quick Ship orders go out within 2 to 4 weeks. Custom orders are built in 8 to 12 weeks. Including consultation and design approval, most projects wrap up within 3 to 4 months from first contact.</p>
					</div>
				</div>
				<div class="hiw-faq-item">
					<div class="hiw-faq-question">
						<span>Is the design consultation really free?</span>
						<span class="hiw-faq-toggle">+</span>
					</div>
					<div class="hiw-faq-answer">
						<p>Yes, totally free with no obligation. We talk through your space, your needs, your sport, and your budget to put together a layout and quote. There's no cost until you approve the design and place a deposit.</p>
					</div>
				</div>
				<div class="hiw-faq-item">
					<div class="hiw-faq-question">
						<span>What happens after I submit a quote request?</span>
						<span class="hiw-faq-toggle">+</span>
					</div>
					<div class="hiw-faq-answer">
						<p>Someone on our team reviews your project within 24 hours and reaches out to set up a call. We then put together a custom design with itemized pricing within 2 to 3 business days.</p>
					</div>
				</div>
				<div class="hiw-faq-item">
					<div class="hiw-faq-question">
						<span>Do I need to install the lockers myself?</span>
						<span class="hiw-faq-toggle">+</span>
					</div>
					<div class="hiw-faq-answer">
						<p>Our lockers are built to be easy to install. We include detailed guides, and our team is on the phone with you whenever you need us. Most facilities managers handle installation themselves, but we can also point you toward professional installers in your area.</p>
					</div>
				</div>
				<div class="hiw-faq-item">
					<div class="hiw-faq-question">
						<span>Can I make changes to the design after I approve it?</span>
						<span class="hiw-faq-toggle">+</span>
					</div>
					<div class="hiw-faq-answer">
						<p>Before production starts, you can make as many revisions as you want at no extra cost. Once production is underway, small adjustments might still be possible. Just give your contact a call and we'll do what we can.</p>
					</div>
				</div>
				<div class="hiw-faq-item">
					<div class="hiw-faq-question">
						<span>What does the 5 year warranty cover?</span>
						<span class="hiw-faq-toggle">+</span>
					</div>
					<div class="hiw-faq-answer">
						<p>Our warranty covers defects in materials and workmanship for 5 years from delivery. Because of our modular design, you can replace just the damaged part without replacing the whole locker. Check our <a href="/warranty">Warranty &amp; Care</a> page for the full details.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="hiw-cta">
		<div class="hiw-cta-badge">free</div>
		<div class="hiw-container">
			<div class="hiw-cta-content">
				<p class="hiw-cta-subtitle">ready to get started?</p>
				<h2 class="hiw-cta-title">Let's Build Your Locker Room</h2>
				<p class="hiw-cta-text">Start with a free consultation, no strings attached. Tell us about your project and we'll take it from there.</p>
				<div class="hiw-cta-buttons">
					<a href="/request-a-quote" class="btn btn-primary btn-large">Request a Quote</a>
					<a href="/room-planner" class="btn btn-secondary btn-large">Try the Room Planner</a>
				</div>
				<p class="hiw-cta-phone">Or call us directly at <a href="tel:+18885841444">1 888 584 1444</a></p>
			</div>
		</div>
	</section>

</BaseLayout>

<style>
	/* Hero */
	.hiw-hero {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}

	.hiw-hero-bg {
		position: absolute;
		top: 0; left: 0; width: 100%; height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.hiw-hero-image {
		width: 100%; height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.hiw-hero-overlay {
		position: absolute;
		top: 0; left: 0; right: 0; bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.hiw-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.hiw-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 30px;
	}

	.hiw-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.hiw-breadcrumbs a:hover {
		color: #fe5900;
	}

	.hiw-breadcrumbs span {
		margin-left: 10px;
		color: #ffffff;
	}

	.hiw-hero-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
	}

	/* Sections (matching homepage materials style) */
	.hiw-section {
		padding: 100px 0;
		background: #ffffff;
	}

	.hiw-section-alt {
		background: #f7f7f7;
	}

	.hiw-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.hiw-section-header {
		text-align: center;
		margin-bottom: 40px;
	}

	.hiw-subtitle {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		letter-spacing: 6px;
		text-transform: uppercase;
		color: #8c8c8c;
		margin-bottom: 10px;
	}

	.hiw-title {
		font-family: 'Oswald', sans-serif;
		font-size: clamp(32px, 4vw, 52px);
		font-weight: 700;
		text-transform: uppercase;
		color: #0d0d0d;
		line-height: 1.1;
		margin: 0;
	}

	.hiw-centered {
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
	}

	.hiw-meta {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 25px;
	}

	.hiw-bio {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		line-height: 1.8;
		color: #666666;
		margin-bottom: 30px;
	}

	.hiw-step-image {
		width: 480px;
		max-width: 100%;
		aspect-ratio: 16 / 9;
		margin: 0 auto 30px;
		overflow: hidden;
	}

	.hiw-step-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.hiw-buttons {
		display: flex;
		gap: 12px;
		justify-content: center;
		flex-wrap: wrap;
		margin-top: 10px;
	}

	.hiw-btn {
		display: inline-block;
		padding: 12px 32px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		text-decoration: none;
		border: 2px solid #0d0d0d;
		color: #0d0d0d;
		transition: all 0.3s;
	}

	.hiw-btn:hover {
		background: #0d0d0d;
		color: #fff;
	}

	.hiw-btn-filled {
		background: #fe5900;
		color: #fff;
		border-color: #fe5900;
	}

	.hiw-btn-filled:hover {
		background: #e04d00;
		border-color: #e04d00;
		color: #fff;
	}

	/* Promise Section */
	.hiw-promise-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 40px;
		margin-top: 40px;
	}

	.hiw-promise-item {
		text-align: center;
	}

	.hiw-promise-icon {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		background: #fe5900;
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: 'Oswald', sans-serif;
		font-size: 24px;
		font-weight: 700;
		margin: 0 auto 20px;
	}

	.hiw-promise-item h4 {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 12px;
	}

	.hiw-promise-item p {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #666666;
		line-height: 1.7;
		margin: 0;
	}

	/* FAQ Section */
	.hiw-faq {
		padding: 100px 0;
		background: #ffffff;
	}

	.hiw-faq-list {
		max-width: 800px;
		margin: 0 auto;
	}

	.hiw-faq-item {
		border-bottom: 1px solid #e0e0e0;
	}

	.hiw-faq-question {
		padding: 24px 0;
		cursor: pointer;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		transition: color 0.3s ease;
	}

	.hiw-faq-question:hover {
		color: #fe5900;
	}

	.hiw-faq-item.active .hiw-faq-question {
		color: #fe5900;
	}

	.hiw-faq-toggle {
		font-size: 24px;
		font-weight: 400;
		transition: transform 0.3s;
		flex-shrink: 0;
		margin-left: 16px;
	}

	.hiw-faq-item.active .hiw-faq-toggle {
		transform: rotate(45deg);
	}

	.hiw-faq-answer {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease;
