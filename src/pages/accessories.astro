---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Locker Accessories | Lock Box & Stick Rack | PlayerStall" description="Lock box with digital key lock (+$80) and stick rack (from $299). Secure valuables and organize sticks. 30+ years experience. Request a quote.">
	<!-- Hero -->
	<section class="accessories-hero">
		<div class="accessories-hero-bg">
			<img src="https://playerstall.b-cdn.net/images/our-team-title-photo.jpg" alt="" class="accessories-hero-img" />
		</div>
		<div class="accessories-hero-content container">
			<nav class="breadcrumbs">
				<a href="/">Home</a>
				<span class="breadcrumbs-sep">/</span>
				<a href="/shop">Shop</a>
				<span class="breadcrumbs-sep">/</span>
				<span class="breadcrumbs-current">Accessories</span>
			</nav>
			<h1 class="accessories-hero-title">Accessories</h1>
			<p class="accessories-hero-subtitle">Lock box and stick rack – secure valuables and keep sticks organized.</p>
		</div>
	</section>

	<!-- Lock Box & Stick Rack -->
	<section class="accessories-main">
		<div class="container">
			<div class="accessories-grid">
				<!-- Lock Box -->
				<article class="accessory-block" id="lock-box">
					<div class="accessory-block-image">
						<img src="https://playerstall.b-cdn.net/images/lock-box.png" alt="Lock box with digital key lock for sports lockers" loading="lazy" />
					</div>
					<div class="accessory-block-content">
						<h2 class="accessory-block-title">Lock Box with Digital Key Lock</h2>
						<p class="accessory-block-price">+ $80.00</p>
						<p class="accessory-block-copy">Secure lock box with a digital key lock for phones, wallets, and other valuables inside each locker.</p>
						<a href="/contact" class="accessory-cta">Request a quote</a>
					</div>
				</article>

				<!-- Stick Rack -->
				<article class="accessory-block" id="stick-rack">
					<div class="accessory-block-image">
						<img src="https://playerstall.b-cdn.net/images/stick-rack.png" alt="Hockey stick rack for locker rooms" loading="lazy" />
					</div>
					<div class="accessory-block-content">
						<h2 class="accessory-block-title">Stick Rack</h2>
						<p class="accessory-block-price">Starting at $299</p>
						<p class="accessory-block-copy">Dedicated stick storage that keeps sticks organized, off the floor, and easy to grab on the way to the ice.</p>
						<a href="/contact" class="accessory-cta">Request a quote</a>
					</div>
				</article>
			</div>
		</div>
	</section>

	<!-- More accessories CTA -->
	<section class="accessories-more">
		<div class="container">
			<p class="accessories-more-text">Cushions, coat rods, hooks, name plates, skate hooks, and custom logos are available as add-ons to our lockers.</p>
			<a href="/services#accessories" class="accessory-cta accessory-cta-secondary">View all locker options</a>
		</div>
	</section>
</BaseLayout>

<style>
	.container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.accessories-hero {
		position: relative;
		min-height: 280px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.accessories-hero-bg {
		position: absolute;
		inset: 0;
	}

	.accessories-hero-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.4;
	}

	.accessories-hero-content {
		position: relative;
		text-align: center;
		z-index: 1;
	}

	.breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		margin-bottom: 12px;
	}

	.breadcrumbs a {
		color: #8c8c8c;
		text-decoration: none;
	}

	.breadcrumbs a:hover {
		color: #fe5900;
	}

	.breadcrumbs-sep {
		margin: 0 6px;
	}

	.breadcrumbs-current {
		color: #0d0d0d;
		font-weight: 500;
	}

	.accessories-hero-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 8px;
		letter-spacing: 0.02em;
		line-height: 1.1;
	}

	.accessories-hero-subtitle {
		font-family: 'Yantramanav', sans-serif;
		font-size: 1rem;
		color: #666;
		margin: 0;
		max-width: 560px;
		margin-left: auto;
		margin-right: auto;
	}

	.accessories-main {
		padding: 60px 0 80px;
		background: #fff;
	}

	.accessories-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 40px;
		max-width: 900px;
		margin: 0 auto;
	}

	.accessory-block {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 32px;
		align-items: center;
		background: #f8f8f8;
		border: 1px solid #eee;
		padding: 32px;
		border-radius: 8px;
	}

	.accessory-block-image {
		background: #fff;
		border-radius: 6px;
		padding: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 180px;
	}

	.accessory-block-image img {
		max-width: 100%;
		max-height: 200px;
		object-fit: contain;
		display: block;
	}

	.accessory-block-title {
		font-family: 'Oswald', sans-serif;
		font-size: 22px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 10px;
		letter-spacing: 0.02em;
	}

	.accessory-block-price {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #fe5900;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin: 0 0 14px;
	}

	.accessory-block-copy {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #0d0d0d;
		line-height: 1.6;
		margin: 0 0 20px;
	}

	.accessory-cta {
		display: inline-block;
		padding: 12px 24px;
		background: #fe5900;
		color: #fff;
		font-family: 'Oswald', sans-serif;
		font-size: 14px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		text-decoration: none;
		transition: background 0.2s;
	}

	.accessory-cta:hover {
		background: #e04e00;
	}

	.accessories-more {
		padding: 40px 0 60px;
		background: #f7f7f7;
		text-align: center;
	}

	.accessories-more-text {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #666;
		max-width: 600px;
		margin: 0 auto 20px;
		line-height: 1.6;
	}

	.accessory-cta-secondary {
		background: transparent;
		color: #0d0d0d;
		border: 2px solid #0d0d0d;
	}

	.accessory-cta-secondary:hover {
		background: #0d0d0d;
		color: #fff;
	}

	@media (max-width: 768px) {
		.accessories-grid {
			grid-template-columns: 1fr;
			gap: 32px;
		}

		.accessory-block {
			grid-template-columns: 1fr;
			gap: 20px;
			padding: 24px;
		}

		.accessory-block-image {
			min-height: 140px;
		}

		.accessory-block-title {
			font-size: 18px;
		}
	}
</style>
