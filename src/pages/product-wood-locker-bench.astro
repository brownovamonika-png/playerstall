<script>
	document.addEventListener('DOMContentLoaded', function() {
		// Bench gallery slider (3-way sliding, same pattern as cushion modal)
		var benchSlidesEl = document.getElementById('bench-slides');
		var benchDots = document.querySelectorAll('.bench-slider-dot');
		var benchThumbs = document.querySelectorAll('.product-gallery-thumbs .thumb');
		var benchPrev = document.getElementById('bench-slider-prev');
		var benchNext = document.getElementById('bench-slider-next');
		var benchSlideIndex = 0;
		var benchSlideCount = benchDots.length || benchThumbs.length || 1;

		function setBenchSlide(index) {
			if (!benchSlidesEl) return;
			if (index < 0) index = benchSlideCount - 1;
			if (index >= benchSlideCount) index = 0;
			benchSlideIndex = index;
			benchSlidesEl.style.transform = 'translateX(-' + (index * 100) + '%)';
			benchDots.forEach(function(dot, i) {
				dot.classList.toggle('active', i === index);
				dot.setAttribute('aria-current', i === index ? 'true' : 'false');
			});
			benchThumbs.forEach(function(t, i) {
				t.classList.toggle('active', i === index);
			});
		}

		benchDots.forEach(function(dot) {
			dot.addEventListener('click', function() {
				var i = parseInt(dot.getAttribute('data-slide') || '0', 10);
				setBenchSlide(i);
			});
		});

		benchThumbs.forEach(function(thumb, idx) {
			thumb.addEventListener('click', function() {
				var attr = thumb.getAttribute('data-slide');
				var i = attr !== null ? parseInt(attr, 10) : idx;
				setBenchSlide(i);
			});
		});

		if (benchPrev) benchPrev.addEventListener('click', function() { setBenchSlide(benchSlideIndex - 1); });
		if (benchNext) benchNext.addEventListener('click', function() { setBenchSlide(benchSlideIndex + 1); });

		// Color dropdown (solid paint + textured woodgrain, same pattern as lockers)
		var colorDropdown = document.getElementById('bench-color-select');
		var colorPreview = document.getElementById('bench-color-preview');

		function slugifyColorLabel(label) {
			return (label || '')
				.trim()
				.toLowerCase()
				.replace(/[^a-z0-9]+/g, '-')
				.replace(/^-+|-+$/g, '');
		}

		function updateColorPreview() {
			if (!colorDropdown || !colorPreview) return;
			var opt = colorDropdown.options[colorDropdown.selectedIndex];
			if (!opt) return;
			var swatchImage = opt.getAttribute('data-swatch-image');
			var color = opt.getAttribute('data-color') || '#f4f4f0';
			if (swatchImage) {
				colorPreview.style.backgroundImage = 'url(' + swatchImage + ')';
				colorPreview.style.backgroundColor = color;
			} else {
				colorPreview.style.backgroundImage = '';
				colorPreview.style.backgroundColor = color;
			}
		}

		function updateBenchModelNumber() {
			var modelEl = document.querySelector('.product-model[data-model-prefix]');
			if (!modelEl) return;
			var widthBtn = document.querySelector('.width-swatch.active');
			var length = (widthBtn && widthBtn.getAttribute('data-width')) ? widthBtn.getAttribute('data-width') : '72';
			var colorCode = colorDropdown ? (colorDropdown.value || 'HRW') : 'HRW';
			modelEl.textContent = 'Model # BENCH-' + length + '-' + colorCode;
		}

		function getActiveBenchPrice() {
			var widthBtn = document.querySelector('.width-swatch.active');
			var priceAttr = widthBtn ? widthBtn.getAttribute('data-price') : null;
			var priceEl = document.querySelector('.product-price');
			var basePrice = priceEl ? parseFloat(priceEl.getAttribute('data-base-price') || '269') : 269;
			var price = priceAttr ? parseFloat(priceAttr) : basePrice;
			return Number.isFinite(price) ? price : 269;
		}

		function updateBenchPrice() {
			var priceEl = document.querySelector('.product-price');
			if (!priceEl) return;
			var price = getActiveBenchPrice();
			priceEl.textContent = '$' + price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
		}

		if (colorDropdown) {
			colorDropdown.addEventListener('change', function() {
				updateColorPreview();
				updateBenchModelNumber();
			});
			updateColorPreview();
		}

		// Width swatches
		document.querySelectorAll('.width-swatch').forEach(function(btn) {
			btn.addEventListener('click', function() {
				document.querySelectorAll('.width-swatch').forEach(function(b) {
					b.classList.remove('active');
					b.setAttribute('aria-pressed', 'false');
				});
				btn.classList.add('active');
				btn.setAttribute('aria-pressed', 'true');
				var option = btn.closest('.product-option');
				var valueEl = option ? option.querySelector('.option-value') : null;
				if (valueEl) valueEl.textContent = (btn.textContent || '').trim();
				updateBenchModelNumber();
				updateBenchPrice();
			});
		});

		updateBenchPrice();

		// Add to cart
		var addCartBtn = document.getElementById('bench-add-cart');
		if (!addCartBtn) return;

		function getCart() {
			var cart = localStorage.getItem('playerstall_cart');
			return cart ? JSON.parse(cart) : [];
		}
		function saveCart(cart) {
			localStorage.setItem('playerstall_cart', JSON.stringify(cart));
			window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: cart.reduce(function(s, i) { return s + i.quantity; }, 0) } }));
		}

		addCartBtn.addEventListener('click', function() {
			var widthBtn = document.querySelector('.width-swatch.active');
			var length = (widthBtn && widthBtn.getAttribute('data-width')) ? widthBtn.getAttribute('data-width') : '72';
			var colorCode = colorDropdown ? (colorDropdown.value || 'HRW') : 'HRW';
			var colorLabel = 'High Reflective White';
			if (colorDropdown) {
				var selectedOpt = colorDropdown.options[colorDropdown.selectedIndex];
				if (selectedOpt) colorLabel = (selectedOpt.textContent || '').trim() || colorLabel;
			}
			var colorSlug = slugifyColorLabel(colorLabel);
			var depth = '18';
			var qtyEl = document.getElementById('product-qty');
			var qty = parseInt((qtyEl && qtyEl.value) ? qtyEl.value : '1', 10) || 1;

			var id = 'wood-bench-' + length + '-' + depth + '-' + colorSlug;
			var name = 'Bench ' + length + '"L × ' + depth + '"D (' + colorLabel + ')';
			var price = getActiveBenchPrice();
			var image = 'https://playerstall.b-cdn.net/images/bench%20top%20above.png';

			var cart = getCart();
			var existing = cart.find(function(item) { return item.id === id; });
			if (existing) existing.quantity += qty;
			else cart.push({ id: id, name: name, price: price, image: image, quantity: qty });
			saveCart(cart);

			var originalText = addCartBtn.textContent;
			addCartBtn.textContent = 'Added to cart';
			setTimeout(function() { addCartBtn.textContent = originalText; }, 1500);
		});
	});
</script>
