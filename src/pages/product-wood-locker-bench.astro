---
import BaseLayout from '../layouts/BaseLayout.astro';
import LockerAccessories from '../components/LockerAccessories.astro';

const lockerAccessoriesItems = [
	{ href: '/accessories#stick-rack', image: 'https://playerstall.b-cdn.net/images/stick-rack.png', alt: 'Stick Rack', category: 'LOCKER ADD-ONS', title: 'Stick Rack', price: 'Starting at $299' },
	{ href: '/accessories#lock-box', image: 'https://playerstall.b-cdn.net/images/lock-box.png', alt: 'Lock Box with Digital Key Lock', category: 'LOCKER ADD-ONS', title: 'Lock Box', price: '+ $80.00' },
	{ href: '/shop#accessories', image: 'https://playerstall.b-cdn.net/images/cushion-logo.png', alt: 'Locker cushions', category: 'LOCKER ADD-ONS', title: 'Cushions', price: '+ $75.00' },
	{ href: '/shop#accessories', image: 'https://playerstall.b-cdn.net/images/name-plate.png', alt: 'Name plate', category: 'LOCKER ADD-ONS', title: 'Name Plate', price: '+ $10.00' },
];
---

<BaseLayout
	title='Bench - Free Standing 36" to 96" Wide | PlayerStall'
	description='Custom wood locker bench, free standing. Available 36" to 96" wide, 9.5" or 14" deep, light or dark finish. Solid wood, black pedestals. Request a quote.'
>
	<!-- Hero Section (same as Stadium) -->
	<section class="product-hero-section">
		<div class="product-hero-background-overlay"></div>
		<div class="product-hero-container">
			<div class="product-breadcrumbs">
				<a href="/">Home</a>
				<span class="breadcrumbs-sep">/</span>
				<a href="/shop">Shop</a>
				<span class="breadcrumbs-sep">/</span>
				<span class="breadcrumbs-current">Bench</span>
			</div>
		</div>
	</section>

	<!-- Product Main (same layout as Stadium) -->
	<section class="product-main-section">
		<div class="product-container">
			<div class="product-layout">
				<!-- Left: Gallery -->
				<div class="product-gallery">
					<div class="product-gallery-main">
						<img src="https://playerstall.b-cdn.net/images/wood-lockers-starting-lineup.jpg" alt="Bench free standing for athletic locker rooms" class="product-main-image" />
						<span class="product-enlarge-hint">Enlarge Image</span>
					</div>
					<div class="product-gallery-thumbs">
						<button type="button" class="thumb active" aria-label="View image 1"><img src="https://playerstall.b-cdn.net/images/wood-lockers-starting-lineup.jpg" alt="Bench view 1" /></button>
						<button type="button" class="thumb" aria-label="View image 2"><img src="https://playerstall.b-cdn.net/images/wood-lockers-team-discount.jpg" alt="Bench view 2" /></button>
						<button type="button" class="thumb" aria-label="View image 3"><img src="https://playerstall.b-cdn.net/images/wood-locer-room-front-2.png" alt="Locker room with bench" /></button>
					</div>
				</div>

				<!-- Right: Details -->
				<div class="product-detail">
					<h1 class="product-title">Bench – Free Standing 36&quot; to 96&quot; Wide</h1>
					<p class="product-model" data-model-prefix="BENCH">Model # BENCH-36-L</p>
					<p class="product-lead-time">Lead time: usually ships within 1–2 weeks</p>
					<div class="product-price-block">
						<span class="product-price" data-base-price="225">From $225.00</span>
					</div>

					<div class="product-options">
						<div class="product-option">
							<label class="option-label">Width:</label>
							<span class="option-value">36&quot;</span>
							<div class="option-swatches">
								<button type="button" class="swatch width-swatch active" data-width="36" title="36 inch" aria-pressed="true">36&quot;</button>
								<button type="button" class="swatch width-swatch" data-width="48" title="48 inch">48&quot;</button>
								<button type="button" class="swatch width-swatch" data-width="60" title="60 inch">60&quot;</button>
								<button type="button" class="swatch width-swatch" data-width="72" title="72 inch">72&quot;</button>
								<button type="button" class="swatch width-swatch" data-width="84" title="84 inch">84&quot;</button>
								<button type="button" class="swatch width-swatch" data-width="96" title="96 inch">96&quot;</button>
							</div>
						</div>
						<div class="product-option">
							<label class="option-label">Color:</label>
							<span class="option-value">Light</span>
							<div class="option-swatches">
								<button type="button" class="swatch active" data-color="light" title="Light" aria-pressed="true">Light</button>
								<button type="button" class="swatch" data-color="dark" title="Dark">Dark</button>
							</div>
						</div>
						<div class="product-option">
							<label class="option-label">Depth:</label>
							<span class="option-value">9.5&quot;</span>
							<div class="option-swatches">
								<button type="button" class="swatch depth-swatch active" data-depth="9.5" title="9.5 inch" aria-pressed="true">9.5&quot;</button>
								<button type="button" class="swatch depth-swatch" data-depth="14" title="14 inch">14&quot;</button>
							</div>
						</div>
						<p class="option-note">Pair with lockers for a complete installation. <a href="/shop">View lockers</a>.</p>
						<div class="product-specs-inline">
							<p><strong>Size (36&quot; W example):</strong> 36&quot; W × 18&quot; H × 9.5&quot; D</p>
							<p><strong>Weight:</strong> approx. 20 lbs (36&quot; width)</p>
						</div>
					</div>

					<div class="product-volume-discounts">
						<h3 class="volume-title">Volume Discounts</h3>
						<table class="volume-table">
							<thead>
								<tr><th>Quantity</th><th>Price</th></tr>
							</thead>
							<tbody>
								<tr><td>1</td><td>$225.00</td></tr>
								<tr><td>2 – 5</td><td>$190.00</td></tr>
								<tr><td>6+</td><td>$180.00</td></tr>
								<tr><td>Bulk</td><td><a href="/contact#quote-form" class="volume-contact-link">Contact us</a> for pricing</td></tr>
							</tbody>
						</table>
					</div>

					<div class="product-actions">
						<label class="quantity-label" for="product-qty">Quantity:</label>
						<input type="number" id="product-qty" class="product-qty-input" value="1" min="1" max="999" />
						<button type="button" class="btn btn-primary product-add-cart" id="bench-add-cart">Add to Cart</button>
					</div>
				</div>
			</div>

			<!-- More Information (same structure as Stadium) -->
			<div class="product-info-section" id="moreinfo">
				<h2 class="product-info-heading">Bench – Features &amp; Options</h2>
				<h3 class="product-info-subheading">Features</h3>
				<ul class="product-features-list">
					<li>Constructed of solid butcher block wood</li>
					<li>Ideal for industrial, office, or recreational locker room facilities</li>
					<li>Classic look with strength and durability</li>
					<li>Available in light or dark finish</li>
					<li>Widths from 36&quot; to 96&quot; in 1-foot increments; easy to assemble</li>
					<li>18&quot; high; 9.5&quot; or 14&quot; deep</li>
					<li>Wood seating area 1¼&quot; thick</li>
					<li>Free-standing benches include black powder-coated pedestals (2 for 36&quot;–72&quot; wide, 3 for 84&quot; and 96&quot;)</li>
					<li>Delivered unassembled – minor assembly required</li>
				</ul>
				<h3 class="product-info-subheading">Options</h3>
				<ul class="product-options-list">
					<li>Widths: 36&quot;, 48&quot;, 60&quot;, 72&quot;, 84&quot;, 96&quot;</li>
					<li>Depth: 9.5&quot; or 14&quot;</li>
					<li>Light or dark finish</li>
					<li>Pair with our wood lockers for a complete locker room</li>
				</ul>
				<h3 class="product-info-subheading">Downloads</h3>
				<ul class="product-downloads-list">
					<li><a href="/colors/all-color-options-pdf.html" target="_blank">All Color Options PDF</a></li>
					<li><a href="/colors/laminate-colors-pdf.html" target="_blank">Laminate Colors PDF</a></li>
					<li><a href="/colors/woodgrain-colors-pdf.html" target="_blank">Woodgrain Colors PDF</a></li>
					<li><a href="/colors/phenolic-colors-pdf.html" target="_blank">Phenolic Colors PDF</a></li>
					<li><a href="/contact">Request spec sheet &amp; quote</a></li>
					<li><a href="/contact">Installation support</a></li>
					<li><a href="/shop">View all lockers</a></li>
				</ul>
			</div>

			<LockerAccessories title="LOCKER ACCESSORIES" items={lockerAccessoriesItems} />
		</div>
	</section>

</BaseLayout>


<style is:global>
	body {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	.product-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.product-hero-section {
		position: relative;
		background: #f7f7f7;
		padding: 80px 0 50px;
		overflow: hidden;
	}

	.product-hero-background-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(13, 13, 13, 0.04) 0%, transparent 100%);
	}

	.product-hero-container {
		position: relative;
		z-index: 2;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.product-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		margin-bottom: 20px;
	}

	.product-breadcrumbs a {
		color: #8c8c8c;
		text-decoration: none;
		transition: color 0.3s;
	}

	.product-breadcrumbs a:hover {
		color: #fe5900;
	}

	.breadcrumbs-sep {
		margin: 0 8px;
		color: #b6b6b6;
	}

	.breadcrumbs-current {
		color: #0d0d0d;
	}

	.product-background-text {
		position: absolute;
		font-family: 'Oswald', sans-serif;
		font-size: 200px;
		font-weight: 700;
		color: rgba(13, 13, 13, 0.04);
		text-transform: uppercase;
		letter-spacing: -2px;
		bottom: -30px;
		left: 50%;
		transform: translateX(-50%);
		white-space: nowrap;
		z-index: 1;
	}

	.product-main-section {
		padding: 60px 0 100px;
		background: #ffffff;
	}

	.product-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: start;
		margin-bottom: 80px;
	}

	.product-gallery-main {
		position: relative;
		background: #f7f7f7;
		aspect-ratio: 1;
		overflow: hidden;
		margin-bottom: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.product-main-image {
		width: 96%;
		height: 96%;
		object-fit: contain;
		display: block;
	}

	.product-enlarge-hint {
		position: absolute;
		bottom: 12px;
		right: 12px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.product-gallery-thumbs {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.thumb {
		width: 80px;
		height: 80px;
		padding: 0;
		border: 2px solid transparent;
		background: #f0f0f0;
		cursor: pointer;
		overflow: hidden;
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	.thumb:hover,
	.thumb.active {
		border-color: #fe5900;
		box-shadow: 0 0 0 1px #fe5900;
	}

	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.product-detail {
		position: sticky;
		top: 120px;
	}

	.product-title {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		line-height: 1.25;
		margin: 0 0 12px;
		text-transform: none;
	}

	.product-model {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 8px;
	}

	.product-lead-time {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin: 0 0 24px;
		text-transform: lowercase;
	}

	.product-price-block {
		margin-bottom: 28px;
		padding-bottom: 24px;
		border-bottom: 1px solid #e0e0e0;
	}

	.product-price {
		font-family: 'Oswald', sans-serif;
		font-size: 36px;
		font-weight: 600;
		color: #0d0d0d;
	}

	.option-label {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 8px;
	}

	.option-value {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 8px;
		display: block;
	}

	.option-swatches {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.swatch {
		padding: 8px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: #f0f0f0;
		border: 2px solid transparent;
		color: #0d0d0d;
		cursor: pointer;
		transition: border-color 0.2s, background 0.2s;
	}

	.swatch:hover {
		background: #e8e8e8;
	}

	.swatch.active {
		border-color: #fe5900;
		background: #fff;
		color: #0d0d0d;
	}

	.option-note {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		margin: 6px 0 0;
		font-style: italic;
	}

	.product-specs-inline {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin-top: 16px;
	}

	.product-specs-inline p {
		margin: 0 0 6px;
	}

	.product-volume-discounts {
		margin-bottom: 28px;
	}

	.volume-title {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0 0 12px;
	}

	.volume-table {
		width: 100%;
		border-collapse: collapse;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
	}

	.volume-table thead {
		background: #0d0d0d;
		color: #fff;
	}

	.volume-table th {
		padding: 12px 14px;
		text-align: left;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.volume-table th:first-child {
		background: #fe5900;
	}

	.volume-table td {
		padding: 12px 14px;
		border-bottom: 1px solid #e0e0e0;
		color: #0d0d0d;
	}

	.volume-contact-link {
		color: #fe5900;
		text-decoration: none;
		font-weight: 500;
	}

	.product-actions {
		display: flex;
		align-items: center;
		gap: 16px;
		flex-wrap: wrap;
	}

	.quantity-label {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #0d0d0d;
	}

	.product-qty-input {
		width: 80px;
		padding: 12px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		border: 1px solid #ccc;
		background: #fff;
		color: #0d0d0d;
	}

	.btn {
		display: inline-block;
		padding: 15px 40px;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 500;
		letter-spacing: 0.1em;
		font-size: 16px;
		transition: all 0.3s;
		font-family: 'Yantramanav', sans-serif;
		border: none;
		cursor: pointer;
	}

	.btn-primary {
		background: #fe5900;
		color: #ffffff;
		border: 2px solid #fe5900;
	}

	.btn-primary:hover {
		background: #e04d00;
		border-color: #e04d00;
	}

	.product-add-cart {
		padding: 16px 36px;
	}

	.product-info-section {
		padding: 60px 0 0;
		border-top: 1px solid #e0e0e0;
		margin-top: 40px;
	}

	.product-info-heading {
		font-family: 'Oswald', sans-serif;
		font-size: 32px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 32px;
	}

	.product-info-subheading {
		font-family: 'Oswald', sans-serif;
		font-size: 20px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 32px 0 16px;
	}

	.product-info-subheading:first-of-type {
		margin-top: 0;
	}

	.product-features-list,
	.product-options-list,
	.product-downloads-list {
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		line-height: 1.7;
		color: #0d0d0d;
		margin: 0 0 24px;
		padding-left: 24px;
	}

	.product-options-list li,
	.product-downloads-list li {
		margin-bottom: 10px;
	}

	.product-downloads-list {
		list-style: none;
		padding-left: 0;
	}

	.product-downloads-list a {
		color: #fe5900;
		text-decoration: none;
	}

	@media (max-width: 1024px) {
		.product-layout {
			grid-template-columns: 1fr;
			gap: 40px;
		}
		.product-detail {
			position: static;
		}
	}

	@media (max-width: 768px) {
		.product-title {
			font-size: 22px;
		}
		.product-price {
			font-size: 28px;
		}
		.product-background-text {
			font-size: 120px;
		}
		.product-actions {
			flex-direction: column;
			align-items: stretch;
		}
		.product-qty-input {
			width: 100%;
		}
	}

	/* Product detail */
	.product-detail-section {
		padding: 60px 0 80px;
		background: #fff;
	}

	.product-detail-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 50px;
		align-items: start;
	}

	.product-gallery {
		position: sticky;
		top: 120px;
	}

	.product-main-image {
		width: 100%;
		aspect-ratio: 3 / 2;
		overflow: hidden;
		background: #f7f7f7;
		margin-bottom: 16px;
	}

	.product-main-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.product-image-note {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: #8c8c8c;
		margin: 0;
		line-height: 1.5;
	}

	.product-info {
		max-width: 520px;
	}

	.product-category {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin: 0 0 12px 0;
	}

	.product-name {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		margin: 0 0 8px 0;
		line-height: 1.2;
	}

	.product-lead {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #666;
		margin: 0 0 24px 0;
	}

	.product-price-block {
		margin-bottom: 20px;
	}

	.product-price-label {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		display: block;
		margin-bottom: 4px;
	}

	.product-price {
		font-family: 'Oswald', sans-serif;
		font-size: 32px;
		font-weight: 600;
		color: #0d0d0d;
	}

	.product-short-desc {
		font-family: 'Yantramanav', sans-serif;
		font-size: 15px;
		color: #333;
		line-height: 1.7;
		margin: 0 0 28px 0;
	}

	.product-options {
		margin-bottom: 28px;
	}

	.product-option {
		margin-bottom: 20px;
	}

	.product-option label {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 8px;
	}

	.product-option-label {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 10px;
	}

	/* Width & color variant rows – same style as lockers */
	.product-variant-row {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.product-variant-option {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding: 10px 16px;
		border: 2px solid #e0e0e0;
		background: #fff;
		cursor: pointer;
		transition: border-color 0.2s, background 0.2s;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
