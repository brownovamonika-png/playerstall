<script>
	document.addEventListener('DOMContentLoaded', function() {
		// Gallery thumbs: click to change main image
		document.querySelectorAll('.product-gallery-thumbs .thumb').forEach(function(thumb) {
			thumb.addEventListener('click', function() {
				document.querySelectorAll('.product-gallery-thumbs .thumb').forEach(function(t) { t.classList.remove('active'); });
				thumb.classList.add('active');
				var img = thumb.querySelector('img');
				if (img && img.src) {
					var main = document.querySelector('.product-main-image');
					if (main && main.tagName === 'IMG') main.src = img.src;
				}
			});
		});

		// Width swatches
		document.querySelectorAll('.width-swatch').forEach(function(btn) {
			btn.addEventListener('click', function() {
				document.querySelectorAll('.width-swatch').forEach(function(b) {
					b.classList.remove('active');
					b.setAttribute('aria-pressed', 'false');
				});
				btn.classList.add('active');
				btn.setAttribute('aria-pressed', 'true');
				var option = btn.closest('.product-option');
				var valueEl = option ? option.querySelector('.option-value') : null;
				if (valueEl) valueEl.textContent = (btn.textContent || '').trim();
				var modelEl = document.querySelector('.product-model[data-model-prefix]');
				if (modelEl) {
					var colorBtn = document.querySelector('.swatch[data-color].active');
					var color = (colorBtn && colorBtn.getAttribute('data-color')) ? colorBtn.getAttribute('data-color').charAt(0).toUpperCase() : 'L';
					modelEl.textContent = 'Model # BENCH-' + (btn.getAttribute('data-width') || '36') + '-' + color;
				}
			});
		});

		// Color swatches (Light/Dark)
		document.querySelectorAll('.swatch[data-color]').forEach(function(btn) {
			btn.addEventListener('click', function() {
				var option = btn.closest('.product-option');
				if (!option) return;
				option.querySelectorAll('.swatch[data-color]').forEach(function(b) {
					b.classList.remove('active');
					b.setAttribute('aria-pressed', 'false');
				});
				btn.classList.add('active');
				btn.setAttribute('aria-pressed', 'true');
				var valueEl = option.querySelector('.option-value');
				if (valueEl) valueEl.textContent = btn.getAttribute('title') || btn.textContent || '';
				var modelEl = document.querySelector('.product-model[data-model-prefix]');
				if (modelEl) {
					var widthBtn = document.querySelector('.width-swatch.active');
					var width = (widthBtn && widthBtn.getAttribute('data-width')) ? widthBtn.getAttribute('data-width') : '36';
					var color = (btn.getAttribute('data-color') || 'light').charAt(0).toUpperCase();
					modelEl.textContent = 'Model # BENCH-' + width + '-' + color;
				}
			});
		});

		// Depth swatches
		document.querySelectorAll('.depth-swatch').forEach(function(btn) {
			btn.addEventListener('click', function() {
				document.querySelectorAll('.depth-swatch').forEach(function(b) {
					b.classList.remove('active');
					b.setAttribute('aria-pressed', 'false');
				});
				btn.classList.add('active');
				btn.setAttribute('aria-pressed', 'true');
				var option = btn.closest('.product-option');
				var valueEl = option ? option.querySelector('.option-value') : null;
				if (valueEl) valueEl.textContent = (btn.textContent || '').trim();
			});
		});

		// Add to cart
		var addCartBtn = document.getElementById('bench-add-cart');
		if (!addCartBtn) return;

		function getCart() {
			var cart = localStorage.getItem('playerstall_cart');
			return cart ? JSON.parse(cart) : [];
		}
		function saveCart(cart) {
			localStorage.setItem('playerstall_cart', JSON.stringify(cart));
			window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { count: cart.reduce(function(s, i) { return s + i.quantity; }, 0) } }));
		}

		addCartBtn.addEventListener('click', function() {
			var widthBtn = document.querySelector('.width-swatch.active');
			var width = (widthBtn && widthBtn.getAttribute('data-width')) ? widthBtn.getAttribute('data-width') : '36';
			var colorBtn = document.querySelector('.swatch[data-color].active');
			var color = (colorBtn && colorBtn.getAttribute('data-color')) ? colorBtn.getAttribute('data-color') : 'light';
			var depthBtn = document.querySelector('.depth-swatch.active');
			var depth = (depthBtn && depthBtn.getAttribute('data-depth')) ? depthBtn.getAttribute('data-depth') : '9.5';
			var qtyEl = document.getElementById('product-qty');
			var qty = parseInt((qtyEl && qtyEl.value) ? qtyEl.value : '1', 10) || 1;

			var id = 'wood-bench-' + width + '-' + depth + '-' + color;
			var name = 'Bench ' + width + '" × ' + depth + '" (' + color + ')';
			var price = 225;
			var image = 'https://playerstall.b-cdn.net/images/wood-lockers-starting-lineup.jpg';

			var cart = getCart();
			var existing = cart.find(function(item) { return item.id === id; });
			if (existing) existing.quantity += qty;
			else cart.push({ id: id, name: name, price: price, image: image, quantity: qty });
			saveCart(cart);

			var originalText = addCartBtn.textContent;
			addCartBtn.textContent = 'Added to cart';
			setTimeout(function() { addCartBtn.textContent = originalText; }, 1500);
		});
	});
</script>
