---
import BaseLayout from '../layouts/BaseLayout.astro';
import LockerAccessories from '../components/LockerAccessories.astro';
import AccessoryModal from '../components/AccessoryModal.astro';
import ProductSpecSheet from '../components/ProductSpecSheet.astro';
import { SHOP_ACCESSORIES_MODAL } from '../data/shop-accessories';
import {
	ADORNUS_DESIGNER_PAINT_FINISHES,
	DEFAULT_ADORNUS_PAINT_CODE,
	DEFAULT_ADORNUS_PAINT_LABEL,
} from '../data/adornus-designer-paint-colors';
import { TEXTURED_WOODGRAIN_OPTIONS, texturedWoodgrainSwatchUrl } from '../data/textured-woodgrain-colors';

const benchSlides = [
	{
		src: 'https://playerstall.b-cdn.net/images/bench%20top%20above.png',
		alt: 'Wood locker bench – front elevation view, light oak top with black powder-coated pedestal legs',
	},
	{
		src: 'https://playerstall.b-cdn.net/images/bench%20side.png',
		alt: 'Wood locker bench – end/side profile view showing seat thickness and pedestal frame',
	},
	{
		src: 'https://playerstall.b-cdn.net/images/bench%20top.png',
		alt: 'Wood locker bench – three-quarter top view showing wood grain seating surface',
	},
];

const benchSpecs = [
	{ label: 'Size (72" L example)', value: '72" L × 18" D × 18" H' },
	{ label: 'Length', value: '72" – 96" (depending on number of users)' },
	{ label: 'Depth', value: '18"' },
	{ label: 'Height', value: '18"' },
	{ label: 'Weight', value: 'Approx. 40 lbs (72" length); varies by size' },
	{ label: 'Construction', value: 'Solid butcher block wood, 1¼" thick seating' },
	{ label: 'Base', value: 'Black powder-coated pedestals' },
	{ label: 'Finish', value: 'Any locker color — full Sherwin-Williams paint palette or textured woodgrain' },
	{ label: 'Assembly', value: 'Delivered unassembled — minor assembly required' },
];
---

<BaseLayout
	title='Bench - Free Standing 72" to 96" Long | PlayerStall'
	description='Custom wood locker bench, free standing. 18" H × 18" D, 72" to 96" long depending on number of users. Available in any locker color – Sherwin-Williams paint palette or textured woodgrain. Solid wood, black pedestals. Request a quote.'
>
	<!-- Hero Section (same as lockers) -->
	<section class="product-hero-section">
		<div class="product-hero-background">
			<img src="https://playerstall.b-cdn.net/images/h1-img-8.jpg" alt="Wood Locker Bench" class="product-hero-bg-image" />
		</div>
		<div class="product-hero-background-overlay"></div>
		<div class="product-hero-container">
			<div class="product-breadcrumbs">
				<a href="/">Home</a>
				<span class="breadcrumbs-sep">/</span>
				<a href="/shop">Shop</a>
				<span class="breadcrumbs-sep">/</span>
				<span class="breadcrumbs-current">Bench</span>
			</div>
			<h1 class="product-page-title">Bench</h1>
		</div>
	</section>

	<!-- Product Main (same layout as Stadium) -->
	<section class="product-main-section">
		<div class="product-container">
			<div class="product-layout">
				<!-- Left: Gallery (3-way slider, same pattern as cushion modal) -->
				<div class="product-gallery">
					<div class="product-gallery-main">
						<div class="bench-slider" id="bench-slider" role="region" aria-label="Bench image slider">
							<div class="bench-slides" id="bench-slides">
								{benchSlides.map((slide) => (
									<div class="bench-slide">
										<img src={slide.src} alt={slide.alt} />
									</div>
								))}
							</div>
							<button type="button" class="bench-slider-arrow bench-slider-arrow-prev" id="bench-slider-prev" aria-label="Previous image">&#10094;</button>
							<button type="button" class="bench-slider-arrow bench-slider-arrow-next" id="bench-slider-next" aria-label="Next image">&#10095;</button>
							<div class="bench-slider-dots" id="bench-slider-dots">
								{benchSlides.map((_, i) => (
									<button
										type="button"
										class={`bench-slider-dot${i === 0 ? ' active' : ''}`}
										data-slide={i}
										aria-label={`View image ${i + 1}`}
										aria-current={i === 0 ? 'true' : 'false'}
									></button>
								))}
							</div>
						</div>
					</div>
					<div class="product-gallery-thumbs">
						{benchSlides.map((slide, i) => (
							<button type="button" class={`thumb${i === 0 ? ' active' : ''}`} data-slide={i} aria-label={`View image ${i + 1}`}>
								<img src={slide.src} alt={slide.alt} />
							</button>
						))}
					</div>
				</div>

				<!-- Right: Details -->
				<div class="product-detail">
					<h1 class="product-title">Bench – Free Standing 72&quot; to 96&quot; Long</h1>
					<p class="product-model" data-model-prefix="BENCH">Model # BENCH-72-HRW</p>
					<p class="product-lead-time">Lead time: usually ships within 1–2 weeks</p>
					<div class="product-price-block">
						<span class="product-price" data-base-price="269">$269.00</span>
					</div>

					<div class="product-options">
						<div class="product-option">
							<label class="option-label">Length:</label>
							<span class="option-value">72&quot;</span>
							<div class="option-swatches">
								<button type="button" class="swatch width-swatch active" data-width="72" data-price="269" title="72 inch" aria-pressed="true">72&quot;</button>
								<button type="button" class="swatch width-swatch" data-width="84" data-price="299" title="84 inch">84&quot;</button>
								<button type="button" class="swatch width-swatch" data-width="96" data-price="349" title="96 inch">96&quot;</button>
							</div>
							<p class="option-note">Length depends on number of users (72&quot;–96&quot;).</p>
						</div>
						<div class="product-option">
							<label class="option-label" for="bench-color-select">Color:</label>
							<div class="color-select-wrapper">
								<span class="color-preview" id="bench-color-preview" style="background-color: #f4f4f0;"></span>
								<select id="bench-color-select" class="color-dropdown">
									<optgroup label="Solid colors (Sherwin-Williams)">
										{ADORNUS_DESIGNER_PAINT_FINISHES.map((o) => (
											<option value={o.code} data-color={o.approxHex} selected={o.code === DEFAULT_ADORNUS_PAINT_CODE}>
												{o.label}
											</option>
										))}
									</optgroup>
									<optgroup label="Textured woodgrain">
										{TEXTURED_WOODGRAIN_OPTIONS.map((o) => (
											<option
												value={o.code}
												data-color={o.fallbackHex}
												data-swatch-image={texturedWoodgrainSwatchUrl(o.fileSlug)}
											>
												{o.label}
											</option>
										))}
									</optgroup>
								</select>
							</div>
							<p class="option-note"><a href="/colors/all-color-options-pdf.html" target="_blank" rel="noopener noreferrer" class="color-pdf-link">View Color Option PDF</a></p>
						</div>
						<p class="option-note">Pair with lockers for a complete installation. <a href="/shop">View lockers</a>.</p>
						<div class="product-specs-inline">
							<p><strong>Size (72&quot; L example):</strong> 72&quot; L × 18&quot; D × 18&quot; H</p>
							<p><strong>Weight:</strong> approx. 40 lbs (72&quot; length)</p>
						</div>
					</div>

					<div class="product-actions">
						<label class="quantity-label" for="product-qty">Quantity:</label>
						<input type="number" id="product-qty" class="product-qty-input" value="1" min="1" max="999" />
						<button type="button" class="btn btn-primary product-add-cart" id="bench-add-cart">Add to Cart</button>
					</div>
				</div>
			</div>

			<!-- More Information (same structure as Stadium) -->
			<div class="product-info-section" id="moreinfo">
				<h2 class="product-info-heading">Bench – Features &amp; Options</h2>

				<div class="product-info-grid">
					<div class="product-info-col product-info-col-specs">
						<ProductSpecSheet productName="Bench" specs={benchSpecs} />
						<h3 class="product-info-subheading">Downloads</h3>
						<ul class="product-downloads-list">
							<li><a href="/pdf/installation-instructions/" target="_blank" rel="noopener noreferrer">Shipping and Assembly Instruction PDF</a></li>
							<li><a href="/colors/all-color-options-pdf.html" target="_blank">Color Option PDF</a></li>
							<li><a href="/colors/laminate-colors-pdf.html" target="_blank">Laminate Colors PDF</a></li>
							<li><a href="/colors/woodgrain-colors-pdf.html" target="_blank">Woodgrain Colors PDF</a></li>
							<li><a href="/colors/phenolic-colors-pdf.html" target="_blank">Phenolic Colors PDF</a></li>
							<li><a href="/colors/cushion-colors-pdf.html" target="_blank">Cushion Colors PDF</a></li>
							<li><a href="#specs">View spec sheet</a></li>
						</ul>
					</div>
					<div class="product-info-col product-info-col-features">
						<h3 class="product-info-subheading">Features</h3>
						<ul class="product-features-list">
							<li>Constructed of solid butcher block wood</li>
							<li>Ideal for industrial, office, or recreational locker room facilities</li>
							<li>Classic look with strength and durability</li>
							<li>Available in any locker color — full Sherwin-Williams paint palette or textured woodgrain finish to match your lockers</li>
							<li>Lengths from 72&quot; to 96&quot;, chosen based on the number of users</li>
							<li>18&quot; high × 18&quot; deep</li>
							<li>Wood seating area 1¼&quot; thick</li>
							<li>Free-standing benches include black powder-coated pedestals</li>
							<li>Delivered unassembled – minor assembly required</li>
						</ul>
						<h3 class="product-info-subheading">Options</h3>
						<ul class="product-options-list">
							<li>Length: 72&quot;, 84&quot;, or 96&quot; (depending on number of users)</li>
							<li>Depth: 18&quot;</li>
							<li>Height: 18&quot;</li>
							<li>Color: any locker color — Sherwin-Williams paint palette or textured woodgrain</li>
							<li>Pair with our wood lockers for a complete locker room</li>
						</ul>
					</div>
				</div>
			</div>

			<LockerAccessories title="LOCKER ACCESSORIES" items={SHOP_ACCESSORIES_MODAL} useModal={true} />
		</div>
	</section>
	<AccessoryModal />
</BaseLayout>


<style is:global>
	body {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	.product-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.product-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}

	.product-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.product-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.product-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.product-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.product-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 20px;
	}

	.product-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.product-breadcrumbs a:hover {
		color: #fe5900;
	}

	.breadcrumbs-sep {
		margin: 0 8px;
		color: rgba(255, 255, 255, 0.6);
	}

	.breadcrumbs-current {
		color: #ffffff;
	}

	.product-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 52px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	.product-background-text {
		position: absolute;
		font-family: 'Oswald', sans-serif;
		font-size: 200px;
		font-weight: 700;
		color: rgba(13, 13, 13, 0.04);
		text-transform: uppercase;
		letter-spacing: -2px;
		bottom: -30px;
		left: 50%;
		transform: translateX(-50%);
		white-space: nowrap;
		z-index: 1;
	}

	.product-main-section {
		padding: 60px 0 100px;
		background: #ffffff;
	}

	.product-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: start;
		margin-bottom: 80px;
	}

	.product-gallery-main {
		position: relative;
		background: #f7f7f7;
		aspect-ratio: 1;
		overflow: hidden;
		margin-bottom: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.product-main-image {
		width: 96%;
		height: 96%;
		object-fit: contain;
		display: block;
	}

	/* Bench slider (3-way sliding gallery, same pattern as cushion modal) */
	.bench-slider {
		position: relative;
		width: 100%;
		height: 100%;
		overflow: hidden;
		background: #fff;
	}

	.bench-slides {
		display: flex;
		width: 100%;
		height: 100%;
		transition: transform 0.35s ease-in-out;
	}

	.bench-slide {
		flex: 0 0 100%;
		min-width: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #fff;
		padding: 4%;
	}

	.bench-slide img {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		display: block;
	}

	/* Front (top-above) view — rendered 20% smaller so it doesn't overfill the slide. */
	.bench-slide:nth-child(1) img {
		transform: scale(0.8);
	}

	.bench-slide:nth-child(3) img {
		transform: translateX(-20%);
	}

	.bench-slider-arrow {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		width: 40px;
		height: 40px;
		border: none;
		background: rgba(255, 255, 255, 0.85);
		color: #0d0d0d;
		font-size: 18px;
		line-height: 1;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.2s, color 0.2s;
		z-index: 2;
	}

	.bench-slider-arrow:hover {
		background: #fe5900;
		color: #fff;
	}

	.bench-slider-arrow-prev {
		left: 10px;
	}

	.bench-slider-arrow-next {
		right: 10px;
	}

	.bench-slider-dots {
		position: absolute;
		bottom: 12px;
		left: 0;
		right: 0;
		display: flex;
		justify-content: center;
		gap: 8px;
		pointer-events: none;
		z-index: 2;
	}

	.bench-slider-dot {
		pointer-events: auto;
		width: 10px;
		height: 10px;
		padding: 0;
		border: none;
		border-radius: 50%;
		background: rgba(0, 0, 0, 0.25);
		cursor: pointer;
		transition: background 0.2s, transform 0.2s;
	}

	.bench-slider-dot:hover {
		background: rgba(0, 0, 0, 0.45);
	}

	.bench-slider-dot.active {
		background: #fe5900;
		transform: scale(1.15);
	}

	.product-gallery-thumbs {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.thumb {
		width: 80px;
		height: 80px;
		padding: 0;
		border: 2px solid transparent;
		background: #f0f0f0;
		cursor: pointer;
		overflow: hidden;
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	.thumb:hover,
	.thumb.active {
		border-color: #fe5900;
		box-shadow: 0 0 0 1px #fe5900;
	}

	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.product-detail {
		position: sticky;
		top: 120px;
	}

	.product-title {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		line-height: 1.25;
		margin: 0 0 12px;
		text-transform: none;
	}

	.product-model {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 8px;
	}

	.product-lead-time {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin: 0 0 24px;
		text-transform: lowercase;
	}

	.product-price-block {
		margin-bottom: 28px;
		padding-bottom: 24px;
		border-bottom: 1px solid #e0e0e0;
	}

	.product-price {
		font-family: 'Oswald', sans-serif;
		font-size: 36px;
		font-weight: 600;
		color: #0d0d0d;
	}

	.option-label {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 8px;
	}

	.option-value {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 8px;
		display: block;
	}

	.option-swatches {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.swatch {
		padding: 8px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: #f0f0f0;
		border: 2px solid transparent;
		color: #0d0d0d;
		cursor: pointer;
		transition: border-color 0.2s, background 0.2s;
	}

	.swatch:hover {
		background: #e8e8e8;
	}

	.swatch.active {
		border-color: #fe5900;
		background: #fff;
		color: #0d0d0d;
	}

	.option-note {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		margin: 6px 0 0;
		font-style: italic;
	}

	.color-select-wrapper {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.color-preview {
		width: 30px;
		height: 30px;
		border: 2px solid #ddd;
		border-radius: 2px;
		flex-shrink: 0;
		box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.1);
		background-size: cover;
		background-position: center;
	}

	.color-dropdown {
		width: auto;
		max-width: 100%;
		padding: 8px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #0d0d0d;
		background: #f0f0f0;
		border: 2px solid transparent;
		cursor: pointer;
		transition: border-color 0.2s, background 0.2s;
	}

	.color-dropdown:hover {
		background: #e8e8e8;
		border-color: #ccc;
	}

	.color-dropdown:focus {
		outline: none;
		border-color: #fe5900;
		box-shadow: 0 0 0 1px #fe5900;
	}

	.color-pdf-link {
		color: #fe5900;
		text-decoration: none;
		font-weight: 500;
		font-style: normal;
		text-transform: none;
		transition: color 0.2s;
	}

	.color-pdf-link:hover {
		color: #e04d00;
		text-decoration: underline;
	}

	.product-specs-inline {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin-top: 16px;
	}

	.product-specs-inline p {
		margin: 0 0 6px;
	}

	.product-volume-discounts {
		margin-bottom: 28px;
	}

	.volume-title {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0 0 12px;
	}

	.volume-table {
		width: 100%;
		border-collapse: collapse;
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
	}

	.volume-table thead {
		background: #0d0d0d;
		color: #fff;
	}

	.volume-table th {
		padding: 12px 14px;
		text-align: left;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.volume-table th:first-child {
		background: #fe5900;
	}

	.volume-table td {
		padding: 12px 14px;
		border-bottom: 1px solid #e0e0e0;
		color: #0d0d0d;
	}

	.volume-contact-link {
		color: #fe5900;
		text-decoration: none;
		font-weight: 500;
	}

	.product-actions {
		display: flex;
		align-items: center;
		gap: 16px;
		flex-wrap: wrap;
	}

	.quantity-label {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #0d0d0d;
	}

	.product-qty-input {
		width: 80px;
		padding: 12px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 16px;
		border: 1px solid #ccc;
		background: #fff;
		color: #0d0d0d;
	}

	.btn {
