---
import BaseLayout from '../layouts/BaseLayout.astro';
import LockerAccessories from '../components/LockerAccessories.astro';

const lockerAccessoriesItems = [
	{ href: '/accessories#stick-rack', image: '/stick-rack.png', alt: 'Stick Rack', category: 'LOCKER ADD-ONS', title: 'Stick Rack', price: 'Starting at $299' },
	{ href: '/accessories#lock-box', image: '/images/lock-box.png', alt: 'Lock Box with Digital Key Lock', category: 'LOCKER ADD-ONS', title: 'Lock Box', price: '+ $80.00' },
	{ href: '/shop#accessories', image: '/images/cushion-logo.png', alt: 'Locker cushions', category: 'LOCKER ADD-ONS', title: 'Cushions', price: '+ $75.00' },
	{ href: '/shop#accessories', image: '/images/name-plate.png', alt: 'Name plate', category: 'LOCKER ADD-ONS', title: 'Name Plate', price: '+ $10.00' },
];
---

<BaseLayout
	title="Varsity Wood Locker - 24-Inch Wide, 76 Inches High, 19 Inches Deep | PlayerStall"
	description="Varsity wood locker: 3/4&quot; solid wood premium finish, 76&quot; H x 19&quot; D, widths 18&quot;–30&quot;. $449 base. Full color options. Quick ship in one month (24&quot; or 30&quot;) or custom-built in three months. 50% deposit to begin. 5 year warranty."
>
	<!-- Hero Section -->
	<section class="product-hero-section">
		<div class="product-hero-background">
			<img src="https://topscorer.qodeinteractive.com/wp-content/uploads/2020/02/h1-img-8.jpg" alt="Varsity Locker" class="product-hero-bg-image" />
		</div>
		<div class="product-hero-background-overlay"></div>
		<div class="product-hero-container">
			<div class="product-breadcrumbs">
				<a href="/">Home</a>
				<span class="breadcrumbs-sep">/</span>
				<a href="/shop">Shop</a>
				<span class="breadcrumbs-sep">/</span>
				<span class="breadcrumbs-current">Varsity Locker</span>
			</div>
			<h1 class="product-page-title">Varsity</h1>
		</div>
	</section>

	<!-- Product Main -->
	<section class="product-main-section">
		<div class="product-container">
			<div class="product-layout">
				<!-- Left: Gallery -->
				<div class="product-gallery">
					<div class="product-gallery-main">
						<img
							src="/images/Athletic-Locker-Varsity.jpg"
							alt="Varsity wood athletic locker for locker rooms"
							class="product-main-image"
						/>
						<span class="product-enlarge-hint">Enlarge Image</span>
					</div>
					<div class="product-gallery-thumbs">
						<button type="button" class="thumb active" aria-label="View image 1">
							<img src="/images/Athletic-Locker-Varsity.jpg" alt="Varsity locker view 1" />
						</button>
						<button type="button" class="thumb" aria-label="View image 2">
							<img src="/images/wood-locer-room-front-2.png" alt="Locker view 2" />
						</button>
						<button type="button" class="thumb" aria-label="View image 3">
							<img src="/images/phenolic-locker-no-background.jpg" alt="Locker view 3" />
						</button>
					</div>
				</div>

				<!-- Right: Details -->
				<div class="product-detail">
					<h1 class="product-title">Varsity Locker – 24&quot; Wide, 76 Inches High, 19 Inches Deep</h1>

					<p class="product-model" data-model-prefix="VAR">Model # VAR-24-MP</p>

					<p class="product-lead-time">Lead time: quick ship in one month (24" or 30" widths, one signature color) · Custom-built in three months</p>

					<div class="product-price-block">
						<span class="product-price" data-base-price="449">$449.00</span>
					</div>

					<div class="product-options">
						<div class="product-option">
							<label class="option-label">Width:</label>
							<span class="option-value">24&quot; (standard)</span>
							<div class="option-swatches">
								<button type="button" class="swatch width-swatch" data-base-price="449" title="18 inch width">18&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="449" title="20 inch width">20&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="449" title="22 inch width">22&quot;</button>
								<button type="button" class="swatch width-swatch active" data-base-price="449" title="24 inch width" aria-pressed="true">24&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="449" title="26 inch width">26&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="449" title="28 inch width">28&quot;</button>
								<button type="button" class="swatch width-swatch" data-base-price="449" title="30 inch width">30&quot;</button>
							</div>
						</div>
						<div class="product-option">
							<label class="option-label">Color:</label>
							<span class="option-value">Designer White</span>
							<span class="swatch-group-label">Solid Colors</span>
							<div class="option-swatches">
								<button type="button" class="swatch active" data-color-code="DW" title="Designer White" aria-pressed="true">Designer White</button>
								<button type="button" class="swatch" data-color-code="WS" title="White Sand">White Sand</button>
								<button type="button" class="swatch" data-color-code="FG" title="Fashion Grey">Fashion Grey</button>
								<button type="button" class="swatch" data-color-code="NS" title="North Sea">North Sea</button>
								<button type="button" class="swatch" data-color-code="GR" title="Graphite">Graphite</button>
								<button type="button" class="swatch" data-color-code="BL" title="Black">Black</button>
								<button type="button" class="swatch" data-color-code="HB" title="Hollyberry">Hollyberry</button>
								<button type="button" class="swatch" data-color-code="LB" title="Lapis Blue">Lapis Blue</button>
							</div>
							<span class="swatch-group-label">Woodgrains</span>
							<div class="option-swatches">
								<button type="button" class="swatch" data-color-code="FM" title="Fusion Maple">Fusion Maple</button>
								<button type="button" class="swatch" data-color-code="PO" title="Pasadena Oak">Pasadena Oak</button>
								<button type="button" class="swatch" data-color-code="WH" title="Walnut Heights">Walnut Heights</button>
								<button type="button" class="swatch" data-color-code="HW" title="Hampton Walnut">Hampton Walnut</button>
							</div>
							<p class="option-note">Custom colors are available upon request (custom orders, three months, 50% deposit).</p>
						</div>
						<div class="product-option">
							<label class="option-label">Accessories:</label>
							<span class="option-value">Select add-ons to update price</span>
							<div class="accessories-grid">
								<button type="button" class="accessory-box" data-price="40" title="Vented front">
									<span class="accessory-square"></span>
									<span class="accessory-label">Vented front (+$40)</span>
								</button>
								<button type="button" class="accessory-box" data-price="80" title="Lock box">
									<span class="accessory-square"></span>
									<span class="accessory-label">Lock box (+$80)</span>
								</button>
								<button type="button" class="accessory-box" data-price="75" title="Bottom cushion">
									<span class="accessory-square"></span>
									<span class="accessory-label">Bottom cushion (+$75)</span>
								</button>
								<button type="button" class="accessory-box" data-price="150" title="Top &amp; bottom cushions">
									<span class="accessory-square"></span>
									<span class="accessory-label">Top &amp; bottom cushions (+$150)</span>
								</button>
								<button type="button" class="accessory-box" data-price="10" title="Name plate">
									<span class="accessory-square"></span>
									<span class="accessory-label">Name plate (+$10)</span>
								</button>
								<button type="button" class="accessory-box" data-price="25" title="Skate hooks">
									<span class="accessory-square"></span>
									<span class="accessory-label">Skate hooks (+$25)</span>
								</button>
							<button type="button" class="accessory-box" data-price="75" title="Custom logo — custom orders only">
								<span class="accessory-square"></span>
								<span class="accessory-label">Custom logo (+$75) · custom orders only</span>
							</button>
								<button type="button" class="accessory-box" data-price="12" title="4 hooks">
									<span class="accessory-square"></span>
									<span class="accessory-label">4 hooks (+$12)</span>
								</button>
							</div>
						</div>
						<div class="product-specs-inline">
							<p><strong>Standard size shown:</strong> 24&quot; W x 76&quot; H x 19&quot; D</p>
							<p><strong>Base:</strong> optional 4&quot; high base can be added</p>
							<p><strong>Weight:</strong> approx. 175 lbs</p>
						</div>
					</div>

					<div class="product-volume-discounts">
						<h3 class="volume-title">Volume Discounts</h3>
						<table class="volume-table">
							<thead>
								<tr>
									<th>Quantity</th>
									<th>Price</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td>50 + lockers</td>
									<td>3–5% discount – <a href="/contact" class="volume-contact-link">Contact us</a> for pricing</td>
								</tr>
							</tbody>
						</table>
					</div>

					<div class="product-actions">
						<label class="quantity-label" for="product-qty">Quantity:</label>
						<input type="number" id="product-qty" class="product-qty-input" value="1" min="1" max="999" />
						<button type="button" class="btn btn-primary product-add-cart">Add to Cart</button>
					</div>
				</div>
			</div>

			<!-- More Information -->
			<div class="product-info-section" id="moreinfo">
				<h2 class="product-info-heading">Varsity Wood Locker – Features &amp; Options</h2>

				<h3 class="product-info-subheading">Features</h3>
				<ul class="product-features-list">
					<li>3/4&quot; solid wood with premium melamine-style finish</li>
					<li>Enhanced durability and moisture resistance; engineered for high-traffic athletic locker rooms</li>
					<li>Modular design for easy repair or replacement of components</li>
					<li>14&quot; high foot locker provides comfortable seating and secure equipment storage</li>
					<li>Available in 18&quot; to 30&quot; widths; standard configuration 24&quot; W x 76&quot; H x 19&quot; D with optional 4&quot; base</li>
					<li>Finishes: Designer White, White Sand, Fashion Grey, North Sea, Graphite, Black, Hollyberry, Lapis Blue, Fusion Maple, Pasadena Oak, Walnut Heights, Hampton Walnut; custom colors available upon request (custom orders, three months, 50% deposit)</li>
					<li>5 year warranty</li>
				</ul>

				<h3 class="product-info-subheading">Options</h3>
				<ul class="product-options-list">
					<li>Choice of 12 Wilsonart&reg; laminate finishes: 8 solid colors + 4 woodgrains</li>
					<li>Vented front panel for increased airflow</li>
					<li>Secure lock box integrated into the upper compartment</li>
					<li>Bottom cushion or both cushions for added seating comfort</li>
					<li>Skate hooks for hockey or figure skating storage</li>
					<li>Custom logo option for teams or programs (custom orders only)</li>
					<li>Name plate and additional gear hooks</li>
				</ul>

				<h3 class="product-info-subheading">Downloads</h3>
				<ul class="product-downloads-list">
					<li><a href="/colors/all-color-options-pdf.html" target="_blank">All Color Options PDF</a></li>
					<li><a href="/colors/laminate-colors-pdf.html" target="_blank">Laminate Colors PDF</a></li>
					<li><a href="/colors/woodgrain-colors-pdf.html" target="_blank">Woodgrain Colors PDF</a></li>
					<li><a href="/colors/phenolic-colors-pdf.html" target="_blank">Phenolic Colors PDF</a></li>
					<li><a href="/contact">Request spec sheet &amp; quote</a></li>
					<li><a href="/contact">Installation support</a></li>
					<li><a href="/shop">View all lockers</a></li>
				</ul>
			</div>

			<LockerAccessories title="LOCKER ACCESSORIES" items={lockerAccessoriesItems} />
		</div>
	</section>
</BaseLayout>

<style is:global>
	body {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #ffffff;
		color: #0d0d0d;
	}

	.product-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.product-hero-section {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 0 80px;
		overflow: hidden;
		min-height: 320px;
	}

	.product-hero-background {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		overflow: hidden;
	}

	.product-hero-bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		filter: grayscale(100%);
	}

	.product-hero-background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.2);
		z-index: 1;
	}

	.product-hero-container {
		position: relative;
		z-index: 10;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		text-align: left;
		width: 100%;
	}

	.product-breadcrumbs {
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 20px;
	}

	.product-breadcrumbs a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.3s;
	}

	.product-breadcrumbs a:hover {
		color: #fe5900;
	}

	.breadcrumbs-sep {
		margin: 0 8px;
		color: rgba(255, 255, 255, 0.6);
	}

	.breadcrumbs-current {
		color: #ffffff;
	}

	.product-page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 72px;
		font-weight: 600;
		color: #ffffff;
		text-transform: uppercase;
		margin: 0 0 0 0;
		line-height: 1.1;
		position: relative;
		z-index: 10;
	}

	.product-background-text {
		position: absolute;
		font-family: 'Oswald', sans-serif;
		font-size: 200px;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.06);
		text-transform: uppercase;
		letter-spacing: -2px;
		bottom: -30px;
		left: 50%;
		transform: translateX(-50%);
		white-space: nowrap;
		z-index: 1;
	}

	.product-main-section {
		padding: 60px 0 100px;
		background: #ffffff;
	}

	.product-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: start;
		margin-bottom: 80px;
	}

	.product-gallery-main {
		position: relative;
		background: #f7f7f7;
		aspect-ratio: 1;
		overflow: hidden;
		margin-bottom: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.product-main-image {
		width: 96%;
		height: 96%;
		object-fit: contain;
		display: block;
	}

	.product-enlarge-hint {
		position: absolute;
		bottom: 12px;
		right: 12px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.product-gallery-thumbs {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.thumb {
		width: 80px;
		height: 80px;
		padding: 0;
		border: 2px solid transparent;
		background: #f0f0f0;
		cursor: pointer;
		overflow: hidden;
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	.thumb:hover,
	.thumb.active {
		border-color: #fe5900;
		box-shadow: 0 0 0 1px #fe5900;
	}

	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.product-detail {
		position: sticky;
		top: 120px;
	}

	.product-title {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 600;
		color: #0d0d0d;
		line-height: 1.25;
		margin: 0 0 12px;
		text-transform: none;
	}

	.product-model {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin: 0 0 8px;
	}

	.product-lead-time {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin: 0 0 24px;
		text-transform: lowercase;
	}

	.product-price-block {
		margin-bottom: 28px;
		padding-bottom: 24px;
		border-bottom: 1px solid #e0e0e0;
	}

	.product-price {
		font-family: 'Oswald', sans-serif;
		font-size: 36px;
		font-weight: 600;
		color: #0d0d0d;
	}

	.product-options {
		margin-bottom: 28px;
	}

	.product-option {
		margin-bottom: 20px;
	}

	.option-label {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 8px;
	}

	.option-value {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		margin-bottom: 8px;
		display: block;
	}

	.option-note {
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		color: #8c8c8c;
		margin: 6px 0 0;
		font-style: italic;
	}

	.accessories-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 8px;
	}

	.accessory-box {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: #f0f0f0;
		border: 2px solid transparent;
		color: #0d0d0d;
		cursor: pointer;
		transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
	}

	.accessory-box:hover {
		border-color: #fe5900;
		background: #ffffff;
		box-shadow: 0 0 0 1px rgba(254, 89, 0, 0.2);
	}

	.accessory-box.selected {
		border-color: #fe5900;
		background: #ffffff;
		box-shadow: 0 0 0 1px rgba(254, 89, 0, 0.2);
	}

	.accessory-square {
		width: 14px;
		height: 14px;
		border-radius: 2px;
		border: 2px solid #b6b6b6;
		background: #ffffff;
		box-sizing: border-box;
	}

	.accessory-box.selected .accessory-square {
		border-color: #fe5900;
		background: #fe5900;
	}

	.swatch-group-label {
		display: block;
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin: 16px 0 8px;
	}

	.swatch-group-label:first-of-type {
		margin-top: 4px;
	}

	.option-swatches {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.swatch {
		padding: 8px 14px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: #f0f0f0;
		border: 2px solid transparent;
		color: #0d0d0d;
		cursor: pointer;
		transition: border-color 0.2s, background 0.2s;
	}

	.swatch:hover {
		background: #e8e8e8;
	}

	.swatch.active {
		border-color: #fe5900;
		box-shadow: 0 0 0 1px #fe5900;
	}
	/* Color swatches: show as text only; show color only on hover */
	.swatch[data-color-code] {
		background: transparent;
		color: #0d0d0d;
		border-color: #ccc;
	}
	.swatch[data-color-code]:hover,
	.swatch[data-color-code].active {
		border-color: transparent;
	}
	.swatch[data-color-code="DW"]:hover, .swatch[data-color-code="DW"].active { background: #F5F5F5; color: #0d0d0d; }
	.swatch[data-color-code="WS"]:hover, .swatch[data-color-code="WS"].active { background: #EDE8DA; color: #0d0d0d; }
	.swatch[data-color-code="FG"]:hover, .swatch[data-color-code="FG"].active { background: #A8A8A8; color: #fff; }
	.swatch[data-color-code="NS"]:hover, .swatch[data-color-code="NS"].active { background: #6E8090; color: #fff; }
	.swatch[data-color-code="GR"]:hover, .swatch[data-color-code="GR"].active { background: #4D4D4D; color: #fff; }
	.swatch[data-color-code="BL"]:hover, .swatch[data-color-code="BL"].active { background: #1A1A1A; color: #fff; }
	.swatch[data-color-code="HB"]:hover, .swatch[data-color-code="HB"].active { background: #C41E3A; color: #fff; }
	.swatch[data-color-code="LB"]:hover, .swatch[data-color-code="LB"].active { background: #1F4E8C; color: #fff; }
	.swatch[data-color-code="FM"]:hover, .swatch[data-color-code="FM"].active { background: #DEC7A0; color: #0d0d0d; }
	.swatch[data-color-code="PO"]:hover, .swatch[data-color-code="PO"].active { background: #A67C52; color: #fff; }
	.swatch[data-color-code="WH"]:hover, .swatch[data-color-code="WH"].active { background: #6B4226; color: #fff; }
	.swatch[data-color-code="HW"]:hover, .swatch[data-color-code="HW"].active { background: #4A2F1B; color: #fff; }

	.product-specs-inline {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #0d0d0d;
		margin-top: 16px;
	}

	.product-specs-inline p {
		margin: 0 0 6px;
	}

	.product-volume-discounts {
		margin-bottom: 28px;
	}

	.volume-title {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 600;
