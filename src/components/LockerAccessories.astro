---
export interface LockerAccessoryItem {
	href: string;
	image: string;
	alt: string;
	category: string;
	title: string;
	tag?: 'SALE' | 'NEW';
	priceOriginal?: string;
	price: string;
}

/** Item with modal data: same card look as shop, opens accessory modal with sliding images. */
export interface LockerAccessoryModalItem {
	accImage: string;
	accTitle: string;
	accPrice: string;
	accDesc: string;
	image: string;
	alt: string;
	title: string;
	accImage2?: string;
	accImage3?: string;
	accImage4?: string;
}

interface Props {
	items: (LockerAccessoryItem | LockerAccessoryModalItem)[];
	title?: string;
	/** When true, items must have accImage/accTitle/accPrice/accDesc; cards open the shared accessory modal (sliding images). */
	useModal?: boolean;
}

const { items, title = 'LOCKER ACCESSORIES', useModal = false } = Astro.props;

function isModalItem(item: LockerAccessoryItem | LockerAccessoryModalItem): item is LockerAccessoryModalItem {
	return useModal && 'accImage' in item && 'accTitle' in item;
}
---

<section class={`locker-accessories ${useModal ? 'locker-accessories--modal' : ''}`}>
	<div class="locker-accessories-inner">
		<h2 class="locker-accessories-heading">{title}</h2>
		<div class="locker-accessories-slider">
			<div class="locker-accessories-track">
				<div class="locker-accessories-track-set">
					{items.map((item) => isModalItem(item) ? (
						<div
							class="locker-accessories-card shop-accessory-item"
							data-acc-image={item.accImage}
							data-acc-image-2={item.accImage2}
							data-acc-image-3={item.accImage3}
							data-acc-image-4={item.accImage4}
							data-acc-title={item.accTitle}
							data-acc-price={item.accPrice}
							data-acc-desc={item.accDesc}
						>
							<button type="button" class="shop-accessory-trigger">
								<div class="shop-product-image">
									<img src={item.image} alt={item.alt} loading="lazy" />
								</div>
								<div class="shop-product-content">
									<div class="shop-product-categories">Accessories</div>
									<h5 class="shop-product-title">{item.title}</h5>
								</div>
							</button>
						</div>
					) : (
						<a href={item.href} class="locker-accessories-card">
							<div class="locker-accessories-card-image-wrap">
								{item.tag && (
									<span class={`locker-accessories-tag locker-accessories-tag-${item.tag.toLowerCase()}`}>
										{item.tag}
									</span>
								)}
								<div class="locker-accessories-card-image">
									<img src={item.image} alt={item.alt} loading="lazy" />
								</div>
							</div>
							<p class="locker-accessories-category">{item.category}</p>
							<h4 class="locker-accessories-card-title">{item.title}</h4>
							<div class="locker-accessories-price">
								{item.priceOriginal && <span class="locker-accessories-price-old">{item.priceOriginal}</span>}
								<span class="locker-accessories-price-current">{item.price}</span>
							</div>
						</a>
					))}
				</div>
				<div class="locker-accessories-track-set" aria-hidden="true">
					{items.map((item) => isModalItem(item) ? (
						<div
							class="locker-accessories-card shop-accessory-item"
							data-acc-image={item.accImage}
							data-acc-image-2={item.accImage2}
							data-acc-image-3={item.accImage3}
							data-acc-image-4={item.accImage4}
							data-acc-title={item.accTitle}
							data-acc-price={item.accPrice}
							data-acc-desc={item.accDesc}
						>
							<button type="button" class="shop-accessory-trigger">
								<div class="shop-product-image">
									<img src={item.image} alt={item.alt} loading="lazy" />
								</div>
								<div class="shop-product-content">
									<div class="shop-product-categories">Accessories</div>
									<h5 class="shop-product-title">{item.title}</h5>
								</div>
							</button>
						</div>
					) : (
						<a href={item.href} class="locker-accessories-card">
							<div class="locker-accessories-card-image-wrap">
								{item.tag && (
									<span class={`locker-accessories-tag locker-accessories-tag-${item.tag.toLowerCase()}`}>
										{item.tag}
									</span>
								)}
								<div class="locker-accessories-card-image">
									<img src={item.image} alt={item.alt} loading="lazy" />
								</div>
							</div>
							<p class="locker-accessories-category">{item.category}</p>
							<h4 class="locker-accessories-card-title">{item.title}</h4>
							<div class="locker-accessories-price">
								{item.priceOriginal && <span class="locker-accessories-price-old">{item.priceOriginal}</span>}
								<span class="locker-accessories-price-current">{item.price}</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.locker-accessories {
		margin-top: 80px;
		padding: 60px 0 80px;
		border-top: 1px solid #e0e0e0;
		background: #fff;
	}

	.locker-accessories-inner {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.locker-accessories-heading {
		font-family: 'Oswald', sans-serif;
		font-size: 32px;
		font-weight: 700;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0 0 24px;
	}

	.locker-accessories-slider {
		overflow: hidden;
		margin: 0 -20px;
		padding: 0 20px;
	}

	.locker-accessories-track {
		display: flex;
		width: max-content;
		animation: locker-accessories-scroll 45s linear infinite;
		will-change: transform;
	}

	.locker-accessories-track:hover {
		animation-play-state: paused;
	}

	.locker-accessories-track-set {
		display: flex;
		gap: 24px;
		flex: 0 0 auto;
		padding-right: 24px;
	}

	@keyframes locker-accessories-scroll {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}

	.locker-accessories-card {
		display: block;
		text-decoration: none;
		color: inherit;
		background: #fff;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
		transition: box-shadow 0.2s, transform 0.2s;
		flex: 0 0 auto;
		width: 260px;
	}

	.locker-accessories-card:hover {
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
		transform: translateY(-2px);
	}

	/* Modal mode: shop-style card (button trigger, image + content like shop) */
	.locker-accessories--modal .locker-accessories-card.shop-accessory-item {
		padding: 0;
		text-align: left;
	}
	.locker-accessories--modal .shop-accessory-trigger {
		display: flex;
		flex-direction: column;
		width: 100%;
		padding: 0;
		border: none;
		background: none;
		color: inherit;
		cursor: pointer;
		font: inherit;
		text-align: left;
	}
	/* Match shop: 200x200 image box */
	.locker-accessories--modal .shop-product-image {
		width: 200px;
		height: 200px;
		flex-shrink: 0;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #fff;
		box-sizing: border-box;
	}
	.locker-accessories--modal .shop-product-image img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center center;
		display: block;
	}
	/* Hooks: 97px max (match shop) */
	.locker-accessories--modal [data-acc-title="Hooks"] .shop-product-image {
		padding-top: 20%;
	}
	.locker-accessories--modal [data-acc-title="Hooks"] .shop-product-image img {
		width: auto;
		height: auto;
		max-width: 97px;
		max-height: 97px;
	}
	/* Name plate: scale 0.8 (match shop) */
	.locker-accessories--modal [data-acc-title="Name Plate"] .shop-product-image {
		padding-top: 20%;
	}
	.locker-accessories--modal [data-acc-title="Name Plate"] .shop-product-image img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		transform: scale(0.8);
	}
	/* Custom logo, Stick Rack: scale 0.8 (match shop) */
	.locker-accessories--modal [data-acc-title="Custom Logo"] .shop-product-image,
	.locker-accessories--modal [data-acc-title="Stick Rack"] .shop-product-image {
		padding-top: 20%;
	}
	.locker-accessories--modal [data-acc-title="Custom Logo"] .shop-product-image img,
	.locker-accessories--modal [data-acc-title="Stick Rack"] .shop-product-image img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		transform: scale(0.8);
	}
	/* Lock Box: 115px max (match shop) */
	.locker-accessories--modal [data-acc-title="Lock Box with Digital Key Lock"] .shop-product-image img {
		width: auto;
		height: auto;
		max-width: 115px;
		max-height: 115px;
	}
	.locker-accessories--modal .shop-product-content {
		padding: 16px;
	}
	.locker-accessories--modal .shop-product-categories {
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #8c8c8c;
		margin: 0 0 4px;
	}
	.locker-accessories--modal .shop-product-title {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 700;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0;
		line-height: 1.25;
	}

	.locker-accessories-card-image-wrap {
		position: relative;
		aspect-ratio: 1;
		background: #fff;
		overflow: hidden;
	}

	.locker-accessories-tag {
		position: absolute;
		top: 12px;
		left: 12px;
		z-index: 2;
		font-family: 'Oswald', sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #fff;
		padding: 6px 12px;
	}

	.locker-accessories-tag-sale {
		background: #0d0d0d;
	}

	.locker-accessories-tag-new {
		background: #fe5900;
	}

	.locker-accessories-card-image {
		position: absolute;
		inset: 0;
	}

	.locker-accessories-card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.locker-accessories-category {
		font-family: 'Yantramanav', sans-serif;
		font-size: 11px;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #8c8c8c;
		margin: 16px 16px 4px;
	}

	.locker-accessories-card-title {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 700;
		color: #0d0d0d;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0 16px 12px;
		line-height: 1.25;
	}

	.locker-accessories-price {
		padding: 0 16px 20px;
		display: flex;
		align-items: baseline;
		gap: 10px;
		flex-wrap: wrap;
	}

	.locker-accessories-price-old {
		font-family: 'Yantramanav', sans-serif;
		font-size: 14px;
		color: #8c8c8c;
		text-decoration: line-through;
	}

	.locker-accessories-price-current {
		font-family: 'Oswald', sans-serif;
		font-size: 18px;
		font-weight: 700;
		color: #0d0d0d;
	}

	@media (max-width: 1024px) {
		.locker-accessories-card {
			width: 240px;
		}
	}

	@media (max-width: 640px) {
		.locker-accessories-heading {
			font-size: 24px;
		}

		.locker-accessories-card {
			width: 200px;
		}
	}
</style>
