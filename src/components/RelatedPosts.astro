---
interface RelatedPost {
  title:    string;
  slug:     string;
  image:    string;
  date:     string;
  category: string;
}
interface Props {
  posts: RelatedPost[];
}
const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="related-posts">
    <h3 class="section-title">Related Posts</h3>
    <div class="related-grid">
      {posts.map(post => (
        <article class="related-card">
          <a href={`/blog/${post.slug}`} class="related-thumb">
            <img src={post.image} alt={post.title} width="300" height="220" loading="lazy" />
            <div class="related-overlay">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28" aria-hidden="true">
                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </div>
          </a>
          <div class="related-body">
            <div class="related-meta">
              <a href={`/categories/${post.category.toLowerCase().replace(/\s+/g, '-')}`} class="category-label">{post.category}</a>
              <time class="related-date">{post.date}</time>
            </div>
            <h4 class="related-title">
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </h4>
          </div>
        </article>
      ))}
    </div>
  </section>
)}

<style>
.related-posts { margin-top: 60px; }

.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.related-card {
  border: 1px solid var(--color-border);
  overflow: hidden;
  transition: box-shadow 0.3s, transform 0.3s;
}
.related-card:hover {
  box-shadow: 0 8px 30px rgba(0,0,0,0.1);
  transform: translateY(-2px);
}

.related-thumb {
  display: block;
  overflow: hidden;
  position: relative;
  aspect-ratio: 4/3;
}
.related-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.related-card:hover .related-thumb img { transform: scale(1.06); }

.related-overlay {
  position: absolute;
  inset: 0;
  background: rgba(254, 89, 0, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-white);
  opacity: 0;
  transition: opacity 0.3s;
}
.related-card:hover .related-overlay { opacity: 1; }

.related-body { padding: 18px 18px 20px; }

.related-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
  flex-wrap: wrap;
}
.related-date {
  font-size: 11px;
  color: var(--color-muted);
  letter-spacing: 0.3px;
}

.related-title {
  font-family: var(--font-heading);
  font-size: 15px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  line-height: 1.3;
  margin: 0;
}
.related-title a { color: var(--color-primary); transition: color 0.2s; text-decoration: none; }
.related-title a:hover { color: var(--color-accent); }

@media (max-width: 700px) {
  .related-grid { grid-template-columns: 1fr; }
}
@media (min-width: 701px) and (max-width: 900px) {
  .related-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
