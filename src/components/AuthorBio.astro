---
interface Props {
  name:    string;
  bio:     string;
  avatar?: string;
  /** Optional: used as an anchor href. Defaults to /about. */
  href?:   string;
}
const {
  name,
  bio,
  avatar  = 'https://playerstall.b-cdn.net/images/logoblack2.png',
  href    = '/about',
} = Astro.props;
---

<div class="author-bio">
  <a href={href} class="author-bio-avatar">
    <img src={avatar} alt={`About ${name}`} width="90" height="90" />
  </a>
  <div class="author-bio-content">
    <span class="author-bio-label">The Author</span>
    <h4 class="author-bio-name">
      <a href={href}>{name}</a>
    </h4>
    <p class="author-bio-text">{bio}</p>
    <div class="author-bio-social">
      <a href="https://www.facebook.com/playerstall" target="_blank" rel="noopener noreferrer" aria-label="PlayerStall on Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
      <a href="https://www.linkedin.com/company/playerstall" target="_blank" rel="noopener noreferrer" aria-label="PlayerStall on LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      </a>
    </div>
  </div>
</div>

<style>
.author-bio {
  display: flex;
  gap: 28px;
  align-items: flex-start;
  padding: 32px;
  background: var(--color-bg-alt);
  border-left: 4px solid var(--color-accent);
  margin: 48px 0;
}

.author-bio-avatar {
  flex-shrink: 0;
  display: block;
  width: 90px;
  height: 90px;
  overflow: hidden;
}
.author-bio-avatar img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.author-bio-content { flex: 1; }

.author-bio-label {
  display: block;
  font-family: var(--font-heading);
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 4px;
}

.author-bio-name {
  font-family: var(--font-heading);
  font-size: 18px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin: 0 0 10px;
}
.author-bio-name a { color: var(--color-primary); transition: color 0.2s; }
.author-bio-name a:hover { color: var(--color-accent); }

.author-bio-text {
  font-size: 13px;
  line-height: 1.7;
  color: var(--color-muted);
  margin-bottom: 14px;
}

.author-bio-social {
  display: flex;
  gap: 10px;
}
.author-bio-social a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  border: 1px solid var(--color-border);
  color: var(--color-muted);
  transition: all 0.2s;
}
.author-bio-social a:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
}

@media (max-width: 560px) {
  .author-bio { flex-direction: column; align-items: center; text-align: center; }
  .author-bio-social { justify-content: center; }
}
</style>
