---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  category?: string;
  datePublished?: string;
  readTime?: string;
  author?: string;
  authorBio?: string;
  authorImage?: string;
  featuredImage?: string;
  tags?: string[];
}

const {
  title,
  description = '',
  category = 'Blog',
  datePublished = '',
  readTime = '',
  author = 'PlayerStall',
  authorBio = 'PlayerStall has been crafting luxury custom-built wood sports lockers for over 30 years, serving collegiate and professional teams across North America with a 5 year warranty.',
  authorImage = 'https://playerstall.b-cdn.net/images/logoblack2.png',
  featuredImage = 'https://topscorer.qodeinteractive.com/wp-content/uploads/2020/01/blog-1-masonry-img-1.jpg',
  tags = []
} = Astro.props;

const formattedDate = datePublished
  ? new Date(datePublished + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---

<BaseLayout title={title + ' | PlayerStall Blog'} description={description}>
  <!-- Breadcrumbs -->
  <div class="blog-post-breadcrumbs-wrapper">
    <div class="blog-post-container">
      <div class="blog-post-breadcrumbs">
        <a href="/">Home</a>
        <span class="sep">-</span>
        <a href="/blog">{category}</a>
        <span class="sep">-</span>
        <span class="current">{title.length > 50 ? title.substring(0, 50) + '...' : title}</span>
      </div>
    </div>
  </div>

  <!-- Main Content Area -->
  <div class="blog-post-main-wrapper">
    <div class="blog-post-container">
      <div class="blog-post-content-area">

        <!-- Featured Image -->
        {featuredImage && (
          <div class="blog-post-featured-image">
            <img src={featuredImage} alt={title} />
          </div>
        )}

        <!-- Meta: Category + Date -->
        <div class="blog-post-meta">
          <span class="blog-post-category">{category}</span>
          <span class="blog-post-meta-sep">-</span>
          <span class="blog-post-date">{formattedDate}</span>
        </div>

        <!-- Title -->
        <h1 class="blog-post-title">{title}</h1>

        <!-- Article Body -->
        <div class="blog-post-body">
          <slot />
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="blog-post-tags">
            {tags.map((tag, i) => (
              <>
                <a href={`/blog?tag=${tag.toLowerCase()}`} class="blog-post-tag">{tag}</a>
                {i < tags.length - 1 && <span class="blog-post-tag-sep">-</span>}
              </>
            ))}
          </div>
        )}

        <!-- Share -->
        <div class="blog-post-share">
          <span class="blog-post-share-label">Share</span>
          <div class="blog-post-share-icons">
            <a href="#" aria-label="Facebook" class="share-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="#" aria-label="Twitter" class="share-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
            </a>
            <a href="#" aria-label="LinkedIn" class="share-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="#" aria-label="Pinterest" class="share-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
          </div>
        </div>

        <!-- Author Box -->
        <div class="blog-post-author-box">
          <div class="blog-post-author-image">
            <img src={authorImage} alt={author} />
          </div>
          <div class="blog-post-author-label">The Author</div>
          <h4 class="blog-post-author-name">
            <a href="/about">{author}</a>
          </h4>
          <p class="blog-post-author-bio">{authorBio}</p>
        </div>

        <!-- Previous / Next -->
        <div class="blog-post-prev-next">
          <a href="/blog" class="blog-post-prev">
            <span class="pn-arrow">&lsaquo;</span>
            <span class="pn-text">Previous</span>
          </a>
          <a href="/blog" class="blog-post-next">
            <span class="pn-text">Next</span>
            <span class="pn-arrow">&rsaquo;</span>
          </a>
        </div>

      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="blog-post-cta-wrapper">
    <div class="blog-post-container">
      <div class="blog-post-cta">
        <h2>Ready for Custom Sports Lockers?</h2>
        <p>Get a free design consultation. 30+ years of craftsmanship. 5 year warranty.</p>
        <a class="blog-post-cta-btn" href="/contact">Get Free Consultation</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ============================================
     TopScorer-style Blog Single Post Layout
     ============================================ */

  /* Container */
  .blog-post-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Breadcrumbs */
  .blog-post-breadcrumbs-wrapper {
    padding: 40px 0 0;
  }
  .blog-post-breadcrumbs {
    font-family: 'Yantramanav', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #b2b2b2;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .blog-post-breadcrumbs a {
    color: #b2b2b2;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .blog-post-breadcrumbs a:hover {
    color: #fe5900;
  }
  .blog-post-breadcrumbs .sep {
    color: #b2b2b2;
  }
  .blog-post-breadcrumbs .current {
    color: #1a1a1a;
    font-weight: 500;
  }

  /* Main Wrapper */
  .blog-post-main-wrapper {
    padding: 30px 0 60px;
  }

  /* Featured Image */
  .blog-post-featured-image {
    margin-bottom: 30px;
  }
  .blog-post-featured-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Meta (Category + Date) */
  .blog-post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    font-family: 'Yantramanav', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #b2b2b2;
  }
  .blog-post-category {
    color: #fe5900;
    cursor: pointer;
  }
  .blog-post-category:hover {
    color: #1a1a1a;
  }
  .blog-post-meta-sep {
    color: #b2b2b2;
  }
  .blog-post-date {
    color: #b2b2b2;
  }

  /* Title */
  .blog-post-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.1;
    color: #1a1a1a;
    text-transform: uppercase;
    margin: 0 0 30px 0;
    letter-spacing: -0.5px;
  }

  /* Article Body */
  .blog-post-body {
    margin-bottom: 40px;
  }
  .blog-post-body :global(p),
  .blog-post-body :global(span) {
    font-family: 'Yantramanav', sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.8;
    color: #999999;
    margin-bottom: 20px;
  }
  .blog-post-body :global(h1) {
    display: none; /* Hide duplicate H1 from content since we already have one */
  }
  .blog-post-body :global(h2) {
    font-family: 'Oswald', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: #1a1a1a;
    text-transform: uppercase;
    margin: 35px 0 15px;
    letter-spacing: 0;
  }
  .blog-post-body :global(h3) {
    font-family: 'Oswald', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #1a1a1a;
    text-transform: uppercase;
    margin: 30px 0 12px;
  }
  .blog-post-body :global(h4) {
    font-family: 'Oswald', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 25px 0 10px;
  }
  .blog-post-body :global(ul),
  .blog-post-body :global(ol) {
    padding-left: 25px;
    margin: 15px 0 25px;
  }
  .blog-post-body :global(li) {
    font-family: 'Yantramanav', sans-serif;
    font-size: 18px;
    line-height: 1.8;
    color: #999999;
    margin-bottom: 8px;
  }
  .blog-post-body :global(a) {
    color: #fe5900;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .blog-post-body :global(a:hover) {
    color: #1a1a1a;
    text-decoration: underline;
  }
  .blog-post-body :global(blockquote) {
    margin: 40px 0;
    padding: 40px 30px;
    text-align: center;
    border: none;
    position: relative;
  }
  .blog-post-body :global(blockquote::before) {
    content: '\201D';
    display: block;
    font-family: Georgia, serif;
    font-size: 80px;
    line-height: 1;
    color: #1a1a1a;
    margin-bottom: 10px;
  }
  .blog-post-body :global(blockquote h4),
  .blog-post-body :global(blockquote p) {
    font-family: 'Oswald', sans-serif;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.3;
    color: #1a1a1a;
    text-transform: uppercase;
    letter-spacing: 0;
    margin: 0;
  }
  .blog-post-body :global(strong) {
    color: #1a1a1a;
    font-weight: 600;
  }
  .blog-post-body :global(em) {
    font-style: italic;
  }
  .blog-post-body :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 20px 0;
  }

  /* Tags */
  .blog-post-tags {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 25px;
    padding-bottom: 0;
  }
  .blog-post-tag {
    font-family: 'Yantramanav', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #b2b2b2;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .blog-post-tag:hover {
    color: #fe5900;
  }
  .blog-post-tag-sep {
    color: #b2b2b2;
    font-size: 12px;
  }

  /* Share */
  .blog-post-share {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 25px 0;
    border-top: 1px solid #e8e8e8;
    border-bottom: 1px solid #e8e8e8;
    margin-bottom: 40px;
  }
  .blog-post-share-label {
    font-family: 'Yantramanav', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #b2b2b2;
  }
  .blog-post-share-icons {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .share-icon {
    color: #b2b2b2;
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
  }
  .share-icon:hover {
    color: #fe5900;
  }

  /* Author Box */
  .blog-post-author-box {
    background: #f5f5f5;
    padding: 50px 40px;
    margin-bottom: 40px;
    border: 1px solid #ebebeb;
  }
  .blog-post-author-image {
    width: 200px;
    height: auto;
    margin-bottom: 20px;
  }
  .blog-post-author-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }
  .blog-post-author-label {
    font-family: 'Yantramanav', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #b2b2b2;
    margin-bottom: 5px;
  }
  .blog-post-author-name {
    font-family: 'Oswald', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: #1a1a1a;
    text-transform: uppercase;
    margin: 0 0 15px;
  }
  .blog-post-author-name a {
    color: #1a1a1a;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .blog-post-author-name a:hover {
    color: #fe5900;
  }
  .blog-post-author-bio {
    font-family: 'Yantramanav', sans-serif;
    font-size: 18px;
    line-height: 1.8;
    color: #999999;
    margin: 0;
  }

  /* Previous / Next */
  .blog-post-prev-next {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30px 0;
    border-top: 1px solid #e8e8e8;
    border-bottom: 1px solid #e8e8e8;
    margin-bottom: 0;
  }
  .blog-post-prev,
  .blog-post-next {
    display: flex;
    align-items: center;
    gap: 15px;
    text-decoration: none;
    color: #1a1a1a;
    transition: color 0.3s ease;
  }
  .blog-post-prev:hover,
  .blog-post-next:hover {
    color: #fe5900;
  }
  .pn-arrow {
    font-size: 50px;
    font-weight: 300;
    line-height: 1;
    color: #d0d0d0;
    transition: color 0.3s ease;
  }
  .blog-post-prev:hover .pn-arrow,
  .blog-post-next:hover .pn-arrow {
    color: #fe5900;
  }
  .pn-text {
    font-family: 'Oswald', sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  /* CTA Section */
  .blog-post-cta-wrapper {
    background: #1a1a1a;
    padding: 60px 0;
  }
  .blog-post-cta {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  .blog-post-cta h2 {
    font-family: 'Oswald', sans-serif;
    font-size: 32px;
    font-weight: 700;
    color: #ffffff;
    text-transform: uppercase;
    margin: 0 0 15px;
  }
  .blog-post-cta p {
    font-family: 'Yantramanav', sans-serif;
    font-size: 18px;
    color: #b2b2b2;
    margin: 0 0 30px;
    line-height: 1.6;
  }
  .blog-post-cta-btn {
    display: inline-block;
    font-family: 'Oswald', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #ffffff;
    background: #fe5900;
    padding: 15px 40px;
    text-decoration: none;
    transition: background 0.3s ease, transform 0.2s ease;
  }
  .blog-post-cta-btn:hover {
    background: #e04f00;
    transform: translateY(-2px);
  }

  /* ============================================
     Responsive
     ============================================ */
  @media (max-width: 768px) {
    .blog-post-container {
      padding: 0 15px;
    }
    .blog-post-breadcrumbs-wrapper {
      padding: 20px 0 0;
    }
    .blog-post-breadcrumbs {
      font-size: 10px;
      letter-spacing: 2px;
    }
    .blog-post-title {
      font-size: 28px;
    }
    .blog-post-body :global(p),
    .blog-post-body :global(span),
    .blog-post-body :global(li) {
      font-size: 16px;
    }
    .blog-post-author-box {
      padding: 30px 20px;
    }
    .blog-post-author-image {
      width: 120px;
    }
    .blog-post-share {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
    .blog-post-prev-next {
      padding: 20px 0;
    }
    .pn-arrow {
      font-size: 35px;
    }
    .pn-text {
      font-size: 14px;
    }
    .blog-post-cta h2 {
      font-size: 24px;
    }
  }

  @media (max-width: 480px) {
    .blog-post-title {
      font-size: 24px;
    }
    .blog-post-body :global(blockquote) {
      padding: 20px 15px;
    }
    .blog-post-body :global(blockquote h4),
    .blog-post-body :global(blockquote p) {
      font-size: 18px;
    }
  }
</style>
