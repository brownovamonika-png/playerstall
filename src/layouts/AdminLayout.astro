---
interface Props {
	title: string;
	activeNav?: string;
}

const { title, activeNav } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<!-- Google Tag Manager -->
		<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
		new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
		j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
		'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
		})(window,document,'script','dataLayer','GTM-5J3PPW7D');</script>
		<!-- End Google Tag Manager -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex, nofollow" />
		<title>{title} | PlayerStall CRM</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link href="https://fonts.googleapis.com/css?family=Yantramanav:400,500,700|Oswald:600,700&display=swap" rel="stylesheet" />
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5J3PPW7D"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		<div class="admin-wrapper">
			<aside class="sidebar" data-crm-tour="sidebar">
				<div class="sidebar-brand">
					<a href="/admin">
						<span class="brand-name">PLAYERSTALL</span>
						<span class="brand-label">CRM</span>
					</a>
				</div>
				<nav class="sidebar-nav">
					<a href="/admin/paste-inquiry" class:list={['nav-item', { active: activeNav === 'paste-inquiry' }]}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13h4"/><path d="M12 11v4"/><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M7 9h.01"/><path d="M7 13h.01"/></svg>
						<span>Paste inquiry</span>
					</a>
					<a href="/admin" data-crm-tour="dashboard" class:list={['nav-item', { active: activeNav === 'dashboard' }]}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
						<span>Dashboard</span>
					</a>
					<a href="/admin/pipeline" data-crm-tour="pipeline" class:list={['nav-item', { active: activeNav === 'pipeline' }]}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
						<span>Pipeline</span>
					</a>
					<a href="/admin/clients" data-crm-tour="clients" class:list={['nav-item', { active: activeNav === 'clients' }]}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
						<span>Clients</span>
					</a>
					<a href="/admin/client-copy" data-crm-tour="client-copy" class:list={['nav-item', { active: activeNav === 'client-copy' }]}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
						<span>Client copy</span>
					</a>
					<a href="/admin/emails" data-crm-tour="emails" class:list={['nav-item', { active: activeNav === 'emails' }]}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
						<span>Email Templates</span>
					</a>
					<a href="/admin/help" data-crm-tour="help" class:list={['nav-item', { active: activeNav === 'help' }]}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
						<span>Help</span>
					</a>
					<a href="/admin/inventory" class:list={['nav-item', { active: activeNav === 'inventory' }]}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
						<span>Inventory</span>
					</a>
					<a href="/admin/shipping" class:list={['nav-item', { active: activeNav === 'shipping' }]}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
						<span>Shipping</span>
					</a>
				</nav>
				<div class="sidebar-footer">
					<a
						href="/admin/manufacturer-forms"
						class:list={['nav-item', { active: activeNav === 'manufacturer-forms' }]}
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="9" rx="0.5" /><rect x="14" y="3" width="7" height="5" rx="0.5" /><rect x="14" y="11" width="7" height="10" rx="0.5" /><rect x="3" y="15" width="7" height="6" rx="0.5" /></svg>
						<span>Manufacturer forms</span>
					</a>
					<a
						href="/admin/locker-build-form"
						class:list={['nav-item', { active: activeNav === 'locker-build-form' }]}
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="4" width="16" height="8" rx="1" /><rect x="4" y="14" width="16" height="6" rx="1" /><line x1="8" y1="8" x2="16" y2="8" /><line x1="8" y1="17" x2="16" y2="17" /></svg>
						<span>Locker build form</span>
					</a>
					<a
						href="/admin/premium-locker-form"
						class:list={['nav-item', { active: activeNav === 'premium-locker-form' }]}
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="4" width="16" height="8" rx="1" /><rect x="4" y="14" width="16" height="6" rx="1" /><line x1="8" y1="8" x2="16" y2="8" /><line x1="8" y1="17" x2="16" y2="17" /></svg>
						<span>Premium locker form</span>
					</a>
					<a
						href="/admin/profit-cost-sheet"
						class:list={['nav-item', { active: activeNav === 'profit-cost-sheet' }]}
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="0"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/><line x1="8" y1="18" x2="14" y2="18"/></svg>
						<span>Profit cost sheet</span>
					</a>
					<a
						href="/admin/interactive-cost-sheet"
						class:list={['nav-item', { active: activeNav === 'interactive-cost-sheet' }]}
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="0"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/><line x1="8" y1="18" x2="14" y2="18"/></svg>
						<span>Interactive cost sheet</span>
					</a>
					<a href="/" class="nav-item" target="_blank">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
						<span>View Site</span>
					</a>
					<form method="POST" action="/admin/logout">
						<button type="submit" class="nav-item logout-btn">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
							<span>Logout</span>
						</button>
					</form>
				</div>
			</aside>
			<main class="admin-main">
				<header class="admin-header">
					<div class="admin-header-leading">
						<h1 class="page-title">{title}</h1>
						<slot name="header-sub" />
					</div>
					<div class="admin-header-actions">
						<slot name="header-actions" />
					</div>
				</header>
				<div class="admin-content">
					<slot />
				</div>
			</main>
		</div>

		<!-- CRM quick tour (same pattern as room planner guide: bottom-right ? + steps) -->
		<div class="crm-guide-fab hidden" id="crm-guide-fab" title="Open CRM quick tour">?</div>
		<div class="crm-guide-panel hidden" id="crm-guide-panel" aria-live="polite">
			<div class="crm-guide-header">
				<span class="crm-guide-title">CRM Quick Tour</span>
				<button type="button" class="crm-guide-minimize" id="crm-guide-minimize" title="Minimize">&minus;</button>
			</div>
			<div class="crm-guide-progress">
				<div class="crm-guide-progress-bar" id="crm-guide-progress-bar"></div>
			</div>
			<div class="crm-guide-step-count" id="crm-guide-step-count">Step 1 of 6</div>
			<div class="crm-guide-body" id="crm-guide-body">
				<div class="crm-guide-step-title" id="crm-guide-step-title"></div>
				<div class="crm-guide-step-desc" id="crm-guide-step-desc"></div>
			</div>
			<div class="crm-guide-nav">
				<button type="button" class="crm-guide-nav-btn" id="crm-guide-prev" disabled>&larr; Back</button>
				<button type="button" class="crm-guide-nav-btn crm-guide-nav-next" id="crm-guide-next">Next &rarr;</button>
			</div>
			<button type="button" class="crm-guide-skip" id="crm-guide-skip">Skip tour</button>
		</div>

		<script is:inline>
			(function () {
				const KEY_DONE = 'ps_crm_tour_done';
				const KEY_COLLAPSE = 'ps_crm_tour_collapsed';

				const STEPS = [
					{
						title: 'Welcome',
						desc: 'This is the <strong>PlayerStall CRM</strong>—clients, orders, and email templates in one place. This short tour matches the <strong>?</strong> helper in the room designer. Use <strong>Next</strong> to continue, or <strong>−</strong> to tuck the panel away (the <strong>?</strong> button brings it back).',
						target: '[data-crm-tour="sidebar"]',
					},
					{
						title: 'Dashboard',
						desc: 'The <strong>Dashboard</strong> shows totals, a pipeline snapshot, and recent activity. Click it anytime to return home.',
						target: '[data-crm-tour="dashboard"]',
					},
					{
						title: 'Pipeline',
						desc: '<strong>Pipeline</strong> is your board by stage—from New Lead through Complete. Move deals as they progress.',
						target: '[data-crm-tour="pipeline"]',
					},
					{
						title: 'Clients',
						desc: 'Open <strong>Clients</strong> for your contact list. Each person can have orders, notes, and a client portal link.',
						target: '[data-crm-tour="clients"]',
					},
					{
						title: 'Email templates',
						desc: 'Under <strong>Email Templates</strong>, edit messages such as inquiry acknowledgments. Use <strong>Send as</strong> to choose <strong>PlayerStall</strong> or <strong>Custom Sport Lockers</strong> so the right brand goes out.',
						target: '[data-crm-tour="emails"]',
					},
					{
						title: 'Help & finished',
						desc: 'Open <strong>Help</strong> for links and reminders anytime. You can <strong>show this tour again</strong> from the Help page. Click <strong>Done</strong> to close the tour for this browser.',
						target: '[data-crm-tour="help"]',
					},
				];

				const fab = document.getElementById('crm-guide-fab');
				const panel = document.getElementById('crm-guide-panel');
				const btnMin = document.getElementById('crm-guide-minimize');
				const btnPrev = document.getElementById('crm-guide-prev');
				const btnNext = document.getElementById('crm-guide-next');
				const btnSkip = document.getElementById('crm-guide-skip');
				const stepTitle = document.getElementById('crm-guide-step-title');
				const stepDesc = document.getElementById('crm-guide-step-desc');
				const stepCount = document.getElementById('crm-guide-step-count');
				const progressBar = document.getElementById('crm-guide-progress-bar');

				if (!fab || !panel || !btnMin || !btnPrev || !btnNext || !btnSkip || !stepTitle || !stepDesc || !stepCount || !progressBar) return;

				let current = 0;
				let highlightEl = null;

				function clearHighlight() {
					if (highlightEl) {
						highlightEl.classList.remove('crm-guide-highlight', 'crm-guide-pulse');
						highlightEl = null;
					}
				}

				function renderStep() {
					const s = STEPS[current];
					stepTitle.textContent = s.title;
					stepDesc.innerHTML = s.desc;
					stepCount.textContent = 'Step ' + (current + 1) + ' of ' + STEPS.length;
					progressBar.style.width = ((100 * (current + 1)) / STEPS.length).toFixed(1) + '%';
					btnPrev.disabled = current === 0;
					btnNext.textContent = current === STEPS.length - 1 ? 'Done ✓' : 'Next →';

					clearHighlight();
					if (s.target) {
						const el = document.querySelector(s.target);
						if (el) {
							highlightEl = el;
							el.classList.add('crm-guide-highlight', 'crm-guide-pulse');
							try {
								el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
							} catch (_) {}
						}
					}
				}

				function goTo(i) {
					current = Math.max(0, Math.min(STEPS.length - 1, i));
					renderStep();
				}

				function showPanel() {
					panel.classList.remove('hidden');
					fab.classList.add('hidden');
					localStorage.removeItem(KEY_COLLAPSE);
					renderStep();
				}

				function minimizePanel() {
					clearHighlight();
					panel.classList.add('hidden');
					fab.classList.remove('hidden');
					localStorage.setItem(KEY_COLLAPSE, '1');
				}

				function finishTour() {
					clearHighlight();
					panel.classList.add('hidden');
					fab.classList.add('hidden');
					localStorage.setItem(KEY_DONE, '1');
					localStorage.removeItem(KEY_COLLAPSE);
				}

				function applyInitialState() {
					if (localStorage.getItem(KEY_DONE) === '1') {
						panel.classList.add('hidden');
						fab.classList.add('hidden');
						return false;
					}
					if (localStorage.getItem(KEY_COLLAPSE) === '1') {
						panel.classList.add('hidden');
						fab.classList.remove('hidden');
						return true;
					}
					panel.classList.remove('hidden');
					fab.classList.add('hidden');
					return true;
				}

				const active = applyInitialState();
				if (!active) return;

				if (!panel.classList.contains('hidden')) renderStep();

				fab.addEventListener('click', showPanel);
				btnMin.addEventListener('click', minimizePanel);
				btnPrev.addEventListener('click', function () {
					goTo(current - 1);
				});
				btnNext.addEventListener('click', function () {
					if (current === STEPS.length - 1) finishTour();
					else goTo(current + 1);
				});
				btnSkip.addEventListener('click', finishTour);
			})();
		</script>
	</body>
</html>

<style>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		font-family: 'Yantramanav', -apple-system, BlinkMacSystemFont, sans-serif;
		background: #f7f7f7;
		color: #0d0d0d;
		min-height: 100vh;
	}

	.admin-wrapper {
		display: flex;
		min-height: 100vh;
	}

	.sidebar {
		width: 240px;
		background: #1a1a1a;
		color: #cccccc;
		display: flex;
		flex-direction: column;
		position: fixed;
		top: 0;
		left: 0;
		bottom: 0;
		z-index: 100;
	}

	.sidebar-brand {
		padding: 28px 20px;
		border-bottom: 1px solid rgba(255,255,255,0.08);
	}

	.sidebar-brand a {
		text-decoration: none;
		display: flex;
		align-items: baseline;
		gap: 10px;
	}

	.brand-name {
		font-family: 'Oswald', sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: #ffffff;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.brand-label {
		font-family: 'Oswald', sans-serif;
		font-size: 12px;
		font-weight: 600;
		color: #fe5900;
		text-transform: uppercase;
		letter-spacing: 0.15em;
	}

	.sidebar-nav {
		flex: 1;
		padding: 20px 14px;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.nav-item {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 12px 14px;
		color: rgba(255,255,255,0.5);
		text-decoration: none;
		font-family: 'Yantramanav', sans-serif;
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		transition: all 0.3s ease;
		cursor: pointer;
	}

	.nav-item:hover {
		color: #ffffff;
	}

	.nav-item.active {
		color: #fe5900;
	}

	.sidebar-footer {
		padding: 14px;
		border-top: 1px solid rgba(255,255,255,0.08);
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.logout-btn {
		width: 100%;
		background: none;
		border: none;
		font: inherit;
		text-align: left;
	}

	.admin-main {
		flex: 1;
		margin-left: 240px;
		display: flex;
		flex-direction: column;
		background: #f7f7f7;
	}

	.admin-header {
		background: #ffffff;
		border-bottom: 1px solid #ececec;
		padding: 28px 40px 22px;
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 20px;
		position: sticky;
		top: 0;
		z-index: 50;
	}

	.admin-header-leading {
		flex: 1;
		min-width: 0;
	}

	.admin-header-actions {
		flex-shrink: 0;
		padding-top: 4px;
	}

	.page-title {
		font-family: 'Oswald', sans-serif;
		font-size: 28px;
		font-weight: 700;
		color: #0d0d0d;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		margin: 0;
	}

	.admin-content {
		padding: 24px 40px 40px;
		flex: 1;
	}

	@media (max-width: 768px) {
		.sidebar {
			transform: translateX(-100%);
			transition: transform 0.3s ease;
		}

		.admin-main {
			margin-left: 0;
		}

		.admin-header {
			padding: 20px;
		}

		.admin-content {
			padding: 20px;
		}
	}
</style>

<style is:global>
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 25px;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		cursor: pointer;
		border: 2px solid transparent;
		transition: all 0.3s ease;
		text-decoration: none;
	}

	.btn-primary {
		background: #fe5900;
		color: #ffffff;
		border-color: #fe5900;
	}

	.btn-primary:hover {
		background: #e04d00;
		border-color: #e04d00;
		color: #ffffff;
