<style>
	:global(html) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #fff;
	}

	:global(body) {
		margin: 0;
		padding: 0;
		color: #0d0d0d;
		line-height: 1.6;
		/* Sporty custom cursor: cartoon orange football 48×30, transparent bg, hotspot at center */
		cursor: url('/cursor-football.png?v=6') 24 15, auto;
	}

	/* Global link styles – brand colors instead of browser default blue */
	:global(a) {
		color: #0d0d0d;
		text-decoration: none;
		transition: color 0.3s ease;
	}
	:global(a:hover) {
		color: #fe5900;
	}
	:global(a:visited) {
		color: #0d0d0d;
	}
	:global(a:visited:hover) {
		color: #fe5900;
	}

	/* Pull quote – use class="pull-quote" on blockquote for standout quotes site-wide (screenshot style) */
	:global(.pull-quote) {
		position: relative;
		margin: 2rem auto;
		padding: 3.5rem 2rem 2rem;
		max-width: 36em;
		text-align: center;
		border: none;
		border-bottom: 1px solid #e3dfd7;
		background: transparent;
	}
	:global(.pull-quote::before) {
		content: '\201C';
		position: absolute;
		top: 0;
		left: 0;
		font-family: 'Oswald', sans-serif;
		font-size: 7.5rem;
		font-weight: 600;
		line-height: 1;
		color: #e3dfd7;
		pointer-events: none;
	}
	:global(.pull-quote p) {
		margin: 0 0 0.75rem;
		font-family: 'Oswald', sans-serif;
		font-size: 1.7rem;
		font-weight: 600;
		line-height: 1.5;
		color: #0d0d0d;
	}
	:global(.pull-quote p:last-of-type) {
		margin-bottom: 0.5rem;
	}
	:global(.pull-quote cite) {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 1.3rem;
		font-weight: 500;
		font-style: normal;
		color: #4a4a4a;
		letter-spacing: 0.02em;
	}

	/* Top Bar */
	.top-bar {
		background: #000000;
		padding: 10px 0;
		border-bottom: none;
		position: sticky;
		top: 0;
		z-index: 1001;
	}

