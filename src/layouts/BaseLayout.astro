<script>
	// Handle header scroll behavior
	function initHeaderScroll() {
		const header = document.querySelector('header');
		const heroSlider = document.querySelector('.hero-slider') as HTMLElement | null;
		
		if (!header || !heroSlider) return;

		const sliderEl = heroSlider;
		const headerEl = header;
		function handleScroll() {
			const scrollY = window.scrollY;
			const heroHeight = sliderEl.offsetHeight;
			
			if (scrollY > heroHeight - 100) {
				headerEl.classList.add('scrolled');
			} else {
				headerEl.classList.remove('scrolled');
			}
		}

		window.addEventListener('scroll', handleScroll, { passive: true });
		handleScroll(); // Initial check
	}

	// Cart utility - update cart count on page load
	function updateCartCount() {
		try {
			const cart = localStorage.getItem('playerstall_cart');
			const cartData: { quantity?: number }[] = cart ? JSON.parse(cart) : [];
			const totalItems = cartData.reduce((sum: number, item: { quantity?: number }) => sum + (item.quantity || 1), 0);
			const cartCounts = document.querySelectorAll('.cart-count');
			cartCounts.forEach((el) => {
				el.textContent = String(totalItems);
			});
		} catch (e) {
			console.error('Error updating cart count:', e);
		}
	}

	// Update cart count on page load
	updateCartCount();

	// Listen for cart updates
	window.addEventListener('cartUpdated', function() {
		updateCartCount();
	});

	// Also check on storage events (for cross-tab updates)
	window.addEventListener('storage', function(e) {
		if (e.key === 'playerstall_cart') {
			updateCartCount();
		}
	});

	// Top bar rotating messages - news ticker style
	const quotes = [
		"Premium wood lockers at unbeatable prices. Price match guarantee.",
		"Quick ship in 2–4 weeks. Stadium & Elite in 24\" or 30\". Custom in 8–12 weeks.",
		"We'll match any USA competitor's price on comparable lockers.",
		"Wood, phenolic & more — custom built your way.",
		"High quality. Lower cost. Efficient production.",
		"Super Bowl halftime. Latest NFL firings. Biggest NFL veterans.",
		"Focused on core models so we never stop production.",
		"Excellence is not a destination, it's a journey.",
		"Champions don't wait for perfect conditions. They create them."
	];

	function initQuoteOfTheDay() {
		const quoteText = document.getElementById('quoteText');
		if (!quoteText) return;

		let currentQuoteIndex = 0;
		
		// Display first quote immediately
		quoteText.textContent = quotes[currentQuoteIndex];
		
		// Rotate quotes every 6 seconds
		setInterval(() => {
			currentQuoteIndex = (currentQuoteIndex + 1) % quotes.length;
			quoteText.textContent = quotes[currentQuoteIndex];
		}, 6000);
	}

	function initBySportDropdown() {
		const trigger = document.getElementById('by-sport-trigger');
		const dropdown = document.querySelector('.nav-dropdown');
		if (!trigger || !dropdown) return;

		trigger.addEventListener('click', (e) => {
			e.preventDefault();
			dropdown.classList.toggle('open');
			trigger.setAttribute('aria-expanded', dropdown.classList.contains('open') ? 'true' : 'false');
		});

		document.addEventListener('click', (e) => {
			const target = e.target as Node | null;
			if (target && !dropdown.contains(target)) {
				dropdown.classList.remove('open');
				trigger.setAttribute('aria-expanded', 'false');
			}
		});
	}

	function initMobileMenu() {
		const header = document.querySelector('header');
		const btn = document.querySelector('.nav-menu-btn');
		const panel = document.getElementById('nav-menu');
		const mobileBySportTrigger = document.getElementById('mobile-by-sport-trigger');
		const mobileBySportDropdown = document.querySelector('.nav-menu-dropdown');

		if (!header || !btn || !panel) return;

		const headerEl = header;
		const btnEl = btn;
		const panelEl = panel;

		function isOpen() {
			return headerEl.classList.contains('menu-open');
		}

		function openMenu() {
			headerEl.classList.add('menu-open');
			document.body.classList.add('menu-open');
			btnEl.setAttribute('aria-expanded', 'true');
			btnEl.setAttribute('aria-label', 'Close menu');
			panelEl.setAttribute('aria-hidden', 'false');
		}

		function closeMenu() {
			headerEl.classList.remove('menu-open');
			document.body.classList.remove('menu-open');
			btnEl.setAttribute('aria-expanded', 'false');
			btnEl.setAttribute('aria-label', 'Open menu');
			panelEl.setAttribute('aria-hidden', 'true');
			if (mobileBySportDropdown) {
				mobileBySportDropdown.classList.remove('open');
				if (mobileBySportTrigger) mobileBySportTrigger.setAttribute('aria-expanded', 'false');
			}
		}

		function toggleMenu() {
			if (isOpen()) closeMenu();
			else openMenu();
		}

		btnEl.addEventListener('click', (e) => {
			e.preventDefault();
			toggleMenu();
		});

		panelEl.addEventListener('click', (e) => {
			const target = e.target as HTMLElement | null;
			const link = target?.closest?.('a');
			if (link && link.getAttribute('href')) {
				closeMenu();
			}
		});

		document.addEventListener('click', (e) => {
			if (!isOpen()) return;
			const target = e.target as Node | null;
			if (target && !panelEl.contains(target) && !btnEl.contains(target)) {
				closeMenu();
			}
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && isOpen()) {
				closeMenu();
			}
		});

		window.addEventListener('resize', () => {
			if (window.innerWidth > 768 && isOpen()) {
				closeMenu();
			}
		});

		if (mobileBySportTrigger && mobileBySportDropdown) {
			mobileBySportTrigger.addEventListener('click', (e) => {
				e.preventDefault();
				mobileBySportDropdown.classList.toggle('open');
				const expanded = mobileBySportDropdown.classList.contains('open');
				mobileBySportTrigger.setAttribute('aria-expanded', expanded ? 'true' : 'false');
			});
		}
	}

	// Initialize when DOM is ready
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', () => {
			initHeaderScroll();
			initQuoteOfTheDay();
			initBySportDropdown();
			initMobileMenu();
		});
	} else {
		initHeaderScroll();
		initQuoteOfTheDay();
		initBySportDropdown();
		initMobileMenu();
	}
</script>