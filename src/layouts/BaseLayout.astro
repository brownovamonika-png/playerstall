	.quote-label {
		color: #b6b6b6;
		font-family: 'Yantramanav', 'Roboto', sans-serif;
		font-size: 13px;
		font-weight: 500;
		white-space: nowrap;
		flex-shrink: 0;
		z-index: 2;
		background: #000000;
		padding-right: 10px;
		position: relative;
	}

	.quote-content {
		flex: 1;
		position: relative;
		min-width: 0;
		overflow: hidden;
	}

	.quote-text {
		color: #e0e0e0;
		font-family: 'Yantramanav', 'Roboto', sans-serif;
		font-size: 13px;
		font-weight: 400;
		letter-spacing: 0.02em;
		white-space: nowrap;
		display: inline-block;
	}

	.top-bar-right {
		display: flex;
		align-items: center;
		gap: 0;
		flex-shrink: 0;
		white-space: nowrap;
	}

	.top-bar-right span {
		color: #ffffff;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-right: 22px;
		font-weight: 500;
		white-space: nowrap;
		display: inline-block;
	}

	.top-bar-right .social-links {
		display: inline-flex;
		align-items: center;
		gap: 18px;
	}

	.top-bar-right .social-icon {
		color: #b6b6b6;
		text-decoration: none;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: none;
		letter-spacing: 0;
		transition: color 0.3s;
		font-weight: 400;
		line-height: 1;
		white-space: nowrap;
		display: inline-block;
		width: auto;
	}

	.top-bar-right .social-icon:hover {
		color: #ffffff;
	}

	/* Navigation */
	header {
		background: transparent;
		color: #ffffff;
		padding: 0;
		position: absolute;
		top: 40px;
		left: 0;
		right: 0;
		z-index: 1000;
		width: 100%;
		transition: background 0.3s ease, top 0.3s ease;
	}

	header.scrolled {
