<style>
	:global(html) {
		font-family: 'Yantramanav', 'Roboto', Arial, sans-serif;
		background: #fff;
	}

	:global(body) {
		margin: 0;
		padding: 0;
		color: #0d0d0d;
		line-height: 1.6;
		/* Sporty custom cursor: cartoon orange football 48×30, transparent bg, hotspot at center */
		cursor: url('/cursor-football.png?v=6') 24 15, auto;
	}

	/* Global link styles – brand colors instead of browser default blue */
	:global(a) {
		color: #0d0d0d;
		text-decoration: none;
		transition: color 0.3s ease;
	}
	:global(a:hover) {
		color: #fe5900;
	}
	:global(a:visited) {
		color: #0d0d0d;
	}
	:global(a:visited:hover) {
		color: #fe5900;
	}

	/* Pull quote – use class="pull-quote" on blockquote for standout quotes site-wide (screenshot style) */
	:global(.pull-quote) {
		position: relative;
		margin: 2rem auto;
		padding: 3.5rem 2rem 2rem;
		max-width: 36em;
		text-align: center;
		border: none;
		border-bottom: 1px solid #e3dfd7;
		background: transparent;
	}
	:global(.pull-quote::before) {
		content: '\201C';
		position: absolute;
		top: 0;
		left: 0;
		font-family: 'Oswald', sans-serif;
		font-size: 7.5rem;
		font-weight: 600;
		line-height: 1;
		color: #e3dfd7;
		pointer-events: none;
	}
	:global(.pull-quote p) {
		margin: 0 0 0.75rem;
		font-family: 'Oswald', sans-serif;
		font-size: 1.7rem;
		font-weight: 600;
		line-height: 1.5;
		color: #0d0d0d;
	}
	:global(.pull-quote p:last-of-type) {
		margin-bottom: 0.5rem;
	}
	:global(.pull-quote cite) {
		display: block;
		font-family: 'Yantramanav', sans-serif;
		font-size: 1.3rem;
		font-weight: 500;
		font-style: normal;
		color: #4a4a4a;
		letter-spacing: 0.02em;
	}

	/* Top Bar */
	.top-bar {
		background: #000000;
		padding: 10px 0;
		border-bottom: none;
		position: sticky;
		top: 0;
		z-index: 1001;
	}

	.top-bar-container {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		height: 100%;
	}

	.top-bar-left {
		display: flex;
		align-items: center;
		gap: 0;
		flex: 1;
	}

	/* Quote of the Day */
	.quote-of-the-day {
		display: flex;
		align-items: center;
		gap: 8px;
		flex: 1;
		margin: 0 20px;
		position: relative;
		min-width: 0;
	}

	.quote-label {
		color: #b6b6b6;
		font-family: 'Yantramanav', 'Roboto', sans-serif;
		font-size: 13px;
		font-weight: 500;
		white-space: nowrap;
		flex-shrink: 0;
		z-index: 2;
		background: #000000;
		padding-right: 10px;
		position: relative;
	}

	.quote-content {
		flex: 1;
		position: relative;
		min-width: 0;
		overflow: hidden;
	}

	.quote-text {
		color: #e0e0e0;
		font-family: 'Yantramanav', 'Roboto', sans-serif;
		font-size: 13px;
		font-weight: 400;
		letter-spacing: 0.02em;
		white-space: nowrap;
		display: inline-block;
	}

	.top-bar-right {
		display: flex;
		align-items: center;
		gap: 0;
		flex-shrink: 0;
		white-space: nowrap;
	}

	.top-bar-right span {
		color: #ffffff;
		font-family: 'Yantramanav', sans-serif;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-right: 22px;
		font-weight: 500;
		white-space: nowrap;
		display: inline-block;
	}

	.top-bar-right .social-links {
		display: inline-flex;
		align-items: center;
		gap: 18px;
	}

	.top-bar-right .social-icon {
		color: #b6b6b6;
		text-decoration: none;
		transition: color 0.3s;
		line-height: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.top-bar-right .social-icon svg {
		display: block;
	}

	.top-bar-right .social-icon:hover {
		color: #fe5900;
	}

	/* Navigation */
	header {
		background: transparent;
		color: #ffffff;
		padding: 0;
		position: absolute;
		top: 40px;
		left: 0;
		right: 0;
		z-index: 1000;
		width: 100%;
		transition: background 0.3s ease, top 0.3s ease;
	}

	header.scrolled {
		background: #ffffff;
		color: #0d0d0d;
		box-shadow: none;
		position: sticky;
		top: 0;
	}

	header.scrolled .navbar {
		color: #0d0d0d;
	}

	header.scrolled .logo h1 {
		color: #0d0d0d;
	}

	header.scrolled .nav-links a,
	header.scrolled .nav-dropdown-trigger {
		color: #0d0d0d;
	}

	/* Blog (and any page with headerBlack): nav and logo black from the start */
	:global(body.header-black) header {
		color: #000000;
	}
	:global(body.header-black) header .navbar {
		color: #000000;
	}
	:global(body.header-black) header .logo,
	:global(body.header-black) header .logo h1 {
		color: #000000;
	}
	:global(body.header-black) header .nav-links a,
	:global(body.header-black) header .nav-dropdown-trigger {
		color: #000000;
	}
	:global(body.header-black) header .nav-links a:hover,
	:global(body.header-black) header .nav-dropdown-trigger:hover {
		color: #fe5900;
	}

	.navbar {
		padding: 20px 0;
	}

	nav {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.nav-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 40px;
		position: relative;
	}

	.logo {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		text-decoration: none;
		color: #ffffff;
		transition: color 0.3s;
	}

	.logo h1 {
		font-family: 'Oswald', sans-serif;
		font-size: 43px;
		font-weight: 600;
		text-transform: uppercase;
		color: #ffffff;
		margin: 0;
		letter-spacing: 0.05em;
	}

	.nav-links {
		display: flex;
		list-style: none;
		gap: 40px;
		margin: 0;
		padding: 0;
		align-items: center;
		flex: 1;
	}

	.nav-links-left {
		justify-content: flex-start;
	}

	.nav-links-right {
		justify-content: flex-end;
	}

	.logo {
		flex-shrink: 0;
		margin: 0;
		z-index: 1;
	}

	.nav-links a {
		color: #ffffff;
		text-decoration: none;
		text-transform: uppercase;
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.3em;
		font-family: 'Yantramanav', sans-serif;
		transition: color 0.3s;
	}

	header.scrolled .nav-links a,
	header.scrolled .nav-dropdown-trigger {
		color: #0d0d0d;
	}

	.nav-links a:hover {
		color: #fe5900;
	}

	.nav-dropdown {
		position: relative;
	}

	.nav-dropdown-trigger {
		color: #ffffff;
		text-transform: uppercase;
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.3em;
		font-family: 'Yantramanav', sans-serif;
		cursor: pointer;
		transition: color 0.3s;
		user-select: none;
	}

	.nav-dropdown:hover .nav-dropdown-trigger,
	.nav-dropdown.open .nav-dropdown-trigger {
		color: #fe5900;
	}

	.nav-dropdown-menu {
		position: absolute;
		top: 100%;
		left: 0;
		margin: 0;
		padding: 12px 0;
		list-style: none;
		background: #ffffff;
		min-width: 200px;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
		border: 1px solid #e8e8e8;
		opacity: 0;
		visibility: hidden;
		transform: translateY(-4px);
		transition: opacity 0.2s, visibility 0.2s, transform 0.2s;
		z-index: 100;
	}

	.nav-dropdown:hover .nav-dropdown-menu,
	.nav-dropdown.open .nav-dropdown-menu {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.nav-dropdown-menu a {
		display: block;
		padding: 10px 20px;
		color: #0d0d0d;
		letter-spacing: 0.15em;
		font-size: 12px;
	}

	header.scrolled .nav-dropdown-menu a {
		color: #0d0d0d;
	}

	.nav-dropdown-menu a:hover {
		background: rgba(254, 89, 0, 0.08);
		color: #fe5900;
	}

	.cart-link {
		display: flex;
		align-items: center;
		gap: 8px;
		position: relative;
	}

	.cart-text {
		font-size: 13px;
	}

	.cart-count {
		background: #fe5900;
		color: #ffffff;
		font-size: 10px;
		font-weight: 600;
		padding: 2px 6px;
		border-radius: 0;
		min-width: 18px;
		text-align: center;
		line-height: 1.4;
		margin-left: 4px;
	}

	/* Hamburger button - hidden on desktop */
	.nav-menu-btn {
		display: none;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		padding: 0;
		border: none;
		background: transparent;
		cursor: pointer;
		color: inherit;
		font: inherit;
	}

	.nav-menu-btn-icon {
		display: block;
		width: 24px;
		height: 2px;
		background: currentColor;
		position: relative;
		transition: background 0.2s;
	}

	.nav-menu-btn-icon::before,
	.nav-menu-btn-icon::after {
		content: '';
		position: absolute;
		left: 0;
		width: 24px;
		height: 2px;
		background: currentColor;
		transition: transform 0.2s;
	}

	.nav-menu-btn-icon::before {
		top: -7px;
	}

	.nav-menu-btn-icon::after {
		top: 7px;
	}

	header.menu-open .nav-menu-btn-icon {
		background: transparent;
	}

	header.menu-open .nav-menu-btn-icon::before {
		transform: translateY(7px) rotate(45deg);
	}

	header.menu-open .nav-menu-btn-icon::after {
		transform: translateY(-7px) rotate(-45deg);
	}

	/* Mobile nav panel - hidden on desktop */
	.nav-menu-panel {
		display: none;
	}

	footer {
		background: #1a1a1a;
