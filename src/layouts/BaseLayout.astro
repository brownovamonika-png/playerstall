	}
	:global(body.header-black) header .nav-links a,
	:global(body.header-black) header .nav-dropdown-trigger {
		color: #000000;
	}
	:global(body.header-black) header .nav-links a:hover,
	:global(body.header-black) header .nav-dropdown-trigger:hover {
		color: #fe5900;
	}

	.navbar {
		padding: 20px 0;
	}

	nav {
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.nav-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
