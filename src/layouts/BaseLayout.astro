	/*
	 * All locker planner flows use .planner-hero (/room-planner, /new-room-planner, /room-planner-v2, etc.).
	 * :has() forces a solid header + dark nav without per-page props (avoids “invisible menu” on light heroes).
	 */
	:global(body:has(.planner-hero)) header {
		background: #ffffff !important;
		color: #0d0d0d !important;
		box-shadow: none !important;
		position: sticky;
		top: 0;
	}
	:global(body:has(.planner-hero)) header .navbar {
		color: #0d0d0d !important;
	}
	:global(body:has(.planner-hero)) header .logo,
	:global(body:has(.planner-hero)) header .logo h1 {
		color: #0d0d0d !important;
	}
	:global(body:has(.planner-hero)) header .nav-links a,
	:global(body:has(.planner-hero)) header .nav-dropdown-trigger {
		color: #0d0d0d !important;
	}
	:global(body:has(.planner-hero)) header .nav-menu-btn {
		color: #0d0d0d !important;
	}
	:global(body:has(.planner-hero)) header .nav-links a:hover,
	:global(body:has(.planner-hero)) header .nav-dropdown-trigger:hover {
		color: #fe5900 !important;
	}
	:global(body:has(.planner-hero)) header.menu-open .logo h1 {
		color: #0d0d0d !important;
	}

	/*
	 * Room planners: same minimal bar as mobile — black top strip hidden, PLAYERSTALL left,
	 * hamburger right, full nav only inside the panel (all breakpoints).
	 */
