---
interface Props {
	title: string;
	description?: string;
	headerBlack?: boolean;
	ogImage?: string;
	canonical?: string;
}

const { 
	title, 
	description = "Premium wood lockers at unbeatable prices. Quick ship in 2–4 weeks or custom in 8–12 weeks. Price match guarantee. 30+ years experience.", 
	headerBlack = false,
	ogImage = "https://playerstall.com/images/logoblack2.png",
	canonical = Astro.url.pathname === "/" ? "https://playerstall.com" : `https://playerstall.com${Astro.url.pathname}`
} = Astro.props;

// Ensure canonical URL doesn't have trailing slash (except for homepage)
const canonicalUrl = canonical.endsWith('/') && canonical !== "https://playerstall.com" 
	? canonical.slice(0, -1) 
	: canonical;
