---
interface Props {
	title: string;
	description?: string;
	headerBlack?: boolean;
	ogImage?: string;
	/** Alt text for og:image and twitter:image (accessibility + X/SEO). Recommended: short, keyword-rich description. */
	ogImageAlt?: string;
	canonical?: string;
	/** When true, sets og:type to "article" and outputs article:published_time if provided */
	isArticle?: boolean;
	articlePublishedTime?: string;
}

const { 
	title, 
	description = "Custom wood sports lockers for collegiate and professional teams. Priced right. Quick ship in 2 to 4 weeks or custom in 8 to 12 weeks. 30+ years of craftsmanship.", 
	headerBlack = false,
	ogImage = "https://playerstall.b-cdn.net/images/logoblack2.png",
	ogImageAlt = "PlayerStall. Custom wood sports lockers for college and pro teams. 30+ years, 5 year warranty.",
	canonical = Astro.url.pathname === "/" ? "https://playerstall.com" : `https://playerstall.com${Astro.url.pathname}`,
	isArticle = false,
	articlePublishedTime,
} = Astro.props;

// Ensure canonical URL doesn't have trailing slash (except for homepage)
const canonicalUrl = canonical.endsWith('/') && canonical !== "https://playerstall.com" 
	? canonical.slice(0, -1) 
	: canonical;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<!-- Google Tag Manager -->
