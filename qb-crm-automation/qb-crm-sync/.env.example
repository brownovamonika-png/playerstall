# QuickBooks Online — from your app at developer.intuit.com
QB_CLIENT_ID=your_qb_client_id_here
QB_CLIENT_SECRET=your_qb_client_secret_here
QB_REFRESH_TOKEN=your_qb_refresh_token_here   # obtained during OAuth setup
QB_REALM_ID=your_qb_company_id_here           # found in QB URL: /app/homepage?realmid=XXXXXXX

# Supabase — from your project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here   # use service_role key (not anon)

# Optional: protects the /api/sync endpoint from unauthorized triggers
CRON_SECRET=some_random_secret_string_here
